---
---

<div id="global-loader" class="fixed inset-0 z-[9999] bg-[#020712] flex flex-col items-center justify-center text-white overflow-hidden pointer-events-auto">

  <!-- Loader typography follows the global font system -->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap');
    
    .font-loader-display {
      font-family: 'Montserrat', sans-serif;
    }
    .font-loader-body {
      font-family: 'Source Sans 3', sans-serif;
    }
  </style>

  <!-- Premium Deep Blue & Gold Vignette Glow background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none z-0"
       style="background:radial-gradient(circle,rgba(2,86,214,0.18) 0%,rgba(242,162,12,0.06) 45%,rgba(2,7,18,0) 70%);filter:blur(80px);"></div>

  <div class="relative z-10 flex flex-col items-center">

    <!-- Thin orbital ring behind the logo -->
    <div class="absolute w-56 h-56 md:w-72 md:h-72 rounded-full border border-blue-500/10 pointer-events-none z-0 top-[-20px] md:top-[-30px] opacity-0 loader-orbit"></div>

    <!-- Standalone 3D Glowing Logo -->
    <div class="mb-6 opacity-0 loader-logo relative flex items-center justify-center z-10">
      <img src="/images/logocbit.webp" 
           alt="CBIT Logo" 
           class="h-28 w-auto md:h-36 object-contain filter drop-shadow-[0_15px_30px_rgba(2,86,214,0.25)] drop-shadow-[0_5px_15px_rgba(242,162,12,0.2)] select-none" />
    </div>

    <!-- CBIT brand title -->
    <div class="text-4xl md:text-5xl font-loader-display tracking-[0.2em] text-white opacity-0 loader-cbit-title mb-4 text-center select-none font-bold">
      CBIT
    </div>

    <!-- Muted subtitle -->
    <div class="text-[0.55rem] md:text-[0.62rem] font-loader-body tracking-[0.3em] uppercase opacity-0 loader-brand leading-relaxed text-center max-w-[420px] text-[#8a9bb4] select-none mb-10 px-4">
      Corporación Boliviana de Talento y Formación Integral
    </div>

    <!-- Progress percentage -->
    <div class="text-5xl md:text-6xl font-loader-body font-semibold tracking-wide mb-6 flex items-end opacity-0 loader-number select-none">
      <span id="loader-progress" class="text-white">0</span>
      <span class="text-2xl md:text-3xl ml-1 mb-1 text-[#fcc506] font-medium">%</span>
    </div>

    <!-- 3D Pill-Shaped Glassmorphic Progress bar container -->
    <div id="loader-bar-container" class="w-64 md:w-80 h-3 relative opacity-0 rounded-full p-[2px] shadow-[inset_0_2px_5px_rgba(0,0,0,0.8)] border border-blue-950/40" 
         style="background:rgba(3,14,33,0.7); backdrop-filter: blur(10px);">
      <!-- Progress Bar Fill -->
      <div id="loader-bar" class="absolute top-[1.5px] bottom-[1.5px] left-[2px] w-0 rounded-full relative transition-all duration-75"
           style="background:linear-gradient(90deg, #0256d6 0%, #e28f09 75%, #fcc506 100%); box-shadow: 0 0 10px rgba(2, 86, 214, 0.4);">
        <!-- Glossy glass reflection highlight on the progress bar -->
        <div class="absolute inset-x-1 top-[0.5px] h-[35%] bg-white/25 rounded-full z-10 pointer-events-none"></div>
        <!-- Sparkling lead spark element -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-4 h-4 rounded-full bg-white shadow-[0_0_8px_#fff,0_0_15px_#fcc506,0_0_25px_#fcc506] z-20"></div>
      </div>
    </div>

    <!-- Loading label in blue/cyan -->
    <div class="text-[0.6rem] font-montserrat tracking-[0.5em] text-[#0a5cd6] font-medium uppercase mt-6 opacity-0 loader-cargando select-none">
      CARGANDO...
    </div>

  </div>
</div>

<script>
  import gsap from 'gsap';

  if (typeof window !== 'undefined') {
    const loader       = document.getElementById('global-loader');
    const progressText = document.getElementById('loader-progress');
    const progressBar  = document.getElementById('loader-bar');

    if (loader && progressText && progressBar) {
      document.body.style.overflow = 'hidden';

      const progress = { value: 0 };

      // Reveal elements elegantly
      gsap.to('.loader-orbit', { opacity: 1, scale: 1, duration: 1.2, ease: 'power2.out' });
      gsap.to('.loader-logo', { opacity: 1, scale: 1, duration: 0.8, ease: 'power3.out' });
      gsap.to('.loader-cbit-title', { opacity: 1, y: 0, duration: 0.6, delay: 0.15, ease: 'power2.out' });
      gsap.to('.loader-brand',   { opacity: 1, y: 0, duration: 0.6, delay: 0.25, ease: 'power2.out' });
      gsap.to('.loader-number',  { opacity: 1, duration: 0.5, delay: 0.35, ease: 'power2.out' });
      gsap.to('#loader-bar-container', { opacity: 1, duration: 0.5, delay: 0.45, ease: 'power2.out' });
      gsap.to('.loader-cargando', { opacity: 1, duration: 0.5, delay: 0.55, ease: 'power2.out' });

      // Subtle pulse to logo
      gsap.to('.loader-logo img', {
        scale: 1.04,
        repeat: -1,
        yoyo: true,
        duration: 2,
        ease: 'sine.inOut',
        delay: 0.8
      });

      // Count to 100 with premium cubic timing matching the reference
      gsap.to(progress, {
        value: 100,
        duration: 3.2,
        ease: 'power2.out',
        onUpdate: () => {
          progressText.innerText = Math.round(progress.value).toString();
          progressBar.style.width = `calc(${progress.value}% - 4px)`;
        },
        onComplete: () => {
          const tl = gsap.timeline();
          tl.to('.loader-orbit, .loader-logo, .loader-cbit-title, .loader-brand, .loader-number, #loader-bar-container, .loader-cargando', {
            opacity: 0,
            y: -15,
            duration: 0.5,
            stagger: 0.04,
            ease: 'power2.in'
          })
          .to(loader, {
            yPercent: -100,
            duration: 0.8,
            ease: 'power4.inOut',
            onComplete: () => {
              loader.style.display = 'none';
              document.body.style.overflow = '';
            }
          });
        }
      });
    }
  }
</script>
