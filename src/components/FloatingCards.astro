---
const cards = [
  {
    title: "The Tactics Behind The Victory",
    image: "/images/ima2.jpg",
    colSpan: "col-span-12 md:col-span-4",
    offset: "md:mt-0"
  },
  {
    title: "Lamine Yamal: The New Prodigy",
    image: "/images/ima3.jpg",
    colSpan: "col-span-12 md:col-span-5",
    offset: "md:mt-24"
  },
  {
    title: "Post-Match Analysis",
    image: "/images/ima4.jpg",
    colSpan: "col-span-12 md:col-span-3",
    offset: "md:mt-12"
  }
];
---

<section class="relative z-20 container mx-auto px-6 md:px-10 -mt-32 pb-24 floating-section perspective-[1000px]">
  <div class="grid grid-cols-12 gap-6">
    {cards.map((card) => (
      <div class={`news-card group ${card.colSpan} ${card.offset} relative cursor-pointer transform-gpu`}>
        <div class="absolute -inset-[1px] bg-gradient-to-b from-yellow-500/50 to-transparent rounded-xl opacity-0 group-hover:opacity-100 transition duration-500 blur-[2px]"></div>
        <div class="relative h-[400px] rounded-xl overflow-hidden bg-[#0a0a0a]/80 backdrop-blur-md border border-white/10 flex flex-col p-4 shadow-2xl transition-all duration-500 transform group-hover:-translate-y-4 group-hover:scale-[1.02] group-hover:shadow-[0_20px_40px_rgba(234,179,8,0.15)] news-card-inner">
          <div class="relative h-2/3 w-full rounded-lg overflow-hidden">
            <img src={card.image} alt={card.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition duration-500"></div>
          </div>
          <div class="pt-4 flex flex-col flex-grow justify-between relative z-10">
            <h3 class="font-display text-2xl leading-tight text-white group-hover:text-yellow-400 transition-colors">{card.title}</h3>
            <div class="flex items-center justify-between mt-4">
              <span class="text-xs text-gray-400 uppercase tracking-widest font-semibold">Editorial</span>
              <button class="flex items-center gap-2 text-sm text-yellow-500 font-bold uppercase tracking-wider overflow-hidden group/btn">
                Full Story
                <span class="block transition-transform duration-300 group-hover/btn:translate-x-1">→</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Reveal animation
    gsap.from('.news-card', {
      scrollTrigger: {
        trigger: '.floating-section',
        start: 'top 85%',
      },
      y: 100,
      opacity: 0,
      rotationX: 15,
      stagger: 0.2,
      duration: 1.2,
      ease: 'power3.out'
    });

    // Mouse parallax effect for depth
    const cards = document.querySelectorAll('.news-card-inner') as NodeListOf<HTMLElement>;
    
    cards.forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = ((y - centerY) / centerY) * -10;
        const rotateY = ((x - centerX) / centerX) * 10;
        
        gsap.to(card, {
          rotateX,
          rotateY,
          duration: 0.5,
          ease: 'power1.out',
          transformPerspective: 1000,
          transformOrigin: 'center'
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.8,
          ease: 'power3.out'
        });
      });
    });
  });
</script>
