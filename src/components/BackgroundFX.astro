---
// components/BackgroundFX.astro
// Aurora Clara — azules suaves + dorado suave sobre fondo blanco
---

<canvas id="bg-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-0"></canvas>

<script>
const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W: number, H: number, animId: number;

// ── Paleta clara: azules suaves, dorado pálido, teal ligero
const BLOB_COLORS: [number, number, number][] = [
  [210, 70, 88],   // azul claro suave
  [37,  90, 88],   // dorado pálido
  [195, 65, 90],   // azul cielo claro
  [175, 60, 88],   // teal suave
  [220, 75, 92],   // azul lavanda
  [43,  80, 88],   // ámbar muy suave
  [200, 68, 90],   // celeste
  [35,  85, 90],   // amarillo suave
  [215, 72, 91],   // azul medio claro
  [180, 65, 90],   // cyan pálido
];

type Blob = {
  x: number; y: number;
  vx: number; vy: number;
  baseR: number;
  hue: number; sat: number; lit: number;
  phase: number;
  pulseSpeed: number; pulseAmp: number;
  alpha: number;
};

let blobs: Blob[] = [];
let scanY = 0;

function resize() {
  W = canvas.width  = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  blobs = buildBlobs();
}

function buildBlobs(): Blob[] {
  const count = Math.max(8, Math.floor((W * H) / 120_000));
  return Array.from({ length: count }, (_, i) => {
    const [hue, sat, lit] = BLOB_COLORS[i % BLOB_COLORS.length];
    const speed = 0.08 + Math.random() * 0.12;
    const angle = Math.random() * Math.PI * 2;
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      baseR: Math.min(W, H) * (0.22 + Math.random() * 0.32),
      hue:   hue + (Math.random() - 0.5) * 12,
      sat, lit,
      phase:      Math.random() * Math.PI * 2,
      pulseSpeed: 0.25 + Math.random() * 0.40,
      pulseAmp:   0.06 + Math.random() * 0.10,
      alpha:      0.06 + Math.random() * 0.07,
    };
  });
}

function smoothNoise(x: number): number {
  return Math.sin(x * 1.3) * 0.5
       + Math.sin(x * 2.7 + 1.1) * 0.3
       + Math.sin(x * 0.7 + 2.3) * 0.2;
}

function draw(ts: number) {
  ctx.clearRect(0, 0, W, H);
  const t = ts * 0.001;

  // ── 1. Fondo base blanco puro
  ctx.fillStyle = '#FFFFFF';
  ctx.fillRect(0, 0, W, H);

  // ── 2. Gradiente central muy suave (azul -> blanco)
  const cg = ctx.createRadialGradient(W * 0.5, H * 0.4, 0, W * 0.5, H * 0.4, Math.max(W, H) * 0.75);
  cg.addColorStop(0, 'rgba(219, 234, 254, 0.35)');
  cg.addColorStop(1, 'rgba(255, 255, 255, 0)');
  ctx.fillStyle = cg;
  ctx.fillRect(0, 0, W, H);

  // ── 3. Blobs de aurora suave
  blobs.forEach((b) => {
    const noiseX = smoothNoise(t * 0.3 + b.phase)       * 0.20;
    const noiseY = smoothNoise(t * 0.3 + b.phase + 1.5) * 0.20;

    b.x += b.vx + noiseX;
    b.y += b.vy + noiseY;

    const margin = b.baseR * 0.5;
    if (b.x < -margin)    { b.x = -margin;    b.vx =  Math.abs(b.vx); }
    if (b.x > W + margin) { b.x = W + margin; b.vx = -Math.abs(b.vx); }
    if (b.y < -margin)    { b.y = -margin;    b.vy =  Math.abs(b.vy); }
    if (b.y > H + margin) { b.y = H + margin; b.vy = -Math.abs(b.vy); }

    const pulse = 1 + Math.sin(t * b.pulseSpeed + b.phase) * b.pulseAmp;
    const r = b.baseR * pulse;

    const grd = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, r);
    grd.addColorStop(0,   `hsla(${b.hue}, ${b.sat}%, ${b.lit}%, ${b.alpha})`);
    grd.addColorStop(0.4, `hsla(${b.hue}, ${b.sat}%, ${b.lit + 3}%, ${b.alpha * 0.5})`);
    grd.addColorStop(1,   `hsla(${b.hue}, ${b.sat}%, ${b.lit + 6}%, 0)`);

    ctx.save();
    const skewX = 1 + smoothNoise(t * 0.15 + b.phase + 3) * 0.12;
    const skewY = 1 + smoothNoise(t * 0.15 + b.phase + 5) * 0.12;
    ctx.translate(b.x, b.y);
    ctx.scale(skewX, skewY);
    ctx.translate(-b.x, -b.y);
    ctx.beginPath();
    ctx.arc(b.x, b.y, r, 0, Math.PI * 2);
    ctx.fillStyle = grd;
    ctx.fill();
    ctx.restore();
  });

  // ── 4. Resplandor azul suave pulsante al centro
  const breathe = 0.5 + 0.5 * Math.sin(t * 0.35);
  const softGlow = ctx.createRadialGradient(
    W * 0.5, H * 0.5, 0,
    W * 0.5, H * 0.5, Math.min(W, H) * 0.6
  );
  softGlow.addColorStop(0,   `rgba(59, 130, 246, ${0.03 + breathe * 0.02})`);
  softGlow.addColorStop(0.5, `rgba(37, 99, 235, ${0.01 + breathe * 0.01})`);
  softGlow.addColorStop(1,   'rgba(255, 255, 255, 0)');
  ctx.fillStyle = softGlow;
  ctx.fillRect(0, 0, W, H);

  // ── 5. Acento dorado suave en esquina superior derecha
  const cornerGlow = ctx.createRadialGradient(W * 0.82, H * 0.12, 0, W * 0.82, H * 0.12, Math.min(W, H) * 0.38);
  cornerGlow.addColorStop(0,   `rgba(251, 191, 36, ${0.06 + breathe * 0.03})`);
  cornerGlow.addColorStop(1,   'rgba(255, 255, 255, 0)');
  ctx.fillStyle = cornerGlow;
  ctx.fillRect(0, 0, W, H);

  // ── 6. Scanline muy sutil (apenas visible en claro)
  scanY += 0.3;
  if (scanY > H + 60) scanY = -60;
  const sg = ctx.createLinearGradient(0, scanY - 40, 0, scanY + 40);
  sg.addColorStop(0,   'rgba(59, 130, 246, 0)');
  sg.addColorStop(0.5, 'rgba(59, 130, 246, 0.012)');
  sg.addColorStop(1,   'rgba(59, 130, 246, 0)');
  ctx.fillStyle = sg;
  ctx.fillRect(0, scanY - 40, W, 80);

  animId = requestAnimationFrame(draw);
}

// ── Lifecycle
window.addEventListener('resize', () => {
  cancelAnimationFrame(animId);
  resize();
  animId = requestAnimationFrame(draw);
});

document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    cancelAnimationFrame(animId);
  } else {
    animId = requestAnimationFrame(draw);
  }
});

document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));

resize();
animId = requestAnimationFrame(draw);
</script>