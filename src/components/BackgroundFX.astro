---
// components/BackgroundFX.astro
// Aurora Nebulosa — blobs suaves animados, sin hexágonos
---

<canvas id="bg-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-0"></canvas>

<script>
const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W: number, H: number, animId: number;

// ── Paleta de colores (HSL)
// Puedes cambiar estos valores para ajustar la paleta de la aurora
const BLOB_COLORS: [number, number, number][] = [
  [210, 80, 60],  // azul cielo
  [175, 75, 55],  // teal / cian
  [230, 70, 65],  // índigo suave
  [195, 85, 58],  // cyan vivo
  [250, 60, 68],  // lavanda
  [185, 78, 52],  // verde agua
];

type Blob = {
  x: number;
  y: number;
  vx: number;
  vy: number;
  baseR: number;
  hue: number;
  sat: number;
  lit: number;
  phase: number;
  pulseSpeed: number;
  pulseAmp: number;
  alpha: number;
};

let blobs: Blob[] = [];
let scanY = 0;

function resize() {
  W = canvas.width  = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  blobs = buildBlobs();
}

function buildBlobs(): Blob[] {
  // Cantidad de blobs escala con el área de la pantalla
  const count = Math.max(6, Math.floor((W * H) / 140_000));

  return Array.from({ length: count }, (_, i) => {
    const [hue, sat, lit] = BLOB_COLORS[i % BLOB_COLORS.length];
    const speed = 0.12 + Math.random() * 0.18;
    const angle  = Math.random() * Math.PI * 2;
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      baseR: Math.min(W, H) * (0.22 + Math.random() * 0.28),
      hue:   hue + (Math.random() - 0.5) * 18,
      sat,
      lit,
      phase:      Math.random() * Math.PI * 2,
      pulseSpeed: 0.4 + Math.random() * 0.5,
      pulseAmp:   0.10 + Math.random() * 0.14,
      alpha:      0.12 + Math.random() * 0.10,
    };
  });
}

// ── Ruido suave para desplazamiento orgánico (pseudo-simplex ligero)
function smoothNoise(x: number): number {
  return Math.sin(x * 1.3) * 0.5 + Math.sin(x * 2.7 + 1.1) * 0.3 + Math.sin(x * 0.7 + 2.3) * 0.2;
}

function draw(ts: number) {
  ctx.clearRect(0, 0, W, H);
  const t = ts * 0.001;

  // ── 1. Fondo base muy oscuro (sin negro puro, más "cielo nocturno")
  ctx.fillStyle = 'hsl(220, 25%, 6%)';
  ctx.fillRect(0, 0, W, H);

  // ── 2. Gradiente radial central sutil (profundidad)
  const center = ctx.createRadialGradient(W * 0.5, H * 0.5, 0, W * 0.5, H * 0.5, Math.max(W, H) * 0.7);
  center.addColorStop(0, 'rgba(30, 45, 80, 0.35)');
  center.addColorStop(1, 'rgba(0, 0, 0, 0)');
  ctx.fillStyle = center;
  ctx.fillRect(0, 0, W, H);

  // ── 3. Blobs de aurora
  blobs.forEach((b) => {
    // Movimiento orgánico: velocidad base + wiggle de ruido
    const noiseX = smoothNoise(t * 0.3 + b.phase)       * 0.25;
    const noiseY = smoothNoise(t * 0.3 + b.phase + 1.5) * 0.25;

    b.x += b.vx + noiseX;
    b.y += b.vy + noiseY;

    // Rebote suave en los bordes con margen
    const margin = b.baseR * 0.5;
    if (b.x < -margin)      { b.x = -margin;      b.vx =  Math.abs(b.vx); }
    if (b.x > W + margin)   { b.x = W + margin;   b.vx = -Math.abs(b.vx); }
    if (b.y < -margin)      { b.y = -margin;       b.vy =  Math.abs(b.vy); }
    if (b.y > H + margin)   { b.y = H + margin;    b.vy = -Math.abs(b.vy); }

    // Radio pulsante
    const pulse = 1 + Math.sin(t * b.pulseSpeed + b.phase) * b.pulseAmp;
    const r = b.baseR * pulse;

    // Gradiente radial del blob
    const grd = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, r);
    grd.addColorStop(0,   `hsla(${b.hue}, ${b.sat}%, ${b.lit}%, ${b.alpha})`);
    grd.addColorStop(0.4, `hsla(${b.hue}, ${b.sat}%, ${b.lit - 8}%, ${b.alpha * 0.6})`);
    grd.addColorStop(1,   `hsla(${b.hue}, ${b.sat}%, ${b.lit - 15}%, 0)`);

    ctx.save();
    // Forma ligeramente elíptica y rotada para parecer más orgánica
    const skewX = 1 + smoothNoise(t * 0.15 + b.phase + 3) * 0.15;
    const skewY = 1 + smoothNoise(t * 0.15 + b.phase + 5) * 0.15;
    ctx.translate(b.x, b.y);
    ctx.scale(skewX, skewY);
    ctx.translate(-b.x, -b.y);

    ctx.beginPath();
    ctx.arc(b.x, b.y, r, 0, Math.PI * 2);
    ctx.fillStyle = grd;
    ctx.fill();
    ctx.restore();
  });

  // ── 4. Capa de mezcla suave (screen-like) para intensificar colores
  //       Pasada de luz central muy tenue
  const gCenter = ctx.createRadialGradient(W * 0.5, H * 0.45, 0, W * 0.5, H * 0.45, Math.min(W, H) * 0.5);
  const breathe = 0.5 + 0.5 * Math.sin(t * 0.4);
  gCenter.addColorStop(0, `rgba(80, 140, 200, ${0.025 + breathe * 0.02})`);
  gCenter.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = gCenter;
  ctx.fillRect(0, 0, W, H);

  // ── 5. Scanline sutil (opcional — comentar para eliminarlo)
  scanY += 0.45;
  if (scanY > H + 60) scanY = -60;
  const sg = ctx.createLinearGradient(0, scanY - 40, 0, scanY + 40);
  sg.addColorStop(0,   'rgba(140, 200, 255, 0)');
  sg.addColorStop(0.5, 'rgba(140, 200, 255, 0.03)');
  sg.addColorStop(1,   'rgba(140, 200, 255, 0)');
  ctx.fillStyle = sg;
  ctx.fillRect(0, scanY - 40, W, 80);

  // ── 6. Viñeta final (oscurece los bordes, encuadra la aurora)
  const vignette = ctx.createRadialGradient(W * 0.5, H * 0.5, Math.min(W, H) * 0.3, W * 0.5, H * 0.5, Math.max(W, H) * 0.8);
  vignette.addColorStop(0, 'rgba(0,0,0,0)');
  vignette.addColorStop(1, 'rgba(0,0,0,0.55)');
  ctx.fillStyle = vignette;
  ctx.fillRect(0, 0, W, H);

  animId = requestAnimationFrame(draw);
}

// ── Lifecycle
window.addEventListener('resize', () => {
  cancelAnimationFrame(animId);
  resize();
  animId = requestAnimationFrame(draw);
});

document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    cancelAnimationFrame(animId);
  } else {
    animId = requestAnimationFrame(draw);
  }
});

// Limpieza para View Transitions de Astro
document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));

resize();
animId = requestAnimationFrame(draw);
</script>