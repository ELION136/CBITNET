---
// components/BackgroundFX.astro
// Aurora Dorada — azul + teal + dorado/ámbar
---

<canvas id="bg-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-0"></canvas>

<script>
const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let W: number, H: number, animId: number;

// ── Paleta: dorado/ámbar mezclado con azul y teal
const BLOB_COLORS: [number, number, number][] = [
  [43,  90, 62],   // dorado cálido principal
  [38,  95, 58],   // ámbar profundo
  [210, 78, 58],   // azul cielo
  [175, 72, 52],   // teal / cian
  [32,  88, 65],   // oro claro
  [230, 65, 62],   // índigo suave
  [48,  82, 55],   // amarillo oscuro
  [195, 82, 55],   // cyan vivo
  [36,  75, 50],   // bronce
  [215, 70, 60],   // azul medio
];

type Blob = {
  x: number; y: number;
  vx: number; vy: number;
  baseR: number;
  hue: number; sat: number; lit: number;
  phase: number;
  pulseSpeed: number; pulseAmp: number;
  alpha: number;
};

let blobs: Blob[] = [];
let scanY = 0;

function resize() {
  W = canvas.width  = canvas.offsetWidth;
  H = canvas.height = canvas.offsetHeight;
  blobs = buildBlobs();
}

function buildBlobs(): Blob[] {
  const count = Math.max(8, Math.floor((W * H) / 120_000));
  return Array.from({ length: count }, (_, i) => {
    const [hue, sat, lit] = BLOB_COLORS[i % BLOB_COLORS.length];
    const speed = 0.10 + Math.random() * 0.17;
    const angle = Math.random() * Math.PI * 2;
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      baseR: Math.min(W, H) * (0.20 + Math.random() * 0.30),
      hue:   hue + (Math.random() - 0.5) * 16,
      sat, lit,
      phase:      Math.random() * Math.PI * 2,
      pulseSpeed: 0.35 + Math.random() * 0.50,
      pulseAmp:   0.09 + Math.random() * 0.13,
      alpha:      0.13 + Math.random() * 0.11,
    };
  });
}

function smoothNoise(x: number): number {
  return Math.sin(x * 1.3) * 0.5
       + Math.sin(x * 2.7 + 1.1) * 0.3
       + Math.sin(x * 0.7 + 2.3) * 0.2;
}

function draw(ts: number) {
  ctx.clearRect(0, 0, W, H);
  const t = ts * 0.001;

  // ── 1. Fondo base — noche con tinte cálido sutil
  ctx.fillStyle = 'hsl(28, 18%, 5%)';
  ctx.fillRect(0, 0, W, H);

  // ── 2. Gradiente de profundidad central con tonalidad cálida
  const cg = ctx.createRadialGradient(W * 0.5, H * 0.5, 0, W * 0.5, H * 0.5, Math.max(W, H) * 0.7);
  cg.addColorStop(0, 'rgba(50, 35, 8, 0.42)');
  cg.addColorStop(1, 'rgba(0, 0, 0, 0)');
  ctx.fillStyle = cg;
  ctx.fillRect(0, 0, W, H);

  // ── 3. Blobs de aurora
  blobs.forEach((b) => {
    const noiseX = smoothNoise(t * 0.3 + b.phase)       * 0.25;
    const noiseY = smoothNoise(t * 0.3 + b.phase + 1.5) * 0.25;

    b.x += b.vx + noiseX;
    b.y += b.vy + noiseY;

    const margin = b.baseR * 0.5;
    if (b.x < -margin)    { b.x = -margin;    b.vx =  Math.abs(b.vx); }
    if (b.x > W + margin) { b.x = W + margin; b.vx = -Math.abs(b.vx); }
    if (b.y < -margin)    { b.y = -margin;    b.vy =  Math.abs(b.vy); }
    if (b.y > H + margin) { b.y = H + margin; b.vy = -Math.abs(b.vy); }

    const pulse = 1 + Math.sin(t * b.pulseSpeed + b.phase) * b.pulseAmp;
    const r = b.baseR * pulse;

    const grd = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, r);
    grd.addColorStop(0,   `hsla(${b.hue}, ${b.sat}%, ${b.lit}%, ${b.alpha})`);
    grd.addColorStop(0.4, `hsla(${b.hue}, ${b.sat}%, ${b.lit - 8}%, ${b.alpha * 0.6})`);
    grd.addColorStop(1,   `hsla(${b.hue}, ${b.sat}%, ${b.lit - 15}%, 0)`);

    ctx.save();
    const skewX = 1 + smoothNoise(t * 0.15 + b.phase + 3) * 0.15;
    const skewY = 1 + smoothNoise(t * 0.15 + b.phase + 5) * 0.15;
    ctx.translate(b.x, b.y);
    ctx.scale(skewX, skewY);
    ctx.translate(-b.x, -b.y);
    ctx.beginPath();
    ctx.arc(b.x, b.y, r, 0, Math.PI * 2);
    ctx.fillStyle = grd;
    ctx.fill();
    ctx.restore();
  });

  // ── 4. Capa de luz cálida — resplandor dorado pulsante al centro
  const breathe = 0.5 + 0.5 * Math.sin(t * 0.35);
  const warmGlow = ctx.createRadialGradient(
    W * 0.5, H * 0.55, 0,
    W * 0.5, H * 0.55, Math.min(W, H) * 0.58
  );
  warmGlow.addColorStop(0,   `rgba(210, 145, 25, ${0.035 + breathe * 0.028})`);
  warmGlow.addColorStop(0.45,`rgba(14, 165, 233, ${0.018 + breathe * 0.012})`);
  warmGlow.addColorStop(1,   'rgba(0, 0, 0, 0)');
  ctx.fillStyle = warmGlow;
  ctx.fillRect(0, 0, W, H);

  // ── 5. Segundo foco de luz dorada en esquina superior (acento)
  const cornerGlow = ctx.createRadialGradient(W * 0.8, H * 0.15, 0, W * 0.8, H * 0.15, Math.min(W, H) * 0.4);
  cornerGlow.addColorStop(0,   `rgba(240, 170, 40, ${0.04 + breathe * 0.02})`);
  cornerGlow.addColorStop(1,   'rgba(0, 0, 0, 0)');
  ctx.fillStyle = cornerGlow;
  ctx.fillRect(0, 0, W, H);

  // ── 6. Scanline dorada sutil
  scanY += 0.4;
  if (scanY > H + 60) scanY = -60;
  const sg = ctx.createLinearGradient(0, scanY - 40, 0, scanY + 40);
  sg.addColorStop(0,   'rgba(210, 160, 50, 0)');
  sg.addColorStop(0.5, 'rgba(210, 160, 50, 0.028)');
  sg.addColorStop(1,   'rgba(210, 160, 50, 0)');
  ctx.fillStyle = sg;
  ctx.fillRect(0, scanY - 40, W, 80);

  // ── 7. Viñeta final
  const vg = ctx.createRadialGradient(
    W * 0.5, H * 0.5, Math.min(W, H) * 0.28,
    W * 0.5, H * 0.5, Math.max(W, H) * 0.82
  );
  vg.addColorStop(0, 'rgba(0, 0, 0, 0)');
  vg.addColorStop(1, 'rgba(0, 0, 0, 0.62)');
  ctx.fillStyle = vg;
  ctx.fillRect(0, 0, W, H);

  animId = requestAnimationFrame(draw);
}

// ── Lifecycle
window.addEventListener('resize', () => {
  cancelAnimationFrame(animId);
  resize();
  animId = requestAnimationFrame(draw);
});

document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    cancelAnimationFrame(animId);
  } else {
    animId = requestAnimationFrame(draw);
  }
});

document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));

resize();
animId = requestAnimationFrame(draw);
</script>