          </a>
          <a href="https://www.tiktok.com/@cenacap.bo" target="_blank" rel="noopener noreferrer"
             class="footer-social w-8 h-8 flex items-center justify-center rounded-lg border border-white/10 bg-white/05 hover:bg-white/10 hover:border-white/30 transition-all duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .8.11V9.4a6.27 6.27 0 0 0-8.31 6A6.25 6.25 0 0 0 12 21.67a6.24 6.24 0 0 0 6.25-6.25v-8.2a8.73 8.73 0 0 0 4.74 1.48V5.3a5.22 5.22 0 0 1-3.4-1.28z"/></svg>
          </a>
        </div>
      </div>

      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h4 class="text-white text-xs font-bold tracking-[0.28em] uppercase mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#F59E0B;"></span>
          Instituciones
        </h4>
        <ul class="space-y-2.5 w-full">
          {slides.map(s => (
            <li>
              <a href={s.href} class="flex items-center gap-2.5 text-blue-200/70 hover:text-white transition-colors duration-200 text-xs group">
                <svg width="6" height="6" viewBox="0 0 6 6" class="flex-shrink-0 group-hover:translate-x-0.5 transition-transform duration-200" style="color:#F59E0B;">
                  <circle cx="3" cy="3" r="3" fill="currentColor"/>
                </svg>
                <span class="font-semibold tracking-wider">{s.title}</span>
                <span class="text-blue-200/40 text-[10px]">— {s.subtitle}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h4 class="text-white text-xs font-bold tracking-[0.28em] uppercase mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#3B82F6;"></span>
          Ubicación y Horarios
        </h4>
        <ul class="space-y-3 text-xs text-blue-200/70 w-full">
          <li class="flex items-start gap-2.5 text-left">
            <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color:#3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span><strong class="text-white/90 block">Central Cochabamba</strong> Av. América Oeste #456, Zona Queru Queru</span>
          </li>
          <li class="flex items-start gap-2.5 text-left">
            <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color:#14B8A6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span><strong class="text-white/90 block">Sucursal Sacaba</strong> Av. Circunvalación, Zona Quintanilla</span>
          </li>
          <li class="flex items-start gap-2.5 text-left mt-1">
            <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color:#F59E0B;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span><strong class="text-white/90 block">Lun–Vie</strong> 08:30–12:30 · 14:30–19:30</span>
          </li>
          <li class="flex items-start gap-2.5 text-left">
            <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color:#F59E0B;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span><strong class="text-white/90 block">Sábados</strong> 09:00–13:00</span>
          </li>
        </ul>
      </div>

      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h4 class="text-white text-xs font-bold tracking-[0.28em] uppercase mb-4 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:#7C3AED;"></span>
          Contacto
