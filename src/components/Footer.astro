---
const slides = [
  { id: 1, title: "INFOCADE",       subtitle: "Instituto Deportivo",      href: "/infocade"    },
  { id: 2, title: "CENACAP",        subtitle: "Centro de Capacitacion",   href: "/cenacap"     },
  { id: 3, title: "NUEVO SIGLO",    subtitle: "Formacion Profesional",    href: "/nuevo-ciclo" },
  { id: 4, title: "FUNDECT",        subtitle: "Fundacion Educativa",      href: "/fundect"     },
  { id: 5, title: "CLUB DE LEONES", subtitle: "Accion Civica y Social",   href: "/club-leones" },
];
---

<!-- FOOTER -->
<footer class="relative w-full overflow-hidden" style="background:#0b337e;">
  <div class="absolute top-0 left-0 right-0 h-[2px]" style="background:linear-gradient(90deg,transparent 0%,#F59E0B 20%,#FCD34D 50%,#F59E0B 80%,transparent 100%);"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[300px] pointer-events-none" style="background:linear-gradient(135deg,transparent,rgba(29,78,216,0.15));transform:skewY(-6deg);transform-origin:top right;"></div>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 pt-14 pb-10 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/milogo.webp" alt="CBIT Logo" class="h-12 w-auto object-contain"
               style="filter: drop-shadow(0 0 8px rgba(255,255,255,0.4)) drop-shadow(0 2px 10px rgba(37,99,235,0.3));" />
          <span class="font-display text-2xl text-white tracking-widest">CB<span style="color:#F59E0B;">IT</span></span>
        </div>
        <p class="text-blue-200/70 text-xs leading-relaxed max-w-xs mb-5">
          Corporación Boliviana de Talento y Formación Integral. Forjando el futuro académico, cívico y deportivo mediante alianzas de excelencia.
        </p>
        <div class="flex items-center gap-2">
          <a href="https://wa.me/59177101440" target="_blank" rel="noopener noreferrer"
             class="footer-social w-8 h-8 flex items-center justify-center rounded-lg border border-white/10 bg-white/05 hover:bg-[#25D366]/15 hover:border-[#25D366]/40 transition-all duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#25D366"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.993L2 22l5.13-1.347a9.947 9.947 0 0 0 4.881 1.279h.005c5.505 0 9.988-4.478 9.99-9.985 0-2.67-1.037-5.18-2.92-7.065A9.925 9.925 0 0 0 12.012 2zm5.727 14.123c-.253.715-1.47 1.387-2.022 1.478-.497.082-1.135.15-3.32-.756-2.793-1.157-4.595-4.004-4.736-4.193-.14-.188-1.136-1.51-1.136-2.88 0-1.37.718-2.043.97-2.317.254-.275.563-.343.75-.343.187 0 .375.002.537.01.17.008.402-.065.63.486.23.557.788 1.92.857 2.062.069.141.115.306.022.493-.092.188-.138.305-.276.467-.137.16-.29.356-.413.478-.138.136-.282.285-.121.562.162.277.72 1.184 1.543 1.916.822.732 1.517.957 1.733 1.05.215.093.342.079.467-.066.126-.145.539-.627.683-.84.143-.214.287-.18.483-.107.195.074 1.238.583 1.452.69.214.108.356.162.408.252.052.09.052.522-.201 1.238z"/></svg>
          </a>
          <a href="https://www.facebook.com/share/192VbQWo7p/" target="_blank" rel="noopener noreferrer"
             class="footer-social w-8 h-8 flex items-center justify-center rounded-lg border border-white/10 bg-white/05 hover:bg-[#1877F2]/15 hover:border-[#1877F2]/40 transition-all duration-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#1877F2"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
          </a>
          <a href="https://www.instagram.com/cenacap.bo" target="_blank" rel="noopener noreferrer"
             class="footer-social w-8 h-8 flex items-center justify-center rounded-lg border border-white/10 bg-white/05 hover:border-pink-400/40 transition-all duration-200">
