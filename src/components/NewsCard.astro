---
// NewsCard.astro
// Props:
//   title, excerpt, category, tag, date, image, href, source, featured, own
interface Props {
  title:    string;
  excerpt:  string;
  category: string;
  tag?:     string;
  date:     string;
  image?:   string;
  href:     string;
  source?:  string;
  featured?: boolean;
  own?:     boolean;       // true = nuestra noticia/anuncio
  size?:    'hero' | 'large' | 'medium' | 'small';
}

const {
  title, excerpt, category, tag, date, image,
  href, source, featured, own, size = 'medium'
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-BO', {
  day: '2-digit', month: 'short', year: 'numeric'
});

// Category color map
const catColors: Record<string, string> = {
  'FÚTBOL':       '#0ea5e9',
  'BALONCESTO':   '#f59e0b',
  'ATLETISMO':    '#10b981',
  'DEPORTES':     '#0ea5e9',
  'ANUNCIO':      '#eab308',
  'INSTITUCIONAL':'#8b5cf6',
  'GENERAL':      '#6b7280',
};
const catColor = catColors[category] ?? '#0ea5e9';
const isExternal = href.startsWith('http://') || href.startsWith('https://') || href.startsWith('tel:') || href.startsWith('mailto:');
const isWhatsapp = href.includes('wa.me') || href.includes('whatsapp.com');
const isFacebook = href.includes('facebook.com');

let badgeText = 'CBTFI';
let badgeBg = '#eab308'; // Default gold
let badgeTextColor = '#000000';

if (isWhatsapp) {
  badgeText = 'WHATSAPP';
  badgeBg = '#25D366'; // WhatsApp Green
  badgeTextColor = '#ffffff';
} else if (isFacebook) {
  badgeText = 'FACEBOOK';
  badgeBg = '#1877F2'; // Facebook Blue
  badgeTextColor = '#ffffff';
} else if (isExternal) {
  badgeText = 'ENLACE';
  badgeBg = '#3b82f6'; // Generic Link Blue
  badgeTextColor = '#ffffff';
}
---

<a
  href={href}
  target={isExternal ? '_blank' : '_self'}
  rel={isExternal ? 'noopener noreferrer' : ''}
  class:list={[
    'news-card group relative flex overflow-hidden transition-all duration-500',
    size === 'hero'   && 'flex-col lg:flex-row h-auto lg:min-h-[420px]',
    size === 'large'  && 'flex-col min-h-[380px] h-auto',
    size === 'medium' && 'flex-col min-h-[280px] h-auto',
    size === 'small'  && 'flex-row h-[100px] items-stretch',
  ]}
  style="clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));"
>
  <!-- Image Container (For non-small sizes) -->
  {size !== 'small' && (
    <div class:list={[
      'relative overflow-hidden flex-shrink-0 bg-[#f8fafc] border-b border-[rgba(26,75,140,0.05)]',
      size === 'hero'   && 'w-full lg:w-[60%] h-[240px] lg:min-h-full lg:h-auto',
      size === 'large'  && 'w-full h-[180px]',
      size === 'medium' && 'w-full h-[130px]',
    ]}>
      {image
        ? <img src={image} alt={title}
               class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
        : <div class="w-full h-full flex items-center justify-center bg-[#f8fafc]">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2D7DD2" stroke-width="1.5" class="opacity-40">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
      }
      
      <!-- Dynamic Source Badge placed on top of the image -->
      {(own || isExternal) && (
        <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2 py-1 z-20"
             style={`background:${badgeBg};clip-path:polygon(0 0,calc(100% - 4px) 0,100% 4px,100% 100%,4px 100%,0 calc(100% - 4px));`}>
          <span class="text-[9px] font-black tracking-[0.15em]" style={`color:${badgeTextColor};`}>{badgeText}</span>
        </div>
      )}
    </div>
  )}

  {size === 'small' && (
    <div class="w-[80px] flex-shrink-0 relative overflow-hidden"
         style="background:#f8fafc;">
      {image
        ? <img src={image} alt={title}
               class="w-full h-full object-cover transition-all duration-500" />
        : <div class="w-full h-full flex items-center justify-center"
               style={`background:linear-gradient(135deg,${catColor}15,#ffffff);`}>
            <span class="text-xs font-bold" style={`color:${catColor};`}>{category.slice(0,3)}</span>
          </div>
      }
    </div>
  )}

  <!-- Content Container (Outside the image) -->
  <div class:list={[
    'flex flex-col justify-between flex-1 relative z-10',
    size === 'hero'   && 'p-6 lg:p-8',
    size === 'large'  && 'p-4 md:p-5',
    size === 'medium' && 'p-4',
    size === 'small'  && 'p-3 justify-center',
  ]}>
    
    <!-- Small layout also gets the badge internally -->
    {size === 'small' && (own || isExternal) && (
      <div class="absolute top-2 right-2 flex items-center gap-1.5 px-2 py-0.5 z-20"
           style={`background:${badgeBg};clip-path:polygon(0 0,calc(100% - 3px) 0,100% 3px,100% 100%,3px 100%,0 calc(100% - 3px));`}>
        <span class="text-[8px] font-black tracking-[0.1em]" style={`color:${badgeTextColor};`}>{badgeText}</span>
      </div>
    )}

    <div>
      <!-- Category + tag row -->
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[9px] font-black tracking-[0.2em] uppercase px-2 py-0.5"
              style={`color:${catColor};border:1px solid ${catColor}44;background:${catColor}11;`}>
          {category}
        </span>
        {tag && (
          <span class="text-[9px] font-bold tracking-[0.15em] uppercase"
                style={`color:${catColor};`}>
            {tag}
          </span>
        )}
        {source && size !== 'small' && (
          <span class="text-[9px] text-gray-600 ml-auto tracking-widest uppercase">{source}</span>
        )}
      </div>

      <!-- Title -->
      <h3 class:list={[
        'font-display text-slate-800 leading-tight tracking-wide uppercase group-hover:text-[#2d7dd2] transition-colors duration-300',
        size === 'hero'   && 'text-xl lg:text-2xl mb-3',
        size === 'large'  && 'text-base md:text-lg mb-2',
        size === 'medium' && 'text-sm mb-2',
        size === 'small'  && 'text-xs mb-1 line-clamp-2',
      ]}>
        {title}
      </h3>

      <!-- Excerpt -->
      {size !== 'small' && (
        <p class:list={[
          'text-slate-600 leading-relaxed mb-3',
          size === 'hero'  ? 'text-sm' : 'text-xs',
        ]}>
          {excerpt}
        </p>
      )}
    </div>

    <!-- Footer: date + read more -->
    <div class="flex items-center justify-between mt-auto">
      <span class="text-[10px] text-slate-500 tracking-widest">{formattedDate}</span>
      {size !== 'small' && (
        <span class="text-[9px] font-bold tracking-[0.2em] uppercase flex items-center gap-1 transition-all duration-300"
              style={`color:${catColor};`}>
          LEER
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
               class="group-hover:translate-x-0.5 transition-transform duration-300">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </span>
      )}
    </div>

    <!-- Bottom accent line -->
    <div class="absolute bottom-0 left-0 right-0 h-[2px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"
         style={`background:linear-gradient(90deg,${catColor},transparent);`}></div>
  </div>

  <!-- Border -->
  <div class="absolute inset-0 pointer-events-none transition-all duration-500"
       style={`border:1px solid rgba(26,75,140,0.08);clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));`}></div>
  <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
       style={`border:1px solid ${catColor}44;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));`}></div>

  <!-- Corner TL -->
  <div class="absolute top-0 left-0 w-5 h-[1.5px] pointer-events-none transition-colors duration-500"
       style={`background:rgba(26,75,140,0.15);`}></div>
  <div class="absolute top-0 left-0 w-[1.5px] h-5 pointer-events-none transition-colors duration-500"
       style={`background:rgba(26,75,140,0.15);`}></div>
</a>

<style>
  .news-card { background: #ffffff; }
  .news-card:hover { background: #f8fafc; }
</style>