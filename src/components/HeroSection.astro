---
// HeroSection.astro — CBIT
// Corporación Boliviana de Talento y Formación Integral
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap"
  rel="stylesheet"
/>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --deep:    #254791;
    --mid:     #0f2d6e;
    --bright:  #1a3f8f;
    --accent:  #1D4ED8;
    --gold:    #F5D76E;
    --gold2:   #E6A800;
    --gold3:   #C9860A;
    --white:   #F8FAFF;
    --muted:   rgba(248,250,255,0.62);
    --dimmed:  rgba(248,250,255,0.38);
    --nav-h:   68px;
    --display: 'Montserrat', sans-serif;
    --body:    'Source Sans 3', sans-serif;
  }

  /* ══ HERO ══════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: calc(100vh - var(--nav-h));
    background:
      radial-gradient(ellipse 90% 70% at 65% 10%, rgba(29,78,216,0.22) 0%, transparent 58%),
      linear-gradient(158deg, var(--deep) 0%, #0d2460 35%, #122f78 65%, #0b1e47 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 40px 100px;
    overflow: hidden;
    text-align: center;
  }

  /* Golden top border */
  .hero::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg,
      transparent 0%, var(--gold) 18%, var(--gold2) 50%,
      var(--gold) 82%, transparent 100%);
    z-index: 3;
  }

  /* Geo shapes */
  .hero-geo {
    position: absolute; inset: 0;
    pointer-events: none; overflow: hidden; z-index: 0;
  }
  .geo-shape {
    position: absolute;
    background: rgba(245,158,11,0.055);
    transform: rotate(-18deg) skewX(-12deg);
  }
  .geo-shape:nth-child(1) { width: 380px; height: 720px; top: -110px; right: -90px; }
  .geo-shape:nth-child(2) {
    width: 230px; height: 500px;
    bottom: -90px; left: -55px;
    background: rgba(29,78,216,0.09);
    transform: rotate(12deg) skewX(8deg);
  }
  .geo-shape:nth-child(3) {
    width: 170px; height: 380px;
    top: 50px; left: 33%;
    background: rgba(245,158,11,0.035);
    transform: rotate(-22deg);
  }
  .geo-shape:nth-child(4) {
    width: 85px; height: 210px;
    bottom: 130px; right: 23%;
    background: rgba(245,215,110,0.04);
    transform: rotate(15deg);
  }

  /* Noise texture */
  .hero-noise {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px;
    opacity: 0.28;
    pointer-events: none; z-index: 0;
  }

  /* Content */
  .hero-content {
    position: relative; z-index: 2;
    max-width: 880px; width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(245,158,11,0.13);
    border: 1px solid rgba(245,158,11,0.32);
    border-radius: 999px;
    padding: 6px 20px;
    font-family: var(--body);
    font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.1s forwards;
  }

  .hero-title {
    font-family: var(--display);
    font-size: clamp(46px, 8vw, 94px);
    line-height: 1.0;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.25s forwards;
  }
  .hero-title .line-gold { color: var(--gold); display: block; }

  .hero-sub {
    font-family: var(--body);
    font-size: clamp(14px, 1.5vw, 16px);
    font-weight: 400;
    line-height: 1.8;
    color: var(--muted);
    max-width: 560px; margin: 0 auto 44px;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.22,1,0.36,1) 0.4s forwards;
  }

  .hero-ctas {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.55s forwards;
  }

  /* Buttons */
  .btn-gold {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 15px 34px;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
    color: #1a1200; font-family: var(--body);
    font-weight: 700; font-size: 13px; letter-spacing: 0.08em;
    text-decoration: none; border-radius: 12px;
    box-shadow: 0 4px 28px rgba(245,180,11,0.3);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    position: relative; overflow: hidden;
  }
  .btn-gold::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22) 0%, transparent 55%);
    pointer-events: none;
  }
  .btn-gold:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 12px 40px rgba(245,180,11,0.44);
  }
  .btn-gold:active { transform: scale(0.97); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 9px;
    padding: 15px 34px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.22);
    color: var(--white); font-family: var(--body);
    font-size: 13px; font-weight: 500; letter-spacing: 0.06em;
    text-decoration: none; border-radius: 12px;
    transition: background 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
  }
  .btn-ghost:hover {
    background: rgba(255,255,255,0.13);
    border-color: rgba(255,255,255,0.38);
    transform: translateY(-2px);
  }

  /* Stats */
  .hero-stats {
    position: relative; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    gap: 0; flex-wrap: wrap;
    margin-top: 72px;
    padding-top: 44px;
    border-top: 1px solid rgba(255,255,255,0.1);
    width: 100%; max-width: 880px;
    opacity: 0;
    animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) 0.7s forwards;
  }

  .stat-item {
    flex: 1; min-width: 120px;
    text-align: center;
    padding: 0 28px;
    position: relative;
  }
  .stat-item + .stat-item::before {
    content: '';
    position: absolute; left: 0; top: 12%; bottom: 12%;
    width: 1px;
    background: rgba(255,255,255,0.11);
  }
  .stat-num {
    font-family: var(--display);
    font-size: clamp(34px, 4vw, 48px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gold);
    line-height: 1; display: block;
  }
  .stat-lbl {
    font-family: var(--body);
    font-size: 10px; font-weight: 600;
    color: var(--dimmed);
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-top: 6px; display: block;
  }

  /* ══ SECTION BASE ════════════════════════════════════ */
  .section-header { text-align: center; margin-bottom: 56px; }

  .eyebrow-badge {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--body);
    font-size: 10px; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(29,78,216,0.08);
    border: 1px solid rgba(29,78,216,0.18);
    padding: 5px 16px; border-radius: 999px;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--display);
    font-size: clamp(30px, 4vw, 50px);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--deep); line-height: 1.05;
    margin-bottom: 14px;
  }
  .section-desc {
    font-family: var(--body);
    font-size: 15px; color: #5a6278;
    max-width: 520px; margin: 0 auto; line-height: 1.75;
    font-weight: 400;
  }

  /* ══ CARDS ════════════════════════════════════════════ */
  .section-cards {
    padding: 96px 40px;
    background: #f3f4f8;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 22px;
    max-width: 1060px; margin: 0 auto;
  }

  .card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 36px 28px 30px;
    position: relative; overflow: hidden;
    transition: transform 0.28s cubic-bezier(0.22,1,0.36,1),
                box-shadow 0.28s ease,
                border-color 0.28s ease;
  }
  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.11);
    border-color: rgba(0,0,0,0.10);
  }
  .card-accent {
    position: absolute; top: 0; left: 0; right: 0; height: 4px;
    border-radius: 20px 20px 0 0;
  }
  .acc-gold  { background: linear-gradient(90deg, #F5D76E, #E6A800); }
  .acc-blue  { background: linear-gradient(90deg, #185FA5, #378ADD); }
  .acc-teal  { background: linear-gradient(90deg, #0F6E56, #1D9E75); }
  .acc-coral { background: linear-gradient(90deg, #D85A30, #F0997B); }

  .card-icon-wrap {
    width: 56px; height: 56px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; margin-bottom: 22px;
  }
  .ico-gold  { background: rgba(245,158,11,0.11); color: var(--gold3); }
  .ico-blue  { background: #E6F1FB; color: #185FA5; }
  .ico-teal  { background: #E1F5EE; color: #0F6E56; }
  .ico-coral { background: #FAECE7; color: #993C1D; }

  .card-title {
    font-family: var(--display);
    font-size: 21px; letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0d1b3e; margin-bottom: 12px;
  }
  .card-text {
    font-family: var(--body);
    font-size: 17px; color: #323e60; line-height: 1.7;
    margin-bottom: 22px; font-weight: 400;
  }
  .card-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--body);
    font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; text-decoration: none;
    transition: gap 0.22s ease;
  }
  .card-link:hover { gap: 11px; }
  .lnk-gold  { color: var(--gold3); }
  .lnk-blue  { color: #185FA5; }
  .lnk-teal  { color: #0F6E56; }
  .lnk-coral { color: #993C1D; }

  /* ══ IMAGES BAND ════════════════════════════════════ */
  .section-images {
    padding: 0;
    background: #ffffff;
    overflow: hidden;
  }
  .images-strip {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    height: 460px;
  }
  .img-panel {
    position: relative; overflow: hidden;
  }
  .img-panel img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
    filter: brightness(0.88);
  }
  .img-panel:hover img {
    transform: scale(1.06);
    filter: brightness(0.75);
  }
  .img-panel-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(11,31,74,0.75) 0%, transparent 55%);
    pointer-events: none;
  }
  .img-panel-label {
    position: absolute; bottom: 22px; left: 22px; right: 22px;
    font-family: var(--body);
    font-size: 12px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.9);
    pointer-events: none;
  }
  .img-panel-label span {
    font-family: var(--display);
    display: block; font-size: 22px;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: #fff; margin-bottom: 4px;
  }
  .img-divider { width: 1px; background: rgba(255,255,255,0.15); }

  /* ══ FEATURES ════════════════════════════════════════ */
  .section-features {
    padding: 96px 40px;
    background: #ffffff;
  }

  .features-grid {
    max-width: 1060px; margin: 56px auto 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
  }

  .feat-item {
    display: flex; gap: 20px; align-items: flex-start;
  }
  .feat-num {
    font-family: var(--display);
    font-size: 58px; line-height: 1;
    color: rgba(245,158,11,0.14);
    flex-shrink: 0; width: 42px;
    user-select: none; text-transform: uppercase;
  }
  .feat-title {
    font-family: var(--body);
    font-size: 15px; font-weight: 700;
    color: #0d1b3e; margin-bottom: 8px;
  }
  .feat-desc {
    font-family: var(--body);
    font-size: 16px; color: #354160; line-height: 1.7;
    font-weight: 400;
  }

  /* ══ TESTIMONIALS ════════════════════════════════════ */
  .section-highlight {
    padding: 80px 40px;
    background: #f3f4f8;
  }

  .highlight-grid {
    max-width: 1060px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(288px, 1fr));
    gap: 22px;
  }

  .highlight-card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 20px;
    padding: 32px 26px;
    position: relative;
    transition: transform 0.28s cubic-bezier(0.22,1,0.36,1), box-shadow 0.28s ease;
  }
  .highlight-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.09);
  }
  .highlight-card::before {
    content: '"';
    position: absolute; top: 10px; left: 22px;
    font-family: var(--display);
    font-size: 78px; line-height: 1;
    color: rgba(245,158,11,0.13);
    pointer-events: none; text-transform: none;
  }
  .highlight-quote {
    font-family: var(--body);
    font-size: 14px; font-style: italic;
    color: #3a4055; line-height: 1.75;
    margin-bottom: 22px; padding-top: 30px;
    font-weight: 400;
  }
  .highlight-author { display: flex; align-items: center; gap: 13px; }
  .author-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--body);
    font-size: 13px; font-weight: 700;
    color: #ffffff; flex-shrink: 0;
  }
  .av-blue  { background: linear-gradient(135deg, #185FA5, #378ADD); }
  .av-gold  { background: linear-gradient(135deg, var(--gold3), var(--gold2)); color: #1a1200; }
  .av-teal  { background: linear-gradient(135deg, #0F6E56, #1D9E75); }
  .author-name {
    font-family: var(--body);
    font-size: 13px; font-weight: 700; color: #0d1b3e;
  }
  .author-role {
    font-family: var(--body);
    font-size: 11px; color: #8a90a0; font-weight: 400;
  }

  /* ══ PROGRAMS ════════════════════════════════════════ */
  .section-programs {
    padding: 96px 40px;
    background: #f3f4f8;
  }

  .programs-grid {
    max-width: 1060px; margin: 52px auto 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .prog-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: block;
    height: 320px;
    background: #0d1b3e;
  }
  .prog-card:nth-child(1) { grid-column: 1; grid-row: 1; }
  .prog-card:nth-child(2) { grid-column: 2; grid-row: 1 / 3; height: auto; min-height: 340px; }
  .prog-card:nth-child(3) { grid-column: 1; grid-row: 2; }
  .prog-card:nth-child(4) {
    grid-column: 1 / 3; grid-row: 3;
    height: 260px;
  }

  .prog-card-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1), filter 0.5s ease;
   
    display: block;
  }
  .prog-card:hover .prog-card-img {
    transform: scale(1.07);
    filter: brightness(0.38) saturate(0.1);
  }

  /* Gold left accent bar */
  .prog-card::before {
    content: '';
    position: absolute; top: 0; left: 0; bottom: 0; width: 4px;
    background: linear-gradient(180deg, var(--gold) 0%, var(--gold2) 100%);
    z-index: 3;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .prog-card:hover::before { transform: scaleY(1); }

  .prog-card-body {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 28px 30px;
    z-index: 2;
    background: linear-gradient(to top,
      rgba(8,18,56,0.92) 0%,
      rgba(8,18,56,0.4) 50%,
      transparent 100%);
    transition: background 0.4s ease;
  }
  .prog-card:hover .prog-card-body {
    background: linear-gradient(to top,
      rgba(8,18,56,0.96) 0%,
      rgba(8,18,56,0.7) 60%,
      rgba(8,18,56,0.1) 100%);
  }

  .prog-card-badge {
    display: inline-block;
    font-family: var(--body);
    font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; padding: 4px 12px;
    border-radius: 999px; margin-bottom: 12px;
    width: fit-content;
  }
  .badge-open  { background: rgba(29,158,117,0.22); color: #4adeac; border: 1px solid rgba(74,222,172,0.3); }
  .badge-soon  { background: rgba(56,132,221,0.22); color: #7dd3fc; border: 1px solid rgba(125,211,252,0.3); }
  .badge-full  { background: rgba(216,90,48,0.22);  color: #fca77a; border: 1px solid rgba(252,167,122,0.3); }

  .prog-card-title {
    font-family: var(--display);
    font-size: clamp(20px, 2.2vw, 26px);
    letter-spacing: 0.04em; text-transform: uppercase;
    color: #ffffff; line-height: 1.05;
    margin-bottom: 10px;
  }

  .prog-card-meta {
    font-family: var(--body);
    font-size: 12px; color: rgba(255,255,255,0.58);
    font-weight: 400; letter-spacing: 0.02em;
    margin-bottom: 18px;
  }

  .prog-card-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--body);
    font-size: 12px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gold);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .prog-card:hover .prog-card-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .prog-card-cta svg {
    transition: transform 0.25s ease;
  }
  .prog-card:hover .prog-card-cta svg {
    transform: translateX(4px);
  }

  @media (max-width: 720px) {
    .programs-grid {
      grid-template-columns: 1fr;
    }
    .prog-card,
    .prog-card:nth-child(1),
    .prog-card:nth-child(2),
    .prog-card:nth-child(3),
    .prog-card:nth-child(4) {
      grid-column: 1; grid-row: auto;
      height: 260px; min-height: unset;
    }
  }

  /* ══ CTA BAND ════════════════════════════════════════ */
  .cta-band {
    position: relative;
    background:
      radial-gradient(ellipse 70% 60% at 30% 50%, rgba(29,78,216,0.22) 0%, transparent 65%),
      linear-gradient(155deg, var(--deep) 0%, #0e2660 50%, var(--bright) 100%);
    padding: 88px 40px;
    text-align: center;
    overflow: hidden;
  }
  .cta-band::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg,
      transparent 0%, var(--gold) 22%, var(--gold2) 50%,
      var(--gold) 78%, transparent 100%);
  }
  .cta-geo {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }
  .cta-geo span {
    position: absolute;
    background: rgba(245,158,11,0.045);
    transform: rotate(-18deg);
  }
  .cta-geo span:nth-child(1) { width: 260px; height: 520px; top: -85px; right: -55px; }
  .cta-geo span:nth-child(2) {
    width: 200px; height: 420px; bottom: -65px; left: -45px;
    background: rgba(29,78,216,0.09);
    transform: rotate(12deg);
  }

  .cta-content { position: relative; z-index: 2; max-width: 660px; margin: 0 auto; }
  .cta-title {
    font-family: var(--display);
    font-size: clamp(34px, 5.5vw, 58px);
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px; line-height: 1.0;
  }
  .cta-title em { font-style: normal; color: var(--gold); }
  .cta-sub {
    font-family: var(--body);
    font-size: 16px; color: var(--muted);
    margin-bottom: 40px; line-height: 1.75; font-weight: 400;
  }
  .cta-buttons {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; flex-wrap: wrap;
  }

  /* ══ SCROLL REVEAL ══════════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-30px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideLeft {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* Base state */
  .reveal            { opacity: 0; transform: translateY(28px); }
  .reveal-right      { opacity: 0; transform: translateX(-28px); }
  .reveal-left       { opacity: 0; transform: translateX(28px); }
  .reveal-scale      { opacity: 0; transform: scale(0.93); }
  .reveal-fade       { opacity: 0; }

  /* Visible (all types share transition base) */
  .reveal.visible,
  .reveal-right.visible,
  .reveal-left.visible,
  .reveal-scale.visible,
  .reveal-fade.visible {
    opacity: 1;
    transform: translateY(0) translateX(0) scale(1);
    transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1),
                transform 0.7s cubic-bezier(0.22,1,0.36,1);
  }

  .reveal-d1 { transition-delay: 0.05s !important; }
  .reveal-d2 { transition-delay: 0.13s !important; }
  .reveal-d3 { transition-delay: 0.21s !important; }
  .reveal-d4 { transition-delay: 0.29s !important; }

  /* Images strip stagger */
  .reveal-fade.visible { transition: opacity 0.9s ease; }

  /* ══ RESPONSIVE ══════════════════════════════════════ */
  @media (max-width: 820px) {
    .hero { padding: 64px 24px 80px; min-height: auto; }
    .section-cards,
    .section-features,
    .section-highlight,
    .section-programs,
    .cta-band { padding: 64px 24px; }
    .hero-stats { margin-top: 50px; padding-top: 32px; }
    .stat-item { min-width: 90px; padding: 0 14px; }
    .images-strip {
      grid-template-columns: 1fr;
      height: auto;
    }
    .img-panel { height: 240px; }
    .img-divider { display: none; }
    .program-row { flex-wrap: wrap; }
    .prog-badge { order: -1; }
  }
  @media (max-width: 480px) {
    .hero { padding: 52px 18px 64px; }
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .btn-gold, .btn-ghost { justify-content: center; }
    .stat-item + .stat-item::before { display: none; }
    .features-grid { gap: 28px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal, .reveal-right, .reveal-left, .reveal-scale, .reveal-fade {
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .hero-eyebrow, .hero-title, .hero-sub, .hero-ctas, .hero-stats {
      animation: none !important;
      opacity: 1 !important;
    }
  }
