---
// components/CustomCursor.astro
// Cursor Elegante y Formal — Doble Anillo con Acento Dorado CBIT
// Diseñado para mantener contraste tanto en fondos claros como oscuros
---

<div id="custom-cursor-container">
  <canvas id="custom-cursor-canvas"></canvas>
</div>

<style>
  #custom-cursor-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 99999;
  }

  #custom-cursor-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script>
  let activeAnimId: number | null = null;
  let cleanupFn: (() => void) | null = null;

  function initCursor() {
    if (cleanupFn) {
      cleanupFn();
      cleanupFn = null;
    }
    if (activeAnimId !== null) {
      cancelAnimationFrame(activeAnimId);
      activeAnimId = null;
    }

    const container = document.getElementById('custom-cursor-container');
    const canvas = document.getElementById('custom-cursor-canvas') as HTMLCanvasElement | null;
    if (!container || !canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // ── Ocultar cursor nativo
    const styleEl = document.createElement('style');
    styleEl.id = 'cursor-hide-style';
    styleEl.innerHTML = `
      * { cursor: none !important; }
      a, button, [role="button"], input, select, textarea, label, .social-btn, .inst-btn, .coverflow-card {
        cursor: none !important;
      }
    `;
    document.head.appendChild(styleEl);

    // ── Dimensiones / High-DPI
    let DPR = window.devicePixelRatio || 1;
    let W = window.innerWidth;
    let H = window.innerHeight;

    function resize() {
      DPR = window.devicePixelRatio || 1;
      W = window.innerWidth;
      H = window.innerHeight;
      canvas!.width = W * DPR;
      canvas!.height = H * DPR;
      canvas!.style.width = W + 'px';
      canvas!.style.height = H + 'px';
      ctx!.setTransform(1, 0, 0, 1, 0, 0);
      ctx!.scale(DPR, DPR);
    }
    resize();
    window.addEventListener('resize', resize);

    // ── Estado
    let mouse = { x: W / 2, y: H / 2 };
    let core = { x: W / 2, y: H / 2 };     // punto central, alta precisión
    let ring = { x: W / 2, y: H / 2 };     // anillo exterior, inercia ligera

    let isHovering = false;
    let isClicking = false;
    let isText = false; // hover sobre texto/inputs -> cursor en barra (I-beam formal)
    let hoverProgress = 0;
    let clickPulse = 0; // animación de pulso al hacer click

    // ── Detección de tipo de elemento bajo el cursor
    const handleMouseOver = (e: MouseEvent) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      const interactive =
        target.tagName === 'A' ||
        target.tagName === 'BUTTON' ||
        target.closest('a') ||
        target.closest('button') ||
        target.closest('.social-btn') ||
        target.closest('.inst-btn') ||
        target.closest('.coverflow-card') ||
        target.getAttribute('role') === 'button';

      const textInput =
        target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        (target as HTMLElement).isContentEditable;

      if (interactive) isHovering = true;
      if (textInput) isText = true;
    };

    const handleMouseOut = (e: MouseEvent) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      const interactive =
        target.tagName === 'A' ||
        target.tagName === 'BUTTON' ||
        target.closest('a') ||
        target.closest('button') ||
        target.closest('.social-btn') ||
        target.closest('.inst-btn') ||
        target.closest('.coverflow-card') ||
        target.getAttribute('role') === 'button';

      const textInput =
        target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        (target as HTMLElement).isContentEditable;

      if (interactive) isHovering = false;
      if (textInput) isText = false;
    };

    const handleMouseMove = (e: MouseEvent) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    };

    const handleMouseDown = () => {
      isClicking = true;
      clickPulse = 1;
    };

    const handleMouseUp = () => {
      isClicking = false;
    };

    window.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('mousedown', handleMouseDown);
    window.addEventListener('mouseup', handleMouseUp);
    document.addEventListener('mouseover', handleMouseOver);
    document.addEventListener('mouseout', handleMouseOut);

    // ── Paleta formal (no depende del fondo: doble contorno claro+oscuro)
    const GOLD = '#caa14a';        // dorado institucional, más apagado/elegante que ámbar vivo
    const GOLD_LIGHT = '#e8cf94';
    const INK = '#16213a';         // azul-tinta oscuro, casi negro, de marca

    function draw() {
      ctx!.clearRect(0, 0, W, H);

      // Interpolación: núcleo muy responsivo, anillo con leve retraso (elegancia, no látigo)
      core.x += (mouse.x - core.x) * 0.45;
      core.y += (mouse.y - core.y) * 0.45;
      ring.x += (mouse.x - ring.x) * 0.16;
      ring.y += (mouse.y - ring.y) * 0.16;

      const targetHover = isHovering ? 1 : 0;
      hoverProgress += (targetHover - hoverProgress) * 0.18;
      clickPulse *= 0.86;

      ctx!.save();

      if (isText) {
        // ── Cursor de texto formal: barra vertical fina, doble contorno
        const h = 17;
        const w = 1.4;
        const x = ring.x;
        const y = ring.y;

        ctx!.strokeStyle = 'rgba(255,255,255,0.9)';
        ctx!.lineWidth = w + 1.6;
        ctx!.lineCap = 'round';
        ctx!.beginPath();
        ctx!.moveTo(x, y - h / 2);
        ctx!.lineTo(x, y + h / 2);
        ctx!.stroke();

        ctx!.strokeStyle = INK;
        ctx!.lineWidth = w;
        ctx!.beginPath();
        ctx!.moveTo(x, y - h / 2);
        ctx!.lineTo(x, y + h / 2);
        ctx!.stroke();

        ctx!.restore();
        activeAnimId = requestAnimationFrame(draw);
        return;
      }

      // ── Anillo exterior
      const baseRadius = 11;
      const hoverExpand = 1 + hoverProgress * 0.9;     // se expande al pasar sobre links/botones
      const clickShrink = isClicking ? 0.82 : 1;
      const radius = baseRadius * hoverExpand * clickShrink;

      // Contorno claro (asegura visibilidad sobre fondos oscuros/saturados)
      ctx!.beginPath();
      ctx!.arc(ring.x, ring.y, radius, 0, Math.PI * 2);
      ctx!.strokeStyle = 'rgba(255,255,255,0.85)';
      ctx!.lineWidth = 2.6;
      ctx!.stroke();

      // Contorno oscuro interior (asegura visibilidad sobre fondos claros/blancos)
      ctx!.beginPath();
      ctx!.arc(ring.x, ring.y, radius, 0, Math.PI * 2);
      ctx!.strokeStyle = isHovering ? GOLD : INK;
      ctx!.lineWidth = 1.3;
      ctx!.stroke();

      // Línea de acento dorada — pequeño arco superior, detalle de marca sobrio
      if (hoverProgress > 0.02) {
        ctx!.beginPath();
        ctx!.arc(ring.x, ring.y, radius + 4.5, -Math.PI * 0.65, -Math.PI * 0.35);
        ctx!.strokeStyle = `rgba(202,161,74,${hoverProgress})`;
        ctx!.lineWidth = 1.6;
        ctx!.lineCap = 'round';
        ctx!.stroke();
      }

      // Pulso sutil al hacer click (anillo de eco, formal, sin chispas)
      if (clickPulse > 0.03) {
        ctx!.beginPath();
        ctx!.arc(ring.x, ring.y, radius + (1 - clickPulse) * 14, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(202,161,74,${clickPulse * 0.55})`;
        ctx!.lineWidth = 1.2;
        ctx!.stroke();
      }

      // ── Núcleo central: punto de precisión, doble contorno también
      const coreRadius = isClicking ? 2.1 : 2.6;

      ctx!.beginPath();
      ctx!.arc(core.x, core.y, coreRadius + 1.1, 0, Math.PI * 2);
      ctx!.fillStyle = 'rgba(255,255,255,0.9)';
      ctx!.fill();

      ctx!.beginPath();
      ctx!.arc(core.x, core.y, coreRadius, 0, Math.PI * 2);
      ctx!.fillStyle = isHovering ? GOLD : INK;
      ctx!.fill();

      ctx!.restore();

      activeAnimId = requestAnimationFrame(draw);
    }

    activeAnimId = requestAnimationFrame(draw);

    cleanupFn = () => {
      const styleNode = document.getElementById('cursor-hide-style');
      if (styleNode) styleNode.remove();

      window.removeEventListener('resize', resize);
      window.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('mousedown', handleMouseDown);
      window.removeEventListener('mouseup', handleMouseUp);
      document.removeEventListener('mouseover', handleMouseOver);
      document.removeEventListener('mouseout', handleMouseOut);
    };
  }

  initCursor();
  document.addEventListener('astro:page-load', initCursor);

  document.addEventListener('astro:before-swap', () => {
    if (cleanupFn) {
      cleanupFn();
      cleanupFn = null;
    }
    if (activeAnimId !== null) {
      cancelAnimationFrame(activeAnimId);
      activeAnimId = null;
    }
  });
</script>