---
import HeroSection from '../components/HeroSection.astro';
import Footer from '../components/Footer.astro';

const slides = [
  { id: 1, title: "INFOCADE",       subtitle: "Instituto Deportivo",      image: "/images/mix5.webp",  href: "/infocade"    },
  { id: 2, title: "CENACAP",        subtitle: "Centro de Capacitacion",   image: "/images/mix3.webp",  href: "/cenacap"     },
  { id: 3, title: "NUEVO SIGLO",    subtitle: "Formacion Profesional",    image: "/images/mix4.webp",  href: "/nuevo-ciclo" },
  { id: 4, title: "FUNDECT",        subtitle: "Fundacion Educativa",      image: "/images/mix2.webp",  href: "/fundect"     },
  
];

const institutions = [
  { name: "INAF",         color: "#D97706", glow: "rgba(217,119,6,0.12)",   path: "M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z M2 12h20", url: "https://inaf.cl" },
  { name: "UNITEP",       color: "#059669", glow: "rgba(5,150,105,0.1)",    path: "M22 10v6M2 10l10-5 10 5-10 5z M6 12.5V16a6 6 0 0 0 12 0v-3.5", url: "https://unitepc.edu.bo" },
  { name: "UNIFRANZ",     color: "#7C3AED", glow: "rgba(124,58,237,0.1)",   path: "M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5z", url: "https://unifranz.edu.bo" },
  { name: "CLUB OLIMPIC", color: "#DC2626", glow: "rgba(220,38,38,0.1)",    path: "M6 9H4.5a2.5 2.5 0 0 1 0-5H6 M18 9h1.5a2.5 2.5 0 0 0 0-5H18 M4 22h16 M10 14.66V17c0 .55.45 1 1 1h2c.55 0 1-.45 1-1v-2.34 M12 2a5 5 0 0 0-5 5v3c0 2.2 1.8 4 4 4h2c2.2 0 4-1.8 4-4V7a5 5 0 0 0-5-5z", url: "https://www.facebook.com/ClubOlympicCbba" },
  { name: "INTRASPORTS",  color: "#0284C7", glow: "rgba(2,132,199,0.1)",    path: "M13 2L3 14h9l-1 8 10-12h-9l1-8z", url: "https://fcintrasports.com" },
];
---

<!-- SECCIÓN PRINCIPAL CON FONDO BLANCO  { id: 5, title: "CLUB DE LEONES", subtitle: "Accion Civica y Social",   image: "/images/mix1.webp",  href: "/club-leones" }, -->
<section
  class="relative min-h-screen w-full flex flex-col items-center justify-center overflow-x-hidden coverflow-section"
  transition:animate="none"
>
  <!-- Fondo blanco con textura sutil -->
  <div class="absolute inset-0 z-0 bg-gradient-to-br from-white via-gray-50 to-gray-100">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.04) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, #000 0px, #000 1px, transparent 1px, transparent 24px);"></div>
  </div>

  <canvas id="beam-canvas" class="absolute inset-0 w-full h-full z-10 pointer-events-none"></canvas>

  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full pointer-events-none z-10"
       style="background:radial-gradient(ellipse, rgba(37,99,235,0.06) 0%, transparent 70%);"></div>

  <div class="relative z-20 w-full max-w-[1600px] mx-auto px-6 md:px-10 flex flex-col xl:flex-row items-center justify-between gap-12 xl:gap-4 pt-8 pb-10 xl:min-h-screen">

    <!-- COLUMNA IZQUIERDA (texto) -->
    <div class="w-full xl:w-[340px] flex flex-col items-center xl:items-start text-center xl:text-left order-1 left-col">
      <div class="relative mb-5 opacity-0 left-reveal-logo group flex items-center justify-center xl:justify-start">
        <div class="relative">
          <div class="absolute inset-0 rounded-2xl animate-logo-pulse"
               style="background:rgba(37,99,235,0.08);filter:blur(12px);transform:scale(1.3);"></div>
          <img src="/images/milogo.webp" alt="Logo CBIT - Corporación Boliviana de Talento y Formación"
               class="relative h-20 md:h-24 w-auto object-contain transition-transform duration-500 group-hover:scale-105"
               style="filter: drop-shadow(0 0 8px rgba(37,99,235,0.2)) drop-shadow(0 2px 10px rgba(0,0,0,0.05));" />
        </div>
      </div>

      <h1 class="font-display text-3xl md:text-4xl text-gray-800 tracking-widest uppercase leading-tight opacity-0 left-reveal-1 mb-1">
        CORPORACION BOLIVIANA
      </h1>
      <h2 class="font-display text-xl md:text-2xl tracking-[0.25em] uppercase leading-tight opacity-0 left-reveal-1 mb-4"
          style="color:#2563EB;">
        DE TALENTO Y FORMACIÓN INTEGRAL
      </h2>

      <div id="left-line" class="h-[2px] mb-4 origin-left rounded-full"
           style="width:0;background:linear-gradient(90deg,#2563EB,#FBBF24);transition:width 1s ease;"></div>

      <p class="text-gray-600 text-sm leading-relaxed max-w-md xl:max-w-sm text-left opacity-0 left-reveal-2 mb-6">
        Entidad orientada a la formación integral del talento boliviano, que integra programas académicos, cívicos y deportivos mediante alianzas estratégicas de excelencia.
      </p>

      <!-- Redes sociales -->
      <div class="flex items-center gap-2 mb-8 opacity-0 left-reveal-social">
        <a href="https://wa.me/59177101440?text=Hola,%20quiero%20información" target="_blank" rel="noopener noreferrer"
           class="social-btn group relative w-9 h-9 flex items-center justify-center rounded-xl border border-gray-300 bg-white shadow-sm transition-all duration-300 hover:shadow-md" aria-label="WhatsApp">
          <span class="social-tip">WhatsApp</span>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="#25D366" class="transition-transform duration-300 group-hover:scale-110">
            <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.993L2 22l5.13-1.347a9.947 9.947 0 0 0 4.881 1.279h.005c5.505 0 9.988-4.478 9.99-9.985 0-2.67-1.037-5.18-2.92-7.065A9.925 9.925 0 0 0 12.012 2zm5.727 14.123c-.253.715-1.47 1.387-2.022 1.478-.497.082-1.135.15-3.32-.756-2.793-1.157-4.595-4.004-4.736-4.193-.14-.188-1.136-1.51-1.136-2.88 0-1.37.718-2.043.97-2.317.254-.275.563-.343.75-.343.187 0 .375.002.537.01.17.008.402-.065.63.486.23.557.788 1.92.857 2.062.069.141.115.306.022.493-.092.188-.138.305-.276.467-.137.16-.29.356-.413.478-.138.136-.282.285-.121.562.162.277.72 1.184 1.543 1.916.822.732 1.517.957 1.733 1.05.215.093.342.079.467-.066.126-.145.539-.627.683-.84.143-.214.287-.18.483-.107.195.074 1.238.583 1.452.69.214.108.356.162.408.252.052.09.052.522-.201 1.238z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/share/192VbQWo7p/" target="_blank" rel="noopener noreferrer"
           class="social-btn group relative w-9 h-9 flex items-center justify-center rounded-xl border border-gray-300 bg-white shadow-sm transition-all duration-300 hover:shadow-md" aria-label="Facebook">
          <span class="social-tip">Facebook</span>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="#1877F2" class="transition-transform duration-300 group-hover:scale-110">
            <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/cenacap.bo" target="_blank" rel="noopener noreferrer"
           class="social-btn group relative w-9 h-9 flex items-center justify-center rounded-xl border border-gray-300 bg-white shadow-sm transition-all duration-300 hover:shadow-md" aria-label="Instagram">
          <span class="social-tip">Instagram</span>
          <svg width="17" height="17" viewBox="0 0 24 24" class="transition-transform duration-300 group-hover:scale-110">
            <defs><linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#FD5949"/><stop offset="50%" stop-color="#D6249F"/><stop offset="100%" stop-color="#285AEB"/></linearGradient></defs>
            <path fill="url(#ig-grad)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
        <a href="https://www.tiktok.com/@cenacap.bo" target="_blank" rel="noopener noreferrer"
           class="social-btn group relative w-9 h-9 flex items-center justify-center rounded-xl border border-gray-300 bg-white shadow-sm transition-all duration-300 hover:shadow-md" aria-label="TikTok">
          <span class="social-tip">TikTok</span>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="#111827" class="transition-transform duration-300 group-hover:scale-110">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .8.11V9.4a6.27 6.27 0 0 0-8.31 6A6.25 6.25 0 0 0 12 21.67a6.24 6.24 0 0 0 6.25-6.25v-8.2a8.73 8.73 0 0 0 4.74 1.48V5.3a5.22 5.22 0 0 1-3.4-1.28z"/>
          </svg>
        </a>
      </div>

      <!-- Controles del carrusel -->
      <div class="flex items-center gap-3 opacity-0 left-reveal-3">
        <button id="btn-prev"
                class="w-9 h-9 border border-gray-300 bg-white flex items-center justify-center transition-all duration-200 hover:border-blue-400 hover:bg-blue-50 rounded-xl shadow-sm" aria-label="Anterior">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4B5563" stroke-width="2.5"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        </button>
        <button id="btn-next"
                class="w-9 h-9 flex items-center justify-center transition-all duration-200 hover:scale-105 rounded-xl"
                style="border:1.5px solid rgba(37,99,235,0.5); background:rgba(37,99,235,0.06); box-shadow:0 2px 8px rgba(37,99,235,0.1);" aria-label="Siguiente">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
        <div class="ml-1 font-display text-xs tracking-[0.22em] text-gray-400">
          <span id="counter-current" class="font-bold" style="color:#2563EB;">01</span>
          <span class="mx-1 text-gray-400">/</span>
          <span>0{slides.length}</span>
        </div>
      </div>
    </div>

    <!-- CARRUSEL CENTRAL (3D COVERFLOW) -->
    <div class="relative w-full xl:flex-1 h-[400px] md:h-[480px] lg:h-[520px] flex items-center justify-center z-20 slider-container pointer-events-auto order-2" style="perspective:1300px;">
      <div class="relative w-[180px] md:w-[230px] lg:w-[270px] h-[280px] md:h-[380px] lg:h-[430px] transform-style-3d carousel-spinner" style="will-change:transform;">
        {slides.map((slide, index) => (
          <div class="absolute top-0 left-0 w-full h-full cursor-pointer coverflow-card group" data-index={index}>
            <div class="w-full h-full relative flex flex-col items-center justify-between overflow-hidden rounded-2xl transition-all duration-500 bg-white shadow-lg"
                 style="box-shadow:0 8px 24px rgba(61, 61, 61, 0.08); border:1px solid rgba(203,213,225,0.6);">
              
              <!-- Imagen de fondo -->
              <img src={slide.image} alt={`${slide.title} - ${slide.subtitle}`}
                   class="absolute inset-0 w-full h-full object-cover pointer-events-none card-img rounded-2xl" />
              
              
              <!-- Reflejo tipo espejo (solo activo en tarjeta central) -->
              <div class="mirror-shine absolute inset-0 pointer-events-none z-[3] rounded-2xl"
                   style="background:linear-gradient(108deg,transparent 20%,rgba(255,255,255,0.4) 45%,rgba(255,255,255,0.1) 52%,transparent 70%);transform:translateX(-130%);"></div>
              
              <!-- Línea superior de acento -->
              <div class="absolute top-0 left-0 right-0 h-[3px] z-10 rounded-t-2xl card-accent-top"
                   style="background:linear-gradient(90deg,#2563EB,#3B82F6 50%,#FBBF24);transform:scaleX(0);transform-origin:left;transition:transform 0.5s ease;"></div>
              
              <!-- Esquinas decorativas -->
              <div class="absolute top-2 left-2 w-5 h-5 z-10 pointer-events-none">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-white/80 rounded-full card-corner"></div>
                <div class="absolute top-0 left-0 w-[2px] h-full bg-white/80 rounded-full card-corner"></div>
              </div>
              <div class="absolute bottom-2 right-2 w-5 h-5 z-10 pointer-events-none">
                <div class="absolute bottom-0 right-0 w-full h-[2px] rounded-full card-corner-gold" style="background:#FBBF24;"></div>
                <div class="absolute bottom-0 right-0 w-[2px] h-full rounded-full card-corner-gold" style="background:#FBBF24;"></div>
              </div>

              <!-- Contenido textual -->
              <div class="relative z-10 w-full flex flex-col items-center mt-auto mb-4 px-4 py-3 text-center">
                <span class="text-white/80 text-[9px] font-bold tracking-[0.3em] uppercase mb-1 card-subtitle drop-shadow-md"></span>
                <h3 class="text-white text-base md:text-lg font-bold tracking-wide drop-shadow-md"></h3>
              </div>

              <!-- Botón CTA -->
              <div class="relative z-10 w-full flex flex-col items-center mb-5 px-4">
                <a href={slide.href}
                   class="px-6 py-2 text-[10px] md:text-xs font-bold tracking-[0.22em] uppercase rounded-xl transition-all duration-200 hover:scale-105 card-cta"
                   style="background:rgba(37,99,235,0.9); color:#fff; border:1.5px solid rgba(59,130,246,0.7); box-shadow:0 4px 16px rgba(37,99,235,0.35),0 0 0 1px rgba(59,130,246,0.2);">
                  <span class="relative z-10">ENTRAR</span>
                </a>
                <!-- Indicadores de página (dots) -->
                <div class="flex gap-1 mt-4 card-dots">
                  <div class="w-1.5 h-1.5 rounded-full bg-white/40"></div>
                  <div class="w-4 h-1.5 rounded-full bg-white/80"></div>
                  <div class="w-1.5 h-1.5 rounded-full bg-white/40"></div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- COLUMNA DERECHA (ALIADOS) -->
    <div class="w-full xl:w-[300px] flex flex-col items-center xl:items-end text-center xl:text-right order-3">
      <div class="right-col opacity-0" style="transform:translateX(20px);">
        <div class="inline-flex items-center gap-2 mb-2 justify-end">
          <span class="text-xs font-bold tracking-[0.28em] uppercase text-gray-500">CONVENIOS</span>
          <span class="w-8 h-[1.5px] block rounded-full" style="background:linear-gradient(90deg,transparent,#2563EB);"></span>
        </div>
        <h3 class="font-display text-xl lg:text-2xl text-gray-800 tracking-[0.2em] uppercase leading-tight mb-1">
          NUESTROS <span style="color:#2563EB;">ALIADOS</span>
        </h3>
        <div class="h-[2px] w-8 mt-2 mb-4 ml-auto rounded-full" style="background:linear-gradient(90deg,transparent,#2563EB);"></div>

        <div class="flex flex-col items-center xl:items-end gap-2 w-full">
          {institutions.map((inst) => (
            <a
              href={inst.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inst-btn group relative px-4 py-2.5 transition-all duration-200 w-full max-w-[260px] xl:w-[220px] flex items-center justify-center xl:justify-end gap-2.5 overflow-hidden opacity-0 rounded-xl border bg-white hover:shadow-md"
              style={`transform:translateX(16px); border-color:${inst.color}40; box-shadow:0 2px 6px rgba(0,0,0,0.04); --inst-color:${inst.color};`}
            >
              <span class="inst-fill absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200 rounded-xl"
                    style={`background:${inst.glow};`}></span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="transition-all duration-200 relative z-10 flex-shrink-0 group-hover:scale-110"
                   style={`color:${inst.color};`}>
                <path d={inst.path} />
              </svg>
              <span class="text-[10px] font-bold tracking-[0.2em] text-gray-700 group-hover:text-gray-900 transition-colors duration-200 z-10 relative">
                {inst.name}
              </span>
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                   class="opacity-30 group-hover:opacity-80 group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0 relative z-10 ml-auto hidden xl:block"
                   style={`color:${inst.color};`}>
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<HeroSection />
<Footer />

<style>
  .transform-style-3d { transform-style: preserve-3d; }

  @keyframes logo-pulse {
    0%,100% { opacity:0.6; transform:scale(1.3); }
    50%      { opacity:0.9; transform:scale(1.45); }
  }
  .animate-logo-pulse { animation: logo-pulse 3s ease-in-out infinite; }

  @keyframes mirrorSlide {
    0%   { transform: translateX(-130%); }
    100% { transform: translateX(230%); }
  }
  .coverflow-card.active .mirror-shine {
    animation: mirrorSlide 2.8s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .coverflow-card.active .mirror-shine { animation: none; }
  }

  .coverflow-card .card-img {
    opacity: 1;
    filter: grayscale(0%);
    transition: transform 0.6s ease;
  }
  .coverflow-card.active .card-img {
    transform: scale(1.04);
  }
  .coverflow-card.active .card-accent-top { transform: scaleX(1) !important; }
  .card-corner, .card-corner-gold { opacity: 0.35; transition: opacity 0.4s; }
  .coverflow-card.active .card-corner,
  .coverflow-card.active .card-corner-gold { opacity: 1; }

  .social-tip {
    position: absolute;
    top: -36px; left: 50%; transform: translateX(-50%);
    padding: 4px 10px;
    background: #1f2937;
    border-radius: 8px;
    font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: white; white-space: nowrap;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s, top 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }
  .social-btn:hover .social-tip { opacity: 1; top: -40px; }
  .social-btn {
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .social-btn:hover { transform: translateY(-3px) scale(1.1); }
</style>

<script>
import gsap from 'gsap';

let floatTween: gsap.core.Tween | null = null;
let autoPlayTween: gsap.core.Tween | null = null;
let resumeTimeout: ReturnType<typeof setTimeout> | null = null;
let userInteracted = false;
let abortController: AbortController | null = null;
let beamRAF: number | null = null;
let wheelTO: ReturnType<typeof setTimeout> | null = null;

interface Beam {
  x: number;
  y: number;
  vx: number;
  vy: number;
  life: number;
  maxLife: number;
  width: number;
  color: string;
}

function cleanup() {
  autoPlayTween?.kill();
  floatTween?.kill();
  autoPlayTween = null;
  floatTween = null;
  if (resumeTimeout) {
    clearTimeout(resumeTimeout);
    resumeTimeout = null;
  }
  abortController?.abort();
  abortController = null;
  userInteracted = false;
  if (beamRAF) {
    cancelAnimationFrame(beamRAF);
    beamRAF = null;
  }
  const spinner = document.querySelector<HTMLElement>('.carousel-spinner');
  if (spinner) {
    gsap.killTweensOf(spinner);
    gsap.set(spinner, { clearProps: 'all' });
  }
}

function initBeam() {
  const canvas = document.getElementById('beam-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const resize = () => {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  };
  resize();
  window.addEventListener('resize', resize);

  const beams: Beam[] = [];
  const colors = ['rgba(37,99,235,0.2)', 'rgba(59,130,246,0.18)', 'rgba(147,197,253,0.2)', 'rgba(245,158,11,0.12)'];

  const spawnBeam = () => {
    const w = canvas.width;
    const h = canvas.height;
    const side = Math.random();
    let x = 0, y = 0, vx = 0, vy = 0;
    const speed = 0.2 + Math.random() * 0.45;
    const angle = (Math.random() * 60 - 30) * Math.PI / 180;
    if (side < 0.5) {
      x = side < 0.25 ? 0 : w;
      y = Math.random() * h;
      vx = side < 0.25 ? Math.cos(angle) * speed : -Math.cos(angle) * speed;
      vy = Math.sin(angle) * speed;
    } else {
      x = Math.random() * w;
      y = side < 0.75 ? 0 : h;
      vx = Math.sin(angle) * speed;
      vy = side < 0.75 ? Math.cos(angle) * speed : -Math.cos(angle) * speed;
    }
    beams.push({
      x, y, vx, vy,
      life: 0,
      maxLife: 180 + Math.random() * 200,
      width: 0.3 + Math.random() * 0.9,
      color: colors[Math.floor(Math.random() * colors.length)]
    });
  };

  for (let i = 0; i < 10; i++) spawnBeam();

  const drawFrame = () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    if (Math.random() < 0.035) spawnBeam();
    for (let i = beams.length - 1; i >= 0; i--) {
      const b = beams[i];
      b.life++;
      b.x += b.vx;
      b.y += b.vy;
      const p = b.life / b.maxLife;
      let alpha = p < 0.15 ? p / 0.15 : p > 0.75 ? 1 - (p - 0.75) / 0.25 : 1;
      alpha *= 0.08;
      ctx.beginPath();
      ctx.moveTo(b.x - b.vx * 100, b.y - b.vy * 100);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = b.color + alpha + ')';
      ctx.lineWidth = b.width;
      ctx.stroke();
      if (b.life >= b.maxLife) beams.splice(i, 1);
    }
    beamRAF = requestAnimationFrame(drawFrame);
  };
  drawFrame();
}

function initCarousel() {
  cleanup();
  const spinner = document.querySelector<HTMLElement>('.carousel-spinner');
  const sliderContainer = document.querySelector<HTMLElement>('.slider-container');
  const cards = document.querySelectorAll<HTMLElement>('.coverflow-card');
  if (!spinner || !sliderContainer || !cards.length) return;

  abortController = new AbortController();
  const { signal } = abortController;
  const totalCards = cards.length;
  const theta = 360 / totalCards;
  let radius = 0;
  let activeIndex = 0;

  const calcRadius = () => window.innerWidth < 640 ? 170 : window.innerWidth < 1024 ? 230 : 330;

  const positionCards = () => {
    radius = calcRadius();
    cards.forEach((card, i) => {
      card.style.transform = `rotateY(${theta * i}deg) translateZ(${radius}px)`;
    });
  };

  const counterEl = document.getElementById('counter-current');

  const updateCards = (animate = true) => {
    const rotation = -activeIndex * theta;
    if (animate) {
      gsap.to(spinner, { z: -radius, rotationY: rotation, duration: 0.85, ease: 'power3.out' });
    } else {
      gsap.set(spinner, { z: -radius, rotationY: rotation });
    }
    const norm = ((activeIndex % totalCards) + totalCards) % totalCards;
    cards.forEach((card, i) => card.classList.toggle('active', i === norm));
    if (counterEl) counterEl.textContent = String(norm + 1).padStart(2, '0');
  };

  const startAutoPlay = () => {
    autoPlayTween?.kill();
    autoPlayTween = gsap.delayedCall(3.5, () => {
      if (!userInteracted) {
        activeIndex++;
        updateCards();
        startAutoPlay();
      }
    });
  };

  const onUserInteraction = () => {
    userInteracted = true;
    autoPlayTween?.kill();
    if (resumeTimeout) clearTimeout(resumeTimeout);
    resumeTimeout = setTimeout(() => {
      userInteracted = false;
      startAutoPlay();
    }, 5000);
  };

  positionCards();
  updateCards(false);
  floatTween = gsap.to(spinner, { y: -10, duration: 4, ease: 'sine.inOut', yoyo: true, repeat: -1 });
  startAutoPlay();
  initBeam();

  gsap.fromTo('.left-reveal-logo',
    { opacity: 0, scale: 0.7, y: -30 },
    { opacity: 1, scale: 1, y: 0, duration: 0.9, delay: 0.1, ease: 'back.out(1.8)' }
  );
  gsap.to('.left-reveal-1', { opacity: 1, y: 0, duration: 0.7, delay: 0.25, ease: 'power3.out' });
  gsap.to('.left-reveal-2', { opacity: 1, y: 0, duration: 0.7, delay: 0.38, ease: 'power3.out' });
  gsap.to('.left-reveal-social', { opacity: 1, duration: 0.6, delay: 0.45, ease: 'power3.out' });
  gsap.fromTo('.social-btn',
    { opacity: 0, y: 14, scale: 0.75 },
    { opacity: 1, y: 0, scale: 1, duration: 0.55, delay: 0.5, stagger: 0.07, ease: 'back.out(1.5)' }
  );
  gsap.to('.left-reveal-3', { opacity: 1, duration: 0.6, delay: 0.7, ease: 'power3.out' });
  gsap.fromTo(cards,
    { opacity: 0, scale: 0.88 },
    { opacity: 1, scale: 1, duration: 0.7, delay: 0.2, ease: 'power3.out' }
  );
  gsap.to('.right-col', { opacity: 1, x: 0, duration: 0.8, delay: 0.3, ease: 'power3.out' });
  gsap.to('.inst-btn', { opacity: 1, x: 0, duration: 0.55, delay: 0.45, stagger: 0.07, ease: 'power3.out' });
  setTimeout(() => {
    const ll = document.getElementById('left-line');
    if (ll) ll.style.width = '72px';
  }, 500);

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      floatTween?.pause();
      autoPlayTween?.kill();
    } else {
      floatTween?.resume();
      if (!userInteracted) startAutoPlay();
    }
  }, { signal });

  cards.forEach(card => {
    card.addEventListener('click', (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const index = parseInt(card.getAttribute('data-index') ?? '0');
      const norm = ((activeIndex % totalCards) + totalCards) % totalCards;
      onUserInteraction();
      if (norm !== index) {
        let diff = index - norm;
        if (diff > totalCards / 2) diff -= totalCards;
        if (diff < -totalCards / 2) diff += totalCards;
        activeIndex += diff;
        updateCards();
      } else {
        gsap.fromTo(card, { scale: 0.95 }, { scale: 1, duration: 0.4, ease: 'back.out(2)' });
      }
    }, { signal });
  });

  document.getElementById('btn-prev')?.addEventListener('click', () => {
    onUserInteraction();
    activeIndex--;
    updateCards();
  }, { signal });
  document.getElementById('btn-next')?.addEventListener('click', () => {
    onUserInteraction();
    activeIndex++;
    updateCards();
  }, { signal });

  sliderContainer.addEventListener('wheel', (e: WheelEvent) => {
    e.preventDefault();
    if (wheelTO) clearTimeout(wheelTO);
    wheelTO = setTimeout(() => {
      onUserInteraction();
      activeIndex += (e.deltaY > 0 || e.deltaX > 0) ? 1 : -1;
      updateCards();
    }, 50);
  }, { passive: false, signal });

  let tx = 0, ty = 0;
  sliderContainer.addEventListener('touchstart', (e: TouchEvent) => {
    tx = e.touches[0].clientX;
    ty = e.touches[0].clientY;
  }, { passive: true, signal });
  sliderContainer.addEventListener('touchend', (e: TouchEvent) => {
    const dx = e.changedTouches[0].clientX - tx;
    const dy = e.changedTouches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      onUserInteraction();
      activeIndex += dx < 0 ? 1 : -1;
      updateCards();
    }
  }, { passive: true, signal });

  window.addEventListener('resize', () => {
    positionCards();
    updateCards(false);
  }, { signal });
}

document.addEventListener('astro:before-swap', cleanup);
document.addEventListener('astro:page-load', initCarousel);
if (document.readyState !== 'loading') {
  initCarousel();
} else {
  document.addEventListener('DOMContentLoaded', initCarousel);
}
</script>