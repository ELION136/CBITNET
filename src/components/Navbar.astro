---
const { pathname } = Astro.url;
const isRegisterPage = pathname === "/inscribirse" || pathname === "/inscribirse/";
---

<!-- Desktop & Mobile Header -->
<nav class="fixed top-0 left-0 w-full z-[100] py-4 px-6 md:py-6 md:px-10 flex justify-between items-center mix-blend-difference pointer-events-auto">
  <a href="/" class="relative z-[101] flex items-center gap-1.5 transition-transform duration-300 hover:scale-105 select-none">
    <img src="/images/milogo.png" alt="CBIT Logo" class="h-12 md:h-16 w-auto object-contain" />
    <span class="text-xl md:text-2xl font-display tracking-widest text-white">CBIT<span class="text-yellow-500">.</span></span>
  </a>
  
  <!-- Desktop Menu with enhanced hover effect: golden corner drawing brackets + smooth glow transition -->
  <ul class="hidden md:flex items-center space-x-6 text-xs font-semibold tracking-widest text-white">
    <li>
      <a href="/sobre-nosotros" class="relative inline-block px-4 py-2 text-white/80 hover:text-amber-400 transition-colors duration-300 group">
        SOBRE NOSOTROS
        <span class="absolute top-0 left-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
        <span class="absolute top-0 left-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></span>
        <span class="absolute bottom-0 right-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
        <span class="absolute bottom-0 right-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-bottom duration-300"></span>
        <span class="absolute inset-0 bg-amber-400/5 rounded opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-[2px] -z-10"></span>
      </a>
    </li>
    <li>
      <a href="/carreras" class="relative inline-block px-4 py-2 text-white/80 hover:text-amber-400 transition-colors duration-300 group">
        CARRERAS Y SERVICIOS
        <span class="absolute top-0 left-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
        <span class="absolute top-0 left-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></span>
        <span class="absolute bottom-0 right-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
        <span class="absolute bottom-0 right-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-bottom duration-300"></span>
        <span class="absolute inset-0 bg-amber-400/5 rounded opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-[2px] -z-10"></span>
      </a>
    </li>
    <li>
      <a href="/proximos-eventos" class="relative inline-block px-4 py-2 text-white/80 hover:text-amber-400 transition-colors duration-300 group">
        PROXIMOS EVENTOS
        <span class="absolute top-0 left-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
        <span class="absolute top-0 left-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></span>
        <span class="absolute bottom-0 right-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
        <span class="absolute bottom-0 right-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-bottom duration-300"></span>
        <span class="absolute inset-0 bg-amber-400/5 rounded opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-[2px] -z-10"></span>
      </a>
    </li>
    <li>
      <a href="/latest" class="relative inline-block px-4 py-2 text-white/80 hover:text-amber-400 transition-colors duration-300 group">
        NOTICIAS
        <span class="absolute top-0 left-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></span>
        <span class="absolute top-0 left-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></span>
        <span class="absolute bottom-0 right-0 w-2.5 h-[2px] bg-amber-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
        <span class="absolute bottom-0 right-0 w-[2px] h-2.5 bg-amber-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-bottom duration-300"></span>
        <span class="absolute inset-0 bg-amber-400/5 rounded opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-[2px] -z-10"></span>
      </a>
    </li>
  </ul>

  <!-- Mobile Hamburger Button -->
  <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 relative z-[101] p-2 cursor-pointer">
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-1"></div>
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-2"></div>
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-3"></div>
  </button>
</nav>

<!-- Mobile Menu Overlay with updated hover color to golden -->
<div id="mobile-menu" class="fixed inset-0 bg-[#030303] z-[90] flex flex-col items-center justify-center translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] pointer-events-auto">
  <!-- Background Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[250px] h-[250px] bg-amber-500/10 blur-[80px] rounded-full pointer-events-none z-0"></div>

  <ul class="flex flex-col items-center space-y-8 text-3xl font-display tracking-widest text-white z-10">
    <li>
      <a href="/sobre-nosotros" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0 text-center">SOBRE NOSOTROS</span>
      </a>
    </li>
    <li>
      <a href="/carreras" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0 text-center">CARRERAS Y SERVICIOS</span>
      </a>
    </li>
    <li>
      <a href="/proximos-eventos" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0 text-center">PROXIMOS EVENTOS</span>
      </a>
    </li>
    <li>
      <a href="/latest" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0 text-center">NOTICIAS</span>
      </a>
    </li>
  </ul>
</div>

<script>
  import gsap from 'gsap';

  if (typeof window !== 'undefined') {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const lines = [
      document.querySelector('.line-1'),
      document.querySelector('.line-2'),
      document.querySelector('.line-3')
    ];
    const links = document.querySelectorAll('.mobile-link span');
    
    let isOpen = false;

    menuBtn?.addEventListener('click', () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        // Animate hamburger to X
        gsap.to(lines[0], { y: 8, rotation: 45, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[1], { opacity: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[2], { y: -8, rotation: -45, duration: 0.3, ease: 'power2.inOut' });

        // Slide in menu
        mobileMenu?.classList.remove('translate-x-full');
        mobileMenu?.classList.add('translate-x-0');

        // Prevent scroll
        document.body.style.overflow = 'hidden';

        // Animate links staggered reveal
        gsap.to(links, {
          y: 0,
          opacity: 1,
          duration: 0.6,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.3 // wait for menu to start sliding in
        });
      } else {
        // Revert hamburger
        gsap.to(lines[0], { y: 0, rotation: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[1], { opacity: 1, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[2], { y: 0, rotation: 0, duration: 0.3, ease: 'power2.inOut' });

        // Animate links out fast
        gsap.to(links, {
          y: '100%',
          opacity: 0,
          duration: 0.3,
          ease: 'power2.in'
        }).then(() => {
          // Slide out menu after links hide
          mobileMenu?.classList.remove('translate-x-0');
          mobileMenu?.classList.add('translate-x-full');
          document.body.style.overflow = '';
        });
      }
    });

    // Close menu when a link is clicked
    const mobileLinks = document.querySelectorAll('.mobile-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) {
          menuBtn?.click();
        }
      });
    });
  }
</script>

<!-- Floating CTA Button (Persistent on all pages, except the register page itself) - Style-matched to CoverflowHero.astro with cut-corners & interactive hover -->
{!isRegisterPage && (
  <a 
    href="https://forms.gle/cVVdBKkZb4oSyXf27" 
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-[80] flex items-center justify-center gap-2 px-5 py-3.5 md:px-6 md:py-4 text-white/90 font-display tracking-widest text-xs md:text-sm uppercase transition-all duration-300 border hover:text-white hover:scale-105 active:scale-95 group pointer-events-auto"
    style="
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
      border: 1.5px solid rgba(245, 158, 11, 0.45);
      background: linear-gradient(135deg, #0a0f1c, #05070d);
      box-shadow: 0 0 20px rgba(245, 158, 11, 0.15);
    "
  >
    <!-- Hover Background Glow Fill -->
    <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
          style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), transparent);"></span>
    
    <!-- Hover Drawing Right Border -->
    <span class="absolute right-0 top-0 bottom-0 w-[2px] origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500 pointer-events-none"
          style="background: linear-gradient(to top, rgb(245, 158, 11), transparent);"></span>

    <!-- Hover Glowing Left Dot -->
    <span class="absolute left-4 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full transition-all duration-300 opacity-0 group-hover:opacity-100 pointer-events-none"
          style="background: rgb(245, 158, 11); box-shadow: 0 0 8px rgb(245, 158, 11);"></span>

    <!-- SVG Icon with Glow -->
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgb(245, 158, 11)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300 relative z-10 filter drop-shadow-[0_0_4px_rgba(245,158,11,0.5)]">
      <path d="M15 3h6v6"/>
      <path d="M10 14 21 3"/>
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
    </svg>
    <span class="relative z-10 transition-colors duration-300 group-hover:text-amber-300 pl-2">INSCRIBIRSE AHORA</span>
  </a>
)}