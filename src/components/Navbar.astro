---
const { pathname } = Astro.url;
const isRegisterPage = pathname === "/inscribirse" || pathname === "/inscribirse/";
---

<!-- Desktop & Mobile Header -->
<nav class="fixed top-0 left-0 w-full z-[100] py-4 px-6 md:py-6 md:px-10 flex justify-between items-center mix-blend-difference pointer-events-auto">
  <a href="/" class="relative z-[101] flex items-center gap-1.5 transition-transform duration-300 hover:scale-105 select-none">
    <img src="/images/milogo.png" alt="CBIT Logo" class="h-12 md:h-16 w-auto object-contain" />
    <span class="text-xl md:text-2xl font-display tracking-widest text-white">CBIT<span class="text-yellow-500">.</span></span>
  </a>
  
  <!-- Desktop Menu with enhanced hover effect: golden underline + smooth scale & color transition -->
  <ul class="hidden md:flex space-x-8 text-xs font-semibold tracking-widest text-white">
    <li>
      <a href="/" class="relative inline-block after:content-[''] after:absolute after:bottom-[-6px] after:left-0 after:w-0 after:h-[2px] after:bg-amber-400 after:transition-all after:duration-300 hover:after:w-full transition-all duration-300 hover:text-amber-300 hover:scale-105">
        HOME
      </a>
    </li>
    <li>
      <a href="/autoridades" class="relative inline-block after:content-[''] after:absolute after:bottom-[-6px] after:left-0 after:w-0 after:h-[2px] after:bg-amber-400 after:transition-all after:duration-300 hover:after:w-full transition-all duration-300 hover:text-amber-300 hover:scale-105">
        AUTORIDADES
      </a>
    </li>
    <li>
      <a href="/servicios" class="relative inline-block after:content-[''] after:absolute after:bottom-[-6px] after:left-0 after:w-0 after:h-[2px] after:bg-amber-400 after:transition-all after:duration-300 hover:after:w-full transition-all duration-300 hover:text-amber-300 hover:scale-105">
        SERVICIOS
      </a>
    </li>
    <li>
      <a href="/sobre-nosotros" class="relative inline-block after:content-[''] after:absolute after:bottom-[-6px] after:left-0 after:w-0 after:h-[2px] after:bg-amber-400 after:transition-all after:duration-300 hover:after:w-full transition-all duration-300 hover:text-amber-300 hover:scale-105">
        SOBRE NOSOTROS
      </a>
    </li>
    <li>
      <a href="/carreras" class="relative inline-block after:content-[''] after:absolute after:bottom-[-6px] after:left-0 after:w-0 after:h-[2px] after:bg-amber-400 after:transition-all after:duration-300 hover:after:w-full transition-all duration-300 hover:text-amber-300 hover:scale-105">
        NUESTROS PROGRAMAS
      </a>
    </li>
  </ul>

  <!-- Mobile Hamburger Button -->
  <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 relative z-[101] p-2 cursor-pointer">
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-1"></div>
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-2"></div>
    <div class="w-6 h-[2px] bg-white transition-all duration-300 line-3"></div>
  </button>
</nav>

<!-- Mobile Menu Overlay with updated hover color to golden -->
<div id="mobile-menu" class="fixed inset-0 bg-[#030303] z-[90] flex flex-col items-center justify-center translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] pointer-events-auto">
  <!-- Background Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[250px] h-[250px] bg-amber-500/10 blur-[80px] rounded-full pointer-events-none z-0"></div>

  <ul class="flex flex-col items-center space-y-8 text-3xl font-display tracking-widest text-white z-10">
    <li>
      <a href="/" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0">HOME</span>
      </a>
    </li>
    <li>
      <a href="/autoridades" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0">AUTORIDADES</span>
      </a>
    </li>
    <li>
      <a href="/servicios" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0">SERVICIOS</span>
      </a>
    </li>
    <li>
      <a href="/sobre-nosotros" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0 text-center">SOBRE NOSOTROS</span>
      </a>
    </li>
    <li>
      <a href="/carreras" class="mobile-link hover:text-amber-300 transition-colors block overflow-hidden">
        <span class="block translate-y-full opacity-0">NUESTROS PROGRAMAS</span>
      </a>
    </li>
  </ul>
</div>

<script>
  import gsap from 'gsap';

  if (typeof window !== 'undefined') {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const lines = [
      document.querySelector('.line-1'),
      document.querySelector('.line-2'),
      document.querySelector('.line-3')
    ];
    const links = document.querySelectorAll('.mobile-link span');
    
    let isOpen = false;

    menuBtn?.addEventListener('click', () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        // Animate hamburger to X
        gsap.to(lines[0], { y: 8, rotation: 45, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[1], { opacity: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[2], { y: -8, rotation: -45, duration: 0.3, ease: 'power2.inOut' });

        // Slide in menu
        mobileMenu?.classList.remove('translate-x-full');
        mobileMenu?.classList.add('translate-x-0');

        // Prevent scroll
        document.body.style.overflow = 'hidden';

        // Animate links staggered reveal
        gsap.to(links, {
          y: 0,
          opacity: 1,
          duration: 0.6,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.3 // wait for menu to start sliding in
        });
      } else {
        // Revert hamburger
        gsap.to(lines[0], { y: 0, rotation: 0, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[1], { opacity: 1, duration: 0.3, ease: 'power2.inOut' });
        gsap.to(lines[2], { y: 0, rotation: 0, duration: 0.3, ease: 'power2.inOut' });

        // Animate links out fast
        gsap.to(links, {
          y: '100%',
          opacity: 0,
          duration: 0.3,
          ease: 'power2.in'
        }).then(() => {
          // Slide out menu after links hide
          mobileMenu?.classList.remove('translate-x-0');
          mobileMenu?.classList.add('translate-x-full');
          document.body.style.overflow = '';
        });
      }
    });

    // Close menu when a link is clicked
    const mobileLinks = document.querySelectorAll('.mobile-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) {
          menuBtn?.click();
        }
      });
    });
  }
</script>

<!-- Floating CTA Button (Persistent on all pages, except the register page itself) - Updated to Golden Yellow with enhanced hover effect -->
{!isRegisterPage && (
  <a 
    href="https://forms.gle/cVVdBKkZb4oSyXf27" 
    target="_blank"
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-[80] flex items-center justify-center gap-2 px-5 py-3 md:px-6 md:py-4 rounded-full bg-amber-500 hover:bg-amber-400 text-black font-bold tracking-widest text-xs md:text-sm uppercase transition-all duration-300 shadow-[0_0_20px_rgba(245,158,11,0.5)] hover:shadow-[0_0_35px_rgba(245,158,11,0.8)] hover:scale-105 active:scale-95 group pointer-events-auto animate-pulse"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300">
      <path d="M15 3h6v6"/>
      <path d="M10 14 21 3"/>
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
    </svg>
    <span>INSCRIBIRSE AHORA</span>
  </a>
)}