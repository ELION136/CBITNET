---
const { pathname } = Astro.url;
const isRegisterPage = pathname === "/inscribirse" || pathname === "/inscribirse/";

const navLinks = [
  { href: "/sobre-nosotros",   label: "Sobre Nosotros" },
  { href: "/carreras",         label: "Programas Academicos" },
  { href: "/proximos-eventos", label: "Evento" },
  { href: "/convenios",        label: "Convenios" },
  { href: "/latest",           label: "Noticias" },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
  /* ══════════════════════════════════════════
     VARIABLES GLOBALES
  ══════════════════════════════════════════ */
  :root {
    --nav-h-desk: 68px;
    --nav-h-mob:  58px;
    --deep:   #0b337e;
    --mid:    #10397a;
    --accent: #1D4ED8;
    --gold:   #F59E0B;
    --gold2:  #FCD34D;
    --white:  #F8FAFF;
    --slash:  rgba(248, 250, 255, 0.15);
  }

  /* ══════════════════════════════════════════
     NAV WRAPPER — scroll hide/show
  ══════════════════════════════════════════ */
  #cbit-nav {
    position: fixed;
    top: 0; left: 0; width: 100%;
    z-index: 200;
    will-change: transform, opacity;
    animation: nav-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes nav-enter {
    from { transform: translateY(-110%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
  #cbit-nav.nav-hidden {
    transform: translateY(-110%);
    opacity: 0;
    transition: transform 0.38s cubic-bezier(0.76, 0, 0.24, 1),
                opacity   0.38s ease;
  }
  #cbit-nav.nav-visible {
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1),
                opacity   0.38s ease;
  }

  /* ══════════════════════════════════════════
     BARRA EXTERNA
  ══════════════════════════════════════════ */
  .nav-shell {
    background: var(--deep);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  /* Raya dorada al tope */
  .nav-shell::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent   0%,
      var(--gold)  20%,
      var(--gold2) 50%,
      var(--gold)  80%,
      transparent  100%
    );
    z-index: 3;
  }

  /* Diagonal decorativa de fondo */
  .nav-shell::after {
    content: '';
    position: absolute;
    top: -40px; right: -20px;
    width: 340px; height: 200px;
    background: var(--accent);
    opacity: 0.06;
    transform: skewX(-18deg);
    pointer-events: none;
    z-index: 0;
  }

  /* ══════════════════════════════════════════
     INNER
  ══════════════════════════════════════════ */
  .nav-inner {
    position: relative; z-index: 2;
    max-width: 1440px; margin: 0 auto;
    padding: 0 48px;
    height: var(--nav-h-desk);
    display: flex;
    align-items: center;
    /* Logo a la izquierda, links + hamburger a la derecha */
    justify-content: space-between;
    gap: 0;
  }

  /* ══════════════════════════════════════════
     LOGO — contorno que sigue la forma (sin cuadros)
  ══════════════════════════════════════════ */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 11px;
  text-decoration: none;
  flex-shrink: 0;
  animation: logo-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.35s both;
}

@keyframes logo-enter {
  from {
    opacity: 0;
    transform: translateX(-20px) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

/* Contenedor sin ningún recuadro ni fondo cuadrado */
.logo-img-wrap {
  display: flex;
  align-items: center;
  /* Eliminamos padding, fondo, bordes y sombras cuadradas */
  padding: 0;
  background: none;
  border: none;
  box-shadow: none;
  transition: transform 0.28s ease;
}

.nav-logo:hover .logo-img-wrap {
  transform: scale(1.06); /* solo la escala, sin efectos cuadrados */
}

.nav-logo img {
  height: 36px;
  width: auto;
  object-fit: contain;
  display: block;
  /* Glow / contorno que respeta la forma real del logo */
  filter:
    drop-shadow(0 0 5px rgba(255, 255, 255, 0.70))
    drop-shadow(0 0 14px rgba(255, 255, 255, 0.30));
  transition: filter 0.28s ease;
}

.nav-logo:hover img {
  filter:
    drop-shadow(0 0 8px rgba(255, 255, 255, 0.95))
    drop-shadow(0 0 22px rgba(255, 255, 255, 0.55));
}


  /* Separador vertical dorado */
  .logo-divider {
    width: 1.5px; height: 28px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    opacity: 0.6;
    flex-shrink: 0;
  }

  .logo-name {
    font-family: 'Anton', sans-serif;
    font-size: 26px;
    letter-spacing: 0.16em;
    color: var(--white);
    line-height: 1;
  }
  .logo-name em {
    font-style: normal;
    color: rgb(240, 207, 18);
  }

  /* ══════════════════════════════════════════
     DESKTOP LINKS — pegados + al extremo derecho
  ══════════════════════════════════════════ */
  .nav-links {
    display: flex;
    align-items: stretch;
    list-style: none;
    margin: 0;
    /* Sin padding para ir al extremo — el nav-inner ya tiene padding */
    padding: 0;
    height: var(--nav-h-desk);
    /* Separa el logo del bloque de links empujando al extremo derecho */
    margin-left: auto;
  }

  .nav-links li {
    display: flex;
    align-items: center;
    opacity: 0;
    animation: link-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .nav-links li:nth-child(1) { animation-delay: 0.55s; }
  .nav-links li:nth-child(2) { animation-delay: 0.65s; }
  .nav-links li:nth-child(3) { animation-delay: 0.75s; }
  .nav-links li:nth-child(4) { animation-delay: 0.85s; }
  @keyframes link-enter {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nav-block {
    position: relative;
    display: flex;
    align-items: center;
    /* Padding horizontal reducido para que queden más pegados */
    padding: 0 18px;
    height: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    /* ── TEXTO SIEMPRE VISIBLE ── */
    color: rgba(248, 250, 255, 0.92);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s ease;
    clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
    /* Fondo reposo: blanco → azul (sutil, no opaco) */
    background: linear-gradient(135deg, rgba(255,255,255,0.10) 0%, rgba(5, 37, 128, 0.14) 100%);
  }

  /* Slash divisor entre items — más visible */
  .nav-links li + li .nav-block::before {
    content: '';
    position: absolute;
    left: -1px; top: 14%; bottom: 14%;
    width: 1.5px;
    background: var(--slash);
    transform: skewX(-14deg);
  }

  /* Capa dorada en hover / activo */
  .nav-block::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #F5D76E 0%,
      #E6C200 35%,
      #C9A227 65%,
      #A67C00 100%
    );
    clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  /* Línea inferior dorada */
  .nav-block .link-underline {
    position: absolute;
    bottom: 0; left: 10px; right: 10px;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--gold2));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 2px;
  }

  /* Hover / activo → dorado + texto blanco brillante */
  .nav-block:hover,
  .nav-block[data-active="true"] {
    color: #FFFFFF;
  }
  .nav-block:hover::after,
  .nav-block[data-active="true"]::after {
    opacity: 1;
  }
  .nav-block:hover .link-underline,
  .nav-block[data-active="true"] .link-underline {
    transform: scaleX(1);
  }

  /* El texto debe quedar por encima del ::after dorado */
  .nav-block > span,
  .nav-block > .link-underline {
    position: relative;
    z-index: 1;
  }

  /* ══════════════════════════════════════════
     DERECHA: HAMBURGER
  ══════════════════════════════════════════ */
  .nav-right {
    display: flex; align-items: center; gap: 14px; flex-shrink: 0;
    animation: right-enter 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.95s both;
  }
  @keyframes right-enter {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ══════════════════════════════════════════
     HAMBURGER (mobile only)
  ══════════════════════════════════════════ */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 42px; height: 42px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    cursor: pointer;
    padding: 10px;
    transition: background 0.2s;
    position: relative; z-index: 300;
  }
  .hamburger:hover { background: rgba(255, 255, 255, 0.1); }
  .bar {
    width: 100%; height: 2px;
    background: var(--white); border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    display: block;
  }
  .hamburger.open .bar:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .hamburger.open .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open .bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  /* ══════════════════════════════════════════
     MOBILE MENU
  ══════════════════════════════════════════ */
  .mobile-menu {
    position: fixed;
    top: var(--nav-h-mob); left: 0; right: 0;
    background: var(--deep);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    z-index: 190;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.76, 0, 0.24, 1);
  }
  .mobile-menu.open { max-height: 420px; }

  .mob-links { list-style: none; margin: 0; padding: 8px 16px 20px; }
  .mob-links li a {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: 0.1em;
    color: rgba(248, 250, 255, 0.75);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
  }
  .mob-links li:last-child a { border-bottom: none; }
  .mob-links li a:hover { color: var(--white); background: rgba(255, 255, 255, 0.05); }
  .mob-arrow {
    font-size: 20px; opacity: 0.25;
    transition: transform 0.2s, opacity 0.2s;
    line-height: 1;
  }
  .mob-links li a:hover .mob-arrow { transform: translateX(6px); opacity: 0.7; }

  /* ══════════════════════════════════════════
     FLOATING CTA
  ══════════════════════════════════════════ */
  .floating-cta {
    position: fixed; bottom: 24px; right: 24px;
    z-index: 180;
    display: flex; align-items: center; gap: 9px;
    padding: 13px 22px;
    background: var(--accent);
    color: var(--white);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px; letter-spacing: 0.16em;
    text-decoration: none;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 4px 24px rgba(29, 78, 216, 0.45),
                0 0 0 1px rgba(29, 78, 216, 0.3);
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
    animation: cta-enter 0.55s cubic-bezier(0.22, 1, 0.36, 1) 1.1s both;
  }
  @keyframes cta-enter {
    from { opacity: 0; transform: translateY(22px) scale(0.88); }
    to   { opacity: 1; transform: translateY(0)     scale(1); }
  }
  .floating-cta::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 55%);
    pointer-events: none;
  }
  .floating-cta:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 10px 36px rgba(29, 78, 216, 0.6),
                0 0 0 1px rgba(29, 78, 216, 0.5);
  }
  .floating-cta:active { transform: scale(0.97); }
  .cta-text, .cta-icon { position: relative; z-index: 1; }

  /* ══════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════ */
  @media (max-width: 1100px) {
    .nav-inner { padding: 0 28px; }
    .nav-block  { padding: 0 13px; font-size: 10.5px; }
  }

  @media (max-width: 820px) {
    .nav-inner  { padding: 0 20px; height: var(--nav-h-mob); }
    .nav-links  { display: none; }
    .hamburger  { display: flex; }
    .logo-name  { font-size: 22px; }
    .nav-logo img { height: 30px; }
    .floating-cta { bottom: 16px; right: 16px; padding: 11px 16px; font-size: 12px; }
  }

  @media (max-width: 440px) {
    .nav-inner  { padding: 0 14px; }
    .logo-name  { font-size: 20px; }
  }
</style>

<!-- ═══════════════════════════════════
     NAVBAR
════════════════════════════════════ -->
<nav id="cbit-nav" role="navigation" aria-label="Menú principal">
  <div class="nav-shell">
    <div class="nav-inner">

      <!-- LOGO -->
      <a href="/" class="nav-logo" aria-label="CBIT · Inicio">
        <div class="logo-img-wrap">
          <img src="/images/milogo.webp" alt="CBIT Logo" />
        </div>
        <span class="logo-divider" aria-hidden="true"></span>
        <span class="logo-name">CB<em>IT</em></span>
      </a>

      <!-- DESKTOP LINKS -->
      <ul class="nav-links" role="list">
        {navLinks.map(link => {
          const active = pathname.startsWith(link.href);
          return (
            <li>
              <a
                href={link.href}
                class="nav-block"
                aria-current={active ? 'page' : undefined}
                data-active={String(active)}
              >
                <span>{link.label}</span>
                <span class="link-underline" aria-hidden="true"></span>
              </a>
            </li>
          );
        })}
      </ul>

      <!-- DERECHA (hamburger mobile) -->
      <div class="nav-right">
        <button
          class="hamburger"
          id="cbit-ham"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="cbit-mob-menu"
        >
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>

    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════
     MOBILE MENU
════════════════════════════════════ -->
<div class="mobile-menu" id="cbit-mob-menu" aria-hidden="true">
  <ul class="mob-links" role="list">
    {navLinks.map(link => (
      <li>
        <a href={link.href}>
          {link.label}
          <span class="mob-arrow" aria-hidden="true">›</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<!-- ═══════════════════════════════════
     FLOATING CTA
════════════════════════════════════ -->
{!isRegisterPage && (
  <a
    href="https://forms.gle/cVVdBKkZb4oSyXf27"
    target="_blank"
    rel="noopener noreferrer"
    class="floating-cta"
    aria-label="Ir a Reservas (abre en nueva pestaña)"
  >
    <svg class="cta-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
         viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M15 3h6v6"/>
      <path d="M10 14 21 3"/>
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
    </svg>
    <span class="cta-text">Reservas</span>
  </a>
)}

<!-- ═══════════════════════════════════
     SCRIPT: hamburger + scroll
════════════════════════════════════ -->
<script>
import gsap from 'gsap';

if (typeof window !== 'undefined') {
  const nav    = document.getElementById('cbit-nav');
  const ham    = document.getElementById('cbit-ham');
  const menu   = document.getElementById('cbit-mob-menu');
  const mLinks = menu?.querySelectorAll('.mob-links li a');
  let isOpen   = false;

  /* ── Hamburger ── */
  function openMenu() {
    isOpen = true;
    ham?.classList.add('open');
    menu?.classList.add('open');
    menu?.setAttribute('aria-hidden', 'false');
    ham?.setAttribute('aria-expanded', 'true');
    ham?.setAttribute('aria-label', 'Cerrar menú');
    document.body.style.overflow = 'hidden';
    if (mLinks) {
      gsap.fromTo(mLinks,
        { x: -20, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.38, stagger: 0.07, ease: 'power3.out', delay: 0.12 }
      );
    }
  }

  function closeMenu() {
    isOpen = false;
    ham?.classList.remove('open');
    menu?.classList.remove('open');
    menu?.setAttribute('aria-hidden', 'true');
    ham?.setAttribute('aria-expanded', 'false');
    ham?.setAttribute('aria-label', 'Abrir menú');
    document.body.style.overflow = '';
  }

  ham?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  mLinks?.forEach(l => l.addEventListener('click', () => { if (isOpen) closeMenu(); }));
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) closeMenu(); });
  window.addEventListener('resize', () => { if (window.innerWidth > 820 && isOpen) closeMenu(); });

  /* ── Scroll hide / show ── */
  let lastY    = window.scrollY;
  let ticking  = false;
  const THRESHOLD = 80;

  function onScroll() {
    const currentY = window.scrollY;
    if (!nav) { ticking = false; return; }

    if (currentY <= THRESHOLD) {
      nav.classList.remove('nav-hidden');
      nav.classList.add('nav-visible');
    } else if (currentY > lastY + 4) {
      nav.classList.add('nav-hidden');
      nav.classList.remove('nav-visible');
      if (isOpen) closeMenu();
    } else if (currentY < lastY - 4) {
      nav.classList.remove('nav-hidden');
      nav.classList.add('nav-visible');
    }

    lastY   = currentY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
  }, { passive: true });
}
</script>