---
// components/AutoridadesCarousel.astro
// Carrusel de Autoridades 3D de alta fidelidad, adaptado para 4 integrantes
---

<div class="relative w-full h-[75vh] min-h-[550px] flex items-center justify-center overflow-hidden perspective-1000 mt-10">
  <!-- Dynamic Beams inside carousel background for premium feel -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
    <h2 class="text-[12vw] font-display font-bold text-white/[0.02] tracking-[0.2em] whitespace-nowrap select-none">CBIT</h2>
  </div>

  <div class="carousel-container relative w-full max-w-6xl h-[480px] flex items-center justify-center px-4">
    <div class="authorities-wrapper relative w-full h-full flex items-center justify-center">
      
      <!-- Authority 1: Rector -->
      <div class="auth-item absolute transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] cursor-pointer group w-[280px] md:w-[340px]" data-index="0">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl h-[420px] bg-[#060606] transition-all duration-500 group-hover:border-amber-400/40">
          <img src="/images/au1.webp" alt="Juan Carlos Rodriguez Ostria" class="w-full h-full object-cover grayscale group-[.active-card]:grayscale-0 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-[.active-card]:opacity-90"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 text-left transform translate-y-2 group-[.active-card]:translate-y-0 transition-transform duration-500">
            <span class="text-[9px] font-bold tracking-[0.3em] text-amber-400 uppercase bg-amber-400/10 px-2.5 py-1 rounded border border-amber-400/20 mb-3 inline-block">Rectorado</span>
            <h3 class="text-[11px] font-semibold text-amber-400/70 uppercase tracking-widest mb-0.5">Ph. Msc. Ing.</h3>
            <h3 class="text-lg md:text-xl font-display text-white mb-1 tracking-wide leading-none">Juan Carlos Rodriguez Ostria</h3>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-3">Rector</p>
            
            <div class="h-[1px] w-0 group-[.active-card]:w-1/3 bg-amber-400 mb-3 transition-all duration-500 delay-200"></div>
            <p class="text-gray-400 text-xs leading-relaxed max-h-0 opacity-0 group-[.active-card]:max-h-20 group-[.active-card]:opacity-100 transition-all duration-500 overflow-hidden">
              Dirección estratégica y representación académica de la corporación. Comprometido con la innovación en la formación del talento integral boliviano.
            </p>

          </div>
        </div>
      </div>

      <!-- Authority 2: Director Administrativo -->
      <div class="auth-item absolute transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] cursor-pointer group w-[280px] md:w-[340px]" data-index="1">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl h-[420px] bg-[#060606] transition-all duration-500 group-hover:border-cyan-400/40">
          <img src="/images/au2.webp" alt="Marco Antonio Rios Pastor" class="w-full h-full object-cover grayscale group-[.active-card]:grayscale-0 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-[.active-card]:opacity-90"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 text-left transform translate-y-2 group-[.active-card]:translate-y-0 transition-transform duration-500">
            <!-- Administración -->
            <span class="text-[9px] font-bold tracking-[0.3em] text-cyan-400 uppercase bg-cyan-400/10 px-2.5 py-1 rounded border border-cyan-400/20 mb-3 inline-block">Administración</span>
            <h3 class="text-[11px] font-semibold text-cyan-400/70 uppercase tracking-widest mb-0.5">Mcs. Ing.</h3>
            <h3 class="text-lg md:text-xl font-display text-white mb-1 tracking-wide leading-none">Marco Antonio Rios Pastor</h3>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-3">Director Administrativo</p>

            <div class="h-[1px] w-0 group-[.active-card]:w-1/3 bg-cyan-400 mb-3 transition-all duration-500 delay-200"></div>
            <p class="text-gray-400 text-xs leading-relaxed max-h-0 opacity-0 group-[.active-card]:max-h-20 group-[.active-card]:opacity-100 transition-all duration-500 overflow-hidden">
              Gestión operativa, alianzas institucionales y planificación de recursos para garantizar el máximo nivel en todos nuestros programas.
            </p>
          </div>
        </div>
      </div>

      <!-- Authority 3: Director Financiero -->
      <div class="auth-item absolute transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] cursor-pointer group w-[280px] md:w-[340px]" data-index="2">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl h-[420px] bg-[#060606] transition-all duration-500 group-hover:border-emerald-400/40">
          <img src="/images/au4.webp" alt="Franklin Quisbert Aguilar" class="w-full h-full object-cover grayscale group-[.active-card]:grayscale-0 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-[.active-card]:opacity-90"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 text-left transform translate-y-2 group-[.active-card]:translate-y-0 transition-transform duration-500">
            <h3 class="text-[11px] font-semibold text-emerald-400/70 uppercase tracking-widest mb-0.5">MSC. SC. ING.</h3>
            <h3 class="text-lg md:text-xl font-display text-white mb-1 tracking-wide leading-none">Franklin Quisbert Aguilar</h3>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-3">Director Financiero</p>
            
            <div class="h-[1px] w-0 group-[.active-card]:w-1/3 bg-emerald-400 mb-3 transition-all duration-500 delay-200"></div>
            <p class="text-gray-400 text-xs leading-relaxed max-h-0 opacity-0 group-[.active-card]:max-h-20 group-[.active-card]:opacity-100 transition-all duration-500 overflow-hidden">
              Supervisión de finanzas, presupuestos e inversiones estratégicas. Garantiza la viabilidad económica y el crecimiento sostenible del Hub.
            </p>
          </div>
        </div>
      </div>

      <!-- Authority 4: Director Académico -->
      <div class="auth-item absolute transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] cursor-pointer group w-[280px] md:w-[340px]" data-index="3">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl h-[420px] bg-[#060606] transition-all duration-500 group-hover:border-violet-400/40">
          <img src="/images/au3.webp" alt="Jorge Arnoldo Lujan Zambrana" class="w-full h-full object-cover grayscale group-[.active-card]:grayscale-0 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-80 group-[.active-card]:opacity-90"></div>
          
          <div class="absolute bottom-0 left-0 w-full p-6 text-left transform translate-y-2 group-[.active-card]:translate-y-0 transition-transform duration-500">
            <span class="text-[9px] font-bold tracking-[0.3em] text-violet-400 uppercase bg-violet-400/10 px-2.5 py-1 rounded border border-violet-400/20 mb-3 inline-block">Académico</span>
            <h3 class="text-[11px] font-semibold text-violet-400/70 uppercase tracking-widest mb-0.5">MSC. SC. ING.</h3>
            <h3 class="text-lg md:text-xl font-display text-white mb-1 tracking-wide leading-none">Jorge Arnoldo Lujan Zambrana</h3>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-3">Director Académico</p>
            
            <div class="h-[1px] w-0 group-[.active-card]:w-1/3 bg-violet-400 mb-3 transition-all duration-500 delay-200"></div>
            <p class="text-gray-400 text-xs leading-relaxed max-h-0 opacity-0 group-[.active-card]:max-h-20 group-[.active-card]:opacity-100 transition-all duration-500 overflow-hidden">
              Dirección de currículum, programas educativos e integración metodológica de alto nivel pedagógico y técnico deportivo.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Controls -->
    <div class="absolute bottom-[-30px] left-1/2 -translate-x-1/2 flex gap-4 z-40">
      <button id="prev-auth-btn" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:border-amber-400 hover:text-amber-400 hover:scale-105 transition-all backdrop-blur-md bg-white/[0.01]" aria-label="Anterior">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      <button id="next-auth-btn" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center text-white hover:border-amber-400 hover:text-amber-400 hover:scale-105 transition-all backdrop-blur-md bg-white/[0.01]" aria-label="Siguiente">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
      </button>
    </div>
  </div>
</div>

<script>
  function initAuthCarousel() {
    const items = document.querySelectorAll('.auth-item') as NodeListOf<HTMLElement>;
    const prevBtn = document.getElementById('prev-auth-btn');
    const nextBtn = document.getElementById('next-auth-btn');

    if (items.length === 0) return;

    let activeIndex = 0; // El Rector empieza activo
    const total = items.length;

    const updateCarousel = () => {
      items.forEach((item, index) => {
        // Encontrar la diferencia circular
        let diff = index - activeIndex;
        if (diff > total / 2) diff -= total;
        if (diff < -total / 2) diff += total;

        item.classList.remove('active-card');
        
        // Asignar clases de transformación 3D según la diferencia de posición
        if (diff === 0) {
          // ACTIVO (Centro y enfrente)
          item.style.transform = `translate3d(0, 0, 100px) scale(1.0)`;
          item.style.opacity = '1';
          item.style.zIndex = '30';
          item.style.filter = 'blur(0px)';
          item.style.pointerEvents = 'auto';
          item.classList.add('active-card');
          
          // Modificar los bordes y sombras para un glow especial
          const borderBox = item.querySelector('.border') as HTMLElement;
          if (borderBox) {
            borderBox.style.boxShadow = '0 15px 45px rgba(0, 0, 0, 0.7)';
            if (index === 0) borderBox.style.borderColor = 'rgba(245, 158, 11, 0.4)';
            if (index === 1) borderBox.style.borderColor = 'rgba(34, 211, 238, 0.4)';
            if (index === 2) borderBox.style.borderColor = 'rgba(52, 211, 153, 0.4)';
            if (index === 3) borderBox.style.borderColor = 'rgba(167, 139, 250, 0.4)';
          }
        } 
        else if (diff === -1 || (diff === total - 1 && total === 2)) {
          // IZQUIERDA
          item.style.transform = `translate3d(-105%, 0, -100px) scale(0.8)`;
          item.style.opacity = '0.4';
          item.style.zIndex = '10';
          item.style.filter = 'blur(3px)';
          item.style.pointerEvents = 'auto';
          const borderBox = item.querySelector('.border') as HTMLElement;
          if (borderBox) {
            borderBox.style.boxShadow = 'none';
            borderBox.style.borderColor = 'rgba(255,255,255,0.08)';
          }
        } 
        else if (diff === 1 || (diff === 1 - total && total === 2)) {
          // DERECHA
          item.style.transform = `translate3d(105%, 0, -100px) scale(0.8)`;
          item.style.opacity = '0.4';
          item.style.zIndex = '10';
          item.style.filter = 'blur(3px)';
          item.style.pointerEvents = 'auto';
          const borderBox = item.querySelector('.border') as HTMLElement;
          if (borderBox) {
            borderBox.style.boxShadow = 'none';
            borderBox.style.borderColor = 'rgba(255,255,255,0.08)';
          }
        } 
        else {
          // OCULTO (Fondo)
          item.style.transform = `translate3d(0, 0, -250px) scale(0.55)`;
          item.style.opacity = '0';
          item.style.zIndex = '0';
          item.style.filter = 'blur(8px)';
          item.style.pointerEvents = 'none';
          const borderBox = item.querySelector('.border') as HTMLElement;
          if (borderBox) {
            borderBox.style.boxShadow = 'none';
          }
        }
      });
    };

    // Inicializar
    updateCarousel();

    // Eventos
    items.forEach((item, index) => {
      item.addEventListener('click', () => {
        if (activeIndex !== index) {
          activeIndex = index;
          updateCarousel();
        }
      });

      // Hover cambia a la autoridad principal
      item.addEventListener('mouseenter', () => {
        if (activeIndex !== index) {
          activeIndex = index;
          updateCarousel();
        }
      });
    });

    prevBtn?.addEventListener('click', () => {
      activeIndex = (activeIndex - 1 + total) % total;
      updateCarousel();
    });

    nextBtn?.addEventListener('click', () => {
      activeIndex = (activeIndex + 1) % total;
      updateCarousel();
    });
  }

  // Inicializar en carga y transiciones de Astro
  initAuthCarousel();
  document.addEventListener('astro:page-load', initAuthCarousel);
</script>
