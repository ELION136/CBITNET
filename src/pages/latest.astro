---
// src/pages/latest.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';
import '../styles/latest.css';

const entries = await getCollection('news');

type NewsEntry = (typeof entries)[number];

const allNews = entries
  .map((e: NewsEntry) => ({
    title:    e.data.title,
    subtitle: e.data.subtitle,
    excerpt:  e.data.excerpt,
    category: e.data.category,
    tag:      e.data.tag,
    date:     e.data.date.toISOString(),
    image:    e.data.image,
    href:     e.data.link || "https://wa.me/5917704659",
    featured: e.data.featured,
    type:     e.data.type,
    own:      !e.data.link,
  }))
  .sort((a: { date: string }, b: { date: string }) =>
    new Date(b.date).getTime() - new Date(a.date).getTime()
  );

const ads      = allNews.filter(n => n.type === 'ad');
const news     = allNews.filter(n => n.type !== 'ad');
const heroNews = news.find(n => n.featured) ?? news[0];
const gridNews = news.filter(n => n !== heroNews);

const allCategories = ['TODOS', ...new Set(news.map(n => n.category))];

// Estadísticas rápidas del portal
const stats = [
  { value: news.length.toString(),        label: "Artículos publicados" },
  { value: ads.length.toString(),         label: "Anuncios activos"     },
  { value: allCategories.length - 1 + "", label: "Categorías cubiertas" },
  { value: "24/7",                        label: "Actualización continua" },
];
---

<Layout title="Noticias | CBIT">
  <Navbar />

  <main class="lt-main">

    <!-- ══════════════════════════════════
         HERO
    ══════════════════════════════════ -->
    <section class="lt-hero" id="lt-hero">
      <div class="lt-hero-mesh"  aria-hidden="true"></div>
      <div class="lt-orb lt-orb-1" aria-hidden="true"></div>
      <div class="lt-orb lt-orb-2" aria-hidden="true"></div>
      <div class="lt-orb lt-orb-3" aria-hidden="true"></div>

      <div class="lt-container lt-hero-inner">
        <div class="lt-reveal">
          <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6
                      border-b pb-12"
               style="border-color:rgba(255,255,255,0.10);">

            <div>
              <!-- eyebrow -->
              

              <h1 class="lt-hero-title font-display">
                NOTICIAS<br/>
                <span style="color:#f2c82f">ANUNCIOS</span>
              </h1>
            </div>

            <div class="lt-hero-side lt-reveal lt-d1">
              <p class="lt-hero-sub">
                Noticias, anuncios y novedades oficiales de la Corporación Boliviana de Talento. Toda la actualidad institucional en un solo lugar.
              </p>
              <!-- live indicator -->
              <div class="lt-live-badge">
                <span class="lt-live-dot" aria-hidden="true"></span>
                <span class="lt-live-label">ACTUALIZADO</span>
                <span class="lt-live-time" id="portal-time"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- STATS STRIP -->
        <div class="lt-stats-strip lt-reveal lt-d2">
          {stats.map(s => (
            <div class="lt-stat">
              <span class="lt-stat-value font-display">{s.value}</span>
              <span class="lt-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         FILTROS DE CATEGORÍA
    ══════════════════════════════════ -->
    <div class="lt-filter-bar lt-reveal">
      <div class="lt-container">
        <div class="lt-filter-inner" id="cat-filter">
          {allCategories.map((cat, i) => (
            <button
              class={`lt-cat-tab${i === 0 ? ' lt-cat-active' : ''}`}
              data-cat={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════
         CONTENIDO PRINCIPAL
    ══════════════════════════════════ -->
    <section class="lt-section lt-soft-bg" id="noticias-grid">
      <div class="lt-container">
        <div class="lt-layout">

          <!-- ── COLUMNA IZQUIERDA ── -->
          <div class="lt-col-main">

            <!-- HERO NEWS -->
            {heroNews && (
              <div class="lt-hero-card-wrap lt-reveal lt-d0">
                <div class="lt-section-label" style="margin-bottom:1rem;">
                  <span class="lt-label-line" style="background:var(--gold)"></span>
                  <span class="lt-label-text" style="color:var(--gold)">Destacado</span>
                </div>
                <div class="lt-float-card lt-news-hero-card">
                  <NewsCard
                    title={heroNews.title}
                    excerpt={heroNews.excerpt}
                    category={heroNews.category}
                    tag={heroNews.tag}
                    date={heroNews.date}
                    image={heroNews.image}
                    href={heroNews.href}
                    own={heroNews.own}
                    size="hero"
                  />
                </div>
              </div>
            )}

            <!-- SECTION LABEL -->
            <div class="lt-section-label lt-reveal" style="margin-top:2.5rem;margin-bottom:1.25rem;">
              <span class="lt-label-line" style="background:var(--blue-mid)"></span>
              <span class="lt-label-text" style="color:var(--blue-mid)">Todas las noticias</span>
              <div class="lt-label-fill"></div>
              <span class="lt-label-count">{gridNews.length} artículos</span>
            </div>

            <!-- GRID -->
            {gridNews.length > 0 ? (
              <div class="lt-news-grid" id="news-grid">
                {gridNews.map((n, i) => (
                  <div class={`news-item lt-float-card lt-reveal lt-s${i % 4}`} data-cat={n.category}>
                    <NewsCard
                      title={n.title}
                      excerpt={n.excerpt}
                      category={n.category}
                      tag={n.tag}
                      date={n.date}
                      image={n.image}
                      href={n.href}
                      own={n.own}
                      size="medium"
                    />
                  </div>
                ))}
              </div>
            ) : (
              <div class="lt-empty lt-reveal">
                <div class="lt-empty-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <p class="lt-empty-title">Sin noticias adicionales</p>
                <p class="lt-empty-sub">Agrega archivos .md en <code>src/content/news/</code></p>
              </div>
            )}

          </div>

          <!-- ── SIDEBAR ── -->
          <aside class="lt-sidebar">
            <div class="lt-sidebar-inner">

              <!-- ANUNCIOS Y CLASIFICADOS -->
              {ads.length > 0 && (
                <div class="lt-sidebar-block lt-reveal">
                  <div class="lt-section-label" style="margin-bottom:1rem;">
                    <span class="lt-label-line" style="background:var(--gold)"></span>
                    <span class="lt-label-text" style="color:var(--gold)">Anuncios y Clasificados</span>
                  </div>
                  <div class="lt-ads-list">
                    {ads.map(ad => {
                      const isExt = ad.href.startsWith('http://') || ad.href.startsWith('https://') || ad.href.startsWith('tel:') || ad.href.startsWith('mailto:');
                      return (
                        <a
                          href={ad.href}
                          target={isExt ? "_blank" : "_self"}
                          rel={isExt ? "noopener noreferrer" : ""}
                          class="lt-ad-card lt-float-card"
                        >
                          {ad.image && (
                            <img src={ad.image} alt={ad.title}
                                 class="lt-ad-img lt-zoom-target"
                                 width="90" height="110" loading="lazy" />
                          )}
                          <div class="lt-ad-body">
                            <span class="lt-ad-cat">{ad.category}</span>
                            <p class="lt-ad-title">{ad.title}</p>
                            <span class="lt-ad-cta">
                              VER MÁS
                              <svg width="9" height="9" viewBox="0 0 24 24" fill="none"
                                   stroke="currentColor" stroke-width="2.5">
                                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                              </svg>
                            </span>
                          </div>
                        </a>
                      );
                    })}
                  </div>
                </div>
              )}

              <!-- ÍNDICE -->
              <div class="lt-sidebar-block lt-reveal lt-d1 lt-sidebar-sticky">
                <div class="lt-section-label" style="margin-bottom:1rem;">
                  <span class="lt-label-line" style="background:var(--blue-mid)"></span>
                  <span class="lt-label-text" style="color:var(--blue-mid)">Índice</span>
                </div>
                <div class="lt-index-list">
                  {allNews.filter(n => n.type !== 'ad').map((n, i) => {
                    const isExt = n.href.startsWith('http://') || n.href.startsWith('https://') || n.href.startsWith('tel:') || n.href.startsWith('mailto:');
                    return (
                      <a
                        href={n.href}
                        target={isExt ? "_blank" : "_self"}
                        rel={isExt ? "noopener noreferrer" : ""}
                        class="lt-index-item"
                      >
                        <span class="lt-index-num font-display">{String(i + 1).padStart(2, '0')}</span>
                        <div class="lt-index-info">
                          <span class="lt-index-cat">{n.category}</span>
                          <p class="lt-index-title">{n.title}</p>
                        </div>
                      </a>
                    );
                  })}
                </div>

                <!-- CTA CONTACTO -->
                <div class="lt-cta-card lt-reveal lt-d2" style="margin-top:1.5rem;">
                  <div class="lt-cta-accent"></div>
                  <p class="lt-cta-label">ATENCIÓN AL CLIENTE</p>
                  <p class="lt-cta-body">
                    ¿Quieres publicar un anuncio o tienes alguna consulta oficial? Contáctanos a través de nuestros canales autorizados de la Corporación Boliviana de Talento.
                  </p>
                  <div class="flex flex-col gap-2 mt-2">
                    <a href="https://wa.me/5917704659" target="_blank" rel="noopener noreferrer" class="lt-cta-btn lt-cta-btn-wa">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.858.002-2.634-1.013-5.11-2.861-6.961S14.64 1.01 12.008 1.01c-5.442 0-9.867 4.422-9.87 9.86-.001 1.702.453 3.361 1.314 4.798L2.437 21.89l5.21-1.366zM17.487 14.4c-.27-.135-1.595-.788-1.842-.877-.246-.089-.426-.135-.606.135-.18.27-.697.877-.855 1.057-.157.18-.315.203-.585.068-1.785-.892-3.132-1.572-4.382-2.73-.33-.306-.63-.615-.92-.937-.27-.463-.03-.715.2-.943.207-.206.463-.538.697-.808.232-.27.31-.462.463-.77.153-.309.076-.58-.039-.808-.112-.228-.977-2.355-1.339-3.227-.353-.849-.714-.734-.977-.734h-.834c-.27 0-.709.102-1.08.512-.371.41-1.417 1.385-1.417 3.377 0 1.99 1.45 3.916 1.652 4.188.203.27 2.855 4.36 6.916 6.113 2.531 1.093 3.498 1.182 4.739.996 1.258-.189 2.59-.974 2.955-1.916.365-.943.365-1.75.257-1.917-.107-.168-.392-.27-.663-.405z"/>
                      </svg>
                      WhatsApp Directo
                    </a>
                    <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="lt-cta-btn lt-cta-btn-fb">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                      Facebook Oficial
                    </a>
                  </div>
                </div>

              </div>
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         CATEGORÍAS — franja visual extra
    ══════════════════════════════════ -->
    <section class="lt-section lt-blue-bg" id="categorias">
      <div class="lt-orb lt-orb-cat" aria-hidden="true"></div>
      <div class="lt-container" style="position:relative;z-index:2;">
        <div class="lt-section-head lt-reveal">
          <span class="lt-eyebrow lt-eyebrow-gold">Explora por tema</span>
          <h2 class="lt-section-title lt-white font-display">CATEGORÍAS <span class="lt-gold">DE INTERÉS</span></h2>
          <div class="lt-bar lt-bar-gold" data-bar></div>
        </div>
        <div class="lt-cats-grid">
          {allCategories.filter(c => c !== 'TODOS').map((cat, i) => (
            <button
              class={`lt-cat-card lt-float-card-dark lt-reveal lt-s${i % 3}`}
              data-cat={cat}
              onclick={`document.querySelector('[data-cat="${cat}"]')?.click(); document.getElementById('noticias-grid')?.scrollIntoView({behavior:'smooth'})`}
            >
              <div class="lt-cat-card-bar"></div>
              <span class="lt-cat-card-name font-display">{cat}</span>
              <span class="lt-cat-card-count">
                {news.filter(n => n.category === cat).length} artículos
              </span>
            </button>
          ))}
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('lt-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.lt-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. BAR DRAW ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('lt-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO TITLE ── */
      const heroTitle = document.querySelector<HTMLElement>('.lt-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20, ease: 'none',
          scrollTrigger: {
            trigger: '.lt-hero',
            start: 'top top', end: 'bottom top',
            scrub: 1.8,
          }
        });
      }

      /* ── 4. PARALLAX ORBS ── */
      document.querySelectorAll<HTMLElement>('.lt-orb-1, .lt-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -22 : 18, ease: 'none',
          scrollTrigger: {
            trigger: '.lt-hero',
            start: 'top top', end: 'bottom top',
            scrub: 2,
          }
        });
      });

      /* ── 5. STAGGER GRIDS ── */
      ['#noticias-grid .lt-news-grid', '#categorias .lt-cats-grid'].forEach(sel => {
        const grid = document.querySelector(sel);
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.lt-reveal'));
        ScrollTrigger.create({
          trigger: grid,
          start: 'top 88%',
          once: true,
          onEnter: () => {
            cards.forEach((card, i) => {
              gsap.to(card, {
                opacity: 1, y: 0,
                duration: 0.7,
                delay: i * 0.09,
                ease: 'power3.out',
                overwrite: true,
              });
            });
          }
        });
      });

      /* ── 6. STAT COUNTERS (números en el hero) ── */
      document.querySelectorAll<HTMLElement>('.lt-stat-value').forEach(el => {
        const raw = el.textContent?.trim() ?? '';
        if (!/^\d+$/.test(raw)) return;          // solo números puros
        const end = parseInt(raw, 10);
        el.textContent = '0';
        ScrollTrigger.create({
          trigger: el,
          start: 'top 90%',
          once: true,
          onEnter: () => {
            gsap.to({ val: 0 }, {
              val: end,
              duration: 1.4,
              ease: 'power2.out',
              onUpdate: function() {
                el.textContent = Math.round(this.targets()[0].val).toString();
              }
            });
          }
        });
      });

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);

  /* ── RELOJ ── */
  const timeEl = document.getElementById('portal-time');
  const tick = () => {
    if (!timeEl) return;
    timeEl.textContent = new Date().toLocaleTimeString('es-BO', { hour: '2-digit', minute: '2-digit' });
  };
  tick();
  setInterval(tick, 60_000);

  /* ── FILTRO DE CATEGORÍAS ── */
  const tabs  = document.querySelectorAll<HTMLButtonElement>('.lt-cat-tab');
  const items = document.querySelectorAll<HTMLElement>('.news-item');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('lt-cat-active'); t.classList.remove('active'); });
      tab.classList.add('lt-cat-active');
      const cat = tab.dataset.cat ?? 'TODOS';
      items.forEach(item => {
        item.classList.toggle('hidden', cat !== 'TODOS' && item.dataset.cat !== cat);
      });
    });
  });
</script>