---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import FloatingCards from '../components/FloatingCards.astro';
import FeaturedSection from '../components/FeaturedSection.astro';
---

<Layout title="Latest News | Sports Editorial">
  <Navbar />
  <main class="bg-black min-h-screen pt-32 text-white">
    <div class="container mx-auto px-6 lg:px-10 mb-20">
      <h1 class="text-6xl md:text-8xl font-display mb-4"><span class="text-yellow-500">LATEST</span> NEWS</h1>
      <p class="text-gray-400 max-w-2xl text-xl mb-16">Stay up to date with the latest developments, match reports, and exclusive interviews.</p>
    </div>

    <!-- We moved the Floating Cards and Featured Section here from the main page -->
    <div class="mt-40">
      <FloatingCards />
    </div>
    
    <div class="mt-20">
      <FeaturedSection />
    </div>
  </main>
</Layout>
