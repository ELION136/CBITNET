---
import Layout from '../layouts/Layout.astro';
import '../styles/club_leones.css';

// ── NUESTRAS CAUSAS (según lineamiento internacional de Lions Clubs) ──
const causas = [
  {
    title: "Cáncer infantil",
    desc: "Brindamos apoyo a las necesidades de los niños y las familias afectadas por el cáncer infantil.",
    gradient: "linear-gradient(135deg,#f0932b 0%,#f6c453 100%)",
    tag: "#e07b1f",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M9 3a3 3 0 1 0 6 0"/><path d="M9 3c0 3-4 4-4 8a4 4 0 0 0 8 0c0-4-4-5-4-8"/><circle cx="12" cy="17" r="4"/></svg>`,
  },
  {
    title: "Diabetes",
    desc: "Trabajamos para reducir la prevalencia de la diabetes y mejorar la calidad de vida de quienes ya la padecen.",
    gradient: "linear-gradient(135deg,#2f6fed 0%,#63a4ff 100%)",
    tag: "#2f6fed",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M12 3s6 7 6 11a6 6 0 0 1-12 0c0-4 6-11 6-11Z"/></svg>`,
  },
  {
    title: "Auxilio en casos de desastre",
    desc: "Satisfacemos las necesidades inmediatas y brindamos apoyo a largo plazo a comunidades devastadas por desastres naturales.",
    gradient: "linear-gradient(135deg,#4b3f8f 0%,#7c5cbf 100%)",
    tag: "#4b3f8f",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M17.5 19a4.5 4.5 0 0 0 0-9 6 6 0 0 0-11.4-1.5A4 4 0 0 0 6.5 16"/><path d="M8 19v2M12 19v2M16 19v2"/></svg>`,
  },
  {
    title: "Medio ambiente",
    desc: "Trabajamos para proteger el medio ambiente y crear comunidades más saludables y un mundo más sostenible.",
    gradient: "linear-gradient(135deg,#2f9e44 0%,#8bd46e 100%)",
    tag: "#2f9e44",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M12 22s8-4 8-11a8 8 0 0 0-16 0c0 7 8 11 8 11Z"/><path d="M12 11a4 4 0 0 1 4-4"/></svg>`,
  },
  {
    title: "Servicio humanitario",
    desc: "Identificamos las necesidades más urgentes del mundo y brindamos ayuda humanitaria donde más se necesita.",
    gradient: "linear-gradient(135deg,#e8433a 0%,#f2825a 100%)",
    tag: "#e8433a",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M11 20a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z"/><path d="M7 12h8M12 8v8"/></svg>`,
  },
  {
    title: "Hambre",
    desc: "Trabajamos para mejorar la seguridad alimentaria y el acceso a alimentos nutritivos para ayudar a mitigar el hambre.",
    gradient: "linear-gradient(135deg,#f2802a 0%,#f7b955 100%)",
    tag: "#f2802a",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M6 3v7a3 3 0 0 0 6 0V3M9 10v11M18 3c-1.5 2-2 4-2 6a2 2 0 0 0 2 2v10"/></svg>`,
  },
  {
    title: "Visión",
    desc: "Ayudamos a prevenir la ceguera evitable y a mejorar la calidad de vida de personas con discapacidad visual.",
    gradient: "linear-gradient(135deg,#7b2ff7 0%,#b45cf0 100%)",
    tag: "#7b2ff7",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><path d="M1.5 12S5 5 12 5s10.5 7 10.5 7-3.5 7-10.5 7S1.5 12 1.5 12Z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    title: "Juventud",
    desc: "Ayudamos a los jóvenes a tomar decisiones positivas y a convertirse en la próxima generación de líderes de servicio.",
    gradient: "linear-gradient(135deg,#0fb9b1 0%,#3fd7c9 100%)",
    tag: "#0fb9b1",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8"><circle cx="8" cy="8" r="3"/><circle cx="17" cy="9" r="2.6"/><path d="M2 20c0-3.3 2.7-6 6-6s6 2.7 6 6M13.5 20c0-2.6 2-4.7 4.5-4.9"/></svg>`,
  },
];

// ── BENEFICIOS DE SER LEÓN ──
const beneficios = [
  {
    title: "Marcar la diferencia",
    desc: "Hay más de 48.000 clubes de Leones en el mundo. Cada club está formado por personas como usted que han decidido actuar y servir a los demás.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="9"/></svg>`,
  },
  {
    title: "Servir con orgullo",
    desc: "Tendrá la oportunidad de dedicar su tiempo, compartir sus talentos y sentirse orgulloso de saber que ha tenido un impacto positivo en la vida de otras personas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z"/><path d="M8.5 14.5 7 22l5-3 5 3-1.5-7.5"/></svg>`,
  },
  {
    title: "Crear conexiones",
    desc: "Entable relaciones con las personas de su club y con los líderes locales con quienes colabora, además de Leones de su distrito y del mundo.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="7" cy="8" r="3"/><circle cx="17" cy="8" r="3"/><path d="M2 20c0-3 2.5-5.5 5.5-5.5S13 17 13 20M11 20c0-2.5 2-4.5 4.5-4.5S20 17.5 20 20"/></svg>`,
  },
  {
    title: "Adquirir credibilidad",
    desc: "Hay Leones en más de 200 países. Reciba el respeto que proviene de ser parte de una organización mundial conocida por su labor durante más de 100 años.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 3 6v6c0 5 4 8.5 9 10 5-1.5 9-5 9-10V6l-9-4Z"/><path d="m9 12 2 2 4-4"/></svg>`,
  },
  {
    title: "Forjar nuevas amistades",
    desc: "Sienta que pertenece a la asociación junto a los demás socios del club y al 1,4 millón de Leones de todo el mundo, conectados a través de la app MyLion.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg>`,
  },
  {
    title: "Mostrar su liderato",
    desc: "Tiene acceso a nuestro sistema de aprendizaje en línea para pulir sus habilidades de liderato, con la oportunidad de dirigir en su club.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 21V9M12 21V3M20 21v-6"/><path d="M4 9h16"/></svg>`,
  },
  {
    title: "Recibir apoyo global",
    desc: "Todo León recibe apoyo de una red mundial de voluntarios y de la Fundación LCIF, que ofrece fondos de subvenciones para respaldar el servicio local y mundial.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a15 15 0 0 0 0 20a15 15 0 0 0 0-20Z"/><path d="M2 12h20"/></svg>`,
  },
];

const activities = [
  { title: "Comunidad Colaborativa", desc: "Conecta con profesionales, comparte conocimientos y escala tus proyectos en equipo.", imagen: "/images/miu12.webp" },
  { title: "Brigadas de Salud", desc: "Campañas médicas gratuitas y soporte nutricional para familias de escasos recursos.", imagen: "/images/miu4.jpeg" },
  { title: "Equipamiento Deportivo", desc: "Renovación de complejos deportivos barriales y dotación de material técnico de calidad.", imagen: "/images/miu3.jpeg" },
  { title: "Formación del Futuro", desc: "Forjadores de liderazgo cívico para guiar el carácter ético de los futuros campeones.", imagen: "/images/miu2.jpeg" },
  { title: "Ceremonia de Afiliación", desc: "Acto formal de bienvenida a nuevos miembros del Club de Leones Sacaba.", imagen: "/images/miro1.JPG" },
  { title: "Día del Peatón", desc: "Campañas de educación vial y seguridad ciudadana en jornadas de restricción vehicular.", imagen: "/images/miu5.jpeg" },
];

const stats = [
  { num: "1.4M+", label: "Socios en el Mundo" },
  { num: "45K+", label: "Clubes Activos" },
  { num: "200+", label: "Países Presentes" },
  { num: "100+", label: "Años de Servicio" },
];

const secretariaWhatsapp = "https://wa.me/59172201160?text=Hola%2C%20quisiera%20más%20información%20sobre%20unirme%20al%20Club%20de%20Leones%20Sacaba";
---

<Layout title="Club de Leones Sacaba | Lions Clubs International" showBackgroundFX={false}>

<!-- NAVBAR -->
<nav id="navbar">
  <a href="/" class="nav-left">
    <img src="/images/log4.png" alt="Club de Leones" class="nav-logo-img" onerror="this.style.display='none'" />
    <div class="nav-wordmark">
      <span class="nav-name">LEONES <em>SACABA</em></span>
      <span class="nav-sub">Lions Clubs International</span>
    </div>
  </a>
  <div class="nav-links">
    <a href="#quienes" class="nav-link">Quiénes Somos</a>
    <a href="#causas" class="nav-link">Nuestras Causas</a>
    <a href="#beneficios" class="nav-link">Beneficios</a>
    <a href="#actividades" class="nav-link">Actividades</a>
    <a href="#unirse" class="nav-link">Unirse</a>
    <a href="https://www.lionsclubs.org/es" target="_blank" class="nav-link">Internacional</a>
  </div>
  <a href="https://www.lionsclubs.org/es/start-our-approach/club-locator/details?id=146647" target="_blank" class="nav-cta">
    Ser León
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
  <button class="nav-toggle" aria-label="Abrir menú" id="nav-toggle">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg" id="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-stripe"></div>

  <div class="hero-badge" id="hero-badge">
    <div class="hero-badge-logo">L</div>
    <span class="hero-badge-title">Miembro Oficial</span>
    <span class="hero-badge-org">Lions Clubs International</span>
  </div>

  <div class="hero-content">
    <div class="hero-kicker" id="hero-kicker">
      <span class="hero-kicker-dot"></span>
      Club de Leones Sacaba — Cochabamba, Bolivia
    </div>

    <h1 class="hero-h1" id="hero-h1">
      <span class="h1-line"><span class="h1-inner">SERVIMOS</span></span>
      <span class="h1-line"><span class="h1-inner">A UN MUNDO</span></span>
      <span class="h1-line"><span class="h1-inner h1-gold">NECESITADO</span></span>
    </h1>

    <div class="hero-divider" id="hero-divider"></div>

    <p class="hero-tagline" id="hero-tagline">
      Voluntarios activos comprometidos con el servicio humanitario y el liderazgo comunitario. Parte de la organización de servicio más grande del mundo.
    </p>

    <div class="hero-btns" id="hero-btns">
      <a href="#unirse" class="btn-gold">
        Unirme al Club
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://www.lionsclubs.org/es" target="_blank" class="btn-outline">
        Lions International
      </a>
    </div>
  </div>

  <div class="scroll-hint" id="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- STATS -->
<div id="stats-strip">
  <div class="stats-row">
    {stats.map(s => (
      <div class="stat-cell">
        <span class="stat-num">{s.num}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
</div>

<!-- QUIENES SOMOS -->
<section id="quienes">
  <div class="section-wrap">
    <div class="quienes-layout">
      <div class="quienes-img-wrap" id="qs-img">
        <img src="/images/miro1.JPG" alt="Club de Leones Sacaba" class="quienes-img"
          onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
        <div class="quienes-float">
          <span class="quienes-float-num">1.4M</span>
          <span class="quienes-float-label">Socios Globales</span>
        </div>
      </div>
      <div id="qs-right">
        <div class="eyebrow">Quiénes Somos</div>
        <h2 class="section-title">MARCAMOS<br/>LA <span class="hl">DIFERENCIA</span></h2>
        <div class="quienes-quote">
          <p>"Los Leones marcamos la diferencia todos los días, en todas partes"</p>
          <span>Lions Clubs International — Desde 1917</span>
        </div>
        <p class="quienes-body">
          Los Leones somos grupos de personas con vocación de servicio interesados en mejorar la comunidad. Ser León es ser un voluntario activo, socio de una organización internacional muy respetada, líder de la comunidad y amigo de los necesitados.<br/><br/>
          El Club de Leones Sacaba opera en Cochabamba, Bolivia, llevando a cabo proyectos de impacto social, deportivo y humanitario para los sectores más vulnerables de nuestra región.
        </p>
        <a href="https://www.lionsclubs.org/es" target="_blank" class="quienes-link">
          Conocer Lions International
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- NUESTRAS CAUSAS -->
<section id="causas">
  <div class="section-wrap">
    <div class="causas-header" id="causas-header">
      <div class="eyebrow">Ideario Institucional</div>
      <h2 class="section-title">NUESTRAS <span class="hl">CAUSAS</span></h2>
    </div>
    <div class="causas-grid" id="causas-grid">
      {causas.map(c => (
        <div class="cause-card">
          <div class="cause-banner" style={`background:${c.gradient}`}>
            <div class="cause-icon" set:html={c.icon} />
            <span class="cause-tag" style={`background:${c.tag}`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              Más información
            </span>
          </div>
          <div class="cause-body">
            <h3 class="cause-title">{c.title}</h3>
            <p class="cause-desc">{c.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BENEFICIOS DE SER LEÓN -->
<section id="beneficios">
  <div class="section-wrap">
    <div class="ben-layout">
      <div class="ben-img-wrap" id="ben-img">
        <img src="https://images.unsplash.com/photo-1593113646773-028c64a8f1b8?w=900&q=80" alt="Voluntarios sirviendo a la comunidad"
          class="ben-img" onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
      </div>
      <div id="ben-text">
        <div class="eyebrow">Por Qué Unirse</div>
        <h2 class="section-title">LOS BENEFICIOS<br/>DE SER <span class="hl">LEÓN</span></h2>
        <p class="ben-intro">Ser socio de un club de Leones beneficia a su comunidad y a usted.</p>
      </div>
    </div>

    <div class="ben-grid" id="ben-grid">
      {beneficios.map(b => (
        <div class="ben-card">
          <div class="ben-icon" set:html={b.icon} />
          <h3 class="ben-title">{b.title}</h3>
          <p class="ben-desc">{b.desc}</p>
        </div>
      ))}
    </div>

    <div class="ben-photos" id="ben-photos">
      <img src="/images/leon1.webp" alt="Liderazgo y trabajo en equipo"
        onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
      <img src="/images/leon2.webp" alt="Red global de voluntarios"
        onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
      <img src="/images/leon3.webp" alt="Amistad entre socios del club"
        onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
    </div>
  </div>
</section>

<!-- ACTIVIDADES / SERVICIO COMUNITARIO -->
<section id="actividades">
  <div class="section-wrap">
    <div class="act-header" id="act-header">
      <div class="eyebrow">Historial de Acciones</div>
      <h2 class="section-title">SERVICIO <span class="hl">COMUNITARIO</span></h2>
    </div>
    <div class="act-grid" id="act-grid">
      {activities.map(act => (
        <div class="act-card">
          <img src={act.imagen} alt={act.title} class="act-img"
            onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&q=80'" />
          <div class="act-overlay"></div>
          <div class="act-content">
            <span class="act-tag">Actividad</span>
            <h3 class="act-title">{act.title}</h3>
            <p class="act-desc">{act.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- UNIRSE -->
<section id="unirse">
  <div class="section-wrap">
    <div class="unirse-layout">
      <div>
        <div class="eyebrow">Cómo Ser León</div>
        <h2 class="section-title" style="margin-bottom:36px;">CONTÁCTANOS Y <span class="hl">ÚNETE</span></h2>
        <div class="unirse-steps" id="unirse-steps">
          {[
            { num: "01", title: "Escríbenos a Secretaría", desc: `Comunícate al <strong>72201160</strong> (Secretaría del Club) por llamada o WhatsApp y cuéntanos tu interés en unirte.` },
            { num: "02", title: "Conversemos", desc: "Coordinamos una breve llamada o reunión para conocer tus motivaciones y responder tus preguntas." },
            { num: "03", title: "Visítanos como invitado", desc: "Asiste a una reunión ordinaria del club, conoce a los socios y nuestros proyectos activos." },
            { num: "04", title: "Ceremonia de Afiliación", desc: "Formalizamos tu ingreso con el certificado oficial de Lions Clubs International." },
          ].map(s => (
            <div class="step-item">
              <span class="step-num">{s.num}</span>
              <div>
                <h3 class="step-title">{s.title}</h3>
                <p class="step-desc" set:html={s.desc} />
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="unirse-right" id="unirse-right">
        <h2 class="unirse-cta-text">SÉ PARTE DEL<br/>CAMBIO <span class="hl">QUE</span><br/>EL MUNDO<br/>NECESITA.</h2>
        <p class="unirse-body">
          La calidad de socio se obtiene por invitación. Escribe hoy mismo a nuestra Secretaría y damos inicio a tu proceso de afiliación.
        </p>
        <div class="unirse-contact-card">
          <div class="unirse-contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          </div>
          <div>
            <div class="unirse-contact-label">Secretaría del Club</div>
            <div class="unirse-contact-value">72201160</div>
          </div>
        </div>
        <a href={secretariaWhatsapp} target="_blank" class="btn-gold" style="align-self:flex-start;">
          Escribir a Secretaría
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="https://www.lionsclubs.org/es" target="_blank" class="quienes-link" style="color:#6370a0;font-size:0.78rem;">
          Visitar lionsclubs.org
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta">
  <div class="cta-bg"></div>
  <div class="cta-shape"></div>
  <div class="cta-shape2"></div>
  <div class="cta-inner">
    <h2 class="cta-h2" id="cta-h2">
      <span class="l1">CONVIÉRTETE</span>
      <span class="l2">EN LEÓN</span>
      <span class="l3">HOY.</span>
    </h2>
    <p class="cta-sub">Nuestras puertas están abiertas para quienes quieran ser voluntarios activos y líderes comunitarios con impacto real.</p>
    <div class="cta-badges">
      {["Voluntariado Activo", "Certificado Internacional", "Red Global de Socios", "Impacto Local Real"].map(b => (
        <span class="cta-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          {b}
        </span>
      ))}
    </div>
    <a href={secretariaWhatsapp} target="_blank" class="btn-gold" style="font-size:1rem;padding:18px 52px;">
      Ser León Ahora
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-left">
    <span class="footer-brand">LEONES <em>SACABA</em></span>
    <span class="footer-sub">Lions Clubs International · Cochabamba, Bolivia</span>
  </div>
  <div class="footer-links">
    <a href="https://www.lionsclubs.org/es" target="_blank" class="footer-link">lionsclubs.org</a>
    <a href="#quienes" class="footer-link">Quiénes Somos</a>
    <a href="#causas" class="footer-link">Nuestras Causas</a>
    <a href="#beneficios" class="footer-link">Beneficios</a>
    <a href="#unirse" class="footer-link">Unirse</a>
  </div>
  <span class="footer-copy">© 2025 Club de Leones Sacaba · Todos los derechos reservados</span>
</footer>

<script lang="ts">
import gsap from 'gsap';
import ScrollTrigger from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// ── NAVBAR scroll ──
const navbar = document.getElementById('navbar');
if (navbar) {
  ScrollTrigger.create({
    start: 'top -60',
    onUpdate: s => {
      navbar.style.boxShadow = s.progress > 0
        ? '0 4px 32px rgba(26,58,143,0.14)'
        : '0 2px 24px rgba(26,58,143,0.08)';
    }
  });
}

// ── HERO PARALLAX ──
gsap.to('#hero-bg', {
  yPercent: 22, ease: 'none',
  scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
});

// ── HERO ENTRANCE ──
const h1Inners = document.querySelectorAll('#hero-h1 .h1-inner');
gsap.set('#hero-h1 .h1-line', { overflow: 'hidden', display: 'block' });
gsap.set(h1Inners, { yPercent: 110, skewY: 4 });
gsap.set(['#hero-tagline', '#hero-btns'], { opacity: 0, y: 24 });
gsap.set('#hero-divider', { width: 0 });

const tl = gsap.timeline({ delay: 0.3 });
tl
  .to('#hero-kicker', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' })
  .to(h1Inners, { yPercent: 0, skewY: 0, duration: 1.1, ease: 'power4.out', stagger: 0.13 }, '-=0.2')
  .to('#hero-divider', { width: 80, duration: 0.6, ease: 'power3.out' }, '-=0.5')
  .to('#hero-tagline', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.4')
  .to('#hero-btns', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.45')
  .to('#hero-badge', { opacity: 1, duration: 0.7, ease: 'power2.out' }, '-=0.3')
  .to('#scroll-hint', { opacity: 1, duration: 0.5 }, '-=0.2');

// ── STATS ──
ScrollTrigger.create({
  trigger: '#stats-strip', start: 'top 85%', once: true,
  onEnter: () => gsap.from('#stats-strip .stat-cell', { opacity: 0, y: 30, duration: 0.65, stagger: 0.1, ease: 'power3.out' })
});

// ── QUIENES ──
ScrollTrigger.create({
  trigger: '#qs-img', start: 'top 78%', once: true,
  onEnter: () => gsap.from('#qs-img', { opacity: 0, x: -50, duration: 1, ease: 'power3.out' })
});
ScrollTrigger.create({
  trigger: '#qs-right', start: 'top 78%', once: true,
  onEnter: () => gsap.from('#qs-right > *', { opacity: 0, x: 40, duration: 0.7, stagger: 0.12, ease: 'power3.out' })
});

// ── CAUSAS ──
ScrollTrigger.create({
  trigger: '#causas-header', start: 'top 80%', once: true,
  onEnter: () => {
    gsap.from('#causas-header .eyebrow', { opacity: 0, x: -30, duration: 0.5 });
    gsap.from('#causas-header .section-title', { opacity: 0, y: 40, duration: 0.8, delay: 0.1, ease: 'power4.out' });
  }
});
ScrollTrigger.create({
  trigger: '#causas-grid', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#causas-grid .cause-card', { opacity: 0, y: 50, duration: 0.65, stagger: 0.08, ease: 'power3.out' })
});

// ── BENEFICIOS ──
ScrollTrigger.create({
  trigger: '#ben-img', start: 'top 78%', once: true,
  onEnter: () => gsap.from('#ben-img', { opacity: 0, x: -40, duration: 0.9, ease: 'power3.out' })
});
ScrollTrigger.create({
  trigger: '#ben-text', start: 'top 78%', once: true,
  onEnter: () => gsap.from('#ben-text > *', { opacity: 0, x: 40, duration: 0.7, stagger: 0.1, ease: 'power3.out' })
});
ScrollTrigger.create({
  trigger: '#ben-grid', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#ben-grid .ben-card', { opacity: 0, y: 40, duration: 0.6, stagger: 0.08, ease: 'power3.out' })
});
ScrollTrigger.create({
  trigger: '#ben-photos', start: 'top 85%', once: true,
  onEnter: () => gsap.from('#ben-photos img', { opacity: 0, scale: 0.95, duration: 0.6, stagger: 0.1, ease: 'power3.out' })
});

// ── ACTIVIDADES ──
ScrollTrigger.create({
  trigger: '#act-grid', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#act-grid .act-card', { opacity: 0, scale: 0.95, duration: 0.6, stagger: 0.08, ease: 'power3.out' })
});

// ── UNIRSE ──
ScrollTrigger.create({
  trigger: '#unirse-steps', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#unirse-steps .step-item', { opacity: 0, x: -40, duration: 0.6, stagger: 0.1, ease: 'power3.out' })
});
ScrollTrigger.create({
  trigger: '#unirse-right', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#unirse-right > *', { opacity: 0, x: 40, duration: 0.6, stagger: 0.1, ease: 'power3.out' })
});

// ── CTA ──
ScrollTrigger.create({
  trigger: '#cta-h2', start: 'top 80%', once: true,
  onEnter: () => gsap.from('#cta-h2 span', { opacity: 0, y: 70, skewY: 4, duration: 0.9, stagger: 0.14, ease: 'power4.out' })
});

// ── SMOOTH SCROLL (nativo, sin dependencias externas) ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const id = a.getAttribute('href');
    if (!id || id === '#') return;
    const target = document.querySelector(id);
    if (target) {
      e.preventDefault();
      const y = target.getBoundingClientRect().top + window.scrollY - 76;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  });
});

// ── MOBILE MENU TOGGLE ──
const toggleBtn = document.getElementById('nav-toggle');
const navLinksContainer = document.querySelector('.nav-links');
if (toggleBtn && navLinksContainer) {
  toggleBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    navLinksContainer.classList.toggle('nav-links-open');
    toggleBtn.classList.toggle('toggle-active');
  });

  // Close menu when clicking outside
  document.addEventListener('click', () => {
    navLinksContainer.classList.remove('nav-links-open');
    toggleBtn.classList.remove('toggle-active');
  });

  // Close menu when clicking any link
  navLinksContainer.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      navLinksContainer.classList.remove('nav-links-open');
      toggleBtn.classList.remove('toggle-active');
    });
  });
}
</script>
</Layout>