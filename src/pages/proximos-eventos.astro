---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/eventos.css';

const events = [
  {
    title: "CONGRESO DEPORTIVO INTERNACIONAL",
    img: "/images/evento1.webp",
  },
  {
    title: "TORNEO INTERDISCIPLINARIO CBIT",
    img: "/images/evento2.webp",
  },
  {
    title: "CARRERA Y FERIA DE SALUD INTEGRAL",
    img: "/images/evento3.webp",
  },
  {
    title: "CAMPAMENTO DE ÉLITE PARA PROMESAS",
    img: "/images/evento4.webp",
  }
];

const destacados = [
  {
    title: "ENTREGA DE MANUALES DE GESTIÓN DE CALIDAD ISO 21001",
    date: "27 JUN 2026",
    location: "Unidad Educativa Pablo Paulo VI, Cochabamba",
    category: "Institucional",
    color: "#C9993A",
    img: "/images/mega1.webp",
    gallery: ["/images/mega1.webp", "/images/mega2.webp", "/images/mega3.webp", "/images/mega4.webp"],
    content: [
      "El sábado 27 de junio de 2026, CBIT/CENACAP realizó la entrega oficial de los manuales de Gestión de Calidad a la Unidad Educativa Pablo Paulo VI, en el marco de su proceso de certificación bajo la norma ISO 21001 para organizaciones educativas.",
      "La Unidad Educativa Pablo Paulo VI es una institución de administración privada, ubicada en la calle Francisco Viedma Nro. 567, en la ciudad de Cochabamba. Cuenta con código RUE 80980341 y atiende actualmente a 575 estudiantes. La institución puede ser contactada al teléfono 4240418.",
      "Con la entrega de estos manuales, la unidad educativa formaliza su Sistema de Gestión de Calidad, alineando sus procesos administrativos y pedagógicos a los estándares internacionales de la norma ISO 21001. Este logro representa un paso importante hacia la mejora continua y la excelencia en la prestación del servicio educativo en la región de Cochabamba."
    ],
  }
];
---

<Layout title="Próximos Eventos | CBIT">
  <Navbar />

  <main class="ev-main">

    <!-- ══════════════════════════════════
         HERO
    ══════════════════════════════════ -->
    <section class="ev-hero" id="ev-hero">
      <div class="ev-hero-mesh" aria-hidden="true"></div>
      <div class="ev-orb ev-orb-1" aria-hidden="true"></div>
      <div class="ev-orb ev-orb-2" aria-hidden="true"></div>
      <div class="ev-orb ev-orb-3" aria-hidden="true"></div>

      <div class="ev-container ev-hero-inner">
        <div class="ev-reveal">
          <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 border-b border-white/10 pb-12">

            <h1 class="ev-hero-title font-display">
              NUESTROS<br/>
              <span style="color:#f2c82f">EVENTOS</span>
            </h1>

            <div class="ev-hero-side ev-reveal ev-d1">
              <p class="ev-hero-sub">
                Mantente al día con Nuestras Competencias, Conferencias Magistrales, Ferias de Salud, Deporte, Nutrición Deportiva y Jornadas de primer nivel en toda Bolivia.
              </p>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         EVENTOS DESTACADOS (REALIZADOS)
    ══════════════════════════════════ -->
    <section class="ev-section" id="destacados">
      <div class="ev-container">

        <div class="ev-section-head ev-reveal">
          <span class="ev-eyebrow">Lo Que Ya Vivimos</span>
          <h2 class="ev-section-title font-display">EVENTOS <span class="ev-gold">DESTACADOS</span></h2>
          <div class="ev-bar" data-bar></div>
        </div>

        <div class="ev-destacados-list">
          {destacados.map((d, i) => (
            <article class={`ev-destacado ev-reveal ev-s${i % 4}`}>

              <div class="ev-dest-media">
                <div class="ev-dest-main-wrap">
                  <img
                    src={d.img}
                    alt={d.title}
                    class="ev-dest-main-img"
                    data-dest-main={i}
                  />
                  <span class="ev-dest-badge" style={`background:${d.color}`}>Evento Realizado</span>
                </div>

                <div class="ev-dest-thumbs">
                  {d.gallery.map((g, gi) => (
                    <button
                      type="button"
                      class={`ev-dest-thumb ${gi === 0 ? 'ev-thumb-active' : ''}`}
                      data-dest-thumb={i}
                      data-src={g}
                      aria-label={`Ver imagen ${gi + 1} de ${d.title}`}
                    >
                      <img src={g} alt="" loading="lazy" />
                    </button>
                  ))}
                </div>
              </div>

              <div class="ev-dest-body">
                <div class="ev-dest-accent" style={`background:${d.color}`}></div>
                <span class="ev-dest-meta-top" style={`color:${d.color}`}>{d.category} · {d.date}</span>
                <h3 class="ev-dest-title font-display">{d.title}</h3>
                <span class="ev-dest-location">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                  {d.location}
                </span>

                {d.content.map((p) => (
                  <p class="ev-dest-text">{p}</p>
                ))}
              </div>

            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════
         GRID DE EVENTOS (AGENDA) — FLYERS
    ══════════════════════════════════ -->
    <section class="ev-section ev-soft-bg" id="eventos">
      <div class="ev-container">

        <div class="ev-section-head ev-reveal">
          <span class="ev-eyebrow">Calendario de Actividades</span>
          <h2 class="ev-section-title font-display">AGENDA <span class="ev-gold">CBIT</span></h2>
          <div class="ev-bar" data-bar></div>
        </div>

        <div class="ev-events-grid">
          {events.map((event, i) => (
            <div class={`ev-float-card ev-flyer-card ev-reveal ev-s${i % 4}`}>
              <img
                src={event.img}
                alt={event.title}
                width="600"
                height="900"
                loading="lazy"
                decoding="async"
                class="ev-flyer-img ev-zoom-target"
              />
            </div>
          ))}
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>



<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('ev-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.ev-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. BAR DRAW ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('ev-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO TITLE ── */
      const heroTitle = document.querySelector<HTMLElement>('.ev-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.ev-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.8,
          }
        });
      }

      /* ── 4. PARALLAX ORBS ── */
      document.querySelectorAll<HTMLElement>('.ev-orb-1, .ev-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -25 : 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.ev-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 2,
          }
        });
      });

      /* ── 5. STAGGER GRID AGENDA ── */
      const grid = document.querySelector('#eventos .ev-events-grid');
      if (grid) {
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.ev-reveal'));
        ScrollTrigger.create({
          trigger: grid,
          start: 'top 86%',
          once: true,
          onEnter: () => {
            cards.forEach((card, i) => {
              gsap.to(card, {
                opacity: 1, y: 0,
                duration: 0.72,
                delay: i * 0.1,
                ease: 'power3.out',
                overwrite: true,
              });
            });
          }
        });
      }

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  /* ── GALERÍA DE EVENTOS DESTACADOS ── */
  function initDestacadosGallery() {
    document.querySelectorAll<HTMLElement>('.ev-destacado').forEach((card, idx) => {
      const mainImg = card.querySelector<HTMLImageElement>(`[data-dest-main="${idx}"]`);
      const thumbs = card.querySelectorAll<HTMLElement>(`[data-dest-thumb="${idx}"]`);
      thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
          const src = thumb.getAttribute('data-src');
          if (!mainImg || !src) return;
          mainImg.style.opacity = '0';
          setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = '1';
          }, 150);
          thumbs.forEach(t => t.classList.remove('ev-thumb-active'));
          thumb.classList.add('ev-thumb-active');
        });
      });
    });
  }

  initPage();
  initDestacadosGallery();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); initDestacadosGallery(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>