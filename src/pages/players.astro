---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlayerSection from '../components/PlayerSection.astro';
---

<Layout title="The Squad | Sports Editorial">
  <Navbar />
  <main class="bg-black min-h-screen pt-32 text-white">
    <!-- Reusing the PlayerSection component for this page -->
    <PlayerSection />
    
    <div class="container mx-auto px-10 pb-32">
      <h2 class="text-4xl font-display mb-10 text-center"><span class="text-yellow-500">FULL</span> ROSTER</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[1, 2, 3, 4, 5, 6, 7, 8].map((i) => (
          <div class="bg-[#0a0a0a] border border-white/5 rounded-lg p-6 text-center group hover:border-yellow-500/50 transition-colors cursor-pointer">
            <div class="w-24 h-24 rounded-full overflow-hidden mx-auto mb-4 bg-black border-2 border-transparent group-hover:border-yellow-500 transition-colors">
              <img src={`/images/head${(i % 3) + 1}.jpg`} alt="Player" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all" />
            </div>
            <h3 class="font-display text-xl">PLAYER {i}</h3>
            <p class="text-yellow-500 font-bold text-sm">#{i + 10}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
