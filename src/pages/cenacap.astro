---

<Layout title="CENACAP | Centro Nacional de Capacitación Profesional" showBackgroundFX={false}>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    /* ── PALETA CENACAP: verde · azul · crema ── */
    --green:     #1e6b45;
    --green-mid: #28834f;
    --green-lt:  #e6f4ec;
    --green-dim: rgba(30,107,69,0.18);
    --blue:      #1a4b8c;
    --blue-mid:  #2d7dd2;
    --blue-lt:   #ebf3fb;
    --cream:     #f5f0e8;
    --cream2:    #ede7d9;
    --beige:     #c9b99a;
    --brown:     #8b7355;
    --dark:      #1a1612;
    --dark2:     #1d2820;   /* verde muy oscuro */
    --mid:       #4a5e52;
    --soft:      #7a9080;
    --faint:     #a8b8b0;
    --white:     #ffffff;
    --accent:    #2ca2f1;   /* dorado para detalles cálidos */
    --r:         12px;
    --r-lg:      20px;
    --r-xl:      32px;
  }
  html { scroll-behavior: smooth; }
  body { background: var(--white); color: var(--dark); font-family: 'Source Sans 3', sans-serif; overflow-x: hidden; }

  /* ══════════════ NAVBAR ══════════════ */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid #dce8e0;
    transition: box-shadow 0.3s;
  }
  #navbar.scrolled { box-shadow: 0 2px 20px rgba(30,107,69,0.10); }
  .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-logo img { height: 32px; }
  .nav-wordmark { font-family: 'Montserrat', sans-serif; font-size: 1.15rem; letter-spacing: 0.08em; color: var(--dark); }
  .nav-wordmark em { color: var(--green); font-style: normal; }
  .nav-links { display: flex; align-items: center; gap: 6px; }
  .nav-link { padding: 7px 16px; color: var(--mid); font-size: 0.83rem; font-weight: 500; text-decoration: none; border-radius: 100px; transition: all 0.2s; }
  .nav-link:hover { color: var(--dark); background: var(--cream); }
  .nav-cta { display: inline-flex; align-items: center; gap: 7px; padding: 9px 22px; background: var(--green); color: #fff; font-size: 0.83rem; font-weight: 700; text-decoration: none; border-radius: 100px; letter-spacing: 0.02em; transition: all 0.25s; }
  .nav-cta:hover { background: var(--green-mid); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(30,107,69,0.35); }

  /* ══════════════ HERO CARRUSEL ══════════════ */
  #hero {
    margin-top: 64px;
    position: relative; overflow: hidden;
    border-radius: 0 0 var(--r-xl) var(--r-xl);
    height: calc(100vh - 64px); min-height: 560px; max-height: 820px;
  }

  /* slides */
  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4,0,0.2,1);
    pointer-events: none;
  }
  .hero-slide.active { opacity: 1; pointer-events: auto; }

  .hero-slide-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transform: scale(1.04);
    transition: transform 7s ease-out;
  }
  .hero-slide.active .hero-slide-img { transform: scale(1); }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(14,30,20,0.82) 0%, rgba(14,30,20,0.3) 55%, transparent 100%);
  }

  /* contenido slide */
  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0 56px 56px; z-index: 2;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 16px;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 100px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; margin-bottom: 20px;
  }
  .hero-tag-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green-mid); }
  .hero-h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.92; letter-spacing: 0.01em; text-transform: uppercase;
    color: #fff; max-width: 700px; margin-bottom: 28px;
  }
  .hero-h1 .c-green { color: #6ee6a0; }

  .hero-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .btn-white {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px; background: var(--white); color: var(--dark);
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    border-radius: 100px; transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .btn-white:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(0,0,0,0.25); background: var(--cream); }
  .btn-outline-white {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 28px;
    border: 1.5px solid rgba(255,255,255,0.45); color: rgba(255,255,255,0.85);
    font-weight: 600; font-size: 0.88rem; text-decoration: none;
    border-radius: 100px; transition: all 0.3s;
  }
  .btn-outline-white:hover { border-color: #fff; color: #fff; background: rgba(255,255,255,0.12); }
  .hero-chips { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
  .hero-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px;
    background: rgba(255,255,255,0.10); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 100px; font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255,255,255,0.8);
  }

  /* controles carrusel */
  .hero-controls {
    position: absolute; bottom: 56px; right: 56px;
    z-index: 10; display: flex; gap: 10px; align-items: center;
  }
  .hc-btn {
    width: 42px; height: 42px; border-radius: 50%;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(8px); color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.25s;
  }
  .hc-btn:hover { background: var(--green); border-color: var(--green); }

  .hero-dots {
    position: absolute; bottom: 72px; left: 56px;
    z-index: 10; display: flex; gap: 8px;
  }
  .hero-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.3); border: none; cursor: pointer;
    transition: all 0.3s; padding: 0;
  }
  .hero-dot.active { background: var(--green-mid); transform: scale(1.4); }

  /* barra de progreso */
  .hero-progress {
    position: absolute; bottom: 0; left: 0; right: 0; height: 3px; z-index: 10;
    background: rgba(255,255,255,0.1);
  }
  .hero-progress-bar {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--green-mid), #6ee6a0);
    transition: none;
  }
  .hero-progress-bar.running {
    width: 100%;
    transition: width 5.5s linear;
  }

  /* ══════════════ ABOUT ══════════════ */
  #about { background: var(--white); }
  .about-wrap { max-width: 1280px; margin: 0 auto; padding: 90px 56px; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .about-eyebrow { display: inline-flex; align-items: center; gap: 9px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
  .about-eyebrow::before { content: ''; width: 28px; height: 2px; background: var(--green); border-radius: 2px; display: block; }
  .about-h2 { font-family: 'Montserrat', sans-serif; font-size: clamp(2rem, 4vw, 3.8rem); line-height: 1; letter-spacing: 0.01em; text-transform: uppercase; color: var(--dark); margin-bottom: 20px; }
  .about-h2 .hl { color: var(--green); }
  .about-desc { font-size: 0.95rem; color: var(--mid); line-height: 1.78; margin-bottom: 32px; }
  .about-features { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ab-feat {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 16px 18px;
    background: var(--cream); border-radius: var(--r);
    border: 1px solid #dce8e0;
    transition: all 0.3s;
  }
  .ab-feat:hover { background: var(--green-lt); border-color: var(--green); transform: translateY(-2px); }
  .ab-feat-icon { color: var(--green); flex-shrink: 0; margin-top: 2px; }
  .ab-feat-title { font-weight: 700; font-size: 0.82rem; color: var(--dark); margin-bottom: 3px; }
  .ab-feat-desc { font-size: 0.76rem; color: var(--soft); line-height: 1.5; }
  .about-right { position: relative; }
  .about-mosaic { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 280px 180px; gap: 12px; }
  .ab-img { border-radius: var(--r-lg); overflow: hidden; }
  .ab-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .ab-img:hover img { transform: scale(1.05); }
  .ab-img.span2 { grid-column: span 2; }
  .about-badge {
    position: absolute; bottom: -20px; left: -20px;
    background: var(--green); color: #fff;
    padding: 18px 24px; border-radius: var(--r-lg);
    text-align: center;
    box-shadow: 0 12px 32px rgba(30,107,69,0.3);
  }
  .about-badge-num { font-family: 'Montserrat', sans-serif; font-size: 2.4rem; color: #6ee6a0; line-height: 1; }
  .about-badge-lbl { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-top: 3px; }

  /* ══════════════ SECCIÓN SHARED ══════════════ */
  .sw { max-width: 1280px; margin: 0 auto; padding: 90px 56px; }
  .sec-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 52px; gap: 24px; flex-wrap: wrap; }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 12px;
  }
  .eyebrow::before { content: ''; width: 28px; height: 2px; border-radius: 2px; display: block; }
  .eyebrow.green  { color: var(--green);    } .eyebrow.green::before  { background: var(--green);    }
  .eyebrow.blue   { color: var(--blue-mid); } .eyebrow.blue::before   { background: var(--blue-mid); }
  .eyebrow.cream  { color: var(--brown);    } .eyebrow.cream::before  { background: var(--brown);    }
  .sec-title { font-family: 'Montserrat', sans-serif; font-size: clamp(2.2rem, 4.5vw, 4rem); line-height: 0.95; letter-spacing: 0.01em; text-transform: uppercase; color: var(--dark); }
  .hl-green { color: var(--green);    }
  .hl-blue  { color: var(--blue-mid); }
  .hl-acc   { color: var(--accent);   }
  .link-all {
    display: inline-flex; align-items: center; gap: 7px; padding: 10px 22px;
    border: 1.5px solid #c8ddd0; border-radius: 100px;
    font-size: 0.8rem; font-weight: 600; color: var(--mid); text-decoration: none; transition: all 0.25s; white-space: nowrap;
  }
  .link-all:hover { border-color: var(--green); color: var(--green); }

  /* ══════════════ SERVICIOS ══════════════ */
  #servicios { background: var(--cream); }
  .servicios-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .serv-card {
    background: var(--white); border-radius: var(--r-lg);
    border: 1px solid #dce8e0; overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34,1.4,0.64,1), box-shadow 0.4s, border-color 0.3s;
  }
  .serv-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(30,107,69,0.12); border-color: var(--green); }
  .serv-img { height: 200px; overflow: hidden; }
  .serv-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s; }
  .serv-card:hover .serv-img img { transform: scale(1.07); }
  .serv-body { padding: 20px 20px 22px; }
  .serv-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); margin-bottom: 10px; }
  .serv-title { font-family: 'Montserrat', sans-serif; font-size: 1rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--dark); margin-bottom: 7px; }
  .serv-desc { font-size: 0.78rem; color: var(--soft); line-height: 1.6; }

  /* ══════════════ PROGRAMAS CERTIFICADOS ══════════════ */
  #programas { background: var(--white); }

  .prog-tabs { display: flex; gap: 8px; margin-bottom: 40px; flex-wrap: wrap; }
  .prog-tab {
    padding: 8px 20px; background: transparent;
    border: 1.5px solid #c8ddd0; border-radius: 100px;
    font-size: 0.78rem; font-weight: 600; color: var(--soft);
    cursor: pointer; transition: all 0.22s;
  }
  .prog-tab:hover { border-color: var(--green); color: var(--green); }
  .prog-tab.active { background: var(--green); border-color: var(--green); color: #fff; }

  .prog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .prog-card {
    border-radius: var(--r-lg); overflow: hidden;
    border: 1px solid #dce8e0;
    background: var(--white);
    box-shadow: 0 2px 8px rgba(30,107,69,0.06);
    transition: transform 0.38s cubic-bezier(0.34,1.4,0.64,1), box-shadow 0.38s, border-color 0.3s;
    display: none; /* oculto por defecto, JS lo muestra */
  }
  .prog-card.visible {
    display: block;
  }
  .prog-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(30,107,69,0.14); border-color: var(--green); }
  .prog-card-img { height: 160px; overflow: hidden; position: relative; }
  .prog-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .prog-card:hover .prog-card-img img { transform: scale(1.06); }
  .prog-card-img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(14,30,20,0.6) 0%, transparent 55%);
  }
  .prog-cat-badge {
    position: absolute; bottom: 10px; left: 12px;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; background: var(--green); padding: 3px 10px; border-radius: 50px;
  }
  .prog-card-body { padding: 14px 16px 18px; }
  .prog-card-title { font-weight: 700; font-size: 0.88rem; color: var(--dark); line-height: 1.3; margin-bottom: 6px; }
  .prog-card-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .prog-modalidad { font-size: 0.65rem; color: var(--faint); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
  .prog-cta {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--green); text-decoration: none; transition: gap 0.2s;
  }
  .prog-cta:hover { gap: 8px; }

  /* ══════════════ WHY ══════════════ */
  #why { background: var(--cream); }
  .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .why-img-col { position: relative; }
  .why-img-main { width: 100%; height: 480px; object-fit: cover; border-radius: var(--r-xl); display: block; }
  .why-float {
    position: absolute; top: 32px; right: -28px;
    background: var(--white); border-radius: var(--r-lg);
    padding: 18px 22px;
    box-shadow: 0 12px 40px rgba(30,107,69,0.15);
    text-align: center; min-width: 130px;
  }
  .why-float-num { font-family: 'Montserrat', sans-serif; font-size: 2.2rem; color: var(--green); line-height: 1; }
  .why-float-lbl { font-size: 0.64rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--soft); margin-top: 3px; }
  .why-float-2 {
    position: absolute; bottom: 32px; left: -28px;
    background: var(--dark2);
    border-radius: var(--r-lg);
    padding: 18px 22px;
    box-shadow: 0 12px 40px rgba(14,30,20,0.25);
    text-align: center; min-width: 130px;
  }
  .why-float-2 .why-float-num { color: #6ee6a0; }
  .why-float-2 .why-float-lbl { color: rgba(255,255,255,0.45); }
  .why-items { display: flex; flex-direction: column; gap: 16px; }
  .why-item {
    display: flex; gap: 16px; align-items: flex-start;
    padding: 20px 22px; background: var(--white);
    border-radius: var(--r); border: 1px solid #dce8e0;
