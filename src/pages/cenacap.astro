<script>
  // Animación de entrada del hero
  const initGSAP = async () => {
    try {
      const gsapModule = await import('gsap');
      return { gsap: gsapModule.default };
    } catch (e) {
      console.warn('GSAP no encontrado como módulo, cargando desde CDN...');
      await new Promise((resolve) => {
        const script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js';
        script.onload = resolve;
        document.head.appendChild(script);
      });
      return { gsap: (window as any).gsap };
    }
  };

  const runHeroAnimation = (gsap: any) => {
    const kicker = document.getElementById('hero-kicker');
    const h1Lines = document.querySelectorAll('#hero-h1 .line-wrap span');
    const heroDesc = document.getElementById('hero-desc');
    const heroCtas = document.getElementById('hero-ctas');
    const scrollHint = document.getElementById('scroll-hint');

    if (!kicker || !h1Lines.length || !heroDesc || !heroCtas || !scrollHint) return;

    gsap.set('#hero-h1 .line-wrap', { overflow: 'hidden', display: 'block' });
    gsap.set(h1Lines, { yPercent: 100 });
    gsap.set([heroDesc, heroCtas], { y: 20 });

    const tl = gsap.timeline({ delay: 0.2 });
    tl
      .to(kicker, { opacity: 1, duration: 0.6, ease: 'power2.out' })
      .to(h1Lines, {
        yPercent: 0,
        duration: 1,
        ease: 'power4.out',
        stagger: 0.12
      }, '-=0.2')
      .to(heroDesc, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.4')
      .to(heroCtas, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.5')
      .to(scrollHint, { opacity: 1, duration: 0.6 }, '-=0.3');
  };

  // Tabs de cursos
  const setupTabs = () => {
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-item');
    const panels = document.querySelectorAll<HTMLElement>('.cursos-panel');
    tabBtns.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        panels[i].classList.add('active');
      });
    });
  };

  // Pausa del ticker al hacer hover
  const track = document.getElementById('stats-track');
  if (track) {
    track.addEventListener('mouseenter', () => {
      track.style.animationPlayState = 'paused';
    });
    track.addEventListener('mouseleave', () => {
      track.style.animationPlayState = 'running';
    });
  }

  // Animación de revelación para la galería (Intersection Observer)
  const setupReveal = () => {
    const items = document.querySelectorAll('[data-reveal]');
    if (!items.length) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    items.forEach(item => observer.observe(item));
  };

  // Inicializar
  initGSAP().then(({ gsap }) => {
    if (gsap) runHeroAnimation(gsap);
    setupTabs();
    setupReveal();
  }).catch(err => console.error('Error al cargar GSAP:', err));
</script>
