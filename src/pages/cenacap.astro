---
import Layout from '../layouts/Layout.astro';

const carreras = [
  {
    categoria: "Gestión y Calidad",
    num: "01",
    cursos: [
      { nombre: "Sistemas de Gestión Ambiental", desc: "Gestión ambiental empresarial, normativas ISO 14001 y desarrollo sostenible.", modalidad: "Presencial / Virtual", imagen: "/images/1.png" },
      { nombre: "Sistemas de Gestión de Calidad", desc: "Implementación de normas ISO 9001, auditoría de calidad y mejora continua.", modalidad: "Presencial", imagen: "/images/2.png" },
      { nombre: "Supervisión y Liderazgo en Prevención de Riesgos", desc: "Gestión de riesgos laborales, seguridad industrial y salud ocupacional.", modalidad: "Presencial", imagen: "/images/5.png" },
    ],
  },
  {
    categoria: "Diseño y Tecnología",
    num: "02",
    cursos: [
      { nombre: "Diseño Gráfico y Producción Audiovisual", desc: "Adobe Creative Suite, motion graphics, edición de video y producción digital.", modalidad: "Presencial / Virtual", imagen: "/images/6.png" },
      { nombre: "Microsoft Project", desc: "Gestión de proyectos con MS Project, planificación y control de cronogramas.", modalidad: "Virtual", imagen: "/images/3.png" },
    ],
  },
  {
    categoria: "Deporte y Rendimiento",
    num: "03",
    cursos: [
      { nombre: "Sistemas Tácticos Deportivos", desc: "Análisis táctico, estrategias de juego y preparación deportiva especializada.", modalidad: "Presencial", imagen: "/images/4.png" },
      { nombre: "Deporte de Alto Rendimiento y Competición", desc: "Preparación física, mental y técnica para deportistas de élite.", modalidad: "Presencial", imagen: "/images/8.png" },
    ],
  },
];

const stats = [
  { num: "2400", suffix: "+", label: "Egresados" },
  { num: "18", suffix: "", label: "Programas" },
  { num: "97", suffix: "%", label: "Inserción Laboral" },
  { num: "12", suffix: "", label: "Años de Experiencia" },
];
---

<Layout title="CENACAP | Centro Nacional de Capacitación Profesional">
<style>
  /* ── RESET & BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --c-black: #000000;
    --c-ink: #080c10;
    --c-blue: #0ea5e9;
    --c-blue-dim: #0369a1;
    --c-green: #22c55e;
    --c-green-dim: #16a34a;
    --c-teal: #2dd4bf;
    --c-white: #f8fafc;
    --c-gray: #94a3b8;
    --c-border: rgba(255,255,255,0.07);
  }

  /* ── NAVBAR ── */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 72px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--c-border);
    transition: background 0.4s;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 14px;
    text-decoration: none;
  }
  .nav-logo img { height: 38px; width: auto; }
  .nav-wordmark {
    font-family: 'Anton', sans-serif;
    letter-spacing: 0.08em;
    font-size: 1.3rem;
    color: var(--c-white);
    line-height: 1;
  }
  .nav-wordmark em { color: var(--c-green); font-style: normal; }
  .nav-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 28px;
    background: transparent;
    border: 1.5px solid var(--c-blue);
    color: var(--c-blue);
    font-family: 'Anton', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.25s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }
  .nav-pill:hover {
    background: var(--c-blue);
    color: #000;
    box-shadow: 0 0 24px rgba(14,165,233,0.5);
  }
  .nav-pill svg { width: 14px; height: 14px; transition: transform 0.25s; }
  .nav-pill:hover svg { transform: translateX(3px); }

  /* ── HERO ── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 0 60px 80px;
    overflow: hidden;
  }
  #hero-bg {
    position: absolute; inset: 0;
    background: url('/images/jun.jpg') center center / cover no-repeat;
    transform-origin: center;
    will-change: transform;
  }
  #hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(0,0,0,0.97) 0%, rgba(0,0,0,0.6) 40%, rgba(0,0,0,0.25) 100%),
      linear-gradient(to right, rgba(0,0,0,0.6) 0%, transparent 60%);
  }
  /* Scan lines */
  #hero::after {
    content: '';
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none; z-index: 1;
  }

  .hero-content { position: relative; z-index: 2; max-width: 900px; }

  .hero-kicker {
    display: inline-flex; align-items: center; gap: 10px;
    margin-bottom: 28px;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-green);
    opacity: 0;
  }
  .hero-kicker-line {
    display: block; width: 40px; height: 1.5px;
    background: var(--c-green);
  }

  .hero-h1 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(4.5rem, 11vw, 10rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--c-white);
    margin-bottom: 8px;
    overflow: hidden;
  }
  .hero-h1 span { display: block; }
  .hero-h1 .line-accent {
    -webkit-text-stroke: 1px rgba(255,255,255,0.25);
    color: transparent;
  }
  .hero-h1 .line-color {
    background: linear-gradient(90deg, var(--c-blue), var(--c-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-meta {
    display: flex; align-items: center; gap: 32px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.55);
    max-width: 420px;
    line-height: 1.75;
    font-weight: 400;
    opacity: 0;
  }
  .hero-cta-group {
    display: flex; gap: 12px; flex-wrap: wrap;
    opacity: 0;
  }
  .btn-hero-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 36px;
    background: linear-gradient(135deg, var(--c-blue), var(--c-teal));
    color: #000;
    font-family: 'Anton', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: all 0.3s;
    box-shadow: 0 0 0 rgba(14,165,233,0);
  }
  .btn-hero-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(14,165,233,0.5);
  }
  .btn-hero-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 28px;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.6);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }
  .btn-hero-secondary:hover {
    border-color: var(--c-green);
    color: var(--c-green);
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute; bottom: 32px; right: 60px; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0;
  }
  .scroll-hint span {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); writing-mode: vertical-rl;
  }
  .scroll-line {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ── STATS TICKER ── */
  #stats-bar {
    background: var(--c-ink);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    overflow: hidden;
    padding: 0;
  }
  .stats-inner {
    display: flex;
    overflow: hidden;
    padding: 36px 0;
  }
  .stats-track {
    display: flex; gap: 0; flex-shrink: 0;
    animation: ticker 30s linear infinite;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .stat-chip {
    display: flex; align-items: center; gap: 24px;
    padding: 0 64px;
    border-right: 1px solid var(--c-border);
    flex-shrink: 0;
  }
  .stat-num {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, var(--c-blue), var(--c-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    max-width: 80px;
    line-height: 1.4;
  }

  /* ── SECTION BASE ── */
  .section-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 120px 60px;
  }
  .section-header {
    margin-bottom: 72px;
  }
  .section-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--c-teal);
    margin-bottom: 20px;
  }
  .section-eyebrow::before {
    content: ''; display: block;
    width: 32px; height: 1px;
    background: var(--c-teal);
  }
  .section-title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    letter-spacing: 0.02em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--c-white);
  }
  .section-title .hl {
    -webkit-text-stroke: 1.5px var(--c-blue);
    color: transparent;
  }

  /* ── CARRERAS ── */
  #carreras { background: #000; }

  .tab-row {
    display: flex; gap: 0;
    border: 1px solid var(--c-border);
    margin-bottom: 48px;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }
  .tab-item {
    flex: 1;
    display: flex; align-items: center; gap: 12px;
    padding: 18px 28px;
    background: transparent;
    border: none;
    border-right: 1px solid var(--c-border);
    color: rgba(255,255,255,0.3);
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .tab-item:last-child { border-right: none; }
  .tab-item::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--c-blue), var(--c-teal));
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .tab-item.active, .tab-item:hover {
    color: var(--c-white);
    background: rgba(14,165,233,0.05);
  }
  .tab-item.active::after, .tab-item:hover::after { transform: scaleX(1); }
  .tab-num {
    font-family: 'Anton', sans-serif;
    font-size: 1.1rem;
    color: var(--c-blue);
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .tab-item.active .tab-num, .tab-item:hover .tab-num { opacity: 1; }

  .cursos-panel { display: none; }
  .cursos-panel.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2px; }

  .curso-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--c-border);
    overflow: hidden;
    position: relative;
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .curso-card:hover {
    border-color: rgba(14,165,233,0.4);
    background: rgba(14,165,233,0.04);
  }
  .curso-card:hover .curso-img { transform: scale(1.06); }
  .curso-img-wrap { height: 220px; overflow: hidden; position: relative; }
  .curso-img-wrap::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.85));
  }
  .curso-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
    display: block;
  }
  .curso-body { padding: 28px 32px 32px; }
  .curso-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--c-teal);
    margin-bottom: 14px;
  }
  .curso-tag::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--c-teal); display: block; }
  .curso-nombre {
    font-family: 'Anton', sans-serif;
    font-size: 1.25rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--c-white);
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .curso-desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.7;
    margin-bottom: 24px;
  }
  .curso-cert {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--c-green);
    padding: 7px 16px;
    border: 1px solid rgba(34,197,94,0.25);
    background: rgba(34,197,94,0.06);
  }
  .curso-cert svg { width: 11px; height: 11px; }

  .curso-arrow {
    position: absolute; top: 20px; right: 20px;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }
  .curso-card:hover .curso-arrow {
    background: var(--c-blue);
    border-color: var(--c-blue);
    transform: translate(2px, -2px);
  }
  .curso-arrow svg { width: 14px; height: 14px; color: rgba(255,255,255,0.4); }
  .curso-card:hover .curso-arrow svg { color: #000; }

  /* ── WHY SECTION ── */
  #why {
    background: var(--c-ink);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }
  .why-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .why-left { position: sticky; top: 100px; }
  .why-visual {
    position: relative; margin-top: 40px;
    height: 420px;
  }
  .why-img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(60%) contrast(1.1);
    transition: filter 0.5s;
  }
  .why-img:hover { filter: grayscale(0%) contrast(1.1); }
  .why-img-frame {
    position: absolute; inset: 0;
    border: 1px solid rgba(14,165,233,0.2);
    pointer-events: none;
  }
  .why-img-frame::before {
    content: '';
    position: absolute; top: -8px; left: -8px;
    width: 24px; height: 24px;
    border-top: 2px solid var(--c-blue);
    border-left: 2px solid var(--c-blue);
  }
  .why-img-frame::after {
    content: '';
    position: absolute; bottom: -8px; right: -8px;
    width: 24px; height: 24px;
    border-bottom: 2px solid var(--c-teal);
    border-right: 2px solid var(--c-teal);
  }

  .why-items { display: flex; flex-direction: column; gap: 2px; }
  .why-item {
    padding: 28px 32px;
    border: 1px solid var(--c-border);
    position: relative; overflow: hidden;
    transition: all 0.35s;
    cursor: default;
  }
  .why-item::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(to bottom, var(--c-blue), var(--c-teal));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s;
  }
  .why-item:hover { background: rgba(14,165,233,0.04); border-color: rgba(14,165,233,0.2); }
  .why-item:hover::before { transform: scaleY(1); }
  .why-item-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .why-item-title {
    font-family: 'Anton', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-white);
  }
  .why-item-num {
    font-family: 'Anton', sans-serif;
    font-size: 1.8rem;
    color: rgba(255,255,255,0.06);
    line-height: 1;
  }
  .why-item-desc {
    font-size: 0.84rem;
    color: rgba(255,255,255,0.38);
    line-height: 1.7;
  }

  /* ── CTA ── */
  #cta {
    position: relative;
    overflow: hidden;
    background: #000;
  }
  .cta-bg {
    position: absolute; inset: 0;
    background: url('/images/jun.jpg') center 30% / cover no-repeat;
    opacity: 0.08;
    filter: blur(4px);
  }
  .cta-content {
    position: relative; z-index: 1;
    max-width: 1280px; margin: 0 auto;
    padding: 140px 60px;
    display: flex; flex-direction: column; align-items: flex-start;
  }
  .cta-h2 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(3rem, 8vw, 8rem);
    letter-spacing: 0.01em;
    line-height: 0.92;
    text-transform: uppercase;
    color: var(--c-white);
    margin-bottom: 48px;
  }
  .cta-h2 .stroke {
    display: block;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.2);
    color: transparent;
  }
  .cta-h2 .filled {
    display: block;
    background: linear-gradient(90deg, var(--c-blue), var(--c-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-row {
    display: flex; align-items: center; gap: 40px; flex-wrap: wrap;
  }
  .cta-badges {
    display: flex; gap: 12px; flex-wrap: wrap;
  }
  .cta-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px;
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }
  .cta-badge svg { width: 12px; height: 12px; color: var(--c-green); }

  /* ── FOOTER ── */
  footer {
    padding: 32px 60px;
    border-top: 1px solid var(--c-border);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-brand {
    font-family: 'Anton', sans-serif;
    font-size: 1.1rem; letter-spacing: 0.12em;
    color: var(--c-white);
  }
  .footer-brand em { color: var(--c-green); font-style: normal; }
  .footer-copy {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.06em;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    #hero { padding: 0 28px 60px; }
    .section-wrap { padding: 80px 28px; }
    .why-layout { grid-template-columns: 1fr; gap: 40px; }
    .why-left { position: static; }
    .cta-content { padding: 80px 28px; }
    footer { padding: 28px; }
    #navbar { padding: 0 24px; }
    .tab-item { padding: 14px 16px; font-size: 0.72rem; }
  }
  @media (max-width: 640px) {
    .hero-meta { flex-direction: column; gap: 20px; }
    .tab-row { flex-direction: column; }
    .tab-item { border-right: none; border-bottom: 1px solid var(--c-border); }
  }
</style>

<!-- NAVBAR -->
<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/images/log2.png" alt="CENACAP" onerror="this.style.display='none'" />
    <span class="nav-wordmark">CENA<em>CAP</em></span>
  </a>
  <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="nav-pill">
    Inscribirme
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
</nav>

<!-- HERO -->
<section id="hero">
  <div id="hero-bg"></div>
  <div id="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-kicker" id="hero-kicker">
      <span class="hero-kicker-line"></span>
      Centro Nacional de Capacitación Profesional
    </div>

    <h1 class="hero-h1" id="hero-h1">
      <span class="line-wrap"><span>FORMACIÓN</span></span>
      <span class="line-wrap"><span class="line-accent">DE ÉLITE</span></span>
      <span class="line-wrap"><span class="line-color">PROFESIONAL</span></span>
    </h1>

    <div class="hero-meta">
      <p class="hero-desc" id="hero-desc">
        Desarrolla competencias certificadas en gestión, tecnología y deporte de alto rendimiento. Programas diseñados por profesionales activos.
      </p>
      <div class="hero-cta-group" id="hero-ctas">
        <a href="#carreras" class="btn-hero-primary">
          Ver Programas
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="btn-hero-secondary">
          Inscribirse
        </a>
      </div>
    </div>
  </div>

  <div class="scroll-hint" id="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- STATS BAR -->
<div id="stats-bar">
  <div class="stats-inner">
    <div class="stats-track" id="stats-track">
      {[...stats, ...stats].map(s => (
        <div class="stat-chip">
          <span class="stat-num">{s.num}<span style="font-size:0.6em">{s.suffix}</span></span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- CARRERAS -->
<section id="carreras">
  <div class="section-wrap">
    <div class="section-header" id="carreras-header">
      <div class="section-eyebrow">Oferta Académica</div>
      <h2 class="section-title">PROGRAMAS <span class="hl">CERTIFI</span><br/>CADOS</h2>
    </div>

    <div class="tab-row" id="tab-row">
      {carreras.map((c, i) => (
        <button class={`tab-item${i === 0 ? ' active' : ''}`} data-idx={i}>
          <span class="tab-num">{c.num}</span>
          {c.categoria}
        </button>
      ))}
    </div>

    {carreras.map((cat, ci) => (
      <div class={`cursos-panel${ci === 0 ? ' active' : ''}`} id={`panel-${ci}`}>
        {cat.cursos.map(curso => (
          <div class="curso-card">
            <div class="curso-img-wrap">
              <img
                src={curso.imagen}
                alt={curso.nombre}
                class="curso-img"
                onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80'"
              />
            </div>
            <div class="curso-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </div>
            <div class="curso-body">
              <span class="curso-tag">{curso.modalidad}</span>
              <h3 class="curso-nombre">{curso.nombre}</h3>
              <p class="curso-desc">{curso.desc}</p>
              <span class="curso-cert">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                Certificado Incluido
              </span>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<!-- WHY -->
<section id="why">
  <div class="section-wrap">
    <div class="why-layout">
      <div class="why-left" id="why-left">
        <div class="section-eyebrow">Por Que Elegirnos</div>
        <h2 class="section-title">LO QUE NOS HACE <span class="hl">DIFE</span><br/>RENTES</h2>
        <div class="why-visual">
          <img src="/images/jun.jpg" alt="Aula CENACAP" class="why-img"
               onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=800&q=80'" />
          <div class="why-img-frame"></div>
        </div>
      </div>
      <div class="why-items" id="why-items">
        {[
          { title: "Certificacion Reconocida", desc: "Respaldo institucional con validez para el mercado laboral local e internacional.", num: "01" },
          { title: "Docentes en Ejercicio", desc: "Profesionales activos que traen experiencia real al aula, no solo teoria.", num: "02" },
          { title: "Metodologia Activa", desc: "Aprende haciendo. Proyectos reales, casos de estudio y simulaciones desde el primer modulo.", num: "03" },
          { title: "Modalidad Flexible", desc: "Presencial, virtual o hibrido. Adapta tu formacion a tu ritmo y disponibilidad.", num: "04" },
          { title: "Resultados Comprobados", desc: "97% de insercion laboral post-certificacion. Los egresados mas demandados del mercado.", num: "05" },
          { title: "Red Profesional", desc: "Comunidad activa de profesionales y empresas aliadas desde el primer dia.", num: "06" },
        ].map(item => (
          <div class="why-item">
            <div class="why-item-head">
              <h3 class="why-item-title">{item.title}</h3>
              <span class="why-item-num">{item.num}</span>
            </div>
            <p class="why-item-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta">
  <div class="cta-bg"></div>
  <div class="cta-content">
    <h2 class="cta-h2" id="cta-h2">
      <span class="stroke">TU CARRERA</span>
      <span class="stroke">PROFESIONAL</span>
      <span class="filled">EMPIEZA AQUI.</span>
    </h2>
    <div class="cta-row">
      <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="btn-hero-primary" style="font-size:1rem;padding:18px 48px;">
        Inscribirme Ahora
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <div class="cta-badges">
        {[
          { label: "100% en Linea" },
          { label: "Certificado Valido" },
          { label: "Horario Flexible" },
        ].map(b => (
          <span class="cta-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            {b.label}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <span class="footer-brand">CENA<em>CAP</em></span>
  <span class="footer-copy">© 2025 CENACAP · Centro Nacional de Capacitacion Profesional · Todos los derechos reservados</span>
</footer>

<script>
import gsap from 'gsap';
import ScrollTrigger from 'gsap/ScrollTrigger';
//import SplitType from 'split-type';

gsap.registerPlugin(ScrollTrigger);

// ── NAVBAR ──
const navbar = document.getElementById('navbar')!;
ScrollTrigger.create({
  start: 'top -80',
  onUpdate: (self) => {
    navbar.style.background = self.progress > 0
      ? 'rgba(0,0,0,0.92)'
      : 'rgba(0,0,0,0.5)';
  }
});

// ── HERO PARALLAX ──
const heroBg = document.getElementById('hero-bg')!;
gsap.to(heroBg, {
  yPercent: 25,
  ease: 'none',
  scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
});

// ── HERO ENTRANCE ──
const tl = gsap.timeline({ delay: 0.2 });
const kicker = document.getElementById('hero-kicker')!;
const h1Lines = document.querySelectorAll('#hero-h1 .line-wrap span');
const heroDesc = document.getElementById('hero-desc')!;
const heroCtas = document.getElementById('hero-ctas')!;
const scrollHint = document.getElementById('scroll-hint')!;

// Each h1 line slides up from a clip
gsap.set('#hero-h1 .line-wrap', { overflow: 'hidden', display: 'block' });
gsap.set(h1Lines, { yPercent: 100 });

tl
  .to(kicker, { opacity: 1, duration: 0.6, ease: 'power2.out' })
  .to(h1Lines, {
    yPercent: 0,
    duration: 1,
    ease: 'power4.out',
    stagger: 0.12
  }, '-=0.2')
  .to(heroDesc, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, '-=0.4')
  .to(heroCtas, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.5')
  .to(scrollHint, { opacity: 1, duration: 0.6 }, '-=0.3');

gsap.set([heroDesc, heroCtas], { y: 20 });

// ── STATS TICKER pause on hover ──
const track = document.getElementById('stats-track')!;
track.addEventListener('mouseenter', () => gsap.to(track, { timeScale: 0, duration: 0.5 }));
track.addEventListener('mouseleave', () => gsap.to(track, { timeScale: 1, duration: 0.5 }));

// ── CARRERAS HEADER ──
ScrollTrigger.create({
  trigger: '#carreras-header',
  start: 'top 80%',
  onEnter: () => {
    gsap.from('#carreras-header .section-eyebrow', { opacity: 0, x: -30, duration: 0.6, ease: 'power3.out' });
    gsap.from('#carreras-header .section-title', { opacity: 0, y: 40, duration: 0.8, ease: 'power4.out', delay: 0.15 });
  }
});

// ── TABS ──
const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-item');
const panels = document.querySelectorAll<HTMLElement>('.cursos-panel');

tabBtns.forEach((btn, i) => {
  btn.addEventListener('click', () => {
    tabBtns.forEach(b => b.classList.remove('active'));
    panels.forEach(p => { p.classList.remove('active'); });
    btn.classList.add('active');
    const panel = panels[i];
    panel.classList.add('active');
    // Animate cards in
    gsap.from(panel.querySelectorAll('.curso-card'), {
      opacity: 0,
      y: 30,
      duration: 0.5,
      stagger: 0.08,
      ease: 'power3.out'
    });
  });
});

// Animate first panel on load
ScrollTrigger.create({
  trigger: '#tab-row',
  start: 'top 75%',
  once: true,
  onEnter: () => {
    gsap.from('#panel-0 .curso-card', {
      opacity: 0, y: 40, duration: 0.6, stagger: 0.1, ease: 'power3.out'
    });
  }
});

// ── WHY SECTION ──
ScrollTrigger.create({
  trigger: '#why-left',
  start: 'top 75%',
  once: true,
  onEnter: () => {
    gsap.from('#why-left .section-eyebrow', { opacity: 0, x: -30, duration: 0.5, ease: 'power3.out' });
    gsap.from('#why-left .section-title', { opacity: 0, y: 30, duration: 0.7, ease: 'power4.out', delay: 0.1 });
    gsap.from('#why-left .why-visual', { opacity: 0, scale: 0.95, duration: 1, ease: 'power3.out', delay: 0.3 });
  }
});

ScrollTrigger.create({
  trigger: '#why-items',
  start: 'top 80%',
  once: true,
  onEnter: () => {
    gsap.from('#why-items .why-item', {
      opacity: 0, x: 40,
      duration: 0.6, stagger: 0.1, ease: 'power3.out'
    });
  }
});

// ── CTA ──
ScrollTrigger.create({
  trigger: '#cta-h2',
  start: 'top 80%',
  once: true,
  onEnter: () => {
    gsap.from('#cta-h2 span', {
      opacity: 0, y: 60,
      duration: 0.9, stagger: 0.15, ease: 'power4.out'
    });
  }
});
</script>
</Layout>