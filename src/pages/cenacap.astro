<script>
  /* ── CARRUSEL HERO ── */
  (() => {
    const slides   = Array.from(document.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots     = Array.from(document.querySelectorAll<HTMLButtonElement>('.hero-dot'));
    const bar      = document.getElementById('hero-prog-bar');
    const DURATION = 5500;
    let current = 0;
    let timer: ReturnType<typeof setTimeout>;

    function goTo(idx: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      resetBar();
    }

    function resetBar() {
      if (!bar) return;
      bar.classList.remove('running');
      // forzar reflow
      void bar.offsetWidth;
      bar.classList.add('running');
      clearTimeout(timer);
      timer = setTimeout(() => goTo(current + 1), DURATION);
    }

    document.getElementById('hc-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('hc-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // pausa en hover
    const hero = document.getElementById('hero')!;
    hero.addEventListener('mouseenter', () => { clearTimeout(timer); bar?.classList.remove('running'); });
    hero.addEventListener('mouseleave', resetBar);

    resetBar(); // arrancar
  })();

  /* ── FILTROS PROGRAMAS (transición instantánea, sin animación de aparición) ── */
  (() => {
    const tabs  = document.querySelectorAll<HTMLButtonElement>('.prog-tab');
    const cards = document.querySelectorAll<HTMLElement>('.prog-card');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter!;

        cards.forEach((card) => {
          const match = filter === 'Todos' || card.dataset.cat === filter;
          card.classList.toggle('visible', match);
        });
      });
    });
  })();

  /* ── NAVBAR: scroll instantáneo a la sección (misma página, sin animación de bajada) ── */
  document.querySelectorAll<HTMLAnchorElement>('.nav-link, .footer-link[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href') || '';
      if (!href.startsWith('#')) return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      const navH = document.getElementById('navbar')?.offsetHeight ?? 64;
      const y = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - navH;
      window.scrollTo({ top: y, behavior: 'auto' });
      history.pushState(null, '', href);
    });
  });

  /* ── NAVBAR MOBILE TOGGLE & SCROLL ── */
  const nb = document.getElementById('navbar')!;
  const ham = document.getElementById('nav-ham');
  const mobMenu = document.getElementById('mobile-menu');

  if (ham && mobMenu) {
    ham.addEventListener('click', () => {
      const isOpen = ham.classList.toggle('open');
      mobMenu.classList.toggle('open');
      document.body.classList.toggle('menu-open');
      ham.setAttribute('aria-expanded', String(isOpen));
    });

    const mobLinks = mobMenu.querySelectorAll('.mob-nav-link, .mob-nav-cta');
    mobLinks.forEach(link => {
      link.addEventListener('click', () => {
        ham.classList.remove('open');
        mobMenu.classList.remove('open');
        document.body.classList.remove('menu-open');
        ham.setAttribute('aria-expanded', 'false');
      });
    });
  }

  window.addEventListener('scroll', () => nb.classList.toggle('scrolled', scrollY > 40), { passive: true });

  /* ── SCROLL REVEAL ── */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });
  document.querySelectorAll('.anim-up, .anim-left, .anim-right, .anim-scale').forEach(el => io.observe(el));
</script>
