---
import Layout from '../layouts/Layout.astro';

const carreras = [
  {
    categoria: "Gestión y Calidad",
    num: "01",
    cursos: [
      {
        nombre: "Sistemas de Gestión Ambiental",
        desc: "Aprende a implementar estrategias que reduzcan el impacto ambiental empresarial. Identificarás riesgos, manejarás residuos, optimizarás recursos y aplicarás normas como ISO 14001, preparándote para trabajar en industrias o consultorías ambientales.",
        modalidad: "Presencial / Virtual",
        imagen: "/images/1.png"
      },
      {
        nombre: "Sistemas de Gestión de Calidad",
        desc: "Diseña e implementa sistemas que garanticen altos estándares en productos y servicios. Aprenderás a aplicar ISO 9001, realizar auditorías internas y optimizar procesos, siendo clave en la mejora continua.",
        modalidad: "Presencial",
        imagen: "/images/2.png"
      },
      {
        nombre: "Supervisión y Liderazgo en Prevención de Riesgos",
        desc: "Prepárate para liderar equipos y garantizar la seguridad laboral. Identificarás riesgos, prevendrás accidentes y aplicarás normativas de seguridad en entornos industriales.",
        modalidad: "Presencial",
        imagen: "/images/5.png"
      },
    ],
  },
  {
    categoria: "Diseño y Tecnología",
    num: "02",
    cursos: [
      {
        nombre: "Diseño Gráfico y Producción Audiovisual",
