---

<Layout title="CENACAP | Centro Nacional de Capacitación Profesional" showBackgroundFX={false}>

<!-- NAVBAR -->
<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/images/log2.png" alt="CENACAP" onerror="this.style.display='none'" />
    <span class="nav-wordmark">CENACAP</span>
  </a>
  <div class="nav-links">
    <a href="#about"      class="nav-link">Nosotros</a>
    <a href="#servicios"  class="nav-link">Servicios</a>
    <a href="#programas"  class="nav-link">Programas</a>
    <a href="#testimonios"class="nav-link">Egresados</a>
    <a href="#vacantes"   class="nav-link">Vacantes</a>
  </div>
  <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="nav-cta">
    Inscribirme
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
  <button class="nav-hamburger" id="nav-ham" aria-label="Abrir menú">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
</nav>

<!-- MOBILE MENU DRAWER -->
<div class="mobile-menu-drawer" id="mobile-menu">
  <a href="#about"      class="mob-nav-link">Nosotros</a>
  <a href="#servicios"  class="mob-nav-link">Servicios</a>
  <a href="#programas"  class="mob-nav-link">Programas</a>
  <a href="#testimonios"class="mob-nav-link">Egresados</a>
  <a href="#vacantes"   class="mob-nav-link">Vacantes</a>
  <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="mob-nav-cta">Inscribirme</a>
</div>

<!-- HERO CARRUSEL -->
<section id="hero">

  {heroSlides.map((slide, i) => (
    <div class={`hero-slide${i === 0 ? ' active' : ''}`} data-slide={i}>
      <img
        src={slide.img}
        alt={slide.tag}
        class="hero-slide-img"
        onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1600&q=80'"
      />
      <div class="hero-overlay"></div>
      <div class="hero-content">
        
        <h1 class="hero-h1">
          <span>{slide.h1a}</span><br/>
          <span>{slide.h1b}</span><br/>
          <span class="c-green">{slide.h1c}</span>
        </h1>
        <div class="hero-row">
          <a href="#programas" class="btn-white">
            Ver Programas
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="btn-outline-white">Inscribirme</a>
        </div>
        <div class="hero-chips">
          <span class="hero-chip">97% Inserción Laboral</span>
          <span class="hero-chip">18 Programas</span>
          <span class="hero-chip">Certificado Válido</span>
        </div>
      </div>
    </div>
  ))}

  <!-- dots -->
  <div class="hero-dots">
    {heroSlides.map((_, i) => (
      <button class={`hero-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Slide ${i+1}`}></button>
    ))}
  </div>

  <!-- prev / next -->
  <div class="hero-controls">
    <button class="hc-btn" id="hc-prev" aria-label="Anterior">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="hc-btn" id="hc-next" aria-label="Siguiente">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <!-- barra de progreso -->
  <div class="hero-progress">
    <div class="hero-progress-bar" id="hero-prog-bar"></div>
  </div>

</section>

<!-- ABOUT -->
<section id="about">
  <div class="about-wrap">
    <div class="about-grid">
      <div class="about-left anim-left">
        <div class="about-eyebrow">Quiénes Somos</div>
        <h2 class="about-h2">SOMOS UN CENTRO DE <span class="hl">FORMACIÓN</span> PROFESIONAL</h2>

        <p class="about-desc">
          El Centro de Capacitación Técnica Privado CENACAP es una Entidad Dedicada a la Formación y Actualización de Competencias Técnicas y Profesionales, Orientada a Responder de Manera Eficiente a las Demandas del Mercado Laboral y al Desarrollo Productivo. Su Enfoque se Basa en la Capacitación Práctica, la Innovación Metodológica y la Mejora Continua, Promoviendo el Aprendizaje Significativo y la Aplicación Efectiva de Conocimientos.
        </p>
        <p class="about-desc">
          Ofrecemos Procesos de Capacitación Flexibles y Especializados, Dirigidos a Personas que Buscan Fortalecer sus Habilidades Técnicas, Mejorar su Desempeño Profesional e Incorporarse de Manera Competitiva al Ámbito Laboral. Asimismo, Fomentamos Valores como la Responsabilidad, la Ética, la Calidad y el Compromiso Social, Contribuyendo al Desarrollo Integral de Nuestros Participantes y al Progreso de la Comunidad.
        </p>
        <div class="about-features">
          {[
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>`, t: "Certificación Reconocida", d: "Validez nacional e internacional" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`, t: "Docentes en Ejercicio", d: "Profesionales activos del sector" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`, t: "Modalidad Flexible", d: "Presencial, virtual o híbrido" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, t: "Metodología Activa", d: "Proyectos reales desde el día 1" },
          ].map(f => (
            <div class="ab-feat">
              <span class="ab-feat-icon" set:html={f.icon} />
              <div>
                <div class="ab-feat-title">{f.t}</div>
                <div class="ab-feat-desc">{f.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="about-right anim-right" style="padding:20px 20px 28px 0;">
        <div class="about-mosaic">
          <div class="ab-img"><img src="/images/cena6.webp" alt="Clase" onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400&q=80'" /></div>
          <div class="ab-img"><img src="/images/cena8.webp" alt="Gestión" onerror="this.src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&q=80'" /></div>
          <div class="ab-img span2"><img src="/images/cena7.webp" alt="Diseño" onerror="this.src='https://images.unsplash.com/photo-1561070791-2526d30994b5?w=800&q=80'" /></div>
        </div>
        <div class="about-badge">
          <div class="about-badge-num"></div>
          <div class="about-badge-lbl">RM 0286/2025</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICIOS -->
<section id="servicios">
  <div class="sw">
    <div class="sec-head">
      <div class="sec-head-left anim-up">
        <div class="eyebrow cream">Nuestras Especialidades</div>
        <h2 class="sec-title">NUESTROS <span class="hl-acc">SERVICIOS</span></h2>
      </div>
      <a href="#programas" class="link-all anim-up d2">
        Ver todos
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="servicios-grid">
      {servicios.map((s, i) => (
        <div class={`serv-card anim-up d${i+1}`}>
          <div class="serv-img">
            <img src={s.imagen} alt={s.titulo} onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400&q=80'" />
          </div>
          <div class="serv-body">
            <div class="serv-dot"></div>
            <div class="serv-title">{s.titulo}</div>
            <div class="serv-desc">{s.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PROGRAMAS CERTIFICADOS -->
<section id="programas">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow green">Oferta Académica</div>
        <h2 class="sec-title">PROGRAMAS <span class="hl-green">CERTIFICADOS</span></h2>
      </div>
    </div>

    <!-- Filtros -->
    <div class="prog-tabs" id="prog-tabs">
      <button class="prog-tab active" data-filter="Todos">Todos</button>
      <button class="prog-tab" data-filter="Calidad">Calidad</button>
      <button class="prog-tab" data-filter="Diseño">Diseño</button>
      <button class="prog-tab" data-filter="Deporte">Deporte</button>
      <button class="prog-tab" data-filter="Tecnología">Tecnología</button>
      <button class="prog-tab" data-filter="Seguridad">Seguridad</button>
    </div>

    <!-- Grid de tarjetas -->
    <div class="prog-grid" id="prog-grid">
      {programas.map((p, i) => (
        <div
          class="prog-card visible"
          data-cat={p.cat}
        >
          <div class="prog-card-img">
            <img src={p.imagen} alt={p.titulo} onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400&q=80'" />
            <div class="prog-card-img-overlay"></div>
            <span class="prog-cat-badge">{p.cat}</span>
          </div>
          <div class="prog-card-body">
            <div class="prog-card-title">{p.titulo}</div>
            <div class="prog-card-meta">
              <span class="prog-modalidad">{p.modalidad}</span>
              <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="prog-cta">
                Ver más
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHY -->
<section id="why">
  <div class="sw">
    <div class="why-grid">
      <div class="why-img-col anim-left">
        <img src="/images/cena6.webp" alt="Formación CENACAP" class="why-img-main"
             onerror="this.src='https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=800&q=80'" />
        <div class="why-float">
          <div class="why-float-num">97%</div>
          <div class="why-float-lbl">Inserción Laboral</div>
        </div>
        <div class="why-float-2">
          <div class="why-float-num">18</div>
          <div class="why-float-lbl">Programas Activos</div>
        </div>
      </div>
      <div>
        <div class="anim-right">
          <div class="eyebrow cream">Por Qué Elegirnos</div>
          <h2 class="sec-title" style="margin-bottom:36px">LO QUE NOS HACE <span class="hl-acc">DIFERENTES</span></h2>
        </div>
        <div class="why-items">
          {whyItems.map((item, i) => (
            <div class={`why-item anim-right d${i+1}`}>
              <span class="why-num">0{i+1}</span>
              <div>
                <div class="why-t">{item.t}</div>
                <div class="why-d">{item.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section id="stats">
  <div class="stats-inner">
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class={`stat-block anim-up d${i+1}`}>
          <div class="stat-num">{s.num}</div>
          <div class="stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TESTIMONIOS -->
<section id="testimonios">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow cream">Testimonios</div>
        <h2 class="sec-title">LO QUE DICEN<br/><span class="hl-acc">NUESTROS</span> ALUMNOS</h2>
      </div>
    </div>
    <div class="testi-grid">
      {testimonios.map((t, i) => (
        <div class={`testi-card anim-up d${i+1}`}>
          <div class="testi-stars">★★★★★</div>
          <p class="testi-cita">"{t.cita}"</p>
          <div class="testi-footer">
            <div class="testi-av">{t.ini}</div>
            <div>
              <div class="testi-autor">{t.autor}</div>
              <div class="testi-rol">{t.rol}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- VACANTES -->
<section id="vacantes">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow green">Oportunidades</div>
        <h2 class="sec-title">CONSTRUYE TU <span class="hl-green">CARRERA</span><br/>CON NOSOTROS</h2>
      </div>
    </div>
    <p class="anim-up" style="font-size:1.05rem;color:var(--soft);margin-bottom:36px;max-width:520px;line-height:1.75;">
      Al graduarte en CENACAP accedes a nuestra red de empresas aliadas. Estas son algunas de las posiciones más solicitadas por nuestros egresados.
    </p>
    <div class="vacantes-list">
      {vacantes.map((v, i) => (
        <div class={`vacante-row anim-up d${i+1}`}>
          <span class="vac-num">0{i+1}</span>
          <div class="vac-info">
            <div class="vac-cargo">{v.cargo}</div>
            <div class="vac-area">{v.area}</div>
          </div>
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="btn-apply">
            Inscribirme
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta">
  <img src="/images/sala.webp" alt="" class="cta-bg-img" aria-hidden="true"
       onerror="this.style.display='none'" />
  <div class="cta-inner">
    <div class="cta-left anim-left">
      <div class="cta-tag">Inscripciones Abiertas 2026</div>
      <h2 class="cta-h2">TU PRÓXIMO<br/>NIVEL ESTÁ<br/><span class="c-acc">AQUÍ.</span></h2>
      <p class="cta-sub">Más de 2,400 profesionales ya dieron el paso. Certifícate con los mejores.</p>
    </div>
    <div class="cta-right anim-right">
      <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="btn-cta-prim">
        Inscribirme Ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="btn-cta-sec">Ver Programas</a>
