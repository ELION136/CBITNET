---

<Layout title="CENACAP | Centro Nacional de Capacitación Profesional" showBackgroundFX={false}>
<style>
  /* ── RESET & BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --c-black: #000000;
    --c-ink: #080c10;
    --c-sky: #38bdf8;        /* azul celeste */
    --c-sky-dim: #0284c7;
    --c-green: #22c55e;
    --c-green-dim: #16a34a;
    --c-cream: #f8fafc;      /* blanco/crema */
    --c-white: #ffffff;
    --c-gray: #94a3b8;
    --c-border: rgba(255,255,255,0.07);
  }

  /* ── NAVBAR ── */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 72px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--c-border);
    transition: background 0.4s;
  }
  .nav-logo {
    display: flex; align-items: center; gap: 14px;
    text-decoration: none;
  }
  .nav-logo img { height: 38px; width: auto; }
  .nav-wordmark {
    font-family: 'Anton', sans-serif;
    letter-spacing: 0.08em;
    font-size: 1.3rem;
    color: var(--c-cream);
    line-height: 1;
  }
  .nav-wordmark em { color: var(--c-green); font-style: normal; }
  .nav-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 28px;
    background: transparent;
    border: 1.5px solid var(--c-sky);
    color: var(--c-sky);
    font-family: 'Anton', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.25s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }
  .nav-pill:hover {
    background: var(--c-sky);
    color: #000;
    box-shadow: 0 0 24px rgba(56,189,248,0.5);
  }
  .nav-pill svg { width: 14px; height: 14px; transition: transform 0.25s; }
  .nav-pill:hover svg { transform: translateX(3px); }

  /* ── HERO ── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 0 60px 80px;
    overflow: hidden;
  }
  #hero-bg {
    position: absolute; inset: 0;
    background: url('/images/sala.webp') center center / cover no-repeat;
  }
  #hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(0,0,0,0.97) 0%, rgba(0,0,0,0.6) 40%, rgba(0,0,0,0.25) 100%),
      linear-gradient(to right, rgba(0,0,0,0.6) 0%, transparent 60%);
  }
  #hero::after {
    content: '';
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none; z-index: 1;
  }

  .hero-content { position: relative; z-index: 2; max-width: 900px; }

  .hero-kicker {
    display: inline-flex; align-items: center; gap: 10px;
    margin-bottom: 28px;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-green);
    opacity: 0;
  }
  .hero-kicker-line {
    display: block; width: 40px; height: 1.5px;
    background: var(--c-green);
  }

  .hero-h1 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(4.5rem, 11vw, 10rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--c-cream);
    margin-bottom: 8px;
  }
  .hero-h1 .line-wrap { display: block; overflow: hidden; }
  .hero-h1 .line-wrap span { display: block; }
  .hero-h1 .line-accent {
    -webkit-text-stroke: 1px rgba(255,255,255,0.25);
    color: transparent;
  }
  .hero-h1 .line-color {
    background: linear-gradient(90deg, var(--c-green), var(--c-sky));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-meta {
    display: flex; align-items: center; gap: 32px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    color: rgba(248,250,252,0.55);
    max-width: 420px;
    line-height: 1.75;
    font-weight: 400;
    opacity: 0;
  }
  .hero-cta-group {
    display: flex; gap: 12px; flex-wrap: wrap;
    opacity: 0;
  }
  .btn-hero-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 36px;
    background: linear-gradient(135deg, var(--c-green), var(--c-sky));
    color: #000;
    font-family: 'Anton', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: all 0.3s;
  }
  .btn-hero-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(34,197,94,0.5);
  }
  .btn-hero-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 28px;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.6);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }
  .btn-hero-secondary:hover {
    border-color: var(--c-green);
    color: var(--c-green);
  }

  .scroll-hint {
    position: absolute; bottom: 32px; right: 60px; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0;
  }
  .scroll-hint span {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); writing-mode: vertical-rl;
  }
  .scroll-line {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ── STATS TICKER ── */
  #stats-bar {
    background: var(--c-ink);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    overflow: hidden;
    padding: 0;
  }
  .stats-inner {
    display: flex;
    overflow: hidden;
    padding: 36px 0;
  }
  .stats-track {
    display: flex; gap: 0; flex-shrink: 0;
    animation: ticker 30s linear infinite;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .stat-chip {
    display: flex; align-items: center; gap: 24px;
    padding: 0 64px;
    border-right: 1px solid var(--c-border);
    flex-shrink: 0;
  }
  .stat-num {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, var(--c-green), var(--c-sky));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    max-width: 80px;
    line-height: 1.4;
  }

  /* ── SECTION BASE ── */
  .section-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 120px 60px;
  }
  .section-header {
    margin-bottom: 72px;
  }
  .section-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--c-sky);
    margin-bottom: 20px;
  }
  .section-eyebrow::before {
    content: ''; display: block;
    width: 32px; height: 1px;
    background: var(--c-sky);
  }
  .section-title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    letter-spacing: 0.02em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--c-cream);
  }
  .section-title .hl {
    -webkit-text-stroke: 1.5px var(--c-sky);
    color: transparent;
  }

  /* ── CARRERAS ── */
  #carreras { background: #000; }

  .tab-row {
    display: flex; gap: 0;
    border: 1px solid var(--c-border);
    margin-bottom: 48px;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }
  .tab-item {
    flex: 1;
    display: flex; align-items: center; gap: 12px;
    padding: 18px 28px;
    background: transparent;
    border: none;
    border-right: 1px solid var(--c-border);
    color: rgba(255,255,255,0.3);
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .tab-item:last-child { border-right: none; }
  .tab-item::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--c-green), var(--c-sky));
    transform: scaleX(0);
    transition: transform 0.3s;
  }
  .tab-item.active, .tab-item:hover {
    color: var(--c-cream);
    background: rgba(56,189,248,0.05);
  }
  .tab-item.active::after, .tab-item:hover::after { transform: scaleX(1); }
  .tab-num {
    font-family: 'Anton', sans-serif;
    font-size: 1.1rem;
    color: var(--c-sky);
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .tab-item.active .tab-num, .tab-item:hover .tab-num { opacity: 1; }

  .cursos-panel { display: none; }
  .cursos-panel.active { display: block; }

  .cursos-scroll {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 12px;
    -webkit-overflow-scrolling: touch;
  }
  .cursos-scroll::-webkit-scrollbar { height: 6px; }
  .cursos-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); }
  .cursos-scroll::-webkit-scrollbar-thumb { background: var(--c-sky); border-radius: 3px; }

  .curso-card-h {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--c-border);
    overflow: hidden;
    transition: all 0.4s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  .curso-card-h:hover {
    border-color: rgba(56,189,248,0.5);
    background: rgba(56,189,248,0.06);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.6);
  }
  .curso-card-h:hover .curso-img { transform: scale(1.08); }
  .curso-img-wrap-h { height: 280px; overflow: hidden; position: relative; }
  .curso-img-wrap-h::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.8));
  }
  .curso-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .curso-body-h { padding: 28px; flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .curso-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--c-sky);
    margin-bottom: 12px;
  }
  .curso-tag::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--c-sky); display: block; }
  .curso-nombre {
    font-family: 'Anton', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--c-cream);
    line-height: 1.15;
    margin-bottom: 14px;
  }
  .curso-desc {
    font-size: 0.85rem;
    color: rgba(248,250,252,0.55);
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }
  .curso-cert {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--c-green);
    padding: 8px 16px;
    border: 1px solid rgba(34,197,94,0.25);
    background: rgba(34,197,94,0.06);
    align-self: flex-start;
  }
  .curso-cert svg { width: 11px; height: 11px; }

  /* ── WHY SECTION ── */
  #why {
    background: var(--c-ink);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }
  .why-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .why-left { position: sticky; top: 100px; }
  .why-visual {
    position: relative; margin-top: 40px;
    height: 420px;
  }
  .why-img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(60%) contrast(1.1);
    transition: filter 0.5s;
  }
  .why-img:hover { filter: grayscale(0%) contrast(1.1); }
  .why-img-frame {
    position: absolute; inset: 0;
    border: 1px solid rgba(56,189,248,0.2);
    pointer-events: none;
  }
  .why-img-frame::before {
    content: '';
    position: absolute; top: -8px; left: -8px;
    width: 24px; height: 24px;
    border-top: 2px solid var(--c-sky);
    border-left: 2px solid var(--c-sky);
  }
  .why-img-frame::after {
    content: '';
    position: absolute; bottom: -8px; right: -8px;
    width: 24px; height: 24px;
    border-bottom: 2px solid var(--c-green);
    border-right: 2px solid var(--c-green);
  }

  .why-items { display: flex; flex-direction: column; gap: 2px; }
  .why-item {
    padding: 28px 32px;
    border: 1px solid var(--c-border);
    position: relative; overflow: hidden;
    transition: all 0.35s;
    cursor: default;
  }
  .why-item::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(to bottom, var(--c-green), var(--c-sky));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s;
  }
  .why-item:hover {
    background: rgba(56,189,248,0.08);
    border-color: rgba(56,189,248,0.5);
  }
  .why-item:hover::before { transform: scaleY(1); }
  .why-item-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 10px;
  }
  .why-item-title {
    font-family: 'Anton', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-cream);
  }
  .why-item-num {
    font-family: 'Anton', sans-serif;
    font-size: 1.8rem;
    color: rgba(248,250,252,0.18);
    line-height: 1;
    transition: color 0.35s;
  }
  .why-item:hover .why-item-num { color: rgba(56,189,248,0.6); }
  .why-item-desc {
    font-size: 0.84rem;
    color: rgba(248,250,252,0.68);
    line-height: 1.7;
    transition: color 0.35s;
  }
  .why-item:hover .why-item-desc { color: rgba(248,250,252,0.9); }

  /* ── TESTIMONIOS ── */
  #testimonios {
    background: #000;
    border-bottom: 1px solid var(--c-border);
  }
  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }
  .testimonio-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--c-border);
    padding: 36px 32px;
    transition: all 0.3s;
  }
  .testimonio-card:hover {
    border-color: rgba(56,189,248,0.3);
    background: rgba(56,189,248,0.04);
  }
  .testimonio-cita {
    font-size: 1rem;
    color: rgba(248,250,252,0.65);
    line-height: 1.7;
    margin-bottom: 24px;
    font-style: italic;
  }
  .testimonio-autor {
    font-family: 'Anton', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    color: var(--c-cream);
    text-transform: uppercase;
  }
  .testimonio-rol {
    font-size: 0.75rem;
    color: var(--c-sky);
    letter-spacing: 0.1em;
    margin-top: 4px;
  }

  /* ── GALERÍA INSTALACIONES ── */
  #instalaciones {
    background: var(--c-ink);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
