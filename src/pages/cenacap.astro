        modalidad: "Presencial / Virtual",
        imagen: "/images/6.png"
      },
      {
        nombre: "Microsoft Project",
        desc: "Domina la herramienta esencial para la gestión de proyectos. Aprende a planificar tareas, asignar recursos, gestionar costos y monitorear el avance en tiempo real.",
        modalidad: "Virtual",
        imagen: "/images/3.png"
      },
    ],
  },
  {
    categoria: "Deporte y Rendimiento",
    num: "03",
    cursos: [
      {
        nombre: "Sistemas Tácticos Deportivos",
        desc: "Descubre cómo se construyen las jugadas ganadoras. Analiza el juego, diseña tácticas y adapta estrategias a diferentes situaciones competitivas.",
        modalidad: "Presencial",
        imagen: "/images/4.png"
      },
      {
        nombre: "Deporte de Alto Rendimiento y Competición",
        desc: "Alcanza el máximo nivel con preparación física, mental y técnica de élite. Métodos de entrenamiento avanzado y manejo psicológico en competencias.",
        modalidad: "Presencial",
        imagen: "/images/8.png"
      },
    ],
  },
];

const stats = [
  { num: "2400", suffix: "+", label: "Egresados" },
  { num: "18", suffix: "", label: "Programas" },
  { num: "97", suffix: "%", label: "Inserción Laboral" },
  { num: "12", suffix: "", label: "Años de Experiencia" },
];

const testimonios = [
  {
    cita: "Gracias a CENACAP conseguí un puesto en una multinacional apenas terminé el curso. La metodología práctica marcó la diferencia.",
    autor: "María Fernández",
    rol: "Egresada de Gestión de Calidad"
  },
  {
    cita: "Los profesores son profesionales en activo, no te enseñan teoría vacía. Aprendí herramientas que uso a diario en mi trabajo.",
    autor: "Carlos López",
    rol: "Egresado de Diseño Gráfico"
  },
  {
    cita: "El enfoque en prevención de riesgos es justo lo que necesitaba para ascender en mi empresa. Recomiendo CENACAP al 100%.",
    autor: "Ana Martínez",
    rol: "Egresada de Prevención de Riesgos"
  }
];

// Nueva galería de instalaciones (reemplaza aliados)
const instalaciones = [
  { imagen: "/images/instalacion1.jpg", titulo: "Aula de Tecnología", desc: "Equipos de última generación para clases prácticas." },
  { imagen: "/images/instalacion2.jpg", titulo: "Laboratorio de Calidad", desc: "Espacios simulados para auditorías y gestión." },
  { imagen: "/images/instalacion3.jpg", titulo: "Estudio de Diseño", desc: "Estaciones de trabajo con software profesional." },
  { imagen: "/images/instalacion4.jpg", titulo: "Área Deportiva", desc: "Instalaciones para entrenamiento táctico y físico." },
