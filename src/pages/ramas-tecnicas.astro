---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const stats = [
  { num: "3500", suffix: "+", label: "Profesionales Graduados" },
  { num: "95",   suffix: "%", label: "Empleabilidad Inicial" },
  { num: "40",   suffix: "+", label: "Empresas Aliadas" },
  { num: "100",  suffix: "%", label: "Validez Curricular" },
];

const programs = [
  {
    num: "01", tag: "Tecnología Industrial",
    title: "Informática Industrial",
    modalidad: "Presencial / Virtual",
    img: "/images/3.png",
    promo: "infocade",
    learn: [
      "Automatización y control industrial con PLC y SCADA",
      "Redes industriales: Profibus, Modbus, Ethernet industrial",
      "Programación de microcontroladores y sistemas embebidos",
      "Mantenimiento preventivo de infraestructura tecnológica",
    ]
  },
  {
    num: "02", tag: "Gestión Ambiental",
    title: "Sistemas de Gestión Ambiental",
    modalidad: "Presencial / Virtual",
    img: "/images/1.png",
    promo: "cenacap",
    learn: [
      "Norma ISO 14001 e implementación de SGA en organizaciones",
      "Identificación y evaluación de aspectos e impactos ambientales",
      "Auditoría ambiental interna y revisión por la dirección",
      "Legislación ambiental boliviana y requisitos legales aplicables",
    ]
  },
  {
    num: "03", tag: "Calidad e Ingeniería",
    title: "Sistemas de Gestión de Calidad",
    modalidad: "Presencial",
    img: "/images/1.png",
    promo: "cenacap",
    learn: [
      "Interpretación y aplicación de la norma ISO 9001:2015",
      "Planificación, implementación y mejora continua del SGC",
      "Auditorías internas de calidad y no conformidades",
      "Indicadores de desempeño (KPI) y revisión por la dirección",
    ]
  },
  {
    num: "04", tag: "Creativo y Multimedia",
    title: "Diseño Gráfico y Producción Audiovisual",
    modalidad: "Presencial / Virtual",
    img: "/images/6.png",
    promo: "cenacap",
    learn: [
      "Diseño editorial y de identidad con Adobe Illustrator y Photoshop",
      "Motion graphics y animación 2D con After Effects",
      "Producción y edición de video con Premiere Pro",
      "Estrategia visual para redes sociales y medios digitales",
    ]
  },
  {
    num: "05", tag: "Seguridad Laboral",
    title: "Supervisión y Liderazgo en Prevención de Riesgos",
    modalidad: "Presencial",
    img: "/images/ima3.jpg",
    promo: "cenacap",
    learn: [
      "Marco normativo de seguridad y salud ocupacional en Bolivia",
      "Identificación, evaluación y control de riesgos laborales",
      "Liderazgo en seguridad: cultura preventiva y gestión de equipos",
      "Investigación de accidentes e incidentes industriales",
    ]
  },
  {
    num: "06", tag: "Gestión y Liderazgo",
    title: "Microsoft Project",
    modalidad: "Virtual",
    img: "/images/ima3.jpg",
    promo: "cenacap",
    learn: [
      "Creación y estructuración de proyectos con EDT en MS Project",
      "Asignación de recursos, costos y control de presupuesto",
      "Seguimiento de avance, línea base y análisis de variaciones",
      "Generación de informes ejecutivos y diagramas de Gantt",
    ]
  },
];

const promoConfig = {
  infocade: { label: "INFOCADE", color: "#06b6d4", colorDim: "rgba(6,182,212,0.3)" },
  cenacap:  { label: "CENACAP",  color: "#2dd4bf", colorDim: "rgba(45,212,191,0.3)" },
};
---

<Layout title="Ramas Técnicas y Digitales | CBIT">
  <Navbar />

  <main class="min-h-screen relative overflow-hidden">

    <!-- ── HERO ── -->
    <section class="relative min-h-screen flex flex-col justify-end overflow-hidden"
             style="padding:0 3rem 5rem;">

      <!-- Grid pattern sobre el fondo del layout -->
      <div class="absolute inset-0 z-0 pointer-events-none"
           style="background-size:40px 40px;
                  background-image:linear-gradient(to right,rgba(255,255,255,0.012) 1px,transparent 1px),
                                   linear-gradient(to bottom,rgba(255,255,255,0.012) 1px,transparent 1px);
                  mask-image:linear-gradient(to top,rgba(0,0,0,0.7),transparent);"></div>

      <!-- Glows hero propios (complementan el canvas) -->
      <div class="absolute top-0 right-0 w-[450px] h-[450px] pointer-events-none rounded-full z-0"
           style="background:radial-gradient(circle,rgba(6,182,212,0.14) 0%,transparent 70%);
                  filter:blur(70px);transform:translate(25%,-25%);"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] pointer-events-none rounded-full z-0"
           style="background:radial-gradient(circle,rgba(139,92,246,0.08) 0%,transparent 70%);
                  filter:blur(80px);transform:translate(-35%,35%);"></div>

      <div class="relative z-[2] max-w-5xl">
      

        <h1 class="font-display font-bold tracking-tighter leading-[0.9] text-white mb-8 overflow-hidden"
            style="font-size:clamp(3.2rem,9vw,8.5rem);">
          <span class="hero-line block overflow-hidden">
            <span class="block translate-y-full">FORMACIÓN</span>
          </span>
          <span class="hero-line block overflow-hidden">
            <span class="block translate-y-full"
                  style="-webkit-text-stroke:1px rgba(255,255,255,0.12);color:rgb(251, 234, 0);">
              TÉCNICA Y
            </span>
          </span>
          <span class="hero-line block overflow-hidden">
            <span class="block translate-y-full"
                  style="background:linear-gradient(90deg,#06b6d4,#f6f65c);
                         -webkit-background-clip:text;-webkit-text-fill-color:transparent;
                         background-clip:text;">
              TECNOLÓGICA
            </span>
          </span>
        </h1>

        <div class="flex flex-wrap items-start gap-10 mt-4">
          <p id="hero-desc"
             class="text-gray-400 text-sm md:text-base max-w-lg leading-[1.85]
                    border-l-2 border-[#06b6d4]/40 pl-5"
             style="opacity:0;transform:translateY(18px);">
            Capacítate en diseño digital, programación, gestión ambiental, calidad,
            seguridad laboral y administración de proyectos bajo el respaldo de CBIT
            con validez laboral inmediata.
          </p>

          <div id="hero-ctas" class="flex gap-3 flex-wrap"
               style="opacity:0;transform:translateY(18px);">
            <a href="#programas"
               class="inline-flex items-center gap-3 font-display font-bold text-[11px]
                      tracking-[0.18em] uppercase px-8 py-4 text-black
                      transition-all duration-300 hover:-translate-y-1 hover:brightness-110"
               style="background:linear-gradient(135deg,#06b6d4,#eef65c);
                      clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));">
              Ver Especialidades
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 font-bold text-[11px] tracking-[0.18em]
                      uppercase px-7 py-4 border text-gray-300
                      transition-all duration-300 hover:border-[#06b6d4] hover:text-[#06b6d4]"
               style="border-color:rgba(255,255,255,0.12);
                      clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));">
              Inscribirme
            </a>
          </div>
        </div>
      </div>

      <div id="scroll-hint" class="absolute bottom-10 right-12 flex flex-col items-center gap-2 z-[2]"
           style="opacity:0;">
        <span class="text-[9px] tracking-[0.25em] uppercase text-white/25"
              style="writing-mode:vertical-rl;">Deslizar</span>
        <div class="w-[1px] h-14"
             style="background:linear-gradient(to bottom,rgba(255,255,255,0.25),transparent);
                    animation:scrollPulse 2s ease-in-out infinite;"></div>
      </div>
    </section>

    <!-- ── STATS BAR ── -->
    <div class="border-t border-b border-white/[0.05]"
         style="background:rgba(0,0,0,0.45);backdrop-filter:blur(12px);">
      <div class="max-w-6xl mx-auto px-10 py-10 flex flex-wrap justify-around gap-8">
        {stats.map(s => (
          <div class="stat-chip flex items-center gap-4">
            <span class="font-display font-bold leading-none"
                  style="font-size:2.75rem;
                         background:linear-gradient(135deg,#06b6d4,#f6f15c);
                         -webkit-background-clip:text;-webkit-text-fill-color:transparent;
                         background-clip:text;">
              {s.num}<span style="font-size:0.5em;">{s.suffix}</span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.15em] uppercase
                         text-white/35 max-w-[110px] leading-[1.5]">
              {s.label}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── PROGRAMAS ── -->
    <section id="programas" class="max-w-7xl mx-auto px-6 md:px-10 py-24 relative z-10">

      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8
                  border-b border-white/[0.07] pb-12 mb-14">
        <div id="prog-header">
          <p class="text-[9px] font-bold tracking-[0.45em] uppercase mb-4" style="color:#06b6d4;">
            Carreras Cortas y Profesionales
          </p>
          <h2 class="font-display font-bold tracking-tighter leading-[0.93] text-white"
              style="font-size:clamp(2.6rem,5.5vw,5rem);">
            ESPECIALIDADES Y<br/>
            <span style="-webkit-text-stroke:1.5px #06b6d4;color:transparent;">ÁREAS</span>
            <span class="text-white"> DIGITALES</span>
          </h2>
          <div id="prog-line" class="w-0 h-[2px] mt-5 origin-left"
               style="background:linear-gradient(to right,#06b6d4,#8b5cf6);"></div>
        </div>

        <!-- Leyenda promotores -->
        <div id="promo-legend" class="flex flex-col gap-2 self-start lg:self-end"
             style="opacity:0;">
          <p class="text-[8px] text-white/25 uppercase tracking-[0.25em] font-bold mb-1">
            Promocionado por
          </p>
          {Object.entries(promoConfig).map(([, v]) => (
            <div class="flex items-center gap-2 border px-4 py-2"
                 style={`border-color:${v.colorDim};
                         background:rgba(0,0,0,0.3);
                         clip-path:polygon(0 0,90% 0,100% 20%,100% 100%,0 100%);`}>
              <div class="w-[11px] h-[11px] rounded-full flex items-center justify-center flex-shrink-0"
                   style={`background:${v.color};`}>
                <svg width="6" height="6" viewBox="0 0 10 10" fill="none"
                     stroke="#000" stroke-width="2.5">
                  <circle cx="5" cy="5" r="3.5"/>
                </svg>
              </div>
              <span class="text-[8px] font-bold tracking-[0.25em] uppercase"
                    style={`color:${v.color};`}>{v.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="prog-grid">
        {programs.map((p, i) => {
          const promo = promoConfig[p.promo as keyof typeof promoConfig];
          return (
            <div
              class="prog-card group relative border border-white/[0.07] overflow-hidden
                     transition-colors duration-300"
              style={`clip-path:polygon(0 0,96% 0,100% 4%,100% 100%,4% 100%,0 96%);
                      background:rgba(255,255,255,0.02);
                      opacity:0;transform:translateY(36px);`}
              data-idx={i}
              data-accent={promo.color}
            >
              <!-- Imagen -->
              <div class="relative overflow-hidden" style="height:190px;">
                <img
                  src={p.img}
                  alt={p.title}
                  class="w-full h-full object-cover block transition-all duration-700
                         group-hover:scale-[1.04]"
                  style="opacity:0.4;"
                  data-card-img
                />
                <div class="absolute inset-0"
                     style="background:linear-gradient(to top,rgba(0,0,0,0.92) 0%,transparent 60%);"></div>

                <!-- Badge promotor -->
                <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2 py-1"
                     style={`background:rgba(4,4,4,0.92);
                             border:1px solid ${promo.colorDim};
                             clip-path:polygon(0 0,88% 0,100% 20%,100% 100%,0 100%);`}>
                  <div class="w-[11px] h-[11px] rounded-full flex items-center
                               justify-center flex-shrink-0"
                       style={`background:${promo.color};`}>
                    <svg width="6" height="6" viewBox="0 0 10 10" fill="none"
                         stroke="#000" stroke-width="2.5">
                      <circle cx="5" cy="5" r="3.5"/>
                    </svg>
                  </div>
                  <span class="text-[7px] font-bold tracking-[0.2em] uppercase"
                        style={`color:${promo.color};`}>{promo.label}</span>
                </div>

                <!-- Número en imagen -->
                <div class="absolute bottom-3 left-4 font-bold leading-none
                             pointer-events-none select-none"
                     style={`font-size:5rem;color:${promo.color};opacity:0.05;line-height:1;`}>
                  {p.num}
                </div>
              </div>

              <!-- Brackets hover -->
              <div class="absolute top-0 left-0 w-0 h-[2px] group-hover:w-9
                          transition-all duration-500"
                   style={`background:${promo.color};`}></div>
              <div class="absolute top-0 left-0 w-[2px] h-0 group-hover:h-9
                          transition-all duration-500 delay-[60ms]"
                   style={`background:${promo.color};`}></div>

              <!-- Cuerpo -->
              <div class="px-5 pt-4 pb-3">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-3 h-[1px] opacity-60"
                       style={`background:${promo.color};`}></div>
                  <span class="text-[8px] font-bold tracking-[0.3em] uppercase"
                        style={`color:${promo.color};`}>{p.tag}</span>
                </div>
                <h3 class="text-white font-bold leading-snug"
                    style="font-size:0.875rem;letter-spacing:0.02em;">{p.title}</h3>
              </div>

              <!-- Footer card -->
              <div class="flex items-center justify-between px-5 py-3"
                   style="border-top:1px solid rgba(255,255,255,0.05);">
                <span class="text-[8px] uppercase tracking-[0.15em] text-white/25 font-semibold">
                  {p.modalidad}
                </span>
                <button
                  class="learn-btn text-[8px] font-bold tracking-[0.2em] uppercase
                         px-3 py-1.5 border transition-colors duration-200"
                  style={`color:${promo.color};
                          border-color:${promo.colorDim};
                          clip-path:polygon(0 0,86% 0,100% 22%,100% 100%,14% 100%,0 78%);`}
                  data-target={`panel-${i}`}
                  data-accent={promo.color}
                >
                  ¿Qué aprenderás?
                </button>
              </div>

              <!-- Panel expandible -->
              <div class="learn-panel overflow-hidden" id={`panel-${i}`}
                   style="max-height:0;">
                <div class="px-5 pb-5 pt-3"
                     style={`background:rgba(0,0,0,0.4);
                             border-top:1px solid ${promo.colorDim};`}>
                  <div class="flex items-center gap-2 mb-3">
                    <div class="w-4 h-[1px]" style={`background:${promo.color};`}></div>
                    <span class="text-[8px] font-bold tracking-[0.25em] uppercase"
                          style={`color:${promo.color};`}>CONTENIDO DEL CURSO</span>
                  </div>
                  <ul class="flex flex-col gap-2.5">
                    {p.learn.map(l => (
                      <li class="flex items-start gap-2.5 text-white/50 text-xs leading-relaxed">
                        <span class="mt-[5px] w-[4px] h-[4px] flex-shrink-0 rotate-45 opacity-70 block"
                              style={`background:${promo.color};`}></span>
                        {l}
                      </li>
                    ))}
                  </ul>
                  <button
                    class="close-panel mt-4 flex items-center gap-2 text-[8px] font-bold
                           tracking-[0.2em] uppercase transition-colors duration-200"
                    style={`color:${promo.color};opacity:0.6;background:none;border:none;cursor:pointer;`}
                    data-target={`panel-${i}`}
                  >
                    <svg width="9" height="9" viewBox="0 0 12 12" fill="none"
                         stroke="currentColor" stroke-width="2">
                      <line x1="2" y1="2" x2="10" y2="10"/>
                      <line x1="10" y1="2" x2="2" y2="10"/>
                    </svg>
                    CERRAR
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ── VENTAJAS ── -->
    <section class="border-t border-white/[0.05]"
             style="background:rgba(0,0,0,0.4);backdrop-filter:blur(8px);">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

          <!-- Izquierda sticky -->
          <div id="adv-left" class="lg:sticky lg:top-28">
            <p class="text-[9px] font-bold tracking-[0.35em] uppercase mb-4"
               style="color:#06b6d4;">Ventaja Curricular</p>
            <h2 class="font-display font-bold tracking-tighter leading-[0.93] text-white mb-6"
                style="font-size:clamp(2.4rem,5vw,4.5rem);">
              RESPALDO Y<br/>
              <span style="-webkit-text-stroke:1.5px #06b6d4;color:transparent;">VALIDEZ</span>
              <span class="text-white"> LABORAL</span>
            </h2>
            <div class="w-12 h-[2px] mb-8"
                 style="background:linear-gradient(to right,#06b6d4,#8b5cf6);"></div>

            <!-- Imagen con marco clip -->
            <div style="padding:2px;
                        clip-path:polygon(8% 0,100% 0,100% 92%,92% 100%,0 100%,0 8%);
                        background:linear-gradient(135deg,#06b6d4,#8b5cf6);">
              <div class="relative overflow-hidden"
                   style="clip-path:polygon(8% 0,100% 0,100% 92%,92% 100%,0 100%,0 8%);
                          background:#090909;">
                <img src="/images/ima1.jpg" alt="Certificación CBIT"
                     class="w-full object-cover block transition-all duration-700
                            hover:scale-105 hover:opacity-90"
                     style="height:360px;opacity:0.55;filter:grayscale(50%);"/>
                <div class="absolute inset-0"
                     style="background:linear-gradient(to top,rgba(0,0,0,0.8) 0%,transparent 55%);"></div>
                <div class="absolute top-3 left-3 w-7 h-[2px]" style="background:#06b6d4;"></div>
                <div class="absolute top-3 left-3 w-[2px] h-7" style="background:#06b6d4;"></div>
                <div class="absolute bottom-3 right-3 w-7 h-[2px]" style="background:#8b5cf6;"></div>
                <div class="absolute bottom-3 right-3 w-[2px] h-7" style="background:#8b5cf6;"></div>
              </div>
            </div>
          </div>

          <!-- Items -->
          <div class="flex flex-col gap-3" id="adv-items">
            {[
              { title: "Bolsa de Empleo Activa", num: "01",
                desc: "Integración con empresas aliadas que buscan perfiles técnicos directamente de nuestras aulas, con seguimiento de inserción laboral post-egreso." },
              { title: "Metodología Práctica y Project-Based", num: "02",
                desc: "Aprende resolviendo desafíos reales del sector corporativo, estructurando un portafolio profesional durante toda la carrera." },
              { title: "Certificados con Validez Oficial", num: "03",
                desc: "Nuestras acreditaciones cumplen los estándares de CENACAP e INFOCADE para potenciar tu CV ante auditorías y reclutamientos nacionales." },
              { title: "Tutoría y Consultoría Personalizada", num: "04",
                desc: "Acompañamiento por instructores certificados para resolver dudas en vivo y guiar proyectos individuales durante todo el programa." },
              { title: "Flexibilidad de Horarios", num: "05",
                desc: "Diseñado para profesionales activos: clases presenciales en fines de semana y sesiones virtuales asincrónicas de soporte." },
            ].map((item) => (
              <div
                class="adv-item relative border border-white/[0.05] p-7 overflow-hidden
                       transition-all duration-300"
                style="clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px));
                       background:rgba(255,255,255,0.015);"
              >
                <div class="absolute left-0 top-0 bottom-0 w-[2px] origin-top scale-y-0
                             adv-bar transition-none"
                     style="background:linear-gradient(to bottom,#06b6d4,#8b5cf6);"></div>
                <div class="flex items-center justify-between mb-2.5">
                  <h3 class="font-display font-bold text-white uppercase tracking-wide"
                      style="font-size:0.95rem;">
                    {item.title}
                  </h3>
                  <span class="font-bold leading-none flex-shrink-0 ml-4"
                        style="font-size:1.6rem;color:rgba(6,182,212,0.1);">
                    {item.num}
                  </span>
                </div>
                <p class="text-white/35 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="relative overflow-hidden border-t border-white/[0.05]">
      <div class="absolute inset-0"
           style="background:url('/images/3.png') center 30% / cover no-repeat;
                  opacity:0.03;filter:blur(6px);"></div>
      <div class="absolute inset-0 pointer-events-none"
           style="background:radial-gradient(ellipse at 20% 50%,rgba(6,182,212,0.06) 0%,transparent 55%),
                             radial-gradient(ellipse at 80% 50%,rgba(139,92,246,0.05) 0%,transparent 55%);"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-10 py-28 flex flex-col items-start"
           id="cta-section">
        <h2 class="font-display font-bold tracking-tighter leading-[0.9] mb-10"
            style="font-size:clamp(2.8rem,7vw,6.5rem);">
          <span class="block"
                style="-webkit-text-stroke:1px rgba(255,255,255,0.1);color:white;">
            CONSTRUYE TU FUTURO
          </span>
          <span class="block"
                style="-webkit-text-stroke:1px rgba(255,255,255,0.1);color:white;">
            TECNOLÓGICO AHORA.
          </span>
          <span class="block"
                style="background:linear-gradient(90deg,#06b6d4,#f6e95c);
                       -webkit-background-clip:text;-webkit-text-fill-color:transparent;
                       background-clip:text;">
            POSTULA HOY MISMO.
          </span>
        </h2>

        <div class="flex flex-wrap items-center gap-5">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 font-display font-bold text-sm
                    tracking-[0.14em] uppercase px-10 py-5 text-black
                    transition-all duration-300 hover:-translate-y-1 hover:brightness-110"
             style="background:linear-gradient(135deg,#06b6d4,#f6e75c);
                    clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px));">
            Iniciar Mi Admisión
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>

          <div class="flex gap-2.5 flex-wrap">
            {["Validez Curricular","Bolsa de Trabajo","Cert. Académico"].map(b => (
              <div class="inline-flex items-center gap-2 px-4 py-2.5 border
                          text-white/40 text-[9px] font-bold tracking-[0.15em] uppercase
                          hover:border-[#06b6d4]/30 hover:text-white/60 transition-colors duration-300"
                   style="border-color:rgba(255,255,255,0.07);
                          clip-path:polygon(0 0,calc(100% - 7px) 0,100% 7px,100% 100%,7px 100%,0 calc(100% - 7px));">
                <svg viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="3"
                     width="10" height="10">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {b}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.25; }
    50%       { opacity: 0.7; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    /* ── HERO ── */
    const heroTl = gsap.timeline({ delay: 0.1 });
    heroTl
      .to('#hero-kicker',    { y: 0, opacity: 1, duration: 0.85, ease: 'power3.out' }, 0.25)
      .to('.hero-line span', { y: '0%', duration: 1.05, stagger: 0.14, ease: 'power4.out' }, 0.42)
      .to('#hero-desc',      { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, 0.85)
      .to('#hero-ctas',      { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, 1.0)
      .to('#scroll-hint',    { opacity: 1, duration: 0.5 }, 1.22);

    /* Stats */
    gsap.utils.toArray<HTMLElement>('.stat-chip').forEach((chip, i) => {
      gsap.from(chip, {
        y: 22, opacity: 0, duration: 0.65, delay: i * 0.08, ease: 'power3.out',
        scrollTrigger: { trigger: chip, start: 'top 90%' }
      });
    });

    /* Header programas */
    const hdrTl = gsap.timeline({
      scrollTrigger: { trigger: '#prog-header', start: 'top 84%' }
    });
    hdrTl
      .from('#prog-header > *', { y: 35, opacity: 0, duration: 0.75, stagger: 0.18, ease: 'power3.out' })
      .to('#prog-line',          { width: '3rem', duration: 0.75, ease: 'power3.out' }, '-=0.35')
      .to('#promo-legend',       { opacity: 1, duration: 0.6, ease: 'back.out(1.4)' }, '-=0.25');

    /* Cards */
    gsap.utils.toArray<HTMLElement>('.prog-card').forEach((card, i) => {
      const img    = card.querySelector<HTMLImageElement>('[data-card-img]');
      const accent = card.dataset.accent || '#06b6d4';

      gsap.to(card, {
        y: 0, opacity: 1, duration: 0.85, ease: 'power3.out',
        delay: (i % 3) * 0.1,
        scrollTrigger: { trigger: card, start: 'top 90%', once: true }
      });

      card.addEventListener('mouseenter', () => {
        if (img) gsap.to(img, { opacity: 0.72, duration: 0.55, ease: 'power2.out' });
        gsap.to(card, { borderColor: accent + '55', duration: 0.25 });
      });
      card.addEventListener('mouseleave', () => {
        if (img) gsap.to(img, { opacity: 0.4, duration: 0.55, ease: 'power2.out' });
        gsap.to(card, { borderColor: 'rgba(255,255,255,0.07)', duration: 0.25 });
      });
    });

    /* Panel expandible */
    document.querySelectorAll<HTMLButtonElement>('.learn-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const panel  = document.getElementById(btn.dataset.target!)!;
        const isOpen = parseFloat(panel.style.maxHeight || '0') > 0;

        document.querySelectorAll<HTMLElement>('.learn-panel').forEach(p => {
          gsap.to(p, {
            maxHeight: 0, duration: 0.38, ease: 'power3.in',
            onComplete: () => { p.style.maxHeight = '0'; }
          });
        });

        if (!isOpen) {
          gsap.fromTo(panel,
            { maxHeight: 0 },
            { maxHeight: 420, duration: 0.48, ease: 'power3.out' }
          );
          gsap.from(panel.querySelectorAll('li'), {
            x: -8, opacity: 0, duration: 0.35,
            stagger: 0.06, delay: 0.14, ease: 'power2.out'
          });
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.close-panel').forEach(btn => {
      btn.addEventListener('click', () => {
        const panel = document.getElementById(btn.dataset.target!)!;
        gsap.to(panel, {
          maxHeight: 0, duration: 0.38, ease: 'power3.in',
          onComplete: () => { panel.style.maxHeight = '0'; }
        });
      });
    });

    /* Ventajas */
    gsap.from('#adv-left > *', {
      y: 35, opacity: 0, duration: 0.75, stagger: 0.16, ease: 'power3.out',
      scrollTrigger: { trigger: '#adv-left', start: 'top 82%' }
    });

    gsap.utils.toArray<HTMLElement>('.adv-item').forEach((item, i) => {
      const bar = item.querySelector<HTMLElement>('.adv-bar');
      gsap.from(item, {
        x: 45, opacity: 0, duration: 0.7, delay: i * 0.09, ease: 'power3.out',
        scrollTrigger: { trigger: '#adv-items', start: 'top 80%' }
      });
      item.addEventListener('mouseenter', () => {
        if (bar) gsap.to(bar, { scaleY: 1, duration: 0.32, ease: 'power2.out' });
        gsap.to(item, {
          borderColor: 'rgba(6,182,212,0.2)',
          backgroundColor: 'rgba(6,182,212,0.03)',
          duration: 0.25
        });
      });
      item.addEventListener('mouseleave', () => {
        if (bar) gsap.to(bar, { scaleY: 0, duration: 0.28, ease: 'power2.in' });
        gsap.to(item, {
          borderColor: 'rgba(255,255,255,0.05)',
          backgroundColor: 'rgba(255,255,255,0.015)',
          duration: 0.25
        });
      });
    });

    /* CTA */
    gsap.from('#cta-section > *', {
      y: 42, opacity: 0, duration: 0.85, stagger: 0.18, ease: 'power3.out',
      scrollTrigger: { trigger: '#cta-section', start: 'top 80%' }
    });
  }
</script>