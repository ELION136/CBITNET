}
.rt-cta-chip:hover { border-color: var(--gold); color: var(--gold); }

/* ══════════════════════════════════
   SCROLL REVEAL — mismo sistema
══════════════════════════════════ */
.rt-reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.75s cubic-bezier(0.22,1,0.36,1),
              transform 0.75s cubic-bezier(0.22,1,0.36,1);
}
.rt-reveal.rt-on { opacity: 1; transform: translateY(0); }
.rt-d1 { transition-delay: .13s; }
.rt-d2 { transition-delay: .26s; }
.rt-s0 { transition-delay: 0s; }
.rt-s1 { transition-delay: .10s; }
.rt-s2 { transition-delay: .20s; }
.rt-s3 { transition-delay: .30s; }

/* ══════════════════════════════════
   RESPONSIVE
══════════════════════════════════ */
@media(max-width:1024px) {
  .rt-prog-grid      { grid-template-columns: repeat(2,1fr); }
  .rt-ventajas-grid  { grid-template-columns: 1fr; gap: 3rem; }
  .rt-vent-left      { position: static; }
}
@media(max-width:640px) {
  .rt-prog-grid      { grid-template-columns: 1fr; }
  .rt-section        { padding: 4.5rem 0; }
  .rt-hero           { padding: 9rem 0 5rem; }
  .rt-container      { padding: 0 1.25rem; }
}
@media(prefers-reduced-motion:reduce) {
  .rt-reveal  { opacity:1; transform:none; transition:none; }
  .rt-bar     { width:56px; transition:none; }
}
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('rt-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.rt-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. GOLD BAR DRAW ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('rt-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO TITLE ── */
      const heroTitle = document.querySelector<HTMLElement>('.rt-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.rt-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.8,
          }
        });
      }

      /* ── 4. PARALLAX ORBS ── */
      document.querySelectorAll<HTMLElement>('.rt-orb-1, .rt-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -25 : 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.rt-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 2,
          }
        });
      });

      /* ── 5. HERO TITLE ENTRANCE ── */
      const heroTl = gsap.timeline({ delay: 0.1 });
      heroTl
        .from('.rt-hero-title', { y: 60, opacity: 0, duration: 1.1, ease: 'power4.out' }, 0.2)
        .from('.rt-hero-sub',   { y: 25, opacity: 0, duration: 0.85, ease: 'power3.out' }, 0.65)
        .from('.rt-hero-ctas',  { y: 20, opacity: 0, duration: 0.8,  ease: 'power3.out' }, 0.85);

      /* ── 6. STAGGER GRIDS ── */
      ['#programas .rt-prog-grid', '#ventajas .rt-vent-items'].forEach(sel => {
        const grid = document.querySelector(sel);
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.rt-reveal'));
        ScrollTrigger.create({
          trigger: grid,
          start: 'top 86%',
          once: true,
          onEnter: () => {
            cards.forEach((card, i) => {
              gsap.to(card, {
                opacity: 1, y: 0,
                duration: 0.72,
                delay: i * 0.1,
                ease: 'power3.out',
                overwrite: true,
              });
            });
          }
        });
      });

      /* ── 7. PANEL EXPANDIBLE ── */
      document.querySelectorAll<HTMLButtonElement>('.rt-learn-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const panel  = document.getElementById(btn.dataset.target!)!;
          const isOpen = parseFloat(panel.style.maxHeight || '0') > 0;

          document.querySelectorAll<HTMLElement>('.rt-learn-panel').forEach(p => {
            gsap.to(p, { maxHeight: 0, duration: 0.38, ease: 'power3.in',
              onComplete: () => { p.style.maxHeight = '0'; } });
          });

          if (!isOpen) {
            gsap.fromTo(panel,
              { maxHeight: 0 },
              { maxHeight: 420, duration: 0.48, ease: 'power3.out' }
            );
            gsap.from(panel.querySelectorAll('li'), {
              x: -8, opacity: 0, duration: 0.35,
              stagger: 0.06, delay: 0.14, ease: 'power2.out'
            });
          }
        });
      });

      document.querySelectorAll<HTMLButtonElement>('.rt-close-panel').forEach(btn => {
        btn.addEventListener('click', () => {
          const panel = document.getElementById(btn.dataset.target!)!;
          gsap.to(panel, { maxHeight: 0, duration: 0.38, ease: 'power3.in',
            onComplete: () => { panel.style.maxHeight = '0'; } });
        });
      });

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>