---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const stats = [
  { num: "3500", suffix: "+", label: "Profesionales Graduados" },
  { num: "95",   suffix: "%", label: "Empleabilidad Inicial" },
  { num: "40",   suffix: "+", label: "Empresas Aliadas" },
  { num: "100",  suffix: "%", label: "Validez Curricular" },
];

const programs = [
  {
    num: "01", tag: "Tecnología Industrial",
    title: "Informática Industrial",
    modalidad: "Presencial / Virtual",
    img: "/images/3.png",
    promo: "infocade",
    learn: [
      "Automatización y control industrial con PLC y SCADA",
      "Redes industriales: Profibus, Modbus, Ethernet industrial",
      "Programación de microcontroladores y sistemas embebidos",
      "Mantenimiento preventivo de infraestructura tecnológica",
    ]
  },
  {
    num: "02", tag: "Gestión Ambiental",
    title: "Sistemas de Gestión Ambiental",
    modalidad: "Presencial / Virtual",
    img: "/images/1.png",
    promo: "cenacap",
    learn: [
      "Norma ISO 14001 e implementación de SGA en organizaciones",
      "Identificación y evaluación de aspectos e impactos ambientales",
      "Auditoría ambiental interna y revisión por la dirección",
      "Legislación ambiental boliviana y requisitos legales aplicables",
    ]
  },
  {
    num: "03", tag: "Calidad e Ingeniería",
    title: "Sistemas de Gestión de Calidad",
    modalidad: "Presencial",
    img: "/images/1.png",
    promo: "cenacap",
    learn: [
      "Interpretación y aplicación de la norma ISO 9001:2015",
      "Planificación, implementación y mejora continua del SGC",
      "Auditorías internas de calidad y no conformidades",
      "Indicadores de desempeño (KPI) y revisión por la dirección",
    ]
  },
  {
    num: "04", tag: "Creativo y Multimedia",
    title: "Diseño Gráfico y Producción Audiovisual",
    modalidad: "Presencial / Virtual",
    img: "/images/6.png",
    promo: "cenacap",
    learn: [
      "Diseño editorial y de identidad con Adobe Illustrator y Photoshop",
      "Motion graphics y animación 2D con After Effects",
      "Producción y edición de video con Premiere Pro",
      "Estrategia visual para redes sociales y medios digitales",
    ]
  },
  {
    num: "05", tag: "Seguridad Laboral",
    title: "Supervisión y Liderazgo en Prevención de Riesgos",
    modalidad: "Presencial",
    img: "/images/ima3.jpg",
    promo: "cenacap",
    learn: [
      "Marco normativo de seguridad y salud ocupacional en Bolivia",
      "Identificación, evaluación y control de riesgos laborales",
      "Liderazgo en seguridad: cultura preventiva y gestión de equipos",
      "Investigación de accidentes e incidentes industriales",
    ]
  },
  {
    num: "06", tag: "Gestión y Liderazgo",
    title: "Microsoft Project",
    modalidad: "Virtual",
    img: "/images/ima3.jpg",
    promo: "cenacap",
    learn: [
      "Creación y estructuración de proyectos con EDT en MS Project",
      "Asignación de recursos, costos y control de presupuesto",
      "Seguimiento de avance, línea base y análisis de variaciones",
      "Generación de informes ejecutivos y diagramas de Gantt",
    ]
  },
];

const promoConfig = {
  infocade: { label: "INFOCADE", color: "#0ea5e9", colorDim: "rgba(14,165,233,0.35)" },
  cenacap:  { label: "CENACAP",  color: "#2dd4bf", colorDim: "rgba(45,212,191,0.35)" },
};
---

<Layout title="Ramas Técnicas y Digitales | CBIT" showBackgroundFX={false}>
  <Navbar />

  <main class="min-h-screen relative overflow-hidden" style="background:#060606;">

    <!-- Glows -->
    <div class="absolute top-0 right-0 w-[700px] h-[700px] pointer-events-none z-0"
         style="background:radial-gradient(ellipse,rgba(6,182,212,0.07) 0%,transparent 65%);filter:blur(60px);transform:translate(30%,-30%);"></div>
    <div class="absolute bottom-1/3 left-0 w-[500px] h-[500px] pointer-events-none z-0"
         style="background:radial-gradient(ellipse,rgba(139,92,246,0.05) 0%,transparent 65%);filter:blur(80px);transform:translateX(-40%);"></div>

    <!-- ── HERO ── -->
    <section class="relative min-h-screen flex flex-col justify-end overflow-hidden" style="padding:0 3rem 5rem;">
      <!-- Grid pattern -->
      <div class="absolute inset-0 z-0 pointer-events-none"
           style="background-size:40px 40px;background-image:linear-gradient(to right,rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.015) 1px,transparent 1px);mask-image:linear-gradient(to top,rgba(0,0,0,0.8),transparent);"></div>
      <!-- Glows hero -->
      <div class="absolute top-0 right-0 w-[400px] h-[400px] pointer-events-none rounded-full"
           style="background:radial-gradient(circle,rgba(6,182,212,0.18) 0%,transparent 70%);filter:blur(60px);transform:translate(20%,-20%);"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] pointer-events-none rounded-full"
           style="background:radial-gradient(circle,rgba(139,92,246,0.1) 0%,transparent 70%);filter:blur(80px);transform:translate(-30%,30%);"></div>

      <div class="relative z-[2] max-w-4xl">
        <div id="hero-kicker" class="flex items-center gap-3 mb-6" style="opacity:0;transform:translateY(20px);">
          <div class="w-12 h-[1.5px]" style="background:#06b6d4;"></div>
          <span class="text-[10px] font-bold tracking-[0.35em] uppercase" style="color:#06b6d4;">
            Carreras Técnicas de Vanguardia · CBIT
          </span>
        </div>

        <h1 class="font-display font-bold tracking-tighter leading-none text-white mb-6"
            style="font-size:clamp(3.5rem,9vw,8rem);line-height:0.9;">
          <span class="hero-line block overflow-hidden"><span class="block translate-y-full">FORMACIÓN</span></span>
          <span class="hero-line block overflow-hidden">
            <span class="block translate-y-full" style="-webkit-text-stroke:1px rgba(255,255,255,0.18);color:transparent;">TÉCNICA Y</span>
          </span>
          <span class="hero-line block overflow-hidden">
            <span class="block translate-y-full" style="background:linear-gradient(90deg,#06b6d4,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">TECNOLÓGICA</span>
          </span>
        </h1>

        <div class="flex flex-wrap items-start gap-12 mt-8">
          <p id="hero-desc" class="text-gray-400 text-base max-w-md leading-relaxed"
             style="opacity:0;transform:translateY(20px);">
            Capacítate en diseño digital, programación, gestión ambiental, calidad, seguridad laboral y administración de proyectos bajo el respaldo de CBIT con validez laboral inmediata.
          </p>
          <div id="hero-ctas" class="flex gap-4 flex-wrap" style="opacity:0;transform:translateY(20px);">
            <a href="#programas"
               class="inline-flex items-center gap-3 font-display font-bold text-[11px] tracking-[0.15em] uppercase px-8 py-4 text-black transition-all duration-300 hover:-translate-y-1"
               style="background:linear-gradient(135deg,#06b6d4,#8b5cf6);clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));">
              Ver Especialidades
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 font-bold text-[11px] tracking-[0.15em] uppercase px-7 py-4 border text-gray-300 transition-all duration-300 hover:border-[#06b6d4] hover:text-[#06b6d4]"
               style="border-color:rgba(255,255,255,0.15);clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));">
              Inscribirme
            </a>
          </div>
        </div>
      </div>

      <div id="scroll-hint" class="absolute bottom-10 right-12 flex flex-col items-center gap-2 z-[2]" style="opacity:0;">
        <span class="text-[9px] tracking-[0.25em] uppercase text-white/30" style="writing-mode:vertical-rl;">Deslizar</span>
        <div class="w-[1px] h-14" style="background:linear-gradient(to bottom,rgba(255,255,255,0.3),transparent);animation:scrollPulse 2s ease-in-out infinite;"></div>
      </div>
    </section>

    <!-- ── STATS BAR ── -->
    <div class="border-t border-b" style="background:#06030c;border-color:rgba(139,92,246,0.08);">
      <div class="max-w-6xl mx-auto px-10 py-10 flex flex-wrap justify-around gap-8">
        {stats.map(s => (
          <div class="stat-chip flex items-center gap-4">
            <span class="font-display font-bold leading-none"
                  style="font-size:3rem;background:linear-gradient(135deg,#06b6d4,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
              {s.num}<span style="font-size:0.55em;">{s.suffix}</span>
            </span>
            <span class="text-[11px] font-bold tracking-[0.12em] uppercase text-white/40 max-w-[110px] leading-[1.4]">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── PROGRAMAS ── -->
    <section id="programas" class="max-w-7xl mx-auto px-6 md:px-10 py-28 relative z-10">

      <!-- Header -->
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 border-b border-white/10 pb-12 mb-16">
        <div id="prog-header">
          <p class="text-[10px] font-display font-bold tracking-[0.4em] uppercase mb-4" style="color:#06b6d4;">
            Carreras Cortas y Profesionales
          </p>
          <h2 class="font-display font-bold tracking-tighter leading-none text-white"
              style="font-size:clamp(2.8rem,6vw,5.5rem);">
            ESPECIALIDADES Y<br/>
            <span style="-webkit-text-stroke:1.5px #06b6d4;color:transparent;">ÁREAS</span>
            <span style="color:#fff;"> DIGITALES</span>
          </h2>
          <div id="prog-line" class="w-0 h-[2px] mt-6 origin-left"
               style="background:linear-gradient(to right,#06b6d4,#8b5cf6);"></div>
        </div>

        <!-- Leyenda promotores -->
        <div id="promo-legend" class="flex flex-col gap-2 self-start lg:self-end" style="opacity:0;">
          <p class="text-[9px] text-gray-600 uppercase tracking-[0.2em] font-bold mb-1">Promocionado por</p>
          {Object.entries(promoConfig).map(([key, v]) => (
            <div class="flex items-center gap-2 border px-4 py-2"
                 style={`border-color:${v.colorDim};clip-path:polygon(0 0,90% 0,100% 20%,100% 100%,0 100%);`}>
              <div class="w-[13px] h-[13px] rounded-full flex items-center justify-center flex-shrink-0"
                   style={`background:${v.color};`}>
                <svg width="7" height="7" viewBox="0 0 10 10" fill="none" stroke="#000" stroke-width="2.5">
                  <circle cx="5" cy="5" r="3.5"/>
                </svg>
              </div>
              <span class="text-[9px] font-bold tracking-[0.2em] uppercase" style={`color:${v.color};`}>{v.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Grid de programas -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5" id="prog-grid">
        {programs.map((p, i) => {
          const promo = promoConfig[p.promo as keyof typeof promoConfig];
          return (
            <div
              class="prog-card group relative border border-white/[0.08] overflow-hidden transition-all duration-400 hover:-translate-y-1"
              style={`clip-path:polygon(0 0,96% 0,100% 4%,100% 100%,4% 100%,0 96%);background:#0a0a0a;opacity:0;transform:translateY(40px);`}
              data-idx={i}
              data-accent={promo.color}
            >
              <!-- Imagen -->
              <div class="relative overflow-hidden" style="height:200px;">
                <img
                  src={p.img}
                  alt={p.title}
                  class="w-full h-full object-cover block transition-all duration-700 group-hover:scale-105"
                  style="opacity:0.45;"
                  data-card-img
                />
                <div class="absolute inset-0" style="background:linear-gradient(to top,#0a0a0a 0%,transparent 55%);"></div>

                <!-- Badge promotor sobre imagen -->
                <div class="absolute top-3 right-3 flex items-center gap-2 border px-2 py-1"
                     style={`background:rgba(6,6,6,0.9);border-color:${promo.colorDim};clip-path:polygon(0 0,90% 0,100% 20%,100% 100%,0 100%);`}>
                  <div class="w-[13px] h-[13px] rounded-full flex items-center justify-center flex-shrink-0"
                       style={`background:${promo.color};`}>
                    <svg width="7" height="7" viewBox="0 0 10 10" fill="none" stroke="#000" stroke-width="2.5">
                      <circle cx="5" cy="5" r="3.5"/>
                    </svg>
                  </div>
                  <span class="text-[8px] font-bold tracking-[0.2em] uppercase" style={`color:${promo.color};`}>
                    {promo.label}
                  </span>
                </div>
              </div>

              <!-- Brackets hover -->
              <div class="absolute top-0 left-0 w-0 h-[2px] group-hover:w-10 transition-all duration-500"
                   style={`background:${promo.color};`}></div>
              <div class="absolute top-0 left-0 w-[2px] h-0 group-hover:h-10 transition-all duration-500 delay-75"
                   style={`background:${promo.color};`}></div>

              <!-- Número decorativo -->
              <div class="absolute top-4 left-4 font-bold leading-none pointer-events-none select-none"
                   style={`font-size:4rem;color:${promo.color};opacity:0.06;`}>{p.num}</div>

              <!-- Cuerpo -->
              <div class="p-5 pb-3">
                <span class="text-[9px] font-bold tracking-[0.25em] uppercase block mb-2"
                      style={`color:${promo.color};`}>{p.tag}</span>
                <h3 class="text-white font-bold leading-snug tracking-wide" style="font-size:0.9rem;">{p.title}</h3>
              </div>

              <!-- Footer card -->
              <div class="flex items-center justify-between px-5 py-3 mt-1"
                   style="border-top:1px solid rgba(255,255,255,0.06);">
                <span class="text-[9px] uppercase tracking-wider text-gray-600 font-semibold">{p.modalidad}</span>
                <button
                  class="learn-btn text-[9px] font-bold tracking-[0.2em] uppercase border px-3 py-2 transition-all duration-250"
                  style={`color:${promo.color};border-color:${promo.colorDim};clip-path:polygon(0 0,88% 0,100% 20%,100% 100%,12% 100%,0 80%);`}
                  data-target={`panel-${i}`}
                  data-accent={promo.color}
                >
                  ¿Qué aprenderás?
                </button>
              </div>

              <!-- Panel expandible -->
              <div class="learn-panel overflow-hidden" id={`panel-${i}`} style="max-height:0;">
                <div class="px-5 pb-5 pt-3" style={`background:#060d14;border-top:1px solid ${promo.colorDim};`}>
                  <div class="flex items-center gap-2 mb-3">
                    <div class="w-5 h-[1px]" style={`background:${promo.color};`}></div>
                    <span class="text-[9px] font-bold tracking-[0.2em] uppercase"
                          style={`color:${promo.color};`}>CONTENIDO DEL CURSO</span>
                  </div>
                  <ul class="flex flex-col gap-2">
                    {p.learn.map(l => (
                      <li class="flex items-start gap-2 text-gray-400 text-xs leading-relaxed">
                        <span class="mt-[6px] w-[5px] h-[5px] flex-shrink-0 rotate-45"
                              style={`background:${promo.color};display:block;`}></span>
                        {l}
                      </li>
                    ))}
                  </ul>
                  <button
                    class="close-panel mt-4 flex items-center gap-2 text-[9px] font-bold tracking-[0.15em] uppercase"
                    style={`color:${promo.color};background:none;border:none;cursor:pointer;`}
                    data-target={`panel-${i}`}
                  >
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none"
                         stroke="currentColor" stroke-width="2">
                      <line x1="2" y1="2" x2="10" y2="10"/>
                      <line x1="10" y1="2" x2="2" y2="10"/>
                    </svg>
                    CERRAR
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ── VENTAJAS ── -->
    <section class="border-t border-white/[0.06]" style="background:#06030c;">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

          <!-- Izquierda sticky -->
          <div id="adv-left" class="lg:sticky lg:top-28">
            <p class="text-[10px] font-bold tracking-[0.3em] uppercase mb-4" style="color:#06b6d4;">
              Ventaja Curricular
            </p>
            <h2 class="font-display font-bold tracking-tighter leading-none text-white mb-6"
                style="font-size:clamp(2.5rem,5vw,4.5rem);">
              RESPALDO Y<br/>
              <span style="-webkit-text-stroke:1.5px #06b6d4;color:transparent;">VALIDEZ</span>
              <span style="color:#fff;"> LABORAL</span>
            </h2>
            <div class="w-12 h-[2px] mb-8" style="background:linear-gradient(to right,#06b6d4,#8b5cf6);"></div>

            <!-- Imagen con marco clip -->
            <div style="padding:2px;clip-path:polygon(8% 0,100% 0,100% 92%,92% 100%,0 100%,0 8%);background:linear-gradient(135deg,#06b6d4,#8b5cf6);">
              <div class="relative overflow-hidden" style="clip-path:polygon(8% 0,100% 0,100% 92%,92% 100%,0 100%,0 8%);background:#090909;">
                <img src="/images/ima1.jpg" alt="Certificación CBIT"
                     class="w-full object-cover block transition-all duration-700 hover:scale-105 hover:opacity-90"
                     style="height:360px;opacity:0.6;filter:grayscale(60%);"/>
                <div class="absolute inset-0" style="background:linear-gradient(to top,#060606 0%,transparent 50%);"></div>
                <div class="absolute top-3 left-3 w-7 h-[2px]" style="background:#06b6d4;"></div>
                <div class="absolute top-3 left-3 w-[2px] h-7" style="background:#06b6d4;"></div>
                <div class="absolute bottom-3 right-3 w-7 h-[2px]" style="background:#8b5cf6;"></div>
                <div class="absolute bottom-3 right-3 w-[2px] h-7" style="background:#8b5cf6;"></div>
              </div>
            </div>
          </div>

          <!-- Items de ventajas -->
          <div class="flex flex-col gap-4" id="adv-items">
            {[
              { title: "Bolsa de Empleo Activa", num: "01",
                desc: "Integración con empresas aliadas que buscan perfiles técnicos directamente de nuestras aulas, con seguimiento de inserción laboral post-egreso." },
              { title: "Metodología Práctica y Project-Based", num: "02",
                desc: "Aprende resolviendo desafíos reales del sector corporativo, estructurando un portafolio profesional durante toda la carrera." },
              { title: "Certificados con Validez Oficial", num: "03",
                desc: "Nuestras acreditaciones cumplen los estándares de CENACAP e INFOCADE para potenciar tu CV ante auditorías y reclutamientos nacionales." },
              { title: "Tutoría y Consultoría Personalizada", num: "04",
                desc: "Acompañamiento por instructores certificados para resolver dudas en vivo y guiar proyectos individuales durante todo el programa." },
              { title: "Flexibilidad de Horarios", num: "05",
                desc: "Diseñado para profesionales activos: clases presenciales en fines de semana y sesiones virtuales asincrónicas de soporte." },
            ].map((item, i) => (
              <div
                class="adv-item relative border border-white/[0.06] p-8 overflow-hidden transition-all duration-350 hover:border-cyan-500/20 hover:bg-cyan-500/[0.02]"
                style="clip-path:polygon(0 0,calc(100% - 16px) 0,100% 16px,100% 100%,16px 100%,0 calc(100% - 16px));"
              >
                <div class="absolute left-0 top-0 bottom-0 w-[3px] origin-top scale-y-0 transition-transform duration-350 group-hover:scale-y-100 adv-bar"
                     style="background:linear-gradient(to bottom,#06b6d4,#8b5cf6);"></div>
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-display font-bold text-white uppercase tracking-wide" style="font-size:1rem;">
                    {item.title}
                  </h3>
                  <span class="font-bold leading-none" style="font-size:1.8rem;color:rgba(6,182,212,0.12);">
                    {item.num}
                  </span>
                </div>
                <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="relative overflow-hidden border-t border-white/[0.06]">
      <div class="absolute inset-0"
           style="background:url('/images/3.png') center 30% / cover no-repeat;opacity:0.04;filter:blur(4px);"></div>
      <div class="relative z-10 max-w-6xl mx-auto px-10 py-32 flex flex-col items-start" id="cta-section">
        <h2 class="font-display font-bold tracking-tighter leading-none mb-12"
            style="font-size:clamp(3rem,7.5vw,7rem);">
          <span class="block" style="-webkit-text-stroke:1.5px rgba(255,255,255,0.12);color:transparent;">CONSTRUYE TU FUTURO</span>
          <span class="block" style="-webkit-text-stroke:1.5px rgba(255,255,255,0.12);color:transparent;">TECNOLÓGICO AHORA.</span>
          <span class="block" style="background:linear-gradient(90deg,#06b6d4,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">POSTULA HOY MISMO.</span>
        </h2>
        <div class="flex flex-wrap items-center gap-6">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 font-display font-bold text-sm tracking-[0.12em] uppercase px-10 py-5 text-black transition-all duration-300 hover:-translate-y-1"
             style="background:linear-gradient(135deg,#06b6d4,#8b5cf6);clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px));">
            Iniciar Mi Admisión
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <div class="flex gap-3 flex-wrap">
            {["Validez Curricular","Bolsa de Trabajo","Cert. Académico"].map(b => (
              <div class="inline-flex items-center gap-2 px-4 py-3 border text-gray-400 text-[10px] font-bold tracking-[0.1em] uppercase"
                   style="border-color:rgba(255,255,255,0.08);clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));">
                <svg viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="3" width="11" height="11">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {b}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="px-10 py-8 flex flex-wrap items-center justify-between gap-5"
            style="background:#06030c;border-top:1px solid rgba(139,92,246,0.08);">
      <span class="font-display font-bold text-lg tracking-widest text-white">
        CBIT <span style="color:#06b6d4;">TÉCNICOS</span>
      </span>
      <span class="text-gray-600 text-xs tracking-widest">
        © {new Date().getFullYear()} CBIT Corporación · Todos los derechos reservados.
      </span>
    </footer>

  </main>
</Layout>

<style>
  @keyframes scrollPulse {
    0%,100%{ opacity:.3; transform:scaleY(1); }
    50%    { opacity:.8; transform:scaleY(1.1); }
  }
  .adv-item:hover .adv-bar { transform: scaleY(1) !important; }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    /* ── HERO ── */
    const heroTl = gsap.timeline({ delay: 0.15 });
    heroTl
      .to('#hero-kicker',    { y: 0, opacity: 1, duration: 0.9, ease: 'power3.out' }, 0.3)
      .to('.hero-line span', { y: '0%', duration: 1, stagger: 0.15, ease: 'power4.out' }, 0.5)
      .to('#hero-desc',      { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, 0.9)
      .to('#hero-ctas',      { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, 1.05)
      .to('#scroll-hint',    { opacity: 1, duration: 0.6 }, 1.3);

    /* ── STATS ── */
    gsap.utils.toArray<HTMLElement>('.stat-chip').forEach((chip, i) => {
      gsap.from(chip, {
        y: 30, opacity: 0, duration: 0.7, delay: i * 0.1, ease: 'power3.out',
        scrollTrigger: { trigger: chip, start: 'top 88%' }
      });
    });

    /* ── HEADER PROGRAMAS ── */
    const hdrTl = gsap.timeline({
      scrollTrigger: { trigger: '#prog-header', start: 'top 82%' }
    });
    hdrTl
      .from('#prog-header > *', { y: 40, opacity: 0, duration: 0.8, stagger: 0.2, ease: 'power3.out' })
      .to('#prog-line',          { width: '3rem', duration: 0.8, ease: 'power3.out' }, '-=0.4')
      .to('#promo-legend',       { opacity: 1, x: 0, duration: 0.7, ease: 'back.out(1.5)' }, '-=0.3');

    /* ── CARDS ── */
    gsap.utils.toArray<HTMLElement>('.prog-card').forEach((card, i) => {
      const img    = card.querySelector<HTMLImageElement>('[data-card-img]');
      const accent = card.dataset.accent || '#06b6d4';

      gsap.to(card, {
        y: 0, opacity: 1, duration: 0.9, ease: 'power3.out',
        delay: (i % 3) * 0.12,
        scrollTrigger: { trigger: card, start: 'top 88%', once: true }
      });

      card.addEventListener('mouseenter', () => {
        if (img) gsap.to(img, { opacity: 0.78, duration: 0.6, ease: 'power2.out' });
        gsap.to(card, { borderColor: accent.replace(')', ',0.4)').replace('rgb','rgba'), duration: 0.3 });
      });
      card.addEventListener('mouseleave', () => {
        if (img) gsap.to(img, { opacity: 0.45, duration: 0.6, ease: 'power2.out' });
        gsap.to(card, { borderColor: 'rgba(255,255,255,0.08)', duration: 0.3 });
      });
    });

    /* ── PANEL EXPANDIBLE ── */
    document.querySelectorAll<HTMLButtonElement>('.learn-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.target!;
        const panel    = document.getElementById(targetId)!;
        const isOpen   = parseFloat(panel.style.maxHeight || '0') > 0;

        document.querySelectorAll<HTMLElement>('.learn-panel').forEach(p => {
          gsap.to(p, { maxHeight: 0, duration: 0.4, ease: 'power3.in',
            onComplete: () => { p.style.maxHeight = '0'; } });
        });

        if (!isOpen) {
          gsap.fromTo(panel,
            { maxHeight: 0 },
            { maxHeight: 400, duration: 0.5, ease: 'power3.out' }
          );
          gsap.from(panel.querySelectorAll('li'), {
            x: -10, opacity: 0, duration: 0.4, stagger: 0.07, delay: 0.15, ease: 'power2.out'
          });
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.close-panel').forEach(btn => {
      btn.addEventListener('click', () => {
        const panel = document.getElementById(btn.dataset.target!)!;
        gsap.to(panel, { maxHeight: 0, duration: 0.4, ease: 'power3.in',
          onComplete: () => { panel.style.maxHeight = '0'; } });
      });
    });

    /* ── VENTAJAS ── */
    gsap.from('#adv-left > *', {
      y: 40, opacity: 0, duration: 0.8, stagger: 0.18, ease: 'power3.out',
      scrollTrigger: { trigger: '#adv-left', start: 'top 80%' }
    });

    gsap.utils.toArray<HTMLElement>('.adv-item').forEach((item, i) => {
      const bar = item.querySelector<HTMLElement>('.adv-bar');
      gsap.from(item, {
        x: 50, opacity: 0, duration: 0.75, delay: i * 0.1, ease: 'power3.out',
        scrollTrigger: { trigger: '#adv-items', start: 'top 78%' }
      });
      item.addEventListener('mouseenter', () => {
        if (bar) gsap.to(bar, { scaleY: 1, duration: 0.35, ease: 'power2.out' });
        gsap.to(item, { borderColor: 'rgba(6,182,212,0.22)', duration: 0.3 });
      });
      item.addEventListener('mouseleave', () => {
        if (bar) gsap.to(bar, { scaleY: 0, duration: 0.3, ease: 'power2.in' });
        gsap.to(item, { borderColor: 'rgba(255,255,255,0.06)', duration: 0.3 });
      });
    });

    /* ── CTA ── */
    gsap.from('#cta-section > *', {
      y: 50, opacity: 0, duration: 0.9, stagger: 0.2, ease: 'power3.out',
      scrollTrigger: { trigger: '#cta-section', start: 'top 78%' }
    });
  }
</script>