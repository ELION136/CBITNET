---

<Layout title="INFOCADE | Instituto de Formación Deportiva y Empresarial" showBackgroundFX={false}>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── PALETA INFOCADE ── */
    --red:        #cc1f1f;
    --red-mid:    #e02424;
    --red-lt:     #fdeaea;
    --red-dim:    rgba(204,31,31,0.12);

    /* Acentos por sección: Azul (secciones impares) · Amarillo (secciones pares) */
    --blue:       #1a4b8c;
    --blue-mid:   #2d6fcc;
    --blue-lt:    #e8f0fb;

    --yellow:     #c48a00;
    --yellow-mid: #e6a800;
    --yellow-lt:  #fdf6e0;

    /* Neutros */
    --white:      #ffffff;
    --off:        #f5f4f1;     /* fondo secciones alternas */
    --cream:      #eeece8;
    --dark:       #111111;
    --mid:        #4a4a4a;
    --soft:       #7a7a7a;
    --faint:      #ababab;
    --border:     #e0ddd8;

    --r:    10px;
    --r-lg: 18px;
    --r-xl: 28px;
  }

  html { scroll-behavior: smooth; }
  body {
    background: var(--white);
    color: var(--dark);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* ══════════════ NAVBAR ══════════════ */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 500;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.3s;
  }
  #navbar.scrolled { box-shadow: 0 2px 20px rgba(204,31,31,0.09); }

  .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-logo img { height: 32px; }
  .nav-wordmark { font-family: 'Anton', sans-serif; font-size: 1.15rem; letter-spacing: 0.08em; color: var(--dark); }
  .nav-wordmark em { color: var(--red); font-style: normal; }

  .nav-links { display: flex; align-items: center; gap: 6px; }
  .nav-link {
    padding: 7px 16px; color: var(--mid);
    font-size: 0.83rem; font-weight: 500;
    text-decoration: none; border-radius: 100px; transition: all 0.2s;
  }
  .nav-link:hover { color: var(--dark); background: var(--cream); }

  .nav-cta {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 22px;
    background: var(--red); color: #fff;
    font-size: 0.83rem; font-weight: 700;
    text-decoration: none; border-radius: 100px;
    letter-spacing: 0.02em; transition: all 0.25s;
  }
  .nav-cta:hover { background: var(--red-mid); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(204,31,31,0.35); }

  /* ══════════════ HERO CARRUSEL ══════════════ */
  #hero {
    margin-top: 64px;
    position: relative; overflow: hidden;
    border-radius: 0 0 var(--r-xl) var(--r-xl);
    height: calc(100vh - 64px); min-height: 560px; max-height: 820px;
  }

  .hero-slide {
    position: absolute; inset: 0;
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4,0,0.2,1);
    pointer-events: none;
  }
  .hero-slide.active { opacity: 1; pointer-events: auto; }

  .hero-slide-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; display: block;
    transform: scale(1.04);
    transition: transform 7s ease-out;
  }
  .hero-slide.active .hero-slide-img { transform: scale(1); }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.88) 0%, rgba(10,10,10,0.35) 55%, transparent 100%);
  }

  .hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0 56px 56px; z-index: 2;
  }

  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 16px;
    background: rgba(255,255,255,0.10);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.20);
    border-radius: 100px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; margin-bottom: 20px;
  }
  .hero-tag-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--red-mid); }

  .hero-h1 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.92; letter-spacing: 0.01em; text-transform: uppercase;
    color: #fff; max-width: 700px; margin-bottom: 28px;
  }
  .hero-h1 .c-red { color: #ff7070; }

  .hero-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }

  .btn-white {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px; background: var(--white); color: var(--dark);
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    border-radius: 100px; transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  }
  .btn-white:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(0,0,0,0.22); background: var(--cream); }

  .btn-outline-white {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 28px;
    border: 1.5px solid rgba(255,255,255,0.42); color: rgba(255,255,255,0.82);
    font-weight: 600; font-size: 0.88rem; text-decoration: none;
    border-radius: 100px; transition: all 0.3s;
  }
  .btn-outline-white:hover { border-color: #fff; color: #fff; background: rgba(255,255,255,0.10); }

  .hero-chips { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
  .hero-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px;
    background: rgba(255,255,255,0.09); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px; font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255,255,255,0.78);
  }

  /* controles carrusel */
  .hero-controls {
    position: absolute; bottom: 56px; right: 56px;
    z-index: 10; display: flex; gap: 10px; align-items: center;
  }
  .hc-btn {
    width: 42px; height: 42px; border-radius: 50%;
    background: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.22);
    backdrop-filter: blur(8px); color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.25s;
  }
  .hc-btn:hover { background: var(--red); border-color: var(--red); }

  .hero-dots {
    position: absolute; bottom: 72px; left: 56px;
    z-index: 10; display: flex; gap: 8px;
  }
  .hero-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.28); border: none; cursor: pointer;
    transition: all 0.3s; padding: 0;
  }
  .hero-dot.active { background: var(--red-mid); transform: scale(1.4); }

  .hero-progress {
    position: absolute; bottom: 0; left: 0; right: 0; height: 3px; z-index: 10;
    background: rgba(255,255,255,0.09);
  }
  .hero-progress-bar {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--red), #ff7070);
    transition: none;
  }
  .hero-progress-bar.running {
    width: 100%;
    transition: width 5.5s linear;
  }

  /* ══════════════ MARQUEE ══════════════ */
  #marquee-strip {
    background: var(--red);
    padding: 13px 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex; gap: 0; flex-shrink: 0;
    animation: marqueeRun 22s linear infinite;
    white-space: nowrap;
  }
  @keyframes marqueeRun { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
  .marquee-item {
    display: inline-flex; align-items: center; gap: 20px;
    padding: 0 40px;
    font-family: 'Anton', sans-serif;
    font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #fff;
  }
  .marquee-dot { width: 5px; height: 5px; background: rgba(255,255,255,0.4); border-radius: 50%; }

  /* ══════════════ ABOUT — Azul ══════════════ */
  #about { background: var(--white); }
  .about-wrap { max-width: 1280px; margin: 0 auto; padding: 90px 56px; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }

  .about-eyebrow {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--blue-mid); margin-bottom: 16px;
  }
  .about-eyebrow::before { content: ''; width: 28px; height: 2px; background: var(--blue-mid); border-radius: 2px; display: block; }

  .about-h2 { font-family: 'Anton', sans-serif; font-size: clamp(2rem, 4vw, 3.8rem); line-height: 1; letter-spacing: 0.01em; text-transform: uppercase; color: var(--dark); margin-bottom: 20px; }
  .about-h2 .hl { color: var(--blue-mid); }
  .about-desc { font-size: 0.95rem; color: var(--mid); line-height: 1.78; margin-bottom: 32px; }

  .about-features { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ab-feat {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 16px 18px;
    background: var(--blue-lt); border-radius: var(--r);
    border: 1px solid #ccdaf4;
    transition: all 0.3s;
  }
  .ab-feat:hover { background: #dae8fb; border-color: var(--blue-mid); transform: translateY(-2px); }
  .ab-feat-icon { color: var(--blue-mid); flex-shrink: 0; margin-top: 2px; }
  .ab-feat-title { font-weight: 700; font-size: 0.82rem; color: var(--dark); margin-bottom: 3px; }
  .ab-feat-desc { font-size: 0.76rem; color: var(--soft); line-height: 1.5; }

  .about-right { position: relative; }
  .about-mosaic { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 280px 180px; gap: 12px; }
  .ab-img { border-radius: var(--r-lg); overflow: hidden; }
  .ab-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .ab-img:hover img { transform: scale(1.05); }
  .ab-img.span2 { grid-column: span 2; }

  .about-badge {
    position: absolute; bottom: -20px; left: -20px;
    background: var(--blue); color: #fff;
    padding: 18px 24px; border-radius: var(--r-lg);
    text-align: center;
    box-shadow: 0 12px 32px rgba(26,75,140,0.28);
  }
  .about-badge-num { font-family: 'Anton', sans-serif; font-size: 2.4rem; color: #7ab4ff; line-height: 1; }
  .about-badge-lbl { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-top: 3px; }

  /* ══════════════ SHARED SECTION ══════════════ */
  .sw { max-width: 1280px; margin: 0 auto; padding: 90px 56px; }
  .sec-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 52px; gap: 24px; flex-wrap: wrap; }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 12px;
  }
  .eyebrow::before { content: ''; width: 28px; height: 2px; border-radius: 2px; display: block; }
  .eyebrow.red    { color: var(--red);       } .eyebrow.red::before    { background: var(--red);       }
  .eyebrow.blue   { color: var(--blue-mid);  } .eyebrow.blue::before   { background: var(--blue-mid);  }
  .eyebrow.yellow { color: var(--yellow);    } .eyebrow.yellow::before { background: var(--yellow);    }

  .sec-title { font-family: 'Anton', sans-serif; font-size: clamp(2.2rem, 4.5vw, 4rem); line-height: 0.95; letter-spacing: 0.01em; text-transform: uppercase; color: var(--dark); }
  .hl-red    { color: var(--red);      }
  .hl-blue   { color: var(--blue-mid); }
  .hl-yellow { color: var(--yellow);   }

  .link-all {
    display: inline-flex; align-items: center; gap: 7px; padding: 10px 22px;
    border: 1.5px solid var(--border); border-radius: 100px;
    font-size: 0.8rem; font-weight: 600; color: var(--soft); text-decoration: none; transition: all 0.25s; white-space: nowrap;
  }
  .link-all:hover { border-color: var(--red); color: var(--red); }

  /* ══════════════ SERVICIOS — Amarillo ══════════════ */
  #servicios { background: var(--off); }
  .servicios-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
  .serv-card {
    background: var(--white); border-radius: var(--r-lg);
    border: 1px solid var(--border); overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34,1.4,0.64,1), box-shadow 0.4s, border-color 0.3s;
  }
  .serv-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(198,139,0,0.13); border-color: var(--yellow-mid); }
  .serv-img { height: 200px; overflow: hidden; }
  .serv-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s; }
  .serv-card:hover .serv-img img { transform: scale(1.07); }
  .serv-body { padding: 20px 20px 22px; }
  .serv-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--yellow-mid); margin-bottom: 10px; }
  .serv-title { font-family: 'Anton', sans-serif; font-size: 1rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--dark); margin-bottom: 7px; }
  .serv-desc { font-size: 0.78rem; color: var(--soft); line-height: 1.6; }

  /* ══════════════ PROGRAMAS — Rojo ══════════════ */
  #programas { background: var(--white); }

  .prog-tabs { display: flex; gap: 8px; margin-bottom: 40px; flex-wrap: wrap; }
  .prog-tab {
    padding: 8px 20px; background: transparent;
    border: 1.5px solid var(--border); border-radius: 100px;
    font-size: 0.78rem; font-weight: 600; color: var(--soft);
    cursor: pointer; transition: all 0.22s;
  }
  .prog-tab:hover { border-color: var(--red); color: var(--red); }
  .prog-tab.active { background: var(--red); border-color: var(--red); color: #fff; }

  .prog-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 18px; }

  .prog-card {
    border-radius: var(--r-lg); overflow: hidden;
    border: 1px solid var(--border);
    background: var(--white);
    box-shadow: 0 2px 8px rgba(204,31,31,0.05);
    transition: transform 0.38s cubic-bezier(0.34,1.4,0.64,1), box-shadow 0.38s, border-color 0.3s;
    display: none;
  }
  .prog-card.visible { display: block; }
  .prog-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(204,31,31,0.12); border-color: var(--red); }

  .prog-card-img { height: 160px; overflow: hidden; position: relative; }
  .prog-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s; }
  .prog-card:hover .prog-card-img img { transform: scale(1.06); }
  .prog-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,10,0.6) 0%, transparent 55%); }
  .prog-cat-badge {
    position: absolute; bottom: 10px; left: 12px;
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: #fff; background: var(--red); padding: 3px 10px; border-radius: 50px;
  }
  .prog-card-body { padding: 14px 16px 18px; }
  .prog-card-code { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--faint); margin-bottom: 6px; }
  .prog-card-title { font-weight: 700; font-size: 0.88rem; color: var(--dark); line-height: 1.3; margin-bottom: 6px; }
  .prog-card-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .prog-cta {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--red); text-decoration: none; transition: gap 0.2s;
  }
  .prog-cta:hover { gap: 8px; }

  /* ══════════════ WHY — Azul ══════════════ */
  #why { background: var(--off); }
  .why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }

  .why-img-col { position: relative; }
  .why-img-main { width: 100%; height: 480px; object-fit: cover; border-radius: var(--r-xl); display: block; }

  .why-float {
    position: absolute; top: 32px; right: -28px;
    background: var(--white); border-radius: var(--r-lg);
    padding: 18px 22px;
    box-shadow: 0 12px 40px rgba(26,75,140,0.12);
    text-align: center; min-width: 130px;
  }
  .why-float-num { font-family: 'Anton', sans-serif; font-size: 2.2rem; color: var(--blue-mid); line-height: 1; }
  .why-float-lbl { font-size: 0.64rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--soft); margin-top: 3px; }

  .why-float-2 {
    position: absolute; bottom: 32px; left: -28px;
    background: var(--blue);
    border-radius: var(--r-lg);
    padding: 18px 22px;
    box-shadow: 0 12px 40px rgba(26,75,140,0.22);
    text-align: center; min-width: 130px;
  }
  .why-float-2 .why-float-num { color: #7ab4ff; }
  .why-float-2 .why-float-lbl { color: rgba(255,255,255,0.45); }

  .why-items { display: flex; flex-direction: column; gap: 16px; }
  .why-item {
    display: flex; gap: 16px; align-items: flex-start;
    padding: 20px 22px; background: var(--white);
    border-radius: var(--r); border: 1px solid var(--border);
    transition: transform 0.35s cubic-bezier(0.34,1.4,0.64,1), border-color 0.3s, box-shadow 0.3s;
  }
  .why-item:hover { transform: translateX(8px); border-color: var(--blue-mid); box-shadow: 0 4px 20px rgba(26,75,140,0.09); }
  .why-num { font-family: 'Anton', sans-serif; font-size: 1.4rem; color: #c5d8f4; line-height: 1; flex-shrink: 0; width: 32px; transition: color 0.3s; }
  .why-item:hover .why-num { color: var(--blue-mid); }
  .why-t { font-weight: 700; font-size: 0.9rem; color: var(--dark); margin-bottom: 4px; }
  .why-d { font-size: 0.8rem; color: var(--soft); line-height: 1.6; }

  /* ══════════════ STATS — oscuro con Amarillo ══════════════ */
  #stats { background: #111111; }
  .stats-inner { max-width: 1280px; margin: 0 auto; padding: 72px 56px; }
  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; }
  .stat-block {
    text-align: center; padding: 48px 32px;
    border-right: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s;
  }
  .stat-block:last-child { border-right: none; }
  .stat-block:hover { background: rgba(255,255,255,0.03); }
  .stat-num { font-family: 'Anton', sans-serif; font-size: clamp(2.8rem,5vw,4rem); color: var(--yellow-mid); line-height: 1; margin-bottom: 10px; }
  .stat-lbl { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.36); }

  /* ══════════════ TESTIMONIOS — blanco ══════════════ */
  #testimonios { background: var(--white); }
  .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
  .testi-card {
    background: var(--off);
    border: 1px solid var(--border); border-radius: var(--r-lg);
    padding: 34px 30px; position: relative; overflow: hidden;
    transition: transform 0.38s cubic-bezier(0.34,1.4,0.64,1), box-shadow 0.38s;
  }
  .testi-card::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--red), var(--yellow-mid));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s ease;
  }
  .testi-card:hover { transform: translateY(-8px); box-shadow: 0 24px 56px rgba(204,31,31,0.08); }
  .testi-card:hover::after { transform: scaleX(1); }
  .testi-stars { color: var(--yellow-mid); font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 16px; }
  .testi-cita { font-size: 0.93rem; color: var(--mid); line-height: 1.76; font-style: italic; margin-bottom: 22px; }
  .testi-footer { display: flex; align-items: center; gap: 12px; }
  .testi-av {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--red);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Anton', sans-serif; font-size: 0.8rem; color: #fff; flex-shrink: 0;
  }
  .testi-card:nth-child(2) .testi-av { background: var(--blue); }
  .testi-card:nth-child(3) .testi-av { background: #8b6914; }
  .testi-autor { font-weight: 700; font-size: 0.87rem; color: var(--dark); }
  .testi-rol { font-size: 0.71rem; color: var(--red); font-weight: 600; margin-top: 2px; }

  /* ══════════════ VACANTES — Amarillo ══════════════ */
  #vacantes { background: var(--off); }
  .vacantes-list { display: flex; flex-direction: column; gap: 14px; }
  .vacante-row {
    display: flex; align-items: center; justify-content: space-between; gap: 20px;
    padding: 24px 28px; background: var(--white);
    border: 1px solid var(--border); border-radius: var(--r-lg); transition: all 0.3s;
  }
  .vacante-row:hover { border-color: var(--yellow-mid); box-shadow: 0 6px 24px rgba(198,139,0,0.10); transform: translateX(6px); }
  .vac-num { font-family: 'Anton', sans-serif; font-size: 1.5rem; color: #e0ceaa; flex-shrink: 0; width: 32px; transition: color 0.3s; }
  .vacante-row:hover .vac-num { color: var(--yellow-mid); }
  .vac-info { flex: 1; }
  .vac-cargo { font-weight: 700; font-size: 1rem; color: var(--dark); margin-bottom: 4px; }
  .vac-area { font-size: 0.78rem; color: var(--soft); }
  .btn-apply {
    display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px;
    background: var(--red); color: #fff;
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em;
    text-decoration: none; border-radius: 100px; transition: all 0.25s;
  }
  .btn-apply:hover { background: var(--red-mid); transform: translateY(-2px); box-shadow: 0 6px 18px rgba(204,31,31,0.35); }

  /* ══════════════ CTA BANNER ══════════════ */
  #cta { position: relative; overflow: hidden; background: #111; }
  .cta-bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.07; }
  .cta-inner {
    position: relative; z-index: 1;
    max-width: 1280px; margin: 0 auto;
    padding: 100px 56px;
    display: flex; align-items: center; justify-content: space-between; gap: 48px; flex-wrap: wrap;
  }
  .cta-tag {
    display: inline-flex; align-items: center; gap: 7px; padding: 6px 14px;
    background: rgba(255,112,112,0.12); border: 1px solid rgba(255,112,112,0.25);
    border-radius: 100px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: #ff7070; margin-bottom: 20px;
  }
  .cta-h2 { font-family: 'Anton', sans-serif; font-size: clamp(2.4rem,5vw,5rem); line-height: 0.93; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; margin-bottom: 16px; }
  .cta-h2 .c-red { color: #ff7070; }
  .cta-sub { font-size: 0.95rem; color: rgba(255,255,255,0.48); line-height: 1.7; max-width: 440px; }
  .cta-right { display: flex; flex-direction: column; gap: 14px; align-items: flex-start; }

  .btn-cta-prim {
    display: inline-flex; align-items: center; gap: 9px; padding: 16px 40px;
    background: var(--red); color: #fff; font-weight: 800; font-size: 0.95rem;
    letter-spacing: 0.02em; text-decoration: none; border-radius: 100px;
    transition: all 0.3s; box-shadow: 0 6px 24px rgba(204,31,31,0.4);
  }
  .btn-cta-prim:hover { background: var(--red-mid); transform: translateY(-3px); box-shadow: 0 12px 36px rgba(204,31,31,0.5); }

  .btn-cta-sec {
    display: inline-flex; align-items: center; gap: 9px; padding: 15px 32px;
    border: 1.5px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.65);
    font-weight: 600; font-size: 0.9rem; text-decoration: none;
    border-radius: 100px; transition: all 0.3s;
  }
  .btn-cta-sec:hover { border-color: rgba(255,255,255,0.48); color: #fff; }

  .cta-chips { display: flex; gap: 10px; flex-wrap: wrap; }
  .cta-chip {
    display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px;
    border: 1px solid rgba(255,255,255,0.09); border-radius: 100px;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: rgba(255,255,255,0.42);
  }
  .chip-d { width: 5px; height: 5px; border-radius: 50%; background: #ff7070; }

  /* ══════════════ FOOTER ══════════════ */
  footer { background: #0a0a0a; padding: 48px 56px 32px; }
  .footer-top {
    display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 48px;
    padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 28px;
  }
  .footer-brand { font-family: 'Anton', sans-serif; font-size: 1.2rem; letter-spacing: 0.1em; color: #fff; margin-bottom: 12px; }
  .footer-brand em { color: var(--red-mid); font-style: normal; }
  .footer-desc { font-size: 0.8rem; color: rgba(255,255,255,0.28); line-height: 1.7; }
  .footer-col-title { font-weight: 700; font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 16px; }
  .footer-links { display: flex; flex-direction: column; gap: 9px; }
  .footer-link { font-size: 0.82rem; color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.2s; }
  .footer-link:hover { color: #ff7070; }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.18); letter-spacing: 0.04em; }
  .footer-accent { display: inline-flex; align-items: center; gap: 6px; font-size: 0.7rem; color: var(--red-mid); font-weight: 600; }

  /* ══════════════ ANIMACIONES ══════════════ */
  .anim-up    { opacity: 0; transform: translateY(44px); transition: opacity 0.72s cubic-bezier(0.16,1,0.3,1), transform 0.72s cubic-bezier(0.16,1,0.3,1); }
  .anim-left  { opacity: 0; transform: translateX(-52px); transition: opacity 0.72s cubic-bezier(0.16,1,0.3,1), transform 0.72s cubic-bezier(0.16,1,0.3,1); }
  .anim-right { opacity: 0; transform: translateX(52px); transition: opacity 0.72s cubic-bezier(0.16,1,0.3,1), transform 0.72s cubic-bezier(0.16,1,0.3,1); }
  .anim-scale { opacity: 0; transform: scale(0.92); transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1); }
  .anim-up.in, .anim-left.in, .anim-right.in, .anim-scale.in { opacity: 1; transform: none; }
  .d1{transition-delay:0.07s} .d2{transition-delay:0.14s}
  .d3{transition-delay:0.21s} .d4{transition-delay:0.28s}

  /* ══════════════ RESPONSIVE ══════════════ */
  @media(max-width:1024px){
    .servicios-grid{grid-template-columns:repeat(2,1fr)}
    .prog-grid{grid-template-columns:repeat(2,1fr)}
    .stats-grid{grid-template-columns:repeat(2,1fr)}
    .footer-top{grid-template-columns:1fr 1fr}
  }
  @media(max-width:768px){
    #navbar{padding:0 20px}
    .nav-links{display:none}
    .hero-content{padding:0 24px 40px}
