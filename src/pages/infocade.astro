    .about-grid,.why-grid{grid-template-columns:1fr;gap:40px}
    .about-mosaic{grid-template-rows:200px 140px}
    .about-badge{left:0;bottom:-14px}
    .testi-grid{grid-template-columns:1fr}
    .servicios-grid{grid-template-columns:1fr}
    .prog-grid{grid-template-columns:repeat(2,1fr)}
    .cta-inner{flex-direction:column;padding:72px 24px}
    footer{padding:40px 24px 24px}
    .footer-top{grid-template-columns:1fr;gap:28px}
    .why-float{right:-10px;top:16px}
    .why-float-2{left:-10px}
  }
  @media(max-width:480px){
    .prog-grid{grid-template-columns:1fr}
  }

