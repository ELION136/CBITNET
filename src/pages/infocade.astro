<script>
import gsap from 'gsap';
import ScrollTrigger from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// ── NAVBAR ──
const navbar = document.getElementById('navbar')!;
ScrollTrigger.create({
  start: 'top -60',
  onUpdate: s => {
    navbar.style.background = s.progress > 0 ? 'rgba(0,0,0,0.95)' : 'rgba(0,0,0,0.6)';
  }
});

// ── HERO PARALLAX ──
gsap.to('#hero-bg', {
  yPercent: 22,
  ease: 'none',
  scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
});

// ── HERO ENTRANCE ──
// Prepare lines
const h1Lines = document.querySelectorAll('#hero-h1 .h1-inner');
gsap.set('#hero-h1 .h1-line', { overflow: 'hidden', display: 'block' });
gsap.set(h1Lines, { yPercent: 110, skewY: 4 });
gsap.set(['#hero-tagline', '#hero-btns', '#hero-stats'], { opacity: 0, y: 24 });

const tl = gsap.timeline({ delay: 0.15 });
tl
  .to('#hero-eyebrow', { opacity: 1, duration: 0.5, ease: 'power2.out' })
  .to(h1Lines, {
    yPercent: 0, skewY: 0,
    duration: 0.9, ease: 'power4.out', stagger: 0.1
  }, '-=0.2')
  .to('#hero-tagline', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.4')
  .to('#hero-btns', { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.45')
  .to('#hero-stats', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', stagger: 0.08 }, '-=0.4')
  .to('#scroll-hint', { opacity: 1, duration: 0.5 }, '-=0.3');

// ── MARQUEE pause on hover ──
const marqueeTrack = document.querySelector('.marquee-track') as HTMLElement;
if (marqueeTrack) {
  marqueeTrack.addEventListener('mouseenter', () => marqueeTrack.style.animationPlayState = 'paused');
  marqueeTrack.addEventListener('mouseleave', () => marqueeTrack.style.animationPlayState = 'running');
}

// ── CURSOS HEADER ──
ScrollTrigger.create({
  trigger: '#cursos-header',
  start: 'top 80%', once: true,
  onEnter: () => {
    gsap.from('#cursos-header .section-eyebrow', { opacity: 0, x: -30, duration: 0.5, ease: 'power3.out' });
    gsap.from('#cursos-header .section-title', { opacity: 0, y: 40, duration: 0.8, ease: 'power4.out', delay: 0.15 });
  }
});

// ── CURSOS GRID stagger ──
ScrollTrigger.create({
  trigger: '#cursos-grid',
  start: 'top 80%', once: true,
  onEnter: () => {
    gsap.from('#cursos-grid .curso-card', {
      opacity: 0, y: 50,
      duration: 0.65, stagger: 0.07, ease: 'power3.out'
    });
  }
});

// ── ABOUT ──
ScrollTrigger.create({
  trigger: '#about-img-wrap',
  start: 'top 75%', once: true,
  onEnter: () => {
    gsap.from('#about-img-wrap', { opacity: 0, x: -50, duration: 0.9, ease: 'power3.out' });
  }
});
ScrollTrigger.create({
  trigger: '#about-right',
  start: 'top 78%', once: true,
  onEnter: () => {
    gsap.from('#about-right > *', {
      opacity: 0, x: 40,
      duration: 0.7, stagger: 0.12, ease: 'power3.out'
    });
    gsap.from('#about-right .about-item', {
      opacity: 0, x: 30,
      duration: 0.5, stagger: 0.07, ease: 'power3.out', delay: 0.4
    });
  }
});

// ── CTA ──
ScrollTrigger.create({
  trigger: '#cta-h2',
  start: 'top 80%', once: true,
  onEnter: () => {
    gsap.from('#cta-h2 span', {
      opacity: 0, y: 70, skewY: 4,
      duration: 0.85, stagger: 0.14, ease: 'power4.out'
    });
    gsap.from('#cta-right > *', {
      opacity: 0, y: 30,
      duration: 0.6, stagger: 0.1, ease: 'power3.out', delay: 0.4
    });
  }
});
</script>
