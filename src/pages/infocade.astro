---
import Layout from '../layouts/Layout.astro';
import '../styles/infocade.css';

const carreras = [
  { nombre: "Arbitraje de Fútbol Amateur",         desc: "Formación de árbitros con las reglas FIFA, control de partidos y gestión de incidencias.", code: "ARB-01", imagen: "/images/1.png" },
  { nombre: "Arbitraje de Voleyball en Cancha",    desc: "Árbitros certificados para competencias de voleibol indoor y playa.",                     code: "ARB-02", imagen: "/images/1.png" },
  { nombre: "Comunicación y Periodismo Deportivo", desc: "Relatos deportivos, cobertura mediática y producción de contenido.",                       code: "COM-01", imagen: "/images/1.png" },
  { nombre: "Entrenador de Fútbol",                desc: "Licencia de entrenador, metodologías de entrenamiento y gestión de equipos.",              code: "ENT-01", imagen: "/images/1.png" },
  { nombre: "Entrenador de Beach Voley",           desc: "Especialización en vóley playa, tácticas y preparación física específica.",                code: "ENT-02", imagen: "/images/1.png" },
  { nombre: "Marketing Deportivo",                 desc: "Estrategias de marketing aplicadas al deporte, patrocinios y gestión de marcas.",          code: "MKT-01", imagen: "/images/1.png" },
  { nombre: "Auditoría de Organizaciones Deportivas", desc: "Control y auditoría de entidades deportivas, cumplimiento normativo.",                  code: "AUD-01", imagen: "/images/1.png" },
  { nombre: "Dirigencia Deportiva",                desc: "Gestión de clubes, federaciones y organizaciones deportivas.",                             code: "DIR-01", imagen: "/images/1.png" },
  { nombre: "Gestión de Eventos Deportivos",       desc: "Organización de eventos, logística, protocolo y ceremonias.",                              code: "EVT-01", imagen: "/images/1.png" },
  { nombre: "Escuela de Negocios Industriales",    desc: "Gestión empresarial aplicada al sector industrial y deportivo.",                           code: "NEG-01", imagen: "/images/1.png" },
  { nombre: "Informática Industrial",              desc: "Tecnología de la información aplicada a la gestión deportiva y empresarial.",              code: "INF-01", imagen: "/images/1.png" },
];

/* Categorías para filtros */
const catMap: Record<string, string> = {
  "ARB-01": "Arbitraje", "ARB-02": "Arbitraje",
  "COM-01": "Comunicación",
  "ENT-01": "Entrenamiento", "ENT-02": "Entrenamiento",
  "MKT-01": "Marketing",
  "AUD-01": "Gestión", "DIR-01": "Gestión", "EVT-01": "Gestión", "NEG-01": "Gestión",
  "INF-01": "Tecnología",
};

const ticker_items = ["ARBITRAJE", "ENTRENAMIENTO", "MARKETING DEPORTIVO", "PERIODISMO", "DIRIGENCIA", "GESTIÓN DE EVENTOS", "INFORMÁTICA INDUSTRIAL", "BEACH VOLEY"];

const servicios = [
  { titulo: "Arbitraje Deportivo",      desc: "Certificación FIFA y FIVB para árbitros de fútbol y vóley a nivel competitivo.",  imagen: "/images/IMG_9547.webp" },
  { titulo: "Entrenamiento de Élite",   desc: "Metodologías modernas de entrenamiento físico, táctico y mental.",                 imagen: "/images/IMG_9548.webp" },
  { titulo: "Gestión y Dirigencia",     desc: "Administración de clubes, auditorías deportivas y gestión de eventos.",            imagen: "/images/1.png" },
  { titulo: "Comunicación Deportiva",   desc: "Periodismo, producción audiovisual y marketing aplicado al deporte.",              imagen: "/images/1.png" },
];

const stats = [
  { num: "800+", label: "Profesionales Egresados" },
  { num: "11",   label: "Programas Activos"        },
  { num: "100%", label: "Certificación Válida"      },
  { num: "8+",   label: "Años de Experiencia"       },
];

const whyItems = [
  { t: "Certificación Reconocida",    d: "Validez nacional respaldada por instituciones del sector deportivo y empresarial." },
  { t: "Instructores en Ejercicio",   d: "Profesionales activos que aportan experiencia real desde el campo de juego."       },
  { t: "Metodología Aplicada",        d: "Casos reales, prácticas de campo y simulaciones desde el primer módulo."           },
  { t: "Modalidad Flexible",          d: "Presencial o virtual. Estudia sin renunciar a tu actividad deportiva o laboral."   },
];

const testimonios = [
  { cita: "Gracias a INFOCADE conseguí mi licencia de entrenador y ahora dirijo un equipo juvenil. La formación práctica fue clave.", autor: "Jorge Ramírez", rol: "Egresado · Entrenador de Fútbol",     ini: "JR" },
  { cita: "El curso de Periodismo Deportivo me abrió puertas en medios locales. Aprendí a relatar partidos con profesionalismo.",       autor: "Lucía Mendoza", rol: "Egresada · Comunicación Deportiva", ini: "LM" },
  { cita: "La certificación en arbitraje me permitió empezar a dirigir partidos oficiales rápidamente. Recomiendo INFOCADE al 100%.", autor: "Andrés Gómez", rol: "Egresado · Arbitraje de Fútbol",      ini: "AG" },
];

const vacantes = [
  { cargo: "Árbitro de Fútbol Amateur",  area: "Arbitraje Deportivo"   },
  { cargo: "Entrenador Juvenil",         area: "Entrenamiento y Tácticas" },
  { cargo: "Gestor de Eventos Deportivos", area: "Organización y Protocolo" },
];

const heroSlides = [
  { img: "/images/mon.webp",  tag: "Arbitraje & Entrenamiento",  h1a: "FORMAMOS",     h1b: "ÁRBITROS Y",   h1c: "ENTRENADORES." },
  { img: "/images/nena.webp",  tag: "Gestión & Dirigencia",       h1a: "DESARROLLAMOS", h1b: "LÍDERES DEL", h1c: "DEPORTE."      },
  { img: "/images/fuchi.webp",  tag: "Comunicación & Marketing",   h1a: "IMPULSAMOS",   h1b: "TU CARRERA",   h1c: "DEPORTIVA."    },
];
---

<Layout title="INFOCADE | Instituto de Formación Deportiva y Empresarial" showBackgroundFX={false}>

<!-- NAVBAR -->
<nav id="navbar">
  <a href="/" class="nav-logo">
    <img src="/images/log3.png" alt="INFOCADE" onerror="this.style.display='none'" />
    <span class="nav-wordmark">INFOCADE</span>
  </a>
  <div class="nav-links">
    <a href="#about"      class="nav-link">Nosotros</a>
    <a href="#servicios"  class="nav-link">Especialidades</a>
    <a href="#programas"  class="nav-link">Programas</a>
    <a href="#testimonios"class="nav-link">Egresados</a>
    <a href="#vacantes"   class="nav-link">Vacantes</a>
  </div>
  <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="nav-cta">
    Inscribirme
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
  <button class="nav-hamburger" id="nav-ham" aria-label="Abrir menú">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
</nav>

<!-- MOBILE MENU DRAWER -->
<div class="mobile-menu-drawer" id="mobile-menu">
  <a href="#about"      class="mob-nav-link">Nosotros</a>
  <a href="#servicios"  class="mob-nav-link">Especialidades</a>
  <a href="#programas"  class="mob-nav-link">Programas</a>
  <a href="#testimonios"class="mob-nav-link">Egresados</a>
  <a href="#vacantes"   class="mob-nav-link">Vacantes</a>
  <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="mob-nav-cta">
    Inscribirme
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </a>
</div>

<!-- HERO CARRUSEL -->
<!-- HERO VIDEO -->
<section id="hero">
  <video
    class="hero-video"
    src="/images/video.mp4"
    autoplay
    muted
    loop
    playsinline
  ></video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag">
      <span class="hero-tag-dot"></span>
      Arbitraje &amp; Entrenamiento
    </div>
    <h1 class="hero-h1">
      FORMAMOS<br/>
      ESPECIALISTAS<br/>
      <span class="c-red"> EN DEPORTE.</span>
    </h1>
    <div class="hero-row">
      <a href="#programas" class="btn-white">
        Ver Programas
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="btn-outline-white">Inscribirme</a>
    </div>
    <div class="hero-chips">
      <span class="hero-chip">100% Certificación Válida</span>
      <span class="hero-chip">11 Programas</span>
      <span class="hero-chip">800+ Egresados</span>
    </div>
  </div>
</section>

  <!-- MARQUEE 
  <div class="hero-dots">
    {heroSlides.map((_, i) => (
      <button class={`hero-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Slide ${i+1}`}></button>
    ))}
  </div>-->

  

  <div class="hero-progress">
    <div class="hero-progress-bar" id="hero-prog-bar"></div>
  </div>


<!-- MARQUEE -->
<div id="marquee-strip" aria-hidden="true">
  <div style="display:flex;overflow:hidden;">
    <div class="marquee-track">
      {[...ticker_items, ...ticker_items].map(item => (
        <span class="marquee-item">
          {item}<span class="marquee-dot"></span>
        </span>
      ))}
    </div>
  </div>
</div>

<!-- ABOUT — Azul -->
<section id="about">
  <div class="about-wrap">
    <div class="about-grid">
      <div class="about-left anim-left">
        <div class="about-eyebrow">Quiénes Somos</div>
        <h2 class="about-h2">INSTITUTO DE <span class="hl">FORMACIÓN</span> DEPORTIVA Y EMPRESARIAL</h2>
        <p class="about-desc">
          INFOCADE es un Instituto de Formación Deportiva con Más de Cinco Años de Trayectoria, Dedicado a Formar y Certificar Profesionales en el Ámbito Deportivo y Empresarial. Nos Caracterizamos por Ofrecer una Educación de Calidad, Impartida por Árbitros, Entrenadores, Gestores y Especialistas en Ejercicio Activo, Quienes Combinan su Experiencia con una Enseñanza Práctica y Actualizada. Nuestro Compromiso es Desarrollar Profesionales Íntegros, Preparados para Afrontar los Desafíos del Mundo Laboral y Contribuir al Crecimiento del Deporte y las Organizaciones.
         </p>
        <div class="about-features">
          {[
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/></svg>`, t: "Certificación Reconocida",  d: "Validez nacional e internacional" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>`, t: "Instructores en Ejercicio",  d: "Profesionales activos del sector" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`, t: "Modalidad Flexible",         d: "Presencial, virtual o híbrido" },
            { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`, t: "Prácticas desde el Día 1",   d: "Simulaciones reales en campo" },
          ].map(f => (
            <div class="ab-feat">
              <span class="ab-feat-icon" set:html={f.icon} />
              <div>
                <div class="ab-feat-title">{f.t}</div>
                <div class="ab-feat-desc">{f.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="about-right anim-right" style="padding:20px 20px 28px 0;">
        <div class="about-mosaic">
          <div class="ab-img"><img src="/images/jun.jpg" alt="Clase" onerror="this.src='https://images.unsplash.com/photo-1547347298-4074fc3086f0?w=400&q=80'" /></div>
          <div class="ab-img"><img src="/images/nena.webp"   alt="Campo" onerror="this.src='https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=400&q=80'" /></div>
          <div class="ab-img span2"><img src="/images/fuchi.webp" alt="Deporte" onerror="this.src='https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&q=80'" /></div>
        </div>
        <div class="about-badge">
          <div class="about-badge-num">RM. 0184/2025</div>
         
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICIOS — Amarillo -->
<section id="servicios">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow yellow">Nuestras Especialidades</div>
        <h2 class="sec-title">ÁREAS DE <span class="hl-yellow">FORMACIÓN</span></h2>
      </div>
      <a href="#programas" class="link-all anim-up d2">
        Ver todos
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
    <div class="servicios-grid">
      {servicios.map((s, i) => (
        <div class={`serv-card anim-up d${i+1}`}>
          <div class="serv-img">
            <img src={s.imagen} alt={s.titulo} onerror="this.src='https://images.unsplash.com/photo-1547347298-4074fc3086f0?w=400&q=80'" />
          </div>
          <div class="serv-body">
            <div class="serv-dot"></div>
            <div class="serv-title">{s.titulo}</div>
            <div class="serv-desc">{s.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- PROGRAMAS — Rojo -->
<section id="programas">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow red">Oferta Académica</div>
        <h2 class="sec-title">PROGRAMAS <span class="hl-red">CERTIFICADOS</span></h2>
      </div>
    </div>

    <div class="prog-tabs anim-up d1" id="prog-tabs">
      <button class="prog-tab active" data-filter="Todos">Todos</button>
      <button class="prog-tab" data-filter="Arbitraje">Arbitraje</button>
      <button class="prog-tab" data-filter="Entrenamiento">Entrenamiento</button>
      <button class="prog-tab" data-filter="Gestión">Gestión</button>
      <button class="prog-tab" data-filter="Comunicación">Comunicación</button>
      <button class="prog-tab" data-filter="Marketing">Marketing</button>
      <button class="prog-tab" data-filter="Tecnología">Tecnología</button>
    </div>

    <div class="prog-grid" id="prog-grid">
      {carreras.map((c, i) => (
        <div
          class="prog-card visible anim-scale"
          data-cat={catMap[c.code]}
          style={`transition-delay:${(i % 4) * 0.07}s`}
        >
          <div class="prog-card-img">
            <img src={c.imagen} alt={c.nombre} onerror="this.src='https://images.unsplash.com/photo-1547347298-4074fc3086f0?w=400&q=80'" />
            <div class="prog-card-img-overlay"></div>
            <span class="prog-cat-badge">{catMap[c.code]}</span>
          </div>
          <div class="prog-card-body">
            <div class="prog-card-code">{c.code}</div>
            <div class="prog-card-title">{c.nombre}</div>
            <div class="prog-card-meta">
              <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="prog-cta">
                Ver más
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHY — Azul -->
<section id="why">
  <div class="sw">
    <div class="why-grid">
      <div class="why-img-col anim-left">
        <img src="/images/jun.jpg" alt="Formación INFOCADE" class="why-img-main"
             onerror="this.src='https://images.unsplash.com/photo-1547347298-4074fc3086f0?w=800&q=80'" />
        <div class="why-float">
          <div class="why-float-num">100%</div>
          <div class="why-float-lbl">Certificación Válida</div>
        </div>
        <div class="why-float-2">
          <div class="why-float-num">11</div>
          <div class="why-float-lbl">Programas Activos</div>
        </div>
      </div>
      <div>
        <div class="anim-right">
          <div class="eyebrow blue">Por Qué Elegirnos</div>
          <h2 class="sec-title" style="margin-bottom:36px">LO QUE NOS HACE <span class="hl-blue">DIFERENTES</span></h2>
        </div>
        <div class="why-items">
          {whyItems.map((item, i) => (
            <div class={`why-item anim-right d${i+1}`}>
              <span class="why-num">0{i+1}</span>
              <div>
                <div class="why-t">{item.t}</div>
                <div class="why-d">{item.d}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS — Amarillo sobre negro -->
<section id="stats">
  <div class="stats-inner">
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class={`stat-block anim-up d${i+1}`}>
          <div class="stat-num">{s.num}</div>
          <div class="stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TESTIMONIOS -->
<section id="testimonios">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow yellow">Testimonios</div>
        <h2 class="sec-title">LO QUE DICEN<br/><span class="hl-yellow">NUESTROS</span> ALUMNOS</h2>
      </div>
    </div>
    <div class="testi-grid">
      {testimonios.map((t, i) => (
        <div class={`testi-card anim-up d${i+1}`}>
          <div class="testi-stars">★★★★★</div>
          <p class="testi-cita">"{t.cita}"</p>
          <div class="testi-footer">
            <div class="testi-av">{t.ini}</div>
            <div>
              <div class="testi-autor">{t.autor}</div>
              <div class="testi-rol">{t.rol}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- VACANTES — Amarillo -->
<section id="vacantes">
  <div class="sw">
    <div class="sec-head">
      <div class="anim-up">
        <div class="eyebrow yellow">Oportunidades</div>
        <h2 class="sec-title">CONSTRUYE TU <span class="hl-blue">CARRERA</span><br/>CON NOSOTROS</h2>
      </div>
    </div>
    <p class="anim-up" style="font-size:0.95rem;color:var(--soft);margin-bottom:36px;max-width:520px;line-height:1.75;">
      Al graduarte en INFOCADE accedes a nuestra red de organizaciones aliadas. Estas son algunas posiciones solicitadas por nuestros egresados.
    </p>
    <div class="vacantes-list">
      {vacantes.map((v, i) => (
        <div class={`vacante-row anim-up d${i+1}`}>
          <span class="vac-num">0{i+1}</span>
          <div class="vac-info">
            <div class="vac-cargo">{v.cargo}</div>
            <div class="vac-area">{v.area}</div>
          </div>
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" class="btn-apply">
            Inscribirme
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta">
  <img src="/images/mon.webp" alt="" class="cta-bg-img" aria-hidden="true"
       onerror="this.style.display='none'" />
  <div class="cta-inner">
    <div class="cta-left anim-left">
      <div class="cta-tag">Inscripciones Abiertas 2026</div>
      <h2 class="cta-h2">TU PRÓXIMO<br/>NIVEL ESTÁ<br/><span class="c-red">AQUÍ.</span></h2>
      <p class="cta-sub">Más de 800 profesionales del deporte ya dieron el paso. Certifícate con los mejores.</p>
    </div>
    <div class="cta-right anim-right">
      <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="btn-cta-prim">
        Inscribirme Ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#servicios" class="btn-cta-sec">Ver Programas</a>
      <div class="cta-chips">
        <span class="cta-chip"><span class="chip-d"></span> Certificado Válido</span>
        <span class="cta-chip"><span class="chip-d"></span> Horario Flexible</span>
        <span class="cta-chip"><span class="chip-d"></span> 100% Certificación</span>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-top">
    <div>
      <div class="footer-brand">INFO<em>CADE</em></div>
      <p class="footer-desc">Instituto de Formación Deportiva y Empresarial. Certificamos profesionales del deporte y la gestión para el mercado laboral actual.</p>
    </div>
    <div>
      <div class="footer-col-title">Programas</div>
      <div class="footer-links">
        <a href="#servicios" class="footer-link">Arbitraje Deportivo</a>
        <a href="#servicios" class="footer-link">Entrenamiento de Élite</a>
        <a href="#servicios" class="footer-link">Marketing Deportivo</a>
        <a href="#servicios" class="footer-link">Comunicación Deportiva</a>
        <a href="#servicios" class="footer-link">Gestión y Dirigencia</a>
      </div>
    </div>
    <div>
      <div class="footer-col-title">Institución</div>
      <div class="footer-links">
        <a href="#about"       class="footer-link">Quiénes Somos</a>
        <a href="#testimonios" class="footer-link">Egresados</a>
        <a href="#vacantes"    class="footer-link">Vacantes</a>
        <a href="#why"         class="footer-link">Por Qué INFOCADE</a>
      </div>
    </div>
    <div>
      <div class="footer-col-title">Contacto</div>
      <div class="footer-links">
