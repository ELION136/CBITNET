</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cv-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.cv-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. GOLD BAR DRAW ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cv-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO TITLE ── */
      const heroTitle = document.querySelector<HTMLElement>('.cv-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.cv-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.8,
          }
        });
      }

      /* ── 4. PARALLAX ORBS HERO ── */
      document.querySelectorAll<HTMLElement>('.cv-orb-1, .cv-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -25 : 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.cv-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 2,
          }
        });
      });

      /* ── 5. STAGGER ENTRANCE ── */
      const instCards = Array.from(document.querySelectorAll<HTMLElement>('.cv-inst-list .cv-inst-card'));
      instCards.forEach((card) => {
        ScrollTrigger.create({
          trigger: card,
          start: 'top 88%',
          once: true,
          onEnter: () => {
            gsap.to(card, { opacity: 1, y: 0, duration: 0.72, ease: 'power3.out', overwrite: true });
          }
        });
      });

      const axisGrid = document.querySelector('#sentido .cv-axis-grid');
      if (axisGrid) {
        const cards = Array.from(axisGrid.querySelectorAll<HTMLElement>('.cv-reveal'));
        ScrollTrigger.create({
          trigger: axisGrid,
          start: 'top 86%',
          once: true,
          onEnter: () => {
            cards.forEach((card, i) => {
              gsap.to(card, {
                opacity: 1, y: 0,
                duration: 0.72,
                delay: i * 0.1,
                ease: 'power3.out',
                overwrite: true,
              });
            });
          }
        });
      }

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>