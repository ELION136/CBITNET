  .fc-news-year { display: block; font-size: 12px; color: var(--gray-5); margin: 0 26px 12px; }
  .fc-news-card p { font-size: 13px; line-height: 1.7; color: var(--gray-6); margin: 0 26px 16px; }
  .fc-news-card .fc-pillar-link { margin: 0 26px; }

  /* ══════════════════ FOOTER ══════════════════ */
  .fc-footer { background: var(--dark); color: rgba(255,255,255,0.7); padding-top: 70px; }
  .fc-footer-top { display: flex; align-items: center; justify-content: space-between; gap: 40px; padding-bottom: 50px; border-bottom: 1px solid rgba(255,255,255,0.1); flex-wrap: wrap; }
  .fc-footer-logo { height: 52px; filter: brightness(0) invert(1); }
  .fc-newsletter { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .fc-newsletter span { font-size: 13.5px; color: rgba(255,255,255,0.6); }
  .fc-newsletter-form { display: flex; width: 100%; max-width: 380px; }
  .fc-newsletter-form input { padding: 12px 18px; border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); color: #fff; border-radius: 40px 0 0 40px; font-size: 13px; flex: 1; min-width: 0; }
  .fc-newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
  .fc-newsletter-form button { padding: 12px 24px; border: none; border-radius: 0 40px 40px 0; background: linear-gradient(135deg, var(--amber) 0%, var(--amber-mid) 100%); color: #fff; font-size: 12.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; cursor: pointer; flex-shrink: 0; }

  .fc-footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.2fr; gap: 40px; padding: 50px 0; }
  .fc-footer-grid h4 { color: #fff; font-family: var(--font-display); font-size: 15px; font-weight: 700; margin: 0 0 18px; text-transform: uppercase; letter-spacing: 0.05em; }
  .fc-footer-grid p { font-size: 13.5px; line-height: 1.7; margin: 0 0 18px; }
  .fc-footer-grid ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .fc-footer-grid a { color: rgba(255,255,255,0.68); text-decoration: none; font-size: 13.5px; transition: color var(--transition); }
  .fc-footer-grid a:hover { color: var(--amber-mid); }
  .fc-footer-social { display: flex; gap: 12px; }
  .fc-footer-social a { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; transition: var(--transition); }
  .fc-footer-social a:hover { background: var(--amber); transform: translateY(-3px); }
  .fc-footer-phone { display: flex; align-items: center; gap: 8px; color: #fff; font-weight: 700; font-size: 14px; margin-bottom: 8px; text-decoration: none; }
  .fc-footer-address { display: block; font-size: 13px; }
  .fc-footer-hours { display: block; font-size: 13px; margin-top: 6px; color: rgba(255,255,255,0.55); }

  .fc-footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding: 22px 0; }
  .fc-footer-bottom-inner { display: flex; justify-content: space-between; font-size: 12.5px; color: rgba(255,255,255,0.5); flex-wrap: wrap; gap: 8px; }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .fc-quickbar-card { padding: 0 28px; gap: 20px; }
    .fc-cta-band-grid { grid-template-columns: 1fr; }
