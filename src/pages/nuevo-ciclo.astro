---
import Layout from '../layouts/Layout.astro';

const pillars = [
  {
    num: "01",
    title: "Investigación Aplicada",
    desc: "Generamos conocimiento riguroso y estudios técnicos que responden a los desafíos reales de organizaciones, comunidades y sectores productivos.",
    img: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=700&auto=format&fit=crop&q=80",
    alt: "Equipo de investigadores analizando datos"
  },
  {
    num: "02",
    title: "Capacitación Técnica",
    desc: "Diplomados complementarios y programas de formación profesional que permiten identificar los principales retos, oportunidades y riesgos del entorno regional, nacional e internacional.",
    img: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=700&auto=format&fit=crop&q=80",
    alt: "Sesión de capacitación profesional"
  },
  {
    num: "03",
    title: "Asistencia Técnica",
    desc: "Acompañamiento especializado para la implementación de soluciones sostenibles, la transferencia de tecnología y la mejora continua institucional.",
    img: "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&auto=format&fit=crop&q=80",
    alt: "Equipo técnico revisando información en pantallas"
  }
];

const achievements = [
  { year: "1997", title: "Fundación Institucional", desc: "Nace la Fundación para la Investigación, Capacitación y Asistencia Técnica mediante Resolución Administrativa N.º 224/1997, con el propósito de generar conocimiento aplicado." },
  { year: "2008", title: "Consolidación de Programas", desc: "Ampliamos nuestra oferta de diplomados y consolidamos alianzas con instituciones académicas y productivas a nivel nacional." },
  { year: "2017", title: "Alcance Regional", desc: "Extendemos nuestros servicios de asistencia técnica a organizaciones de distintos sectores, con proyectos de alcance regional e internacional." },
  { year: "2026", title: "Compromiso Renovado", desc: "Continuamos formando profesionales y acompañando procesos de innovación, con presencia activa en investigación, capacitación y asistencia técnica." }
];

const gallery = [
  { src: "https://images.unsplash.com/photo-1552581234-26160f608093?w=900&auto=format&fit=crop&q=80", alt: "Equipo en reunión de trabajo", span: "tall" },
  { src: "https://images.unsplash.com/photo-1543269865-cbf427effbad?w=600&auto=format&fit=crop&q=80", alt: "Taller de capacitación técnica" },
  { src: "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=600&auto=format&fit=crop&q=80", alt: "Equipo de investigación aplicada" },
  { src: "https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&auto=format&fit=crop&q=80", alt: "Reunión de asistencia técnica" },
  { src: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=600&auto=format&fit=crop&q=80", alt: "Sala de formación profesional" },
];
---

<Layout title="FICAT | Fundación para la Investigación, Capacitación y Asistencia Técnica">

  <!-- Google Fonts con font-display=swap -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700;800&family=Outfit:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <main class="ns-root">

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section class="ns-hero" id="ns-hero">

      <!-- Columna izquierda: texto -->
      <div class="ns-hero-left">

        <!-- Logo -->
        <div class="ns-logo-wrap">
          <img
            src="/images/ns.png"
            alt="FICAT — Fundación para la Investigación, Capacitación y Asistencia Técnica"
            class="ns-logo"
          />
        </div>

        <div class="ns-eyebrow">
          <span class="ns-eyebrow-line"></span>
          Fundación de Investigación, Capacitación y Asistencia Técnica
        </div>

        <h1 class="ns-hero-h1">
          CONVERTIMOS <em>CONOCIMIENTO</em> EN DESARROLLO REAL
        </h1>

        <p class="ns-hero-p">
          Desde 1997 generamos investigación aplicada, formamos talento humano y brindamos
          asistencia técnica especializada. Creemos que el conocimiento riguroso es la base
          de un desarrollo sostenible y duradero.
        </p>

        <div class="ns-hero-btns">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="ns-btn-primary">
            Inscribirse a un diplomado
            <!-- Icono flecha derecha -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <button class="ns-btn-secondary">
            <!-- Icono play -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Ver nuestra historia
          </button>
        </div>

        <!-- Estadísticas -->
        <div class="ns-stats-row" id="ns-stats">
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="8000">0</span>+</span>
            <span class="ns-stat-label">Profesionales capacitados</span>
          </div>
          <div class="ns-stat-divider"></div>
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="180">0</span>+</span>
            <span class="ns-stat-label">Instituciones asesoradas</span>
          </div>
          <div class="ns-stat-divider"></div>
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="29">0</span>+</span>
            <span class="ns-stat-label">Años de trayectoria</span>
          </div>
        </div>
      </div>

      <!-- Columna derecha: imagen principal -->
      <div class="ns-hero-right">
        <img
          src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1000&auto=format&fit=crop&q=85"
          alt="Equipo técnico de la fundación trabajando en conjunto"
          class="ns-hero-img"
        />
        <div class="ns-hero-overlay">
          <span class="ns-hero-badge">Resolución Administrativa N.º 224/1997</span>
          <p class="ns-hero-caption">Casi tres décadas construyendo capacidades técnicas</p>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════ BARRA DE IMPACTO ════════════════════ -->
    <div class="ns-impact-bar">
      <div class="ns-impact-item">
        <!-- Icono lupa/investigación -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Investigación aplicada y rigurosa
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono birrete/académico -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        Formación técnica certificada
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono engranaje -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Asistencia técnica especializada
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono globo terráqueo -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Compromiso con el desarrollo sostenible
      </div>
    </div>

    <!-- ═══════════════════════════════ MISIÓN ══════════════════════════════ -->
    <section class="ns-mission" id="ns-mission">

      <!-- Mosaico de imágenes -->
      <div class="ns-mission-mosaic">
        <div class="ns-mosaic-main">
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=900&auto=format&fit=crop&q=80" alt="Reunión de trabajo técnico" />
        </div>
        <div class="ns-mosaic-sm">
          <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?w=500&auto=format&fit=crop&q=80" alt="Notas de un taller de formación" />
        </div>
        <div class="ns-mosaic-sm">
          <img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=500&auto=format&fit=crop&q=80" alt="Grupo en discusión técnica" />
        </div>
      </div>

      <!-- Texto -->
      <div class="ns-mission-text">
        <div class="ns-section-eyebrow">Quiénes somos</div>
        <h2 class="ns-section-h2">
          Una fundación construida sobre <em>conocimiento</em> y compromiso técnico
        </h2>
        <p>
          Desde 1997, mediante la Resolución Administrativa N.º 224/1997, trabajamos para
          generar conocimiento aplicado, fortalecer capacidades y brindar asistencia técnica
          especializada a organizaciones, comunidades y sectores productivos.
        </p>
        <blockquote class="ns-quote">
          "Creemos que el conocimiento solo transforma cuando se traduce en capacidades
          reales y soluciones concretas para quienes las necesitan."
        </blockquote>
        <p>
          Articulamos investigación, formación y transferencia tecnológica bajo principios
          de responsabilidad social, ética e inclusión, generando impacto positivo y
          soluciones pertinentes para el desarrollo económico, social y ambiental.
        </p>
      </div>

    </section>

    <!-- ═══════════════════════════════ PILARES ═════════════════════════════ -->
    <section class="ns-pillars-section">
      <div class="ns-container">
        <div class="ns-section-center">
          <span class="ns-section-eyebrow">Áreas de acción</span>
          <h2 class="ns-section-h2">Los tres pilares que sostienen nuestro trabajo</h2>
          <p class="ns-section-sub">Cada pilar refleja nuestro compromiso: generar conocimiento, formar talento humano y acompañar procesos técnicos con excelencia.</p>
        </div>

        <div class="ns-pillars-grid" id="ns-pillars">
          {pillars.map((pillar, i) => (
            <article class="ns-pillar-card" data-delay={i * 120}>
              <div class="ns-pillar-img">
                <img src={pillar.img} alt={pillar.alt} loading="lazy" />
              </div>
              <div class="ns-pillar-body">
                <span class="ns-pillar-num">{pillar.num} · Pilar</span>
                <h3>{pillar.title}</h3>
                <p>{pillar.desc}</p>
                <span class="ns-pillar-link">
                  Saber más
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ TIMELINE ════════════════════════════ -->
    <section class="ns-timeline-section">
      <div class="ns-container ns-timeline-inner">

        <!-- Imagen lateral -->
        <div class="ns-timeline-img-col">
          <img
            src="/images/mipo.jpg"
            alt="Profesionales en una sesión de trabajo técnico"
            class="ns-timeline-side-img"
          />
          <div class="ns-timeline-img-caption">
            <span>Desde 1997</span>
            generando conocimiento aplicado
          </div>
        </div>

        <!-- Timeline -->
        <div class="ns-timeline-col">
          <div class="ns-section-eyebrow">Nuestra trayectoria</div>
          <h2 class="ns-section-h2">Casi tres décadas generando impacto</h2>

          <div class="ns-timeline" id="ns-timeline">
            <div class="ns-tl-line"></div>
            <div class="ns-tl-fill" id="ns-tl-fill"></div>

            {achievements.map((ach, i) => (
              <div class="ns-tl-row" data-idx={i}>
                <div class="ns-tl-dot">
                  <div class="ns-tl-dot-inner"></div>
                </div>
                <div class="ns-tl-card">
                  <span class="ns-tl-year">{ach.year}</span>
                  <h3 class="ns-tl-title">{ach.title}</h3>
                  <p class="ns-tl-desc">{ach.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════ GALERÍA ═════════════════════════════ -->
    <section class="ns-gallery-section" id="ns-gallery-section">
      <div class="ns-container">
        <div class="ns-section-center" style="margin-bottom: 48px;">
          <span class="ns-section-eyebrow">Nuestro trabajo</span>
          <h2 class="ns-section-h2">Investigación, formación y asistencia técnica en acción</h2>
        </div>
        <div class="ns-gallery-grid" id="ns-gallery">
          {gallery.map((img, i) => (
            <div class={`ns-gallery-item ${img.span === 'tall' ? 'ns-gallery-tall' : ''}`} data-delay={i * 100}>
              <img src={img.src} alt={img.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ TESTIMONIAL ═════════════════════════ -->
    <section class="ns-testimonial-section">
      <div class="ns-container">
        <div class="ns-testimonial-grid">
          <div class="ns-testimonial-img">
            <img
              src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&auto=format&fit=crop&q=80"
              alt="Egresada de un diplomado de la fundación"
            />
          </div>
          <div class="ns-testimonial-body">
            <div class="ns-section-eyebrow">Testimonio</div>
            <blockquote class="ns-testimonial-quote">
              "El diplomado me dio herramientas concretas para enfrentar los retos técnicos
              de mi organización. Hoy aplico ese conocimiento en cada proyecto que lidero."
            </blockquote>
            <div class="ns-testimonial-author">
              <div class="ns-testimonial-avatar">MF</div>
              <div>
                <strong>María Fernández</strong>
                <span>Egresada · Diplomado en Gestión de Proyectos, 2024</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ CTA FINAL ═══════════════════════════ -->
    <section class="ns-cta-section" id="ns-cta">
      <div class="ns-cta-bg-img">
        <img
          src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1600&auto=format&fit=crop&q=80"
          alt="Profesionales participando en un encuentro de capacitación"
        />
        <div class="ns-cta-overlay"></div>
      </div>
      <div class="ns-cta-content">
        <span class="ns-eyebrow" style="color: #F0C9A8;">
          <span class="ns-eyebrow-line" style="background:#F0C9A8;"></span>
          Sé parte del cambio
        </span>
        <h2 class="ns-cta-h2">Impulsa tu desarrollo profesional hoy</h2>
        <p class="ns-cta-p">
          Ya sea que busques formación especializada, participar en un proyecto de
          investigación o solicitar asistencia técnica para tu organización,
          estamos listos para acompañarte.
        </p>
        <div class="ns-cta-btns">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="ns-btn-primary">
            Inscribirse a un diplomado
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <button class="ns-btn-ghost">Solicitar asistencia técnica</button>
        </div>
      </div>
    </section>

  </main>

</Layout>


<!-- ════════════════════════════════════════════════════════════════════════
     ESTILOS
     ═══════════════════════════════════════════════════════════════════════ -->
<style>

  /* ── Tipografía ──────────────────────────────────────────────────────────
     Fraunces → títulos H1 / H2 / CTA (serif cálida, con carácter institucional)
     Karla    → cuerpo, labels, botones (sans humanista, suave y legible)
     font-display:swap está declarado en la llamada a Google Fonts (ver <link>)
  ─────────────────────────────────────────────────────────────────────── */

  /* ── Tokens ──────────────────────────────────────────────────────────────── */
  :root {
    /* Paleta vibrante y colorida (Vaporwave / High-Energy Tech) */
    --amber:        #6366F1;  /* Indigo vibrante */
    --amber-dark:   #4F46E5;  /* Indigo oscuro */
    --amber-light:  #EEF2FF;  /* Indigo muy claro */
    --amber-mid:    #EC4899;  /* Rosa fucsia vibrante */
    --dark:         #0F172A;  /* Slate 900 */
    --dark-2:       #1E293B;  /* Slate 800 */
    --gray-1:       #F8FAFC;  /* Slate 50 (Fondo ultra claro) */
    --gray-2:       #F1F5F9;  /* Slate 100 */
    --gray-3:       #E2E8F0;  /* Slate 200 */
    --gray-4:       #CBD5E1;  /* Slate 300 */
    --gray-5:       #64748B;  /* Slate 500 */
    --gray-6:       #475569;  /* Slate 600 */
    --radius-sm:    8px;
    --radius-md:    16px;
    --radius-lg:    24px;
    --shadow-sm:    0 2px 12px rgba(99, 102, 241, 0.06);
    --shadow-md:    0 8px 32px rgba(99, 102, 241, 0.10);
    --shadow-lg:    0 20px 60px rgba(99, 102, 241, 0.12);
    --transition:   0.35s cubic-bezier(0.4, 0, 0.2, 1);

    /* Fuentes */
    --font-display: 'Manrope', sans-serif;
--font-body: 'Inter', sans-serif;
  }

  /* ── Reset / base ─────────────────────────────────────────────────────────── */
  .ns-root {
    background: var(--gray-1);
    color: var(--dark);
    overflow-x: hidden;
    font-family: var(--font-body);
  }

  .ns-root * {
    box-sizing: border-box;
  }

  .ns-container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* ── Logo ─────────────────────────────────────────────────────────────────── */
  .ns-logo-wrap {
    margin-bottom: 10px;
  }

  .ns-logo {
    height: 200px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  /* ── Eyebrow genérico ─────────────────────────────────────────────────────── */
  .ns-section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .ns-section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* Títulos H2 — serif cálida */
  .ns-section-h2 {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--dark);
    margin-bottom: 18px;
  }

  .ns-section-h2 em {
    font-style: italic;
    background: linear-gradient(135deg, var(--amber) 0%, var(--amber-mid) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ns-section-sub {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--gray-5);
    max-width: 520px;
    margin: 0 auto;
  }

  .ns-section-center {
    text-align: center;
    margin-bottom: 64px;
  }

  .ns-section-center .ns-section-eyebrow::before { display: none; }

  /* ── Botones ──────────────────────────────────────────────────────────────── */
  .ns-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--amber) 0%, var(--amber-mid) 100%);
    color: #fff;
    border: none;
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.2);
  }

  .ns-btn-primary:hover {
    background: linear-gradient(135deg, var(--amber-dark) 0%, var(--amber) 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35);
  }

  .ns-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--dark);
    border: 1.5px solid var(--gray-3);
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
  }

  .ns-btn-secondary:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  .ns-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: rgba(255,255,255,0.78);
    border: 1.5px solid rgba(255,255,255,0.28);
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
  }

  .ns-btn-ghost:hover {
    border-color: rgba(255,255,255,0.6);
    color: #fff;
  }


  /* ══════════════════════════════════════════════════════════
     HERO
     ══════════════════════════════════════════════════════════ */
  .ns-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 94vh;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }

  .ns-hero.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Columna texto */
  .ns-hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px 80px 64px;
    background: var(--gray-1);
  }

  .ns-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .ns-eyebrow-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* H1 hero */
  .ns-hero-h1 {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--dark);
    margin-bottom: 24px;
    max-width: 540px;
  }

  .ns-hero-h1 em {
    font-style: italic;
    background: linear-gradient(135deg, var(--amber) 0%, var(--amber-mid) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ns-hero-p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.8;
    color: var(--gray-6);
    max-width: 460px;
    margin-bottom: 40px;
  }

  .ns-hero-btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .ns-stats-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding-top: 40px;
    border-top: 1px solid var(--gray-3);
  }

  .ns-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ns-stat-val {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 500;
    color: var(--dark);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .ns-stat-label {
    font-family: var(--font-body);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--gray-5);
    text-transform: uppercase;
  }

  .ns-stat-divider {
    width: 1px;
    height: 44px;
    background: var(--gray-3);
    margin: 0 24px;
    flex-shrink: 0;
  }

  /* Columna imagen */
  .ns-hero-right {
    position: relative;
    overflow: hidden;
  }

  .ns-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 7s ease;
  }

  .ns-hero-right:hover .ns-hero-img {
    transform: scale(1.05);
  }

  .ns-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(43,34,28,0.80) 0%, transparent 65%);
    padding: 44px 40px 40px;
  }

  .ns-hero-badge {
    display: inline-block;
    background: rgba(182,113,79,0.90);
    color: #fff;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 40px;
    margin-bottom: 12px;
    backdrop-filter: blur(6px);
  }

  .ns-hero-caption {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    line-height: 1.35;
    margin: 0;
  }


  /* ══════════════════════════════════════════════════════════
     BARRA DE IMPACTO
     ══════════════════════════════════════════════════════════ */
  .ns-impact-bar {
    background: var(--dark);
    padding: 18px 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .ns-impact-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .ns-impact-icon {
    color: var(--amber-mid);
    flex-shrink: 0;
  }

  .ns-impact-sep {
    width: 1px;
    height: 22px;
    background: rgba(255,255,255,0.12);
  }


  /* ══════════════════════════════════════════════════════════
     MISIÓN
     ══════════════════════════════════════════════════════════ */
  .ns-mission {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 100px 64px;
    max-width: 1260px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ns-mission.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ns-mission-mosaic {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 240px 190px;
    gap: 12px;
  }

  .ns-mosaic-main {
    grid-column: 1 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .ns-mosaic-sm {
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .ns-mosaic-main img,
  .ns-mosaic-sm img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }

  .ns-mosaic-main:hover img,
  .ns-mosaic-sm:hover img {
    transform: scale(1.06);
  }

  .ns-mission-text p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.82;
    color: var(--gray-6);
    margin-bottom: 16px;
  }

  .ns-quote {
    margin: 24px 0;
    padding: 20px 24px;
    border-left: 3px solid var(--amber);
    background: var(--amber-light);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--gray-6);
    line-height: 1.75;
  }


  /* ══════════════════════════════════════════════════════════
     PILARES
     ══════════════════════════════════════════════════════════ */
  .ns-pillars-section {
    background: var(--gray-2);
    padding: 100px 0;
  }

  .ns-pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .ns-pillar-card {
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: translateY(44px);
    transition: opacity 0.7s ease, transform 0.7s ease, box-shadow var(--transition);
  }

  .ns-pillar-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ns-pillar-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .ns-pillar-img {
    height: 210px;
    overflow: hidden;
  }

  .ns-pillar-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }

  .ns-pillar-card:hover .ns-pillar-img img {
    transform: scale(1.07);
  }

  .ns-pillar-body {
    padding: 28px 28px 32px;
  }

  .ns-pillar-num {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .ns-pillar-body h3 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--dark);
    margin-bottom: 12px;
    line-height: 1.15;
  }

  .ns-pillar-body p {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.75;
    color: var(--gray-5);
    margin-bottom: 20px;
  }

  .ns-pillar-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--amber);
    text-transform: uppercase;
    cursor: pointer;
    transition: gap var(--transition);
  }

  .ns-pillar-link:hover {
    gap: 10px;
  }


  /* ══════════════════════════════════════════════════════════
     TIMELINE
     ══════════════════════════════════════════════════════════ */
  .ns-timeline-section {
    background: var(--gray-1);
    padding: 100px 0;
  }

  .ns-timeline-inner {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 80px;
    align-items: start;
  }

  .ns-timeline-img-col {
    position: sticky;
    top: 100px;
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ns-timeline-img-col.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .ns-timeline-side-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
    box-shadow: var(--shadow-md);
  }

  .ns-timeline-img-caption {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--gray-5);
  }

  .ns-timeline-img-caption span {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--amber);
    line-height: 1;
  }

  .ns-timeline-col .ns-section-h2 {
    margin-bottom: 48px;
  }

  .ns-timeline {
    position: relative;
    padding-left: 36px;
  }

  .ns-tl-line {
    position: absolute;
    left: 8px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gray-3);
    z-index: 0;
  }

  .ns-tl-fill {
    position: absolute;
    left: 8px;
    top: 0;
    width: 2px;
    height: 0%;
    background: var(--amber);
    z-index: 1;
    transition: height 0.05s linear;
  }

  .ns-tl-row {
    position: relative;
    margin-bottom: 44px;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .ns-tl-row.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .ns-tl-dot {
    position: absolute;
    left: -32px;
    top: 4px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--gray-1);
    border: 2px solid var(--gray-3);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: border-color var(--transition);
  }

  .ns-tl-row.visible .ns-tl-dot {
    border-color: var(--amber);
  }

  .ns-tl-dot-inner {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--amber);
  }

  .ns-tl-card {
    background: #fff;
    border: 1px solid var(--gray-3);
    border-radius: var(--radius-md);
    padding: 24px 28px;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .ns-tl-row:hover .ns-tl-card {
    border-color: var(--amber);
    box-shadow: var(--shadow-md);
  }

  .ns-tl-year {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .ns-tl-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--dark);
    margin-bottom: 8px;
  }

  .ns-tl-desc {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.75;
    color: var(--gray-5);
    margin: 0;
  }


  /* ══════════════════════════════════════════════════════════
     GALERÍA
     ══════════════════════════════════════════════════════════ */
  .ns-gallery-section {
    background: var(--gray-2);
    padding: 100px 0;
  }

  .ns-gallery-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 270px 200px;
    gap: 14px;
  }

  .ns-gallery-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }

  .ns-gallery-item.visible {
    opacity: 1;
    transform: scale(1);
  }

  .ns-gallery-tall {
    grid-row: 1 / 3;
  }

  .ns-gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }

  .ns-gallery-item:hover img {
    transform: scale(1.07);
  }


  /* ══════════════════════════════════════════════════════════
     TESTIMONIAL
     ══════════════════════════════════════════════════════════ */
  .ns-testimonial-section {
    background: var(--gray-1);
    padding: 100px 0;
  }

  .ns-testimonial-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 72px;
    align-items: center;
  }

  .ns-testimonial-img {
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 440px;
    box-shadow: var(--shadow-md);
  }

  .ns-testimonial-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ns-testimonial-quote {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.5;
    color: var(--dark);
    border: none;
    padding: 0;
    margin: 0 0 32px;
    font-style: italic;
  }

  .ns-testimonial-author {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ns-testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--amber);
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ns-testimonial-author strong {
    display: block;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 2px;
  }

  .ns-testimonial-author span {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--gray-5);
    letter-spacing: 0.03em;
  }


  /* ══════════════════════════════════════════════════════════
     CTA FINAL
     ══════════════════════════════════════════════════════════ */
  .ns-cta-section {
    position: relative;
    min-height: 540px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .ns-cta-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ns-cta-bg-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ns-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(43,34,28,0.88) 0%, rgba(149,88,64,0.72) 100%);
  }

  .ns-cta-content {
    position: relative;
    z-index: 1;
    padding: 80px 48px;
    max-width: 680px;
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ns-cta-content.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* H2 CTA */
  .ns-cta-h2 {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 16px;
  }

  .ns-cta-p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    margin-bottom: 40px;
  }

  .ns-cta-btns {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .ns-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .ns-hero-left {
      padding: 60px 48px;
    }
    .ns-hero-right {
      height: 400px;
    }
    .ns-mission {
      grid-template-columns: 1fr;
      gap: 56px;
      padding: 80px 48px;
    }
    .ns-pillars-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .ns-timeline-inner {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .ns-timeline-img-col {
      position: relative;
      top: 0;
      max-width: 480px;
      margin: 0 auto;
    }
    .ns-gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      gap: 12px;
    }
    .ns-gallery-tall {
      grid-row: span 1;
    }
    .ns-testimonial-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .ns-testimonial-img {
      max-width: 480px;
      margin: 0 auto;
      height: 360px;
    }
  }

  @media (max-width: 768px) {
    .ns-container {
      padding: 0 24px;
    }
    .ns-hero-left {
      padding: 48px 24px;
    }
    .ns-hero-h1 {
      font-size: 38px;
    }
    .ns-logo {
      height: 140px;
    }
    .ns-stats-row {
      flex-direction: column;
      align-items: stretch;
      gap: 20px;
    }
    .ns-stat-divider {
      display: none;
    }
    .ns-stat {
      align-items: center;
      text-align: center;
    }
    .ns-impact-bar {
      padding: 24px;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
    }
    .ns-impact-sep {
      display: none;
    }
    .ns-mission {
      padding: 60px 24px;
    }
    .ns-mission-mosaic {
      grid-template-rows: 180px 140px;
    }
    .ns-pillars-section {
      padding: 60px 0;
    }
    .ns-pillars-grid {
      grid-template-columns: 1fr;
    }
    .ns-timeline-section {
      padding: 60px 0;
    }
    .ns-gallery-section {
      padding: 60px 0;
    }
    .ns-testimonial-section {
      padding: 60px 0;
    }
    .ns-testimonial-img {
      height: 280px;
    }
    .ns-testimonial-quote {
      font-size: 20px;
    }
    .ns-section-h2 {
      font-size: 32px;
    }
    .ns-cta-content {
      padding: 60px 24px;
    }
    .ns-cta-h2 {
      font-size: 36px;
    }
  }

  @media (max-width: 480px) {
    .ns-hero-h1 {
      font-size: 30px;
    }
    .ns-hero-btns {
      flex-direction: column;
      align-items: stretch;
    }
    .ns-hero-btns a, .ns-hero-btns button {
      justify-content: center;
    }
    .ns-cta-btns {
      flex-direction: column;
      align-items: stretch;
    }
    .ns-cta-btns a, .ns-cta-btns button {
      justify-content: center;
    }
    .ns-gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .ns-hero,
    .ns-mission,
    .ns-pillar-card,
    .ns-tl-row,
    .ns-gallery-item,
    .ns-cta-content,
    .ns-timeline-img-col {
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

</style>


<!-- ═══════════════════════════════════════════════════════════════════════════
     ANIMACIONES GSAP
     ════════════════════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    /* ── 1. Hero entrada al cargar ───────────────────────────────────────── */
    window.addEventListener('load', () => {
      const hero = document.getElementById('ns-hero');
      if (hero) setTimeout(() => hero.classList.add('visible'), 120);
    });

    /* ── 2. Contadores de estadísticas ───────────────────────────────────── */
    let statsAnimated = false;
    ScrollTrigger.create({
      trigger: '#ns-stats',
      start: 'top 85%',
      onEnter: () => {
        if (statsAnimated) return;
        statsAnimated = true;
        document.querySelectorAll('.count').forEach((el) => {
          const target = parseInt(el.getAttribute('data-target') || '0', 10);
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: () => {
              (el as HTMLElement).innerText = Math.floor(obj.val).toLocaleString();
            },
          });
        });
      },
    });

    /* ── 3. Sección Misión ───────────────────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '#ns-mission',
      start: 'top 80%',
      onEnter: () => {
        const el = document.getElementById('ns-mission');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 4. Pilares en cascada ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-pillar-card').forEach((card) => {
      ScrollTrigger.create({
        trigger: card,
        start: 'top 88%',
        onEnter: () => {
          const delay = parseInt((card as HTMLElement).dataset.delay || '0', 10);
          setTimeout(() => card.classList.add('visible'), delay);
        },
      });
    });

    /* ── 5. Imagen lateral del timeline ─────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '.ns-timeline-img-col',
      start: 'top 82%',
      onEnter: () => {
        const el = document.querySelector('.ns-timeline-img-col');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 6. Filas del timeline ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-tl-row').forEach((row, i) => {
      ScrollTrigger.create({
        trigger: row,
        start: 'top 84%',
        onEnter: () => {
          setTimeout(() => row.classList.add('visible'), i * 110);
        },
      });
    });

    /* ── 7. Línea de relleno (scrub) ─────────────────────────────────────── */
    gsap.to('#ns-tl-fill', {
      scrollTrigger: {
        trigger: '#ns-timeline',
        start: 'top 60%',
        end: 'bottom 40%',
        scrub: 1,
      },
      height: '100%',
    });

    /* ── 8. Galería en cascada ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-gallery-item').forEach((item) => {
      ScrollTrigger.create({
        trigger: item,
        start: 'top 90%',
        onEnter: () => {
          const delay = parseInt((item as HTMLElement).dataset.delay || '0', 10);
          setTimeout(() => item.classList.add('visible'), delay);
        },
      });
    });

    /* ── 9. CTA final ────────────────────────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '#ns-cta',
      start: 'top 80%',
      onEnter: () => {
        const el = document.querySelector('.ns-cta-content');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 10. Parallax sutil hero ─────────────────────────────────────────── */
    gsap.to('.ns-hero-img', {
      scrollTrigger: {
        trigger: '.ns-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
      y: 60,
      ease: 'none',
    });
  }
</script>