<!-- ═══════════════════════════════════════════════════════════════════════════
     ANIMACIONES GSAP
     ════════════════════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    /* ── 1. Hero entrada al cargar ───────────────────────────────────────── */
    window.addEventListener('load', () => {
      const hero = document.getElementById('ns-hero');
      if (hero) setTimeout(() => hero.classList.add('visible'), 120);
    });

    /* ── 2. Contadores de estadísticas ───────────────────────────────────── */
    let statsAnimated = false;
    ScrollTrigger.create({
      trigger: '#ns-stats',
      start: 'top 85%',
      onEnter: () => {
        if (statsAnimated) return;
        statsAnimated = true;
        document.querySelectorAll('.count').forEach((el) => {
          const target = parseInt(el.getAttribute('data-target') || '0', 10);
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: () => {
              (el as HTMLElement).innerText = Math.floor(obj.val).toLocaleString();
            },
          });
        });
      },
    });

    /* ── 3. Sección Misión ───────────────────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '#ns-mission',
      start: 'top 80%',
      onEnter: () => {
        const el = document.getElementById('ns-mission');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 4. Pilares en cascada ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-pillar-card').forEach((card) => {
      ScrollTrigger.create({
        trigger: card,
        start: 'top 88%',
        onEnter: () => {
          const delay = parseInt((card as HTMLElement).dataset.delay || '0', 10);
          setTimeout(() => card.classList.add('visible'), delay);
        },
      });
    });

    /* ── 5. Imagen lateral del timeline ─────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '.ns-timeline-img-col',
      start: 'top 82%',
      onEnter: () => {
        const el = document.querySelector('.ns-timeline-img-col');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 6. Filas del timeline ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-tl-row').forEach((row, i) => {
      ScrollTrigger.create({
        trigger: row,
        start: 'top 84%',
        onEnter: () => {
          setTimeout(() => row.classList.add('visible'), i * 110);
        },
      });
    });

    /* ── 7. Línea de relleno (scrub) ─────────────────────────────────────── */
    gsap.to('#ns-tl-fill', {
      scrollTrigger: {
        trigger: '#ns-timeline',
        start: 'top 60%',
        end: 'bottom 40%',
        scrub: 1,
      },
      height: '100%',
    });

    /* ── 8. Galería en cascada ───────────────────────────────────────────── */
    document.querySelectorAll('.ns-gallery-item').forEach((item) => {
      ScrollTrigger.create({
        trigger: item,
        start: 'top 90%',
        onEnter: () => {
          const delay = parseInt((item as HTMLElement).dataset.delay || '0', 10);
          setTimeout(() => item.classList.add('visible'), delay);
        },
      });
    });

    /* ── 9. CTA final ────────────────────────────────────────────────────── */
    ScrollTrigger.create({
      trigger: '#ns-cta',
      start: 'top 80%',
      onEnter: () => {
        const el = document.querySelector('.ns-cta-content');
        if (el) el.classList.add('visible');
      },
    });

    /* ── 10. Parallax sutil hero ─────────────────────────────────────────── */
    gsap.to('.ns-hero-img', {
      scrollTrigger: {
        trigger: '.ns-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
      y: 60,
      ease: 'none',
    });
  }
</script>