---
import Layout from '../layouts/Layout.astro';

const pillars = [
  {
    num: "01",
    title: "Desarrollo Deportivo",
    desc: "Entrenamientos estructurados de alto rendimiento y clínicas deportivas impartidas por directores certificados internacionales.",
    img: "https://images.unsplash.com/photo-1431324155629-1a6deb1dec8d?w=700&auto=format&fit=crop&q=80",
    alt: "Jóvenes en entrenamiento deportivo"
  },
  {
    num: "02",
    title: "Soporte Académico",
    desc: "Mentorías personalizadas, clases de nivelación académica y preparación para exámenes de ingreso a universidades de prestigio.",
    img: "https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=700&auto=format&fit=crop&q=80",
    alt: "Estudiantes en clase"
  },
  {
    num: "03",
    title: "Liderazgo & Valores",
    desc: "Talleres prácticos de resolución de conflictos, inteligencia emocional, oratoria y compromiso cívico comunitario.",
    img: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=700&auto=format&fit=crop&q=80",
    alt: "Taller de liderazgo grupal"
  }
];

const achievements = [
  { year: "2021", title: "Fundación e Inicios", desc: "Nace la fundación con el objetivo de rescatar espacios deportivos y guiar académicamente a 50 jóvenes talentos en comunidades vulnerables." },
  { year: "2023", title: "Expansión y Becas USA", desc: "Firmamos convenios clave con academias de EE. UU. y logramos las primeras 12 becas deportivas completas para jóvenes de la fundación." },
  { year: "2025", title: "Centro de Alto Rendimiento", desc: "Inauguramos el primer centro integral con salas de estudio híbridas y clínicas médicas asociadas para el desarrollo pleno del atleta." },
  { year: "2026", title: "Impacto Global Continuo", desc: "Superamos la cifra de 1,500 alumnos guiados en todo el país con presencia en múltiples disciplinas deportivas." }
];

const gallery = [
  { src: "https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=900&auto=format&fit=crop&q=80", alt: "Partido de fútbol comunitario", span: "tall" },
  { src: "https://images.unsplash.com/photo-1567581935884-3349723552ca?w=600&auto=format&fit=crop&q=80", alt: "Taller académico" },
  { src: "https://images.unsplash.com/photo-1509062522246-3755977927d7?w=600&auto=format&fit=crop&q=80", alt: "Entrenamiento físico" },
  { src: "https://images.unsplash.com/photo-1607962837359-5e7e89f86776?w=600&auto=format&fit=crop&q=80", alt: "Celebración de logros" },
  { src: "https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&auto=format&fit=crop&q=80", alt: "Sala de estudio" },
];
---

<Layout title="NUEVO CICLO | Fundación Deportiva y Académica">

  <!-- Google Fonts con font-display=swap -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <main class="ns-root">

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section class="ns-hero" id="ns-hero">

      <!-- Columna izquierda: texto -->
      <div class="ns-hero-left">

        <!-- Logo -->
        <div class="ns-logo-wrap">
          <img
            src="/images/ns.png"
            alt="Nuevo Ciclo — Fundación Deportiva y Académica"
            class="ns-logo"
          />
        </div>

        <div class="ns-eyebrow">
          <span class="ns-eyebrow-line"></span>
          Fundación de Solidaridad &amp; Apoyo
        </div>

        <h1 class="ns-hero-h1">
          Transformamos vidas con <em>amor</em> y compromiso
        </h1>

        <p class="ns-hero-p">
          Desde 2021 acompañamos a jóvenes talentos con apoyo deportivo, académico y humano.
          Creemos que cada niño merece una oportunidad real de brillar.
        </p>

        <div class="ns-hero-btns">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="ns-btn-primary">
            Inscribirse ahora
            <!-- Icono flecha derecha -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <button class="ns-btn-secondary">
            <!-- Icono play -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Ver historia
          </button>
        </div>

        <!-- Estadísticas -->
        <div class="ns-stats-row" id="ns-stats">
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="1500">0</span>+</span>
            <span class="ns-stat-label">Jóvenes apoyados</span>
          </div>
          <div class="ns-stat-divider"></div>
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="45">0</span>+</span>
            <span class="ns-stat-label">Becas deportivas USA</span>
          </div>
          <div class="ns-stat-divider"></div>
          <div class="ns-stat">
            <span class="ns-stat-val"><span class="count" data-target="10">0</span>K+</span>
            <span class="ns-stat-label">Horas de formación</span>
          </div>
        </div>
      </div>

      <!-- Columna derecha: imagen principal -->
      <div class="ns-hero-right">
        <img
          src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1000&auto=format&fit=crop&q=85"
          alt="Jóvenes de la fundación unidos en comunidad"
          class="ns-hero-img"
        />
        <div class="ns-hero-overlay">
          <span class="ns-hero-badge">Comunidad activa · 2025</span>
          <p class="ns-hero-caption">Unidos por un mismo sueño: un futuro digno</p>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════ BARRA DE IMPACTO ════════════════════ -->
    <div class="ns-impact-bar">
      <div class="ns-impact-item">
        <!-- Icono corazón (profesional, outline) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Solidaridad como pilar central
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono birrete/académico -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        Apoyo académico personalizado
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono trofeo -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>
        Desarrollo deportivo de élite
      </div>
      <div class="ns-impact-sep"></div>
      <div class="ns-impact-item">
        <!-- Icono globo terráqueo -->
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="ns-impact-icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Becas internacionales EE.UU.
      </div>
    </div>

    <!-- ═══════════════════════════════ MISIÓN ══════════════════════════════ -->
    <section class="ns-mission" id="ns-mission">

      <!-- Mosaico de imágenes -->
      <div class="ns-mission-mosaic">
        <div class="ns-mosaic-main">
          <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=900&auto=format&fit=crop&q=80" alt="Entrenamiento deportivo grupal" />
        </div>
        <div class="ns-mosaic-sm">
          <img src="https://images.unsplash.com/photo-1544717297-fa95b6ee9643?w=500&auto=format&fit=crop&q=80" alt="Estudio y aprendizaje" />
        </div>
        <div class="ns-mosaic-sm">
          <img src="https://images.unsplash.com/photo-1576866209830-589e1bfbaa4d?w=500&auto=format&fit=crop&q=80" alt="Comunidad unida" />
        </div>
      </div>

      <!-- Texto -->
      <div class="ns-mission-text">
        <div class="ns-section-eyebrow">Quiénes somos</div>
        <h2 class="ns-section-h2">
          Una fundación hecha de <em>corazón</em> y esfuerzo colectivo
        </h2>
        <p>
          No somos solo una institución — somos una familia que cree profundamente en el
          potencial de cada joven. Nuestro modelo une el entrenamiento deportivo de alto
          nivel con la guía académica y el desarrollo humano integral.
        </p>
        <blockquote class="ns-quote">
          "Cuando un joven descubre que alguien cree en él, cambia no solo su historia
          sino la de toda su comunidad."
        </blockquote>
        <p>
          Cada programa está diseñado con cariño, rigor y visión de futuro. Trabajamos
          codo a codo con familias, entrenadores y educadores para que ningún talento
          quede invisible.
        </p>
      </div>

    </section>

    <!-- ═══════════════════════════════ PILARES ═════════════════════════════ -->
    <section class="ns-pillars-section">
      <div class="ns-container">
        <div class="ns-section-center">
          <span class="ns-section-eyebrow">Áreas de enfoque</span>
          <h2 class="ns-section-h2">Los tres pilares que sostienen nuestra misión</h2>
          <p class="ns-section-sub">Cada pilar es una promesa: acompañarte con excelencia en el deporte, en el aula y en la vida.</p>
        </div>

        <div class="ns-pillars-grid" id="ns-pillars">
          {pillars.map((pillar, i) => (
            <article class="ns-pillar-card" data-delay={i * 120}>
              <div class="ns-pillar-img">
                <img src={pillar.img} alt={pillar.alt} loading="lazy" />
              </div>
              <div class="ns-pillar-body">
                <span class="ns-pillar-num">{pillar.num} · Pilar</span>
                <h3>{pillar.title}</h3>
                <p>{pillar.desc}</p>
                <span class="ns-pillar-link">
                  Saber más
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ TIMELINE ════════════════════════════ -->
    <section class="ns-timeline-section">
      <div class="ns-container ns-timeline-inner">

        <!-- Imagen lateral -->
        <div class="ns-timeline-img-col">
          <img
            src="https://images.unsplash.com/photo-1593476087123-36d1de271f08?w=700&auto=format&fit=crop&q=80"
            alt="Atleta en acción representando el crecimiento de la fundación"
            class="ns-timeline-side-img"
          />
          <div class="ns-timeline-img-caption">
            <span>Más de 5 años</span>
            construyendo caminos
          </div>
        </div>

        <!-- Timeline -->
        <div class="ns-timeline-col">
          <div class="ns-section-eyebrow">Nuestra historia</div>
          <h2 class="ns-section-h2">Línea de tiempo del impacto</h2>

          <div class="ns-timeline" id="ns-timeline">
            <div class="ns-tl-line"></div>
            <div class="ns-tl-fill" id="ns-tl-fill"></div>

            {achievements.map((ach, i) => (
              <div class="ns-tl-row" data-idx={i}>
                <div class="ns-tl-dot">
                  <div class="ns-tl-dot-inner"></div>
                </div>
                <div class="ns-tl-card">
                  <span class="ns-tl-year">{ach.year}</span>
                  <h3 class="ns-tl-title">{ach.title}</h3>
                  <p class="ns-tl-desc">{ach.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════ GALERÍA ═════════════════════════════ -->
    <section class="ns-gallery-section" id="ns-gallery-section">
      <div class="ns-container">
        <div class="ns-section-center" style="margin-bottom: 48px;">
          <span class="ns-section-eyebrow">Momentos reales</span>
          <h2 class="ns-section-h2">Nuestra comunidad en acción</h2>
        </div>
        <div class="ns-gallery-grid" id="ns-gallery">
          {gallery.map((img, i) => (
            <div class={`ns-gallery-item ${img.span === 'tall' ? 'ns-gallery-tall' : ''}`} data-delay={i * 100}>
              <img src={img.src} alt={img.alt} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ TESTIMONIAL ═════════════════════════ -->
    <section class="ns-testimonial-section">
      <div class="ns-container">
        <div class="ns-testimonial-grid">
          <div class="ns-testimonial-img">
            <img
              src="https://images.unsplash.com/photo-1607746882042-944635dfe10e?w=600&auto=format&fit=crop&q=80"
              alt="Joven beneficiario de la fundación"
            />
          </div>
          <div class="ns-testimonial-body">
            <div class="ns-section-eyebrow">Testimonio</div>
            <blockquote class="ns-testimonial-quote">
              "La fundación no solo me dio una beca — me dio familia, dirección y la
              confianza de que yo podía lograr cosas grandes. Hoy estudio en EE.UU.
              gracias a ellos."
            </blockquote>
            <div class="ns-testimonial-author">
              <div class="ns-testimonial-avatar">JM</div>
              <div>
                <strong>Juan Medina</strong>
                <span>Beneficiario 2023 · Beca Deportiva Miami</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════ CTA FINAL ═══════════════════════════ -->
    <section class="ns-cta-section" id="ns-cta">
      <div class="ns-cta-bg-img">
        <img
          src="https://images.unsplash.com/photo-1526976668912-1a811878dd37?w=1600&auto=format&fit=crop&q=80"
          alt="Equipo de jóvenes celebrando juntos"
        />
        <div class="ns-cta-overlay"></div>
      </div>
      <div class="ns-cta-content">
        <span class="ns-eyebrow" style="color: #f5c87a;">
          <span class="ns-eyebrow-line" style="background:#f5c87a;"></span>
          Sé parte del cambio
        </span>
        <h2 class="ns-cta-h2">Únete y cambia una vida hoy</h2>
        <p class="ns-cta-p">
          Ya sea que busques inscribir a un joven talentoso o colaborar como voluntario,
          tu esfuerzo multiplica las posibilidades de transformar el futuro de una generación.
        </p>
        <div class="ns-cta-btns">
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="ns-btn-primary">
            Inscribirse ahora
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <button class="ns-btn-ghost">Ser voluntario</button>
        </div>
      </div>
    </section>

  </main>

</Layout>


<!-- ════════════════════════════════════════════════════════════════════════
     ESTILOS
     ═══════════════════════════════════════════════════════════════════════ -->
<style>

  /* ── Tipografía ──────────────────────────────────────────────────────────
     Bebas Neue  → títulos H1 / H2 / CTA (display, uppercase natural)
     Inter       → cuerpo, labels, botones
     font-display:swap está declarado en la llamada a Google Fonts (ver <link>)
  ─────────────────────────────────────────────────────────────────────── */

  /* ── Tokens ──────────────────────────────────────────────────────────────── */
  :root {
    --amber:        #C4873A;
    --amber-dark:   #a86e2a;
    --amber-light:  #FFF4E6;
    --amber-mid:    #F5C87A;
    --dark:         #1a1a18;
    --dark-2:       #2e2e2b;
    --gray-1:       #FAFAF8;
    --gray-2:       #F5F2EC;
    --gray-3:       #E8E4DC;
    --gray-4:       #C8C4BC;
    --gray-5:       #888580;
    --gray-6:       #555450;
    --radius-sm:    8px;
    --radius-md:    16px;
    --radius-lg:    24px;
    --shadow-sm:    0 2px 12px rgba(0,0,0,0.07);
    --shadow-md:    0 8px 32px rgba(0,0,0,0.10);
    --shadow-lg:    0 20px 60px rgba(0,0,0,0.12);
    --transition:   0.35s cubic-bezier(0.4, 0, 0.2, 1);

    /* Fuentes */
    --font-display: 'Bebas Neue', 'Arial Narrow', sans-serif;
    --font-body:    'Inter', system-ui, sans-serif;
  }

  /* ── Reset / base ─────────────────────────────────────────────────────────── */
  .ns-root {
    background: var(--gray-1);
    color: var(--dark);
    overflow-x: hidden;
    font-family: var(--font-body);
  }

  .ns-root * {
    box-sizing: border-box;
  }

  .ns-container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* ── Logo ─────────────────────────────────────────────────────────────────── */
  .ns-logo-wrap {
    margin-bottom: 10px;
  }

  .ns-logo {
    height: 200px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  /* ── Eyebrow genérico ─────────────────────────────────────────────────────── */
  .ns-section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .ns-section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--amber);
    flex-shrink: 0;
  }

  /* Títulos H2 — display uppercase */
  .ns-section-h2 {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 400; /* Bebas Neue sólo tiene weight 400 */
    line-height: 1.05;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--dark);
    margin-bottom: 18px;
  }

  .ns-section-h2 em {
    font-style: normal;
    color: var(--amber);
  }

  .ns-section-sub {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--gray-5);
    max-width: 520px;
    margin: 0 auto;
  }

  .ns-section-center {
    text-align: center;
    margin-bottom: 64px;
  }

  .ns-section-center .ns-section-eyebrow::before { display: none; }

  /* ── Botones ──────────────────────────────────────────────────────────────── */
  .ns-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--amber);
    color: #fff;
    border: none;
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition);
  }

  .ns-btn-primary:hover {
    background: var(--amber-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(196, 135, 58, 0.32);
  }

  .ns-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--dark);
    border: 1.5px solid var(--gray-3);
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
  }

  .ns-btn-secondary:hover {
    border-color: var(--amber);
    color: var(--amber);
  }

  .ns-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: rgba(255,255,255,0.75);
    border: 1.5px solid rgba(255,255,255,0.25);
    padding: 14px 30px;
    border-radius: 40px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
  }

  .ns-btn-ghost:hover {
    border-color: rgba(255,255,255,0.6);
    color: #fff;
  }


