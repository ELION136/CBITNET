  .fc-play-btn:hover { transform: translate(-50%, -50%) scale(1.08); }
  .fc-play-btn::before { content: ''; position: absolute; inset: -10px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.5); animation: fc-pulse 2.2s ease-out infinite; }
  @keyframes fc-pulse { 0% { transform: scale(1); opacity: 0.8; } 100% { transform: scale(1.5); opacity: 0; } }

