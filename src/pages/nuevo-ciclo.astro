  }

  @media (max-width: 960px) {
    .fc-nav { display: none; }
    .fc-nav-toggle { display: flex; }
    .fc-mobile-nav { display: flex; }
    .fc-hero-h1 { font-size: 42px; }
    .fc-hero-stat-card { position: static; margin: 24px auto 0; width: fit-content; }
    .fc-quickbar-inner { flex-direction: column; }
    .fc-quickbar-col { padding: 20px 0; width: 100%; }
    .fc-quickbar-divider { display: none; }
    .fc-quickbar-card { width: 100%; justify-content: center; padding: 24px; flex-wrap: wrap; }
    .fc-intro-grid { grid-template-columns: 1fr; }
    .fc-pillars-grid { grid-template-columns: repeat(2, 1fr); }
    .fc-news-grid { grid-template-columns: repeat(2, 1fr); }
