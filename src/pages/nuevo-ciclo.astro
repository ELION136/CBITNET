</style>


<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    /* Menú móvil */
    const navToggle = document.getElementById('fc-nav-toggle');
    const mobileNav = document.getElementById('fc-mobile-nav');
    navToggle?.addEventListener('click', () => {
      mobileNav?.classList.toggle('fc-open');
    });
    mobileNav?.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => mobileNav.classList.remove('fc-open'));
    });

    /* Reveal genérico al hacer scroll para elementos .fc-reveal */
    document.querySelectorAll('.fc-reveal').forEach((el) => {
      ScrollTrigger.create({
        trigger: el,
        start: 'top 88%',
        onEnter: () => el.classList.add('is-visible'),
      });
    });

    /* Animación del contador */
    let statsAnimated = false;
    ScrollTrigger.create({
      trigger: '.fc-intro-media',
      start: 'top 85%',
      onEnter: () => {
        if (statsAnimated) return;
        statsAnimated = true;
        document.querySelectorAll('.count').forEach((el) => {
          const target = parseInt(el.getAttribute('data-target') || '0', 10);
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: () => {
              (el as HTMLElement).innerText = Math.floor(obj.val).toLocaleString();
            },
          });
        });
      },
    });

    /* Cascada de tarjetas de pilares */
    document.querySelectorAll('.fc-pillar-card').forEach((card, i) => {
      gsap.set(card, { opacity: 0, y: 40 });
      ScrollTrigger.create({
        trigger: card,
        start: 'top 88%',
        onEnter: () => {
          gsap.to(card, { opacity: 1, y: 0, duration: 0.6, delay: i * 0.1, ease: 'power2.out' });
        },
      });
    });

    /* Cascada de tarjetas de noticias */
    document.querySelectorAll('.fc-news-card').forEach((card, i) => {
      gsap.set(card, { opacity: 0, y: 40 });
      ScrollTrigger.create({
        trigger: card,
        start: 'top 90%',
        onEnter: () => {
          gsap.to(card, { opacity: 1, y: 0, duration: 0.6, delay: i * 0.1, ease: 'power2.out' });
        },
      });
    });

    /* Cascada de columnas del quickbar */
    document.querySelectorAll('.fc-quickbar-col').forEach((col, i) => {
      gsap.set(col, { opacity: 0, y: 16 });
      gsap.to(col, { opacity: 1, y: 0, duration: 0.6, delay: 0.15 + i * 0.1, ease: 'power2.out' });
    });

    /* Cascada de iconos de la banda de features */
    document.querySelectorAll('.fc-feature-icon-item').forEach((item, i) => {
      gsap.set(item, { opacity: 0, y: 20 });
      ScrollTrigger.create({
        trigger: item,
        start: 'top 92%',
        onEnter: () => {
          gsap.to(item, { opacity: 1, y: 0, duration: 0.5, delay: i * 0.12, ease: 'power2.out' });
        },
      });
    });

    /* Entrada del hero */
    gsap.from('.fc-hero-content', { opacity: 0, y: 30, duration: 0.9, ease: 'power2.out', delay: 0.1 });
    gsap.from('.fc-hero-stat-card', { opacity: 0, y: 20, duration: 0.9, ease: 'power2.out', delay: 0.4 });

    /* Sombra del header al hacer scroll */
    const header = document.querySelector('.fc-header');
    window.addEventListener('scroll', () => {
      if (!header) return;
      if (window.scrollY > 40) header.classList.add('fc-scrolled');
      else header.classList.remove('fc-scrolled');
    });

    /* Tabs del formulario */
    const tabs = document.querySelectorAll('.fc-form-tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('fc-form-tab-active'));
        tab.classList.add('fc-form-tab-active');
      });
    });
  }
</script>