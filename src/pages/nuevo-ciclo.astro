---
import Layout from '../layouts/Layout.astro';


const pillars = [
  {
    num: "01",
    title: "Desarrollo Deportivo",
    desc: "Entrenamientos estructurados de alto rendimiento y clínicas deportivas impartidas por directores certificados internacionales.",
    color: "from-yellow-500/20 to-amber-500/10"
  },
  {
    num: "02",
    title: "Soporte Académico",
    desc: "Mentorías personalizadas, clases de nivelación académica y preparación para exámenes de ingreso a universidades de prestigio.",
    color: "from-amber-600/20 to-yellow-600/10"
  },
  {
    num: "03",
    title: "Liderazgo & Valores",
    desc: "Talleres prácticos de resolución de conflictos, inteligencia emocional, oratoria y compromiso cívico comunitario.",
    color: "from-yellow-400/20 to-amber-600/10"
  }
];

const achievements = [
  { year: "2021", title: "Fundación e Inicios", desc: "Nace la fundación con el objetivo de rescatar espacios deportivos y guiar académicamente a 50 jóvenes talentos." },
  { year: "2023", title: "Expansión y Becas USA", desc: "Firmamos convenios clave con academias de EE. UU. y logramos las primeras 12 becas deportivas completas." },
  { year: "2025", title: "Centro de Alto Rendimiento", desc: "Inauguramos el primer centro integral con salas de estudio híbridas y clínicas médicas asociadas." },
  { year: "2026", title: "Impacto Global Continuo", desc: "Superamos la cifra de 1,500 alumnos guiados en todo el país con presencia en múltiples disciplinas deportivas." }
];
---

<Layout title="NUEVO SIGLO | Fundación Deportiva y Académica">

  
  <main class="bg-[#030303] text-white min-h-screen overflow-hidden pt-28">
    
    <!-- Hero Section: Warm Amber Mesh Glow and Dynamic Counter Stats -->
    <section class="relative min-h-[95vh] flex flex-col items-center justify-center text-center px-6 py-12 md:py-0 border-b border-white/5">
      
      <!-- Fluid Warm Amber Mesh Background -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(234,179,8,0.04)_0%,transparent_50%)] pointer-events-none"></div>
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[350px] md:w-[650px] h-[350px] md:h-[650px] bg-yellow-500/10 blur-[130px] md:blur-[190px] rounded-full pointer-events-none"></div>
      
      <!-- Main Container -->
      <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 border border-yellow-500/30 bg-yellow-950/20 text-yellow-400 rounded-full text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-yellow-400"></span>
          FUNDACIÓN PARA EL DESARROLLO INTEGRAL Y DEPORTIVO
        </div>
        
        <h1 class="text-6xl md:text-8xl font-display font-bold tracking-widest text-white leading-none uppercase mb-6 hero-title">
          NUEVO SIGLO<span class="text-yellow-500 font-sans">_</span>
        </h1>
        
        <p class="text-gray-400 text-sm md:text-lg max-w-xl md:max-w-2xl leading-relaxed mb-16 hero-desc">
          Transformamos realidades a través del poder integrador del deporte de élite y la excelencia académica. Creemos en dar alas al talento juvenil para forjar profesionales y atletas de impacto global.
        </p>

        <!-- Stats Counters -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 w-full max-w-3xl border-t border-white/10 pt-10" id="stats-section">
          <div class="flex flex-col items-center">
            <span class="text-5xl md:text-6xl font-display font-bold text-yellow-500 tracking-wider flex items-center">
              <span class="stat-counter" data-target="1500">0</span><span>+</span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.2em] text-gray-500 uppercase mt-2">JÓVENES APOYADOS</span>
          </div>
          <div class="flex flex-col items-center border-y border-white/5 sm:border-y-0 sm:border-x sm:border-white/10 py-6 sm:py-0">
            <span class="text-5xl md:text-6xl font-display font-bold text-white tracking-wider flex items-center">
              <span class="stat-counter" data-target="45">0</span><span>+</span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.2em] text-gray-500 uppercase mt-2">BECAS DEPORTIVAS USA</span>
          </div>
          <div class="flex flex-col items-center">
            <span class="text-5xl md:text-6xl font-display font-bold text-yellow-500 tracking-wider flex items-center">
              <span class="stat-counter" data-target="10">0</span><span>K+</span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.2em] text-gray-500 uppercase mt-2">HORAS DE ENTRENAMIENTO</span>
          </div>
        </div>

      </div>
    </section>

    <!-- Pillars of the Foundation -->
    <section class="py-24 px-6 relative">
      <div class="absolute bottom-1/4 left-0 w-[300px] h-[300px] bg-yellow-500/5 blur-[100px] rounded-full pointer-events-none"></div>

      <div class="max-w-[1200px] mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
          <div class="text-left">
            <span class="text-yellow-500 font-display text-sm tracking-[0.3em] block mb-2">ÁREAS METODOLÓGICAS</span>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-white tracking-widest uppercase">NUESTROS TRES PILARES</h2>
          </div>
          <div class="h-[2px] w-24 bg-yellow-500/50 hidden md:block"></div>
        </div>

        <!-- Pillars Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="pillars-grid">
          {pillars.map((pillar) => (
            <div class={`p-8 border border-white/10 bg-gradient-to-br ${pillar.color} rounded-md hover:border-yellow-500/40 hover:shadow-[0_0_30px_rgba(234,179,8,0.1)] transition-all duration-500 flex flex-col justify-between group`}>
              <div>
                <span class="text-3xl font-display text-yellow-500/60 block mb-6 font-semibold">{pillar.num}</span>
                <h3 class="text-2xl font-display text-white group-hover:text-yellow-400 transition-colors mb-4">{pillar.title}</h3>
                <p class="text-gray-400 text-sm leading-relaxed mb-6">{pillar.desc}</p>
              </div>
              <div class="h-[1px] w-12 bg-white/10 group-hover:w-full group-hover:bg-yellow-500/30 transition-all duration-500"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Scrolling GSAP timeline Section -->
    <section class="py-24 px-6 bg-[#050505]/40 border-t border-white/5 relative">
      <div class="absolute top-1/2 right-10 w-[350px] h-[350px] bg-yellow-500/5 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="max-w-[1000px] mx-auto">
        <div class="text-center mb-20">
          <span class="text-yellow-500 font-display text-sm tracking-[0.3em] block mb-2">NUESTRA HISTORIA</span>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-white tracking-widest uppercase">LÍNEA DE TIEMPO DEL IMPACTO</h2>
        </div>

        <!-- Vertical Timeline for scroll-triggered GSAP animations -->
        <div class="relative pl-8 md:pl-0" id="vertical-timeline">
          
          <!-- Connective line down center on desktop, side on mobile -->
          <div class="absolute top-0 bottom-0 left-[16px] md:left-1/2 w-[2px] bg-white/10 z-0 -translate-x-1/2"></div>
          <div class="absolute top-0 left-[16px] md:left-1/2 w-[2px] bg-yellow-500 z-0 -translate-x-1/2 timeline-fill" style="height: 0%;"></div>

          {achievements.map((ach, idx) => (
            <div class="relative mb-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 timeline-row group">
              
              <!-- Indicator Year circle -->
              <div class="absolute left-[-26px] md:left-1/2 w-8 h-8 rounded-full bg-[#030303] border-2 border-white/20 group-hover:border-yellow-500 transition-colors flex items-center justify-center z-10 -translate-x-1/2 shadow-[0_0_10px_rgba(0,0,0,0.8)]">
                <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
              </div>

              <!-- Content left column (Desktop) -->
              <div class="w-full md:w-[45%] text-left md:text-right hidden md:block select-none pointer-events-none">
                {idx % 2 === 0 && (
                  <div>
                    <span class="text-4xl font-display font-bold text-yellow-500/40 group-hover:text-yellow-500 transition-colors duration-500">{ach.year}</span>
                  </div>
                )}
              </div>

              <!-- Content Card right/left depending on index -->
              <div class="w-full md:w-[45%] bg-black/60 border border-white/5 p-6 md:p-8 hover:border-yellow-500/20 transition-all duration-300 rounded-md">
                <span class="text-3xl font-display font-bold text-yellow-500/50 block md:hidden mb-2">{ach.year}</span>
                {idx % 2 !== 0 && (
                  <span class="hidden md:block text-xs font-mono tracking-widest text-yellow-500/50 uppercase mb-2">{ach.year} / CRONOLOGÍA</span>
                )}
                {idx % 2 === 0 && (
                  <span class="hidden md:block text-xs font-mono tracking-widest text-gray-500 uppercase mb-2">{ach.year} / CRONOLOGÍA</span>
                )}
                <h3 class="text-xl font-display text-white mb-2">{ach.title}</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{ach.desc}</p>
              </div>

            </div>
          ))}

        </div>
      </div>
    </section>

    <!-- Core CTA for Foundations -->
    <section class="py-32 px-6 relative text-center">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[600px] h-[350px] md:h-[600px] bg-yellow-500/10 blur-[120px] md:blur-[180px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-6 cta-title">
          ÚNETE Y CAMBIA UNA VIDA HOY
        </h2>
        <p class="text-gray-400 text-sm md:text-lg leading-relaxed mb-12 max-w-2xl">
          Ya sea que busques postular a un joven atleta talentoso o colaborar como padrino o voluntario académico/deportivo, tu esfuerzo multiplica las posibilidades de transformar el futuro.
        </p>

        <a 
          href="https://forms.gle/cVVdBKkZb4oSyXf27" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-yellow-500 hover:bg-yellow-400 text-black font-bold tracking-widest text-sm uppercase transition-all duration-300 shadow-[0_0_30px_rgba(234,179,8,0.3)] hover:shadow-[0_0_45px_rgba(234,179,8,0.6)] hover:scale-105 active:scale-95 group"
        >
          INSCRIBIRSE AHORA
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </main>
</Layout>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    // Hero Anim
    gsap.from('.hero-title', { opacity: 0, y: 30, duration: 1, ease: 'power3.out', delay: 0.4 });
    gsap.from('.hero-desc', { opacity: 0, y: 35, duration: 1, ease: 'power3.out', delay: 0.6 });

    // Numeric Stats Counters triggers
    const statCounters = document.querySelectorAll('.stat-counter');
    gsap.from(statCounters, {
      scrollTrigger: {
        trigger: '#stats-section',
        start: 'top 85%',
        toggleActions: 'play none none reverse'
      },
      opacity: 0,
      y: 20,
      duration: 0.8,
      ease: 'power3.out',
      onComplete: () => {
        statCounters.forEach(counter => {
          const target = parseInt(counter.getAttribute('data-target') || '0');
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: () => {
              counter.innerText = Math.floor(obj.val).toString();
            }
          });
        });
      }
    });

    // Pillars Grid Trigger
    gsap.from('#pillars-grid > div', {
      scrollTrigger: {
        trigger: '#pillars-grid',
        start: 'top 80%',
        toggleActions: 'play none none reverse'
      },
      y: 50,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out'
    });

    // Vertical Timeline fill animation
    gsap.to('.timeline-fill', {
      scrollTrigger: {
        trigger: '#vertical-timeline',
        start: 'top 60%',
        end: 'bottom 40%',
        scrub: 1
      },
      height: '100%'
    });

    // Timeline rows trigger
    const rows = document.querySelectorAll('.timeline-row');
    rows.forEach((row) => {
      gsap.from(row, {
        scrollTrigger: {
          trigger: row,
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: 'power3.out'
      });
    });
  }
</script>
