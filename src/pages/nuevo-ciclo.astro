</Layout>


<style>

  /* ── Tokens ─────────────────────────────────────────────────────────── */
  :root {
    --amber:        #1B5FAE;  /* azul institucional (acento primario) */
    --amber-dark:   #0F3E78;  /* azul profundo, para degradados y hover */
    --amber-light:  #E8F1FB;  /* tinte azul muy claro */
    --amber-mid:    #F2871F;  /* naranja (acento secundario) */
    --gold:         #FBBB21;  /* amarillo (tercer acento) */
    --dark:         #0E2C4E;  /* azul marino profundo */
    --dark-2:       #163F6E;  /* azul marino medio */
    --gray-1:       #F8FAFC;
    --gray-2:       #EEF2F6;
    --gray-3:       #DCE3EA;
    --gray-4:       #C0CBD6;
    --gray-5:       #64748B;
    --gray-6:       #45526A;
    --radius-sm:    6px;
    --radius-md:    14px;
    --radius-lg:    20px;
    --shadow-sm:    0 2px 12px rgba(14, 44, 78, 0.07);
    --shadow-md:    0 8px 32px rgba(14, 44, 78, 0.10);
    --shadow-lg:    0 20px 60px rgba(14, 44, 78, 0.16);
    --transition:   0.35s cubic-bezier(0.4, 0, 0.2, 1);
    --font-display: 'Poppins', sans-serif;
    --font-body:    'Work Sans', sans-serif;
  }

  .fc-root { background: var(--gray-1); color: var(--dark); overflow-x: hidden; font-family: var(--font-body); }
  .fc-root * { box-sizing: border-box; }
  .fc-container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }

  /* ── Scroll reveal base (JS agrega .is-visible) ───────────────────── */
  .fc-reveal { opacity: 0; transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.4,0,0.2,1); will-change: transform, opacity; }
  .fc-reveal-left { transform: translateX(-36px); }
  .fc-reveal-right { transform: translateX(36px); }
  .fc-reveal-up { transform: translateY(36px); }
  .fc-reveal.is-visible { opacity: 1; transform: translate(0,0); }

  /* ── Top bar ────────────────────────────────────────────────────────── */
  .fc-topbar { background: var(--dark); color: rgba(255,255,255,0.72); font-size: 12.5px; }
  .fc-topbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 9px 48px; gap: 16px; flex-wrap: wrap; }
  .fc-topbar-item strong { color: #fff; font-weight: 600; }
  .fc-topbar-right { display: flex; align-items: center; gap: 20px; }
  .fc-topbar-social { display: flex; gap: 12px; }
  .fc-topbar-social a { color: rgba(255,255,255,0.6); display: flex; transition: color var(--transition), transform var(--transition); }
  .fc-topbar-social a:hover { color: var(--amber-mid); transform: translateY(-2px); }

  /* ── Header ─────────────────────────────────────────────────────────── */
  .fc-header { background: #fff; border-bottom: 1px solid var(--gray-3); position: sticky; top: 0; z-index: 50; transition: box-shadow var(--transition); }
  .fc-header.fc-scrolled { box-shadow: var(--shadow-sm); }
  .fc-header-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 10px 48px; }
  .fc-header-logo-link { display: flex; align-items: center; flex-shrink: 0; }
  .fc-header-logo { height: 68px; width: auto; object-fit: contain; display: block; transition: transform var(--transition); }
  .fc-header-logo-link:hover .fc-header-logo { transform: scale(1.03); }
  .fc-nav { display: flex; gap: 32px; }
  .fc-nav a { font-size: 13.5px; font-weight: 600; color: var(--dark-2); text-decoration: none; transition: color var(--transition); position: relative; }
  .fc-nav a::after { content: ''; position: absolute; left: 0; bottom: -4px; width: 0; height: 2px; background: var(--amber); transition: width var(--transition); }
  .fc-nav a:hover { color: var(--amber); }
  .fc-nav a:hover::after { width: 100%; }
  .fc-header-actions { display: flex; align-items: center; gap: 14px; }
  .fc-icon-btn { background: var(--gray-2); border: none; width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--dark-2); cursor: pointer; transition: var(--transition); }
  .fc-icon-btn:hover { background: var(--amber-light); color: var(--amber); }
  .fc-nav-toggle { display: none; background: var(--gray-2); border: none; width: 38px; height: 38px; border-radius: 50%; align-items: center; justify-content: center; color: var(--dark-2); cursor: pointer; }
  .fc-mobile-nav { display: none; flex-direction: column; background: #fff; border-top: 1px solid var(--gray-3); overflow: hidden; max-height: 0; transition: max-height var(--transition); }
  .fc-mobile-nav.fc-open { max-height: 400px; }
  .fc-mobile-nav a { padding: 14px 22px; font-size: 14px; font-weight: 600; color: var(--dark-2); text-decoration: none; border-bottom: 1px solid var(--gray-2); }
  .fc-mobile-nav a:hover { background: var(--amber-light); color: var(--amber); }

  /* ── Buttons ────────────────────────────────────────────────────────── */
  .fc-btn-primary, .fc-btn-outline-light, .fc-btn-dark {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 14px 30px; border-radius: 40px; font-family: var(--font-body);
    font-size: 13px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase;
    cursor: pointer; text-decoration: none; border: none; transition: var(--transition);
  }
  .fc-btn-primary { background: linear-gradient(135deg, var(--amber) 0%, var(--amber-dark) 100%); color: #fff; box-shadow: 0 4px 15px rgba(15,92,76,0.28); }
  .fc-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,92,76,0.42); }
  .fc-btn-sm { padding: 10px 22px; font-size: 12px; }
  .fc-btn-outline-light { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.5); }
  .fc-btn-outline-light:hover { background: rgba(255,255,255,0.12); border-color: #fff; transform: translateY(-2px); }
  .fc-btn-dark { background: var(--dark); color: #fff; width: 100%; }
  .fc-btn-dark:hover { background: var(--dark-2); }

  /* ── Eyebrow / headings ─────────────────────────────────────────────── */
  .fc-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 10.5px; font-weight: 700; letter-spacing: 0.18em; color: var(--amber); text-transform: uppercase; margin-bottom: 16px; }
  .fc-eyebrow::before { content: ''; width: 20px; height: 2px; background: var(--amber); }
  .fc-eyebrow-center { justify-content: center; }
  .fc-eyebrow-center::before { display: none; }
  .fc-eyebrow-light { color: var(--gold); }
  .fc-eyebrow-light::before { background: var(--gold); }

  .fc-h2 { font-family: var(--font-display); font-size: 40px; font-weight: 600; line-height: 1.14; letter-spacing: 0.01em; color: var(--dark); margin: 0 0 16px; text-transform: uppercase; }
  .fc-h2-light { color: #fff; }
  .fc-section-head { text-align: center; max-width: 620px; margin: 0 auto 56px; }
  .fc-section-sub { font-size: 15px; color: var(--gray-5); line-height: 1.7; margin: 0; }

  .fc-check { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 50%; background: var(--amber); color: #fff; font-size: 11px; font-weight: 800; flex-shrink: 0; }
  .fc-check-sm { width: 16px; height: 16px; font-size: 9px; }
  .fc-check-light { background: rgba(255,255,255,0.25); }

  /* ══════════════════ HERO ══════════════════ */
  .fc-hero { position: relative; min-height: 88vh; display: flex; align-items: center; overflow: hidden; }
  .fc-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .fc-hero-bg img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fc-hero-scrim { position: absolute; inset: 0; background: linear-gradient(100deg, rgba(14,44,78,0.82) 20%, rgba(14,44,78,0.42) 65%, rgba(14,44,78,0.18) 100%); }
  .fc-hero-inner { position: relative; z-index: 1; display: flex; align-items: center; gap: 40px; padding-top: 60px; padding-bottom: 60px; }
  .fc-hero-arrow { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.3); color: #fff; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; transition: var(--transition); }
  .fc-hero-arrow:hover { background: var(--amber); border-color: var(--amber); }
  .fc-hero-content { max-width: 620px; }
  .fc-hero-h1 { font-family: var(--font-display); font-size: 54px; font-weight: 700; line-height: 1.14; color: #fff; margin: 0 0 28px; text-transform: uppercase; letter-spacing: 0.005em; }
  .fc-hero-h1 em { font-style: italic; background: linear-gradient(135deg, var(--gold) 0%, var(--amber-mid) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .fc-hero-checklist { list-style: none; margin: 0 0 36px; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .fc-hero-checklist li { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.92); font-size: 15px; font-weight: 500; }
  .fc-hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .fc-hero-dots { position: absolute; left: 50%; bottom: -8px; transform: translateX(-50%); display: flex; gap: 8px; }
  .fc-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.35); cursor: pointer; transition: var(--transition); }
  .fc-dot-active { background: var(--amber); width: 22px; border-radius: 5px; }

  .fc-hero-stat-card {
    position: absolute; right: 48px; bottom: 40px; z-index: 2;
    background: #fff; border-radius: var(--radius-md); box-shadow: var(--shadow-lg);
    display: flex; align-items: center; padding: 22px 30px; gap: 22px;
  }
  .fc-hero-stat-item { display: flex; align-items: center; gap: 12px; color: var(--amber); }
  .fc-hero-stat-item div { display: flex; flex-direction: column; color: var(--dark); }
  .fc-hero-stat-item strong { font-family: var(--font-display); font-size: 15px; font-weight: 700; }
  .fc-hero-stat-item span { font-size: 11.5px; color: var(--gray-5); }
  .fc-hero-stat-sep { width: 1px; height: 40px; background: var(--gray-3); }

  /* ══════════════════ QUICK CONTACT STRIP ══════════════════ */
  .fc-quickbar { background: #fff; border-bottom: 1px solid var(--gray-3); }
  .fc-quickbar-inner { display: flex; align-items: stretch; padding: 0; flex-wrap: wrap; }
  .fc-quickbar-col { display: flex; align-items: center; gap: 14px; padding: 28px 32px 28px 0; flex: 1; min-width: 200px; }
  .fc-quickbar-icon { width: 46px; height: 46px; border-radius: 50%; background: var(--amber-light); color: var(--amber); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .fc-quickbar-label { display: block; font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-5); margin-bottom: 4px; }
  .fc-quickbar-col p { margin: 0; font-size: 14px; font-weight: 600; color: var(--dark); line-height: 1.5; }
  .fc-quickbar-divider { width: 1px; background: var(--gray-3); margin: 20px 0; }
  .fc-quickbar-card { background: linear-gradient(135deg, var(--amber) 0%, var(--amber-mid) 100%); display: flex; align-items: center; padding: 0 40px; gap: 24px; flex-shrink: 0; }
  .fc-quickbar-card-item { display: flex; align-items: center; gap: 10px; color: #fff; font-size: 12.5px; font-weight: 700; line-height: 1.3; }
  .fc-quickbar-card-sep { width: 1px; height: 34px; background: rgba(255,255,255,0.3); }

  /* ══════════════════ INTRO ══════════════════ */
  .fc-intro { padding: 100px 0; }
  .fc-intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: center; }
  .fc-intro-text p { font-size: 15px; line-height: 1.82; color: var(--gray-6); margin: 0 0 28px; }
  .fc-intro-points { display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px; }
  .fc-intro-point { display: flex; gap: 14px; align-items: flex-start; }
  .fc-intro-point-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--amber); margin-top: 6px; flex-shrink: 0; }
  .fc-intro-point strong { display: block; font-size: 15px; color: var(--dark); margin-bottom: 4px; }
  .fc-intro-point p { font-size: 13.5px; color: var(--gray-5); margin: 0; line-height: 1.6; }
  .fc-intro-signature { display: flex; align-items: center; gap: 16px; padding-top: 24px; border-top: 1px solid var(--gray-3); }
  .fc-signature-mark { font-family: var(--font-display); font-style: italic; font-size: 22px; font-weight: 700; color: var(--amber); }
  .fc-intro-signature strong { display: block; font-size: 14px; color: var(--dark); }
  .fc-intro-signature span { font-size: 12px; color: var(--gray-5); }

  .fc-intro-media { position: relative; }
  .fc-intro-media img { width: 100%; height: 460px; object-fit: cover; border-radius: var(--radius-lg); display: block; }
  .fc-intro-stat { position: absolute; left: -28px; bottom: -28px; background: var(--dark); color: #fff; border-radius: var(--radius-md); padding: 24px 30px; box-shadow: var(--shadow-lg); display: flex; flex-wrap: wrap; align-items: baseline; gap: 2px; max-width: 220px; }
  .fc-intro-stat .count, .fc-intro-stat > span:first-of-type { font-family: var(--font-display); font-size: 34px; font-weight: 700; color: var(--amber-mid); }
  .fc-intro-stat p { width: 100%; margin: 4px 0 0; font-size: 11.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255,255,255,0.7); }

  /* ══════════════════ PILLARS ══════════════════ */
  .fc-pillars { background: var(--gray-2); padding: 100px 0; }
  .fc-pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .fc-pillar-card { background: #fff; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform var(--transition), box-shadow var(--transition); }
  .fc-pillar-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); }
  .fc-pillar-img { height: 190px; overflow: hidden; }
  .fc-pillar-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s ease; }
  .fc-pillar-card:hover .fc-pillar-img img { transform: scale(1.07); }
  .fc-pillar-body { padding: 28px; }
  .fc-pillar-body h3 { font-family: var(--font-display); font-size: 21px; font-weight: 600; color: var(--dark); margin: 0 0 10px; text-transform: uppercase; letter-spacing: 0.01em; }
  .fc-pillar-body > p { font-size: 13.5px; line-height: 1.7; color: var(--gray-5); margin: 0 0 18px; }
  .fc-pillar-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 9px; }
  .fc-pillar-list li { display: flex; align-items: center; gap: 10px; font-size: 12.5px; font-weight: 600; color: var(--dark-2); }
  .fc-pillar-link { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; color: var(--amber); text-transform: uppercase; text-decoration: none; transition: gap var(--transition); }
  .fc-pillar-link:hover { gap: 10px; }

  /* ══════════════════ CTA BAND ══════════════════ */
  .fc-cta-band { background: linear-gradient(120deg, var(--amber-dark) 0%, var(--amber-mid) 100%); padding: 90px 0 130px; }
  .fc-cta-band-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 56px; align-items: start; }
  .fc-cta-band-text p { color: rgba(255,255,255,0.85); font-size: 15px; line-height: 1.8; margin: 0 0 24px; }
  .fc-cta-checklist { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; }
  .fc-cta-checklist ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .fc-cta-checklist li { display: flex; align-items: center; gap: 10px; color: #fff; font-size: 14px; font-weight: 500; }

  /* ══════════════════ FORM ══════════════════ */
  .fc-form-section { margin-top: -90px; padding-bottom: 100px; position: relative; z-index: 3; }
