---
import Layout from '../layouts/Layout.astro';

const nav = [
  { label: "Inicio", href: "#fc-hero" },
  { label: "Nosotros", href: "#fc-intro" },
  { label: "Programas", href: "#fc-pillars" },
  { label: "Noticias", href: "#fc-news" },
  { label: "Contacto", href: "#fc-cta" },
];

const pillars = [
  {
    num: "Investigación",
    title: "Investigación Aplicada",
    desc: "Generamos conocimiento riguroso y estudios técnicos que responden a los desafíos reales de organizaciones, comunidades y sectores productivos.",
    points: ["Metodología rigurosa", "Datos verificables", "Impacto medible"],
    img: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=700&auto=format&fit=crop&q=80",
    alt: "Equipo de investigadores analizando datos"
  },
  {
    num: "Capacitación",
    title: "Capacitación Técnica",
    desc: "Cursos, talleres y seminarios complementarios para identificar retos, oportunidades y riesgos del entorno regional e internacional.",
    points: ["Docentes especializados", "Certificación oficial", "Modalidad flexible"],
    img: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=700&auto=format&fit=crop&q=80",
    alt: "Sesión de capacitación profesional"
  },
  {
    num: "Asistencia",
    title: "Asistencia Técnica",
    desc: "Acompañamiento especializado para la implementación de soluciones sostenibles, la transferencia de tecnología y la mejora institucional.",
    points: ["Diagnóstico a medida", "Seguimiento continuo", "Soluciones sostenibles"],
    img: "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&auto=format&fit=crop&q=80",
    alt: "Equipo técnico revisando información en pantallas"
  }
];

const news = [
  {
    year: "1997",
    tag: "Institucional",
    title: "Fundación Institucional",
    desc: "Nace la Fundación mediante Resolución Administrativa N.º 224/1997, con el propósito de generar conocimiento aplicado.",
    img: "https://images.unsplash.com/photo-1552581234-26160f608093?w=700&auto=format&fit=crop&q=80"
  },
  {
    year: "2017",
    tag: "Alcance regional",
    title: "Alcance Regional",
    desc: "Extendemos nuestros servicios de asistencia técnica a organizaciones de distintos sectores, con proyectos de alcance regional.",
    img: "https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=700&auto=format&fit=crop&q=80"
  },
  {
    year: "2026",
    tag: "Compromiso renovado",
    title: "Compromiso Renovado",
    desc: "Continuamos formando profesionales y acompañando procesos de innovación, con presencia activa en tres frentes de trabajo.",
    img: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=700&auto=format&fit=crop&q=80"
  }
];

const partners = ["ANDEC", "Cámara de Industria", "Red Universitaria", "Instituto Técnico", "Consorcio Regional", "Alianza Productiva"];
---

<Layout title="Fundación Nuevo Siglo | Investigación, Capacitación y Asistencia Técnica">

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Work+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <main class="fc-root">

    <!-- ═══════════════════════════ TOP BAR ═══════════════════════════ -->
    <div class="fc-topbar">
      <div class="fc-container fc-topbar-inner">
        <span class="fc-topbar-item">¿Necesitas orientación? Escríbenos: <strong>info@nuevosiglo.org.bo</strong></span>
        <div class="fc-topbar-right">
          <span class="fc-topbar-item">Tel: <strong>75463703</strong></span>
          <div class="fc-topbar-social">
            <a href="#" aria-label="Facebook">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z"/></svg>
            </a>
            <a href="#" aria-label="Instagram">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
            </a>
            <a href="#" aria-label="LinkedIn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.1 3.77-2.1 4 0 4.75 2.7 4.75 6.1V21h-4v-5.6c0-1.3 0-3-1.85-3-1.85 0-2.13 1.4-2.13 2.9V21H9z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
    <header class="fc-header">
      <div class="fc-container fc-header-inner">
        <a href="#fc-hero" class="fc-header-logo-link">
          <img src="/images/ns.png" alt="Fundación Nuevo Siglo — Investigación, Capacitación y Asistencia Técnica" class="fc-header-logo" />
        </a>
        <nav class="fc-nav">
          {nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
        <div class="fc-header-actions">
          <button class="fc-icon-btn" aria-label="Buscar">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
          <a href="https://forms.gle/cVVdBKkZb4oSyXf27" target="_blank" rel="noopener noreferrer" class="fc-btn-primary fc-btn-sm">
            Inscribirse
          </a>
          <button class="fc-nav-toggle" aria-label="Abrir menú" id="fc-nav-toggle">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
      <nav class="fc-mobile-nav" id="fc-mobile-nav">
        {nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </header>

    <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
    <section class="fc-hero" id="fc-hero">
      <div class="fc-hero-bg">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1600&auto=format&fit=crop&q=80" alt="Equipo técnico de la fundación trabajando en conjunto" loading="eager" decoding="async" onerror="this.style.display='none'" />
        <div class="fc-hero-scrim"></div>
      </div>

      <div class="fc-container fc-hero-inner">
        <button class="fc-hero-arrow fc-hero-arrow-left" aria-label="Anterior">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        </button>

        <div class="fc-hero-content">
          <h1 class="fc-hero-h1">Convertimos<br/>Conocimiento en<br/><em>Desarrollo Real</em></h1>

          <ul class="fc-hero-checklist">
            <li><span class="fc-check">✓</span> Investigación aplicada y rigurosa</li>
            <li><span class="fc-check">✓</span> Cursos, talleres y seminarios certificados</li>
            <li><span class="fc-check">✓</span> Asistencia técnica especializada</li>
          </ul>

          <div class="fc-hero-btns">
            <a href="#fc-intro" class="fc-btn-outline-light">Más sobre nosotros</a>
            <a href="#fc-pillars" class="fc-btn-primary">Nuestros programas</a>
          </div>
        </div>

        <div class="fc-hero-dots">
          <span class="fc-dot fc-dot-active"></span>
          <span class="fc-dot"></span>
          <span class="fc-dot"></span>
        </div>
      </div>

      <div class="fc-hero-stat-card">
        <div class="fc-hero-stat-item">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <div>
            <strong>Investigación</strong>
            <span>Rigurosa y aplicada</span>
          </div>
        </div>
        <div class="fc-hero-stat-sep"></div>
        <div class="fc-hero-stat-item">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          <div>
            <strong>29 años</strong>
            <span>De trayectoria</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ QUICK CONTACT STRIP ═══════════════════════════ -->
    <section class="fc-quickbar">
      <div class="fc-container fc-quickbar-inner">
        <div class="fc-quickbar-col">
          <div class="fc-quickbar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16v16H4z"/><path d="m4 4 8 9 8-9"/></svg>
          </div>
          <div>
            <span class="fc-quickbar-label">Contacto Directo</span>
            <p>info@nuevosiglo.org.bo<br/>75463703</p>
          </div>
        </div>
        <div class="fc-quickbar-divider"></div>
        <div class="fc-quickbar-col">
          <div class="fc-quickbar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <span class="fc-quickbar-label">Nuestra Sede</span>
            <p>C. J. de la Reza 236, Cochabamba</p>
          </div>
        </div>
        <div class="fc-quickbar-divider"></div>
        <div class="fc-quickbar-col">
          <div class="fc-quickbar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          </div>
          <div>
            <span class="fc-quickbar-label">Horario de Atención</span>
            <p>Lun-Vie 09:30-12:30 y 15:00-18:30</p>
          </div>
        </div>
        <div class="fc-quickbar-card">
          <div class="fc-quickbar-card-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            <span>Certificación<br/>Oficial</span>
          </div>
          <div class="fc-quickbar-card-sep"></div>
          <div class="fc-quickbar-card-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span>Compromiso<br/>Sostenible</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ INTRO / QUIÉNES SOMOS ═══════════════════════════ -->
    <section class="fc-intro" id="fc-intro">
      <div class="fc-container fc-intro-grid">
        <div class="fc-intro-text fc-reveal fc-reveal-left">
          <span class="fc-eyebrow">Quiénes Somos</span>
          <h2 class="fc-h2">Fortaleciendo el desarrollo con conocimiento aplicado</h2>
          <p>
            Desde 1997, mediante la Resolución Administrativa N.º 224/1997, trabajamos para
            generar conocimiento aplicado, fortalecer capacidades y brindar asistencia técnica
            especializada a organizaciones, comunidades y sectores productivos.
          </p>

          <div class="fc-intro-points">
            <div class="fc-intro-point">
              <span class="fc-intro-point-dot"></span>
              <div>
                <strong>Rigor investigativo</strong>
                <p>Cada estudio que publicamos sigue una metodología verificable y trazable.</p>
              </div>
            </div>
            <div class="fc-intro-point">
              <span class="fc-intro-point-dot"></span>
              <div>
                <strong>Compromiso institucional</strong>
                <p>Acompañamos a nuestros aliados con seguimiento continuo, no solo entrega de informes.</p>
              </div>
            </div>
          </div>

          <div class="fc-intro-signature">
            <div class="fc-signature-mark">NS</div>
            <div>
              <strong>Directorio Ejecutivo</strong>
              <span>Fundación Nuevo Siglo</span>
            </div>
          </div>
        </div>

        <div class="fc-intro-media fc-reveal fc-reveal-right">
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=900&auto=format&fit=crop&q=80" alt="Reunión de trabajo técnico" loading="lazy" decoding="async" />
          <div class="fc-intro-stat">
            <span class="count" data-target="8000">0</span><span>+</span>
            <p>Profesionales Capacitados</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ PILARES ═══════════════════════════ -->
    <section class="fc-pillars" id="fc-pillars">
      <div class="fc-container">
        <div class="fc-section-head">
          <span class="fc-eyebrow fc-eyebrow-center">Áreas de Acción</span>
          <h2 class="fc-h2">Gestionando desarrollo para instituciones y comunidades</h2>
        </div>

        <div class="fc-pillars-grid" id="fc-pillars-grid">
          {pillars.map((pillar) => (
            <article class="fc-pillar-card">
              <div class="fc-pillar-img">
                <img src={pillar.img} alt={pillar.alt} loading="lazy" decoding="async" />
              </div>
              <div class="fc-pillar-body">
                <h3>{pillar.title}</h3>
                <p>{pillar.desc}</p>
                <ul class="fc-pillar-list">
                  {pillar.points.map((p) => (
                    <li><span class="fc-check fc-check-sm">✓</span>{p}</li>
                  ))}
                </ul>
                <a href="#fc-cta" class="fc-pillar-link">
                  Leer más
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ CTA BAND + FORM ═══════════════════════════ -->
    <section class="fc-cta-band" id="fc-cta">
      <div class="fc-container fc-cta-band-grid">
        <div class="fc-reveal fc-reveal-left">
          <span class="fc-eyebrow fc-eyebrow-light">Formación Que Transforma</span>
          <h2 class="fc-h2 fc-h2-light">Cursos y talleres que<br/>impulsan tu futuro profesional</h2>
        </div>
        <div class="fc-cta-band-text fc-reveal fc-reveal-right">
          <p>
            Nos enorgullece ofrecer los mejores programas de formación técnica disponibles.
            Nuestro cuerpo docente combina experiencia académica y de campo, apoyado en
            metodologías actualizadas y décadas de trabajo aplicado.
          </p>
          <div class="fc-cta-checklist">
            <ul>
              <li><span class="fc-check fc-check-light">✓</span> Metodología rigurosa</li>
              <li><span class="fc-check fc-check-light">✓</span> Certificación oficial</li>
              <li><span class="fc-check fc-check-light">✓</span> Docentes especializados</li>
            </ul>
            <ul>
              <li><span class="fc-check fc-check-light">✓</span> Modalidad flexible</li>
              <li><span class="fc-check fc-check-light">✓</span> Seguimiento continuo</li>
              <li><span class="fc-check fc-check-light">✓</span> Soluciones sostenibles</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="fc-form-section">
      <div class="fc-container">
        <div class="fc-form-card fc-reveal fc-reveal-up">
          <div class="fc-form-tabs">
            <button class="fc-form-tab fc-form-tab-active" data-tab="inscripcion">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              Inscribirse a un Curso
            </button>
            <button class="fc-form-tab" data-tab="asistencia">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              Solicitar Asistencia Técnica
            </button>
          </div>

          <div class="fc-form-body">
            <form class="fc-form-fields" id="fc-form-inscripcion">
              <div class="fc-form-row">
                <input type="text" placeholder="Nombre completo" required />
                <input type="email" placeholder="Correo electrónico" required />
                <input type="tel" placeholder="Teléfono" required />
              </div>
              <div class="fc-form-row">
                <select required>
                  <option value="">Programa de interés</option>
                  <option>Curso de Gestión de Proyectos</option>
                  <option>Taller de Formulación de Estudios Técnicos</option>
                  <option>Seminario de Gestión Institucional</option>
                </select>
                <input type="text" placeholder="Ciudad" />
                <select>
                  <option value="">Modalidad</option>
                  <option>Presencial</option>
                  <option>Virtual</option>
                </select>
              </div>
              <button type="submit" class="fc-btn-dark fc-form-submit">Enviar Inscripción</button>
            </form>

            <div class="fc-form-side">
              <span class="fc-form-side-eyebrow">Programa Docente</span>
              <h3>¿Quieres ser ponente?</h3>
              <p>Compartimos conocimiento con especialistas comprometidos con el desarrollo técnico regional.</p>
              <a href="#" class="fc-btn-primary fc-btn-sm">Postular ahora</a>
            </div>
          </div>
        </div>

        <!-- Testimonials -->
        <div class="fc-testimonials">
          <div class="fc-testimonial fc-reveal fc-reveal-up">
            <div class="fc-stars">★★★★★</div>
            <p>El curso me dio herramientas concretas para enfrentar los retos técnicos de mi organización. Hoy aplico ese conocimiento en cada proyecto que lidero.</p>
            <strong>María Fernández</strong>
            <span>Egresada · Curso de Gestión de Proyectos, 2024</span>
          </div>
          <div class="fc-testimonial fc-reveal fc-reveal-up">
            <div class="fc-stars">★★★★★</div>
            <p>El acompañamiento técnico fue clave para implementar mejoras reales en nuestros procesos, con seguimiento constante del equipo de la fundación.</p>
            <strong>Sami Wade</strong>
            <span>Responsable Logístico, Institución Aliada</span>
          </div>
        </div>

        <!-- Partners -->
        <div class="fc-partners-wrap">
          <div class="fc-partners-track">
            {partners.map((p) => (
              <span class="fc-partner-name">{p}</span>
            ))}
            {partners.map((p) => (
              <span class="fc-partner-name" aria-hidden="true">{p}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ FEATURE BAND ═══════════════════════════ -->
    <section class="fc-feature-band">
      <div class="fc-container fc-feature-grid">
        <div class="fc-feature-text fc-reveal fc-reveal-left">
          <span class="fc-eyebrow fc-eyebrow-light">Acompañamiento Continuo</span>
          <h2 class="fc-h2 fc-h2-light">Un aliado técnico para instituciones y comunidades</h2>
          <p>
            Articulamos investigación, formación y transferencia tecnológica bajo principios
            de responsabilidad social, ética e inclusión, generando soluciones pertinentes
            para el desarrollo económico, social y ambiental.
          </p>

          <div class="fc-feature-icons">
            <div class="fc-feature-icon-item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M2 12h20"/></svg>
              <span>Transparencia<br/>Institucional</span>
            </div>
            <div class="fc-feature-icon-item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
              <span>Seguimiento<br/>Continuo</span>
            </div>
            <div class="fc-feature-icon-item">
