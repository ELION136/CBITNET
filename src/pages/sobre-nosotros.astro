---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AutoridadesCarousel from '../components/AutoridadesCarousel.astro';

// Datos de los Valores Corporativos
const valores = [
  {
    id: "integridad",
    title: "INTEGRIDAD",
    color: "#f59e0b", // Dorado / Ámbar
    glow: "rgba(245,158,11,0.25)",
    image: "https://picsum.photos/seed/valintegrity/600/400",
    desc: "Actuamos con honestidad, ética y responsabilidad en cada acción de formación educativa y deportiva.",
    details: "Para nosotros, la integridad es el pilar de la confianza. Formamos a estudiantes y atletas bajo rigurosos principios morales, garantizando una competencia justa y un aprendizaje transparente y de alta calidad."
  },
  {
    id: "inclusion",
    title: "INCLUSIÓN",
    color: "#10b981", // Esmeralda / Verde
    glow: "rgba(16,185,129,0.25)",
    image: "https://picsum.photos/seed/valinclusion/600/400",
    desc: "Promovemos la igualdad de oportunidades, respetando la diversidad cultural, social y de capacidades.",
    details: "Derribamos barreras físicas y sociales para construir una comunidad diversa. En CBIT, creemos que el talento no tiene fronteras y que cada persona aporta un valor único e indispensable al colectivo."
  },
  {
    id: "bienestar",
    title: "BIENESTAR",
    color: "#8b5cf6", // Violeta / Lavanda
    glow: "rgba(139,92,246,0.25)",
    image: "https://picsum.photos/seed/valwellbeing/600/400",
    desc: "Promovemos hábitos saludables y una vida equilibrada en lo físico, emocional y social.",
    details: "El éxito verdadero nace de la armonía. Diseñamos entornos educativos y rutinas físicas que priorizan la salud mental, el descanso, la alimentación balanceada y las relaciones interpersonales sanas."
  },
  {
    id: "disciplina",
    title: "DISCIPLINA",
    color: "#ef4444", // Rojo
    glow: "rgba(239,68,68,0.25)",
    image: "https://picsum.photos/seed/valdiscipline/600/400",
    desc: "Fomentamos el compromiso, la constancia y la responsabilidad personal como fundamentos del desarrollo humano y deportivo.",
    details: "La constancia supera al talento innato. Inculcamos la dedicación diaria y la auto-exigencia organizada como herramientas indispensables para superar desafíos y forjar caracteres inquebrantables."
  },
  {
    id: "superacion",
    title: "SUPERACIÓN",
    color: "#0ea5e9", // Cian
    glow: "rgba(14,165,233,0.25)",
    image: "https://picsum.photos/seed/valexcellence/600/400",
    desc: "Impulsamos el deseo de aprender, mejorar y alcanzar metas, tanto personales como colectivas.",
    details: "Buscamos siempre rebasar nuestros propios límites. Fomentamos una mentalidad de crecimiento continuo (kaizen) donde los errores son oportunidades de aprendizaje y cada meta alcanzada es el punto de inicio de un nuevo reto."
  },
  {
    id: "trabajo-equipo",
    title: "TRABAJO EN EQUIPO",
    color: "#2dd4bf", // Teal / Turquesa
    glow: "rgba(45,212,191,0.25)",
    image: "https://picsum.photos/seed/valteamwork/600/400",
    desc: "Valoramos la cooperación, la solidaridad y el apoyo mutuo como principios que fortalecen el crecimiento comunitario.",
    details: "La sinergia de voluntades multiplica los resultados. Enseñar a colaborar, delegar y celebrar el triunfo ajeno es la piedra angular sobre la que descansa el éxito colectivo de nuestros alumnos y atletas."
  }
];

// Datos del Personal
const personal = [
  { name: "Prof. Alejandro Valda", role: "Coordinador Deportivo", desc: "Ex-atleta olímpico y consultor certificado en alto rendimiento.", image: "https://picsum.photos/seed/staff1/300/300", badge: "Deportes", color: "#f59e0b" },
  { name: "Dra. Valeria Sanjinés", role: "Psicóloga del Deporte", desc: "Especialista en preparación mental y motivación estudiantil.", image: "https://picsum.photos/seed/staff2/300/300", badge: "Bienestar", color: "#8b5cf6" },
  { name: "Ing. Roberto Claros", role: "Tecnología Educativa", desc: "Director de plataformas virtuales y educación digital.", image: "https://picsum.photos/seed/staff3/300/300", badge: "Académica", color: "#0ea5e9" },
  { name: "Lic. Andrea Torrico", role: "Coordinadora de Relaciones", desc: "Gestora de convenios internacionales y apoyo social.", image: "https://picsum.photos/seed/staff4/300/300", badge: "Convenios", color: "#2dd4bf" }
];

// Datos de los Certificados
const certificados = [
  {
    title: "Alto Rendimiento Deportivo",
    issuer: "INAF - Deportes CBIT",
    desc: "Acredita capacidades de nivel competitivo, preparación física táctica y liderazgo de equipo.",
    badge: "Sports Certified",
    color: "#f59e0b",
    glow: "rgba(245,158,11,0.25)",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
  },
  {
    title: "Formación Integral Académica",
    issuer: "CBIT Corporativo",
    desc: "Valida competencias profesionales de gestión, ética y desarrollo en planes curriculares avanzados.",
    badge: "Academic Honor",
    color: "#0ea5e9",
    glow: "rgba(14,165,233,0.25)",
    icon: "M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 6v12M6 12h12"
  },
  {
    title: "Gestión y Liderazgo Cívico",
    issuer: "Club de Leones Alianza",
    desc: "Certifica proyectos de voluntariado de alto impacto y gestión social cívico-comunitaria.",
    badge: "Civic Leadership",
    color: "#10b981",
    glow: "rgba(16,185,129,0.25)",
    icon: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"
  }
];
---

<Layout title="Sobre Nosotros | Sports & Academic Hub">
  <Navbar />
  <main class="bg-[#030303] min-h-screen overflow-hidden pt-32 pb-24 relative">
    
    <!-- ── BACKGROUND BEAM CANVAS ── -->
    <canvas id="about-beam-canvas" class="absolute inset-0 w-full h-full z-0 pointer-events-none opacity-40"></canvas>

    <!-- ── 1. SECCIÓN: RESEÑA HISTÓRICA ── -->
    <section class="container mx-auto px-6 relative z-10 mb-36" id="history-section">
      <!-- Title Block -->
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 border-b border-white/10 pb-12 mb-16">
        <h1 class="text-5xl md:text-7xl lg:text-[8rem] font-display font-bold text-white tracking-tighter leading-none reveal-item">
          RESEÑA <br/>
          <span class="text-[#0ea5e9] filter drop-shadow-[0_0_20px_rgba(14,165,233,0.3)]">HISTÓRICA</span>
        </h1>
        <div class="w-full lg:w-5/12 pb-2 reveal-item delay-200">
          <p class="text-gray-400 text-base md:text-lg border-l-2 border-[#0ea5e9] pl-6 leading-relaxed">
            Forjando campeones dentro y fuera de las aulas. Una trayectoria orientada al desarrollo integral del talento boliviano mediante alianzas educativas de gran envergadura.
          </p>
        </div>
      </div>

      <!-- Historical Content Frame (Estilo CoverflowHero) -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Foto Histórica con marco tecnológico -->
        <div class="lg:col-span-7 relative group overflow-hidden select-none reveal-item" style="perspective:1000px;">
          <!-- Glowing Border Frame using cut-path -->
          <div class="absolute inset-0 p-[2px] transition-all duration-500 group-hover:scale-[1.01]"
               style="
                 clip-path: polygon(10% 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%);
                 background: linear-gradient(135deg, #0ea5e9, #2dd4bf);
               ">
            <div class="w-full h-full bg-[#060606] relative overflow-hidden"
                 style="clip-path: polygon(10% 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%);">
              <img src="https://picsum.photos/seed/aboutlegacy/900/600" alt="Reseña histórica" 
                   class="w-full h-[380px] md:h-[480px] object-cover opacity-60 group-hover:opacity-90 group-hover:scale-105 transition-all duration-1000" />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/35 to-transparent"></div>
              
              <!-- Corner technological brackets inside card -->
              <div class="absolute top-0 left-0 w-8 h-[2px] bg-[#0ea5e9]"></div>
              <div class="absolute top-0 left-0 w-[2px] h-8 bg-[#0ea5e9]"></div>
              <div class="absolute bottom-0 right-0 w-8 h-[2px] bg-[#2dd4bf]"></div>
              <div class="absolute bottom-0 right-0 w-[2px] h-8 bg-[#2dd4bf]"></div>

              <!-- Label text inside image -->
              <div class="absolute bottom-8 left-8 text-left z-10">
                <span class="text-[#0ea5e9] font-bold tracking-[0.25em] text-xs uppercase mb-2 block font-display">FUNDACIÓN E IMPACTO</span>
                <h3 class="font-display text-2xl md:text-3xl text-white tracking-wider leading-none">CBIT: EL INICIO DE LA EXCELENCIA</h3>
              </div>
            </div>
          </div>
        </div>

        <!-- Texto Histórico -->
        <div class="lg:col-span-5 flex flex-col gap-6 reveal-item delay-300 text-left">
          <div class="relative">
            <h2 class="text-xl font-display text-white tracking-widest uppercase mb-4">
              VISIÓN <span class="text-[#2dd4bf]">GLOBAL</span> Y LEGADO
            </h2>
            <div class="h-[2px] w-12 bg-gradient-to-r from-[#0ea5e9] to-[#2dd4bf] mb-6"></div>
          </div>

          <p class="text-gray-400 text-sm md:text-base leading-relaxed">
            Desde la fundación de la **Corporación Boliviana de Talento (CBIT)**, nos propusimos un desafío audaz: demostrar que el desarrollo intelectual y el rendimiento físico no son caminos paralelos, sino fuerzas que se complementan para dar origen a líderes íntegros.
          </p>

          <p class="text-gray-400 text-sm md:text-base leading-relaxed">
            A lo largo de los años, hemos consolidado alianzas estratégicas con institutos de alto renombre deportivo como **INAF**, centros de capacitación como **CENACAP**, e importantes instituciones sociales y cívicas. Evaluamos de manera constante planes educativos, infraestructura y oportunidades académicas para abrirle las mejores puertas internacionales a nuestros atletas.
          </p>

          <div class="mt-4 flex items-center gap-4">
            <div class="flex flex-col">
              <span class="text-3xl font-display font-bold text-white leading-none">50+</span>
              <span class="text-[#0ea5e9] text-[10px] font-bold uppercase tracking-wider mt-1">Convenios de Nivel</span>
            </div>
            <div class="w-[1px] h-10 bg-white/10 mx-2"></div>
            <div class="flex flex-col">
              <span class="text-3xl font-display font-bold text-white leading-none">2000+</span>
              <span class="text-[#2dd4bf] text-[10px] font-bold uppercase tracking-wider mt-1">Talentos Formados</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 2. SECCIÓN: VALORES CORPORATIVOS ── -->
    <section class="container mx-auto px-6 relative z-10 mb-36" id="valores-section">
      <div class="text-center mb-16">
        <span class="text-[#f59e0b] font-bold tracking-[0.3em] text-xs uppercase mb-3 block font-display">FUNDAMENTOS ÉTICOS</span>
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-4 reveal-item">
          VALORES <span class="text-amber-400 filter drop-shadow-[0_0_15px_rgba(245,158,11,0.25)]">COOPERATIVOS</span>
        </h2>
        <div class="w-16 h-[2px] bg-amber-400 mx-auto reveal-item"></div>
      </div>

      <!-- Acordeón Deslizante Vertical e Interactivo (Creatividad en mostrarlo!) -->
      <div class="max-w-4xl mx-auto flex flex-col gap-4 relative z-20 reveal-item">
        {valores.map((val, index) => (
          <div 
            class="value-accordion-item border transition-all duration-500 overflow-hidden bg-[#060606]/85 backdrop-blur-md relative"
            style={`
              border-color: rgba(255,255,255,0.06);
              clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
              --val-color: ${val.color};
              --val-glow: ${val.glow};
            `}
            data-value-id={val.id}
          >
            <!-- Background Glow Dynamic -->
            <div class="absolute inset-0 opacity-0 transition-opacity duration-500 bg-glow-layer pointer-events-none" 
                 style={`background: linear-gradient(135deg, ${val.glow}, transparent);`}></div>
                 
            <!-- Top indicator line -->
            <div class="absolute top-0 left-0 right-0 h-[2px] scale-x-0 origin-left transition-transform duration-500 indicator-line"
                 style={`background: ${val.color};`}></div>

            <!-- Trigger Button -->
            <button 
              class="w-full px-6 py-6 md:px-8 md:py-7 flex items-center justify-between gap-4 text-left select-none outline-none focus:outline-none pointer-events-auto"
              aria-expanded="false"
            >
              <div class="flex items-center gap-4">
                <span class="font-display text-lg md:text-xl font-bold tracking-[0.2em] transition-colors duration-300 val-title" style={`color: ${val.color};`}>
                  {val.title}
                </span>
              </div>
              
              <!-- Interactive Arrow Bracket -->
              <div class="w-8 h-8 rounded-full border flex items-center justify-center transition-all duration-500 transform arrow-box bg-white/[0.01]"
                   style={`border-color: rgba(255,255,255,0.1); color: ${val.color};`}>
                <svg class="w-3.5 h-3.5 transition-transform duration-500 transform rotate-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </button>

            <!-- Slide Vertical Container -->
            <div class="value-content-wrapper max-h-0 opacity-0 transition-all duration-500 ease-in-out overflow-hidden">
              <div class="px-6 pb-8 md:px-8 md:pb-10 pt-2 grid grid-cols-1 md:grid-cols-12 gap-8 items-center border-t border-white/5">
                <!-- Text Area -->
                <div class="md:col-span-7 text-left">
                  <p class="text-white text-base md:text-lg font-medium leading-relaxed mb-4 border-l-2 pl-4" style={`border-color: ${val.color};`}>
                    {val.desc}
                  </p>
                  <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                    {val.details}
                  </p>
                </div>
                
                <!-- Image Area with Cut-Path Cyber styling -->
                <div class="md:col-span-5 relative group overflow-hidden select-none">
                  <div class="absolute inset-0 p-[1.5px]"
                       style={`
                         clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
                         background: linear-gradient(135deg, ${val.color}, transparent);
                       `}>
                    <div class="w-full h-full bg-[#030303]" style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));">
                      <img src={val.image} alt={val.title} 
                           class="w-full h-[180px] object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-all duration-750" />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 3. SECCIÓN: AUTORIDADES ── -->
    <section class="border-t border-white/5 pt-24 relative z-10 mb-36" id="autoridades-section">
      <div class="container mx-auto px-6 text-center mb-6">
        <span class="text-[#0ea5e9] font-bold tracking-[0.3em] text-xs uppercase mb-3 block font-display">LIDERAZGO ACTIVO</span>
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-4 reveal-item">
          NUESTRAS <span class="text-cyan-400 filter drop-shadow-[0_0_15px_rgba(14,165,233,0.25)]">AUTORIDADES</span>
        </h2>
        <div class="w-16 h-[2px] bg-cyan-400 mx-auto reveal-item"></div>
      </div>
      
      <div class="reveal-item">
        <AutoridadesCarousel />
      </div>
    </section>

    <!-- ── 4. SECCIÓN: NUESTRO PERSONAL ── -->
    <section class="container mx-auto px-6 relative z-10 mb-36" id="personal-section">
      <div class="text-center mb-16">
        <span class="text-[#2dd4bf] font-bold tracking-[0.3em] text-xs uppercase mb-3 block font-display">EQUIPO DE EXCELENCIA</span>
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-4 reveal-item">
          NUESTRO <span class="text-teal-400 filter drop-shadow-[0_0_15px_rgba(45,212,191,0.25)]">PERSONAL</span>
        </h2>
        <div class="w-16 h-[2px] bg-teal-400 mx-auto reveal-item"></div>
      </div>

      <!-- Staff Cards Grid (Cyber Digital ID cards) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        {personal.map((staff, idx) => (
          <div 
            class="staff-card border bg-[#060606]/80 backdrop-blur-md overflow-hidden relative group transition-all duration-300 cursor-default reveal-item"
            style={`
              border-color: rgba(255,255,255,0.06);
              clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
              transform: translateY(0);
            `}
          >
            <!-- Hover Dynamic Fill -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
                 style={`background: linear-gradient(135deg, ${staff.color}15, transparent);`}></div>
            
            <div class="p-5 flex flex-col items-center text-center">
              <!-- Profile Image Frame -->
              <div class="w-28 h-28 rounded-full overflow-hidden border-2 mb-4 transition-all duration-500 scale-95 group-hover:scale-100 shadow-lg"
                   style={`border-color: ${staff.color}60; box-shadow: 0 0 15px ${staff.color}1a;`}>
                <img src={staff.image} alt={staff.name} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
              </div>

              <!-- Badge -->
              <span class="text-[9px] font-bold tracking-[0.2em] uppercase px-2 py-0.5 rounded border mb-3"
                    style={`color: ${staff.color}; border-color: ${staff.color}35; background: ${staff.color}0a;`}>
                {staff.badge}
              </span>

              <!-- Text Info -->
              <h3 class="font-display text-base text-white font-bold leading-tight group-hover:text-white transition-colors duration-300">
                {staff.name}
              </h3>
              <p class="text-white/40 text-[10px] font-semibold uppercase tracking-wider mt-1 mb-3">
                {staff.role}
              </p>
              
              <div class="w-8 h-[1px] bg-white/10 mb-3 group-hover:w-16 transition-all duration-300"></div>

              <p class="text-gray-400 text-xs leading-relaxed">
                {staff.desc}
              </p>
            </div>

            <!-- Sleek indicator bar at the bottom -->
            <div class="absolute bottom-0 left-0 right-0 h-[2px] scale-x-0 group-hover:scale-x-100 origin-center transition-transform duration-300"
                 style={`background: ${staff.color};`}></div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 5. SECCIÓN: CERTIFICACIÓN ── -->
    <section class="container mx-auto px-6 relative z-10 mb-20" id="certificacion-section">
      <div class="text-center mb-16">
        <span class="text-[#8b5cf6] font-bold tracking-[0.3em] text-xs uppercase mb-3 block font-display">DOCUMENTACIÓN OFICIAL</span>
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-4 reveal-item">
          VALIDEZ Y <span class="text-violet-400 filter drop-shadow-[0_0_15px_rgba(139,92,246,0.25)]">CERTIFICACIÓN</span>
        </h2>
        <div class="w-16 h-[2px] bg-violet-400 mx-auto reveal-item"></div>
      </div>

      <!-- Certificates interactive grids -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {certificados.map((cert, index) => (
          <div 
            class="certificate-card border bg-[#060606]/85 backdrop-blur-md overflow-hidden relative group transition-all duration-500 cursor-default select-none reveal-item"
            style={`
              border-color: rgba(255,255,255,0.06);
              clip-path: polygon(10% 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%);
              --cert-color: ${cert.color};
              --cert-glow: ${cert.glow};
            `}
          >
            <!-- Simulated metallic holographic glow sweep -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-750 pointer-events-none z-10"
                 style="
                   background: linear-gradient(135deg, 
                     rgba(255,255,255,0) 30%, 
                     rgba(255,255,255,0.08) 48%, 
                     rgba(255,255,255,0.2) 50%, 
                     rgba(255,255,255,0.08) 52%, 
                     rgba(255,255,255,0) 70%
                   );
                   background-size: 200% 200%;
                   background-position: -120% -120%;
                 "
                 id={`holo-sweep-${index}`}></div>

            <!-- Soft background color glow -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                 style={`background: linear-gradient(135deg, ${cert.glow}, transparent 60%);`}></div>

            <div class="p-6 md:p-8 flex flex-col justify-between h-[360px] text-left relative z-20">
              <!-- Top Header -->
              <div class="flex items-start justify-between">
                <!-- Glowing Badge Icon with glow -->
                <div class="w-12 h-12 rounded-xl flex items-center justify-center border transition-all duration-300"
                     style={`border-color: ${cert.color}40; background: ${cert.color}0a; color: ${cert.color}; box-shadow: 0 0 12px ${cert.color}15;`}>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform duration-300">
                    <path d={cert.icon} />
                  </svg>
                </div>
                
                <!-- Badge Text -->
                <span class="text-[9px] font-bold tracking-[0.2em] uppercase px-2.5 py-1 rounded border"
                      style={`color: ${cert.color}; border-color: ${cert.color}35; background: ${cert.color}0f;`}>
                  {cert.badge}
                </span>
              </div>

              <!-- Center Body -->
              <div class="my-6">
                <span class="text-white/40 text-[9px] font-bold tracking-[0.25em] uppercase block mb-1">PROGRAMA OFICIAL</span>
                <h3 class="font-display text-xl md:text-2xl text-white font-bold leading-tight group-hover:text-white transition-colors duration-300">
                  {cert.title}
                </h3>
                <p class="text-gray-400 text-xs leading-relaxed mt-3">
                  {cert.desc}
                </p>
              </div>

              <!-- Bottom Footer -->
              <div class="border-t border-white/5 pt-4 flex justify-between items-center">
                <div>
                  <span class="text-white/30 text-[8px] font-bold tracking-widest uppercase block">ENTIDAD EMISORA</span>
                  <span class="text-white/80 font-display text-[10px] tracking-widest uppercase font-semibold group-hover:text-white transition-colors duration-300">
                    {cert.issuer}
                  </span>
                </div>
                
                <!-- Tiny Secure Logo -->
                <div class="flex items-center gap-1 opacity-20 group-hover:opacity-80 transition-opacity duration-300">
                  <span class="text-[7px] font-bold tracking-wider text-white">SECURE</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                </div>
              </div>
            </div>

            <!-- Drawing glowing corner borders -->
            <div class="absolute top-0 left-0 w-3 h-[1.5px] bg-white/20 group-hover:w-6 transition-all duration-300" style={`background: ${cert.color};`}></div>
            <div class="absolute top-0 left-0 w-[1.5px] h-3 bg-white/20 group-hover:h-6 transition-all duration-300" style={`background: ${cert.color};`}></div>
            <div class="absolute bottom-0 right-0 w-3 h-[1.5px] bg-white/20 group-hover:w-6 transition-all duration-300" style={`background: ${cert.color};`}></div>
            <div class="absolute bottom-0 right-0 w-[1.5px] h-3 bg-white/20 group-hover:h-6 transition-all duration-300" style={`background: ${cert.color};`}></div>
          </div>
        ))}
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Valores corporativos Accordion styling */
  .value-accordion-item {
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }
  
  .value-accordion-item.active {
    border-color: var(--val-color) !important;
    box-shadow: 0 10px 30px var(--val-glow);
  }

  .value-accordion-item.active .bg-glow-layer {
    opacity: 1;
  }

  .value-accordion-item.active .indicator-line {
    transform: scale-x(1);
  }

  .value-accordion-item.active .arrow-box {
    transform: rotate(180deg);
    border-color: var(--val-color) !important;
    background: var(--val-glow);
  }

  /* Staff Cards styling */
  .staff-card {
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .staff-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 0.15) !important;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
  }

  /* Certificates styling */
  .certificate-card {
    transition: all 0.45s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .certificate-card:hover {
    transform: translateY(-5px) scale(1.02);
    border-color: var(--cert-color) !important;
    box-shadow: 0 15px 40px var(--cert-glow);
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let beamRAF: number | null = null;
  let resizeListener: (() => void) | null = null;

  // ── A. BEAM BACKGROUND CANVAS ANIMATION ──
  type Beam = {
    x: number; y: number; vx: number; vy: number;
    life: number; maxLife: number; width: number; color: string;
  };

  function initBeams() {
    const canvas = document.getElementById('about-beam-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const resize = () => { 
      canvas.width = canvas.offsetWidth; 
      canvas.height = canvas.offsetHeight; 
    };
    resize();
    
    resizeListener = resize;
    window.addEventListener('resize', resize);

    const beams: Beam[] = [];
    const colors = ['rgba(14,165,233,', 'rgba(45,212,191,', 'rgba(139,92,246,'];

    const spawnBeam = () => {
      const w = canvas.width;
      const h = canvas.height;
      const side = Math.random();
      let x = 0, y = 0, vx = 0, vy = 0;
      const speed = 0.3 + Math.random() * 0.55;
      const angle = (Math.random() * 50 - 25) * Math.PI / 180;
      
      if (side < 0.5) {
        x = side < 0.25 ? 0 : w;
        y = Math.random() * h;
        vx = side < 0.25 ?  Math.cos(angle) * speed : -Math.cos(angle) * speed;
        vy = Math.sin(angle) * speed;
      } else {
        x = Math.random() * w;
        y = side < 0.75 ? 0 : h;
        vx = Math.sin(angle) * speed;
        vy = side < 0.75 ? Math.cos(angle) * speed : -Math.cos(angle) * speed;
      }
      beams.push({
        x, y, vx, vy, life: 0,
        maxLife: 200 + Math.random() * 250,
        width: 0.3 + Math.random() * 1.0,
        color: colors[Math.floor(Math.random() * colors.length)]
      });
    };

    // Spawn inicial
    for (let i = 0; i < 8; i++) spawnBeam();

    const drawFrame = () => {
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      if (Math.random() < 0.035) spawnBeam();

      for (let i = beams.length - 1; i >= 0; i--) {
        const b = beams[i];
        b.life++; b.x += b.vx; b.y += b.vy;
        const p = b.life / b.maxLife;
        let alpha = p < 0.15 ? p / 0.15 : p > 0.75 ? 1 - (p - 0.75) / 0.25 : 1;
        alpha *= 0.15;
        
        ctx.beginPath();
        ctx.moveTo(b.x - b.vx * 100, b.y - b.vy * 100);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = b.color + alpha + ')';
        ctx.lineWidth = b.width;
        ctx.stroke();
        
        if (b.life >= b.maxLife) beams.splice(i, 1);
      }
      beamRAF = requestAnimationFrame(drawFrame);
    };
    drawFrame();
  }

  // ── B. INTERACTIVIDAD DEL ACORDEÓN DE VALORES ──
  function initAccordion() {
    const items = document.querySelectorAll('.value-accordion-item');
    
    items.forEach((item) => {
      const button = item.querySelector('button');
      const contentWrapper = item.querySelector('.value-content-wrapper') as HTMLElement;
      
      if (!button || !contentWrapper) return;

      button.addEventListener('click', () => {
        const isCurrentlyActive = item.classList.contains('active');
        
        // Cerrar todos los acordeones
        items.forEach((otherItem) => {
          otherItem.classList.remove('active');
          const otherButton = otherItem.querySelector('button');
          const otherContent = otherItem.querySelector('.value-content-wrapper') as HTMLElement;
          if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
          if (otherContent) {
            gsap.to(otherContent, { maxH: 0, opacity: 0, maxHeight: 0, duration: 0.45, ease: 'power2.inOut' });
          }
        });

        // Si el clickeado no estaba activo, abrirlo
        if (!isCurrentlyActive) {
          item.classList.add('active');
          button.setAttribute('aria-expanded', 'true');
          
          // Calcular la altura del contenido real
          contentWrapper.style.maxHeight = 'none';
          const realHeight = contentWrapper.scrollHeight;
          contentWrapper.style.maxHeight = '0px';

          // Animar apertura vertical deslizante con GSAP
          gsap.to(contentWrapper, {
            maxHeight: realHeight + 40, // Agregar algo de padding
            opacity: 1,
            duration: 0.6,
            ease: 'power3.out'
          });

          // Scroll suave para enfocar el elemento expandido
          setTimeout(() => {
            item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }, 350);
        }
      });
    });

    // Expandir el primer valor por defecto
    if (items.length > 0) {
      const firstItem = items[0];
      const button = firstItem.querySelector('button');
      const content = firstItem.querySelector('.value-content-wrapper') as HTMLElement;
      if (button && content) {
        firstItem.classList.add('active');
        button.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = 'none';
        const realHeight = content.scrollHeight;
        gsap.set(content, { maxHeight: realHeight + 40, opacity: 1 });
      }
    }
  }

  // ── C. EFECTO HOLOGRÁFICO EN CERTIFICADOS ──
  function initHoloSweep() {
    const cards = document.querySelectorAll('.certificate-card');
    cards.forEach((card, index) => {
      const holo = document.getElementById(`holo-sweep-${index}`);
      if (!holo) return;

      card.addEventListener('mousemove', (e: any) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left; // Posición x del cursor dentro de la carta
        const y = e.clientY - rect.top;  // Posición y del cursor dentro de la carta
        const px = (x / rect.width) * 100;
        const py = (y / rect.height) * 100;

        // Mover la posición del degradado holográfico en base al cursor
        holo.style.backgroundPosition = `${px}% ${py}%`;
      });

      card.addEventListener('mouseleave', () => {
        holo.style.backgroundPosition = '-120% -120%';
      });
    });
  }

  // ── D. REVELACIÓN CON SCROLL GSAP ──
  function initScrollReveals() {
    gsap.registerPlugin(ScrollTrigger);

    // Animación de los elementos cargados
    gsap.utils.toArray('.reveal-item').forEach((elem: any) => {
      gsap.from(elem, {
        scrollTrigger: {
          trigger: elem,
          start: 'top 88%',
          toggleActions: 'play none none reverse'
        },
        y: 40,
        opacity: 0,
        duration: 0.95,
        ease: 'power3.out'
      });
    });
  }

  // ── E. CONTROL DE LIFECYCLE ──
  function cleanup() {
    if (beamRAF) {
      cancelAnimationFrame(beamRAF);
      beamRAF = null;
    }
    if (resizeListener) {
      window.removeEventListener('resize', resizeListener);
      resizeListener = null;
    }
    ScrollTrigger.getAll().forEach(trigger => trigger.kill());
  }

  function initPage() {
    cleanup();
    initBeams();
    initAccordion();
    initHoloSweep();
    initScrollReveals();
  }

  // Iniciar en carga y cambios de vista de Astro
  initPage();
  document.addEventListener('astro:page-load', initPage);
  document.addEventListener('astro:before-swap', cleanup);
</script>
