---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AutoridadesCarousel from '../components/AutoridadesCarousel.astro';
import Footer from '../components/Footer.astro';
import '../styles/sobre-nosotros.css';

const valores = [
  { id: "integridad",    title: "INTEGRIDAD",       color: "#C9993A", image: "/images/int.webp",   desc: "Actuamos con Honestidad, Ética y Responsabilidad en cada Acción de Formación, Educativa y Deportiva.", details: "La integridad es el pilar de la confianza. Formamos a estudiantes y atletas bajo rigurosos principios morales, garantizando una competencia justa y un aprendizaje transparente." },
  { id: "inclusion",    title: "INCLUSIÓN",         color: "#1A4B8C", image: "/images/jun.webp",   desc: "Promovemos la Igualdad de Oportunidades, Respetando la Diversidad Cultural, Social y de Capacidades.", details: "Derribamos barreras físicas y sociales para construir una comunidad diversa donde el talento no tiene fronteras." },
  { id: "bienestar",    title: "BIENESTAR",         color: "#2D7DD2", image: "/images/ban.webp",   desc: "Promovemos Hábitos Saludables y una Vida Equilibrada en lo Físico, Emocional y Social.", details: "Diseñamos entornos y rutinas que priorizan la salud mental, el descanso y las relaciones interpersonales sanas." },
  { id: "disciplina",   title: "DISCIPLINA",        color: "#C9993A", image: "/images/ku.webp",    desc: "Fomentamos el Compromiso, la Constancia y la Responsabilidad como Fundamentos del Desarrollo Humano.", details: "La constancia supera al talento innato. Inculcamos la dedicación diaria para superar desafíos y forjar caracteres." },
  { id: "superacion",   title: "SUPERACIÓN",        color: "#1A4B8C", image: "/images/sup5.webp",  desc: "Impulsamos el Deseo de Aprender, Mejorar y Alcanzar Metas tanto Personales como Colectivas.", details: "Fomentamos una mentalidad de crecimiento donde cada error es oportunidad y cada meta el inicio de un reto nuevo." },
  { id: "equipo",       title: "TRABAJO EN EQUIPO", color: "#2D7DD2", image: "/images/eq8.webp",   desc: "Valoramos la Cooperación, la Solidaridad y el Apoyo Mutuo como Principios que Fortalecen el Crecimiento.", details: "La sinergia de voluntades multiplica los resultados. Colaborar y celebrar el triunfo ajeno es nuestra piedra angular." }
];

const personal = [
  { name: "Aleida Flora Borda Vidal Ph.D",        role: "Coordinadora de Programas de Educación Superior e Institucional", badge: "Institucional", image: "/images/per25.webp" },
  { name: "Gómez Guerra Rodrigo Germán Ph.D",                       role: "Coordinador de Programas de Calidad Educativa",                  badge: "Calidad",       image: "/images/per24.webp" },
  { name: "Msc. Ing Cesar Aleberto Quiroga Beltran",                       role: "Coordinador de Negocios y Emprendimientos",                     badge: "Negocios",      image: "/images/per8.webp" },
  { name: "Roberto Torico Ph.D",                       role: "Coordinador de Programas Económicos y Financieros",             badge: "Finanzas",      image: "/images/per11.webp" },
  { name: "Msc. Lic. Karina Negron Montaño",      role: "Coordinadora de Marketing Digital",                              badge: "Marketing",     image: "/images/per9.webp" },
  { name: "Carmen Gloria Aguilar Solar Ph.D",     role: "Coordinadora de Programas de Fisioterapia, Salud y Kinesiología", badge: "Salud",         image: "/images/per23.webp" },
  { name: "Msc. Lic. Manuel Vargas Zapata",                       role: "Coordinador de Programas Deportivos",                           badge: "Deportes",      image: "/images/per32.webp" },
  { name: "Ing. Jhon Calsina Alanoca",                       role: "Coordinador de Programas Fundación",                      badge: "Fundación",     image: "/images/per31.webp" },
  { name: "Ing. Juan Jimmy Beller Torrico",                       role: "Coordinador de Gestión de Proyecto de Desarrollo",                              badge: "Proyectos",     image: "/images/per3.webp" },
  { name: "Msc. Ing. Sergio Fernando Mendizabal Gomez ",                       role: "Coordinador de Seguridad y Salud Laboral",                      badge: "Seguridad",     image: "/images/per22.webp" },
  { name: "Msc. Ing. Maria Fernanda Martinez Buais",                       role: "Coordinadora de Gestion Medio Ambiente",                      badge: "Ambiente",     image: "/images/per21.webp" },
  { name: "Ing. Melani Karina Vargas Zapata",                       role: "Coordinadora de Protocolo y Organización",                      badge: "Protocolo",     image: "/images/per30.webp" }
  
  // 👉 Para reemplazar una foto: subí el archivo a /public/images/personal/ con
  //    ese mismo nombre. Si el archivo no existe todavía, la card cae sola en
  //    la imagen genérica /images/personal/default-avatar.svg (no se rompe el diseño).
].map(p => ({ ...p, anon: p.image.endsWith('default-avatar.svg') }));

const sellos = [
  { title: "INFOCADE",     type: "Resolución Ministerial",     code: "RM. 0148/2025" },
  { title: "CENACAP",      type: "Resolución Ministerial",     code: "RM. 0286/2025" },
  { title: "FUNDECT",      type: "Resolución Administrativa",  code: "R.ADM. 078/1996" },
  { title: "NUEVO SIGLO",  type: "Resolución Administrativa",  code: "R.ADM. 224/1997" }
].map(c => ({ ...c, year: c.code.split('/').pop() }));
---

<Layout title="Sobre Nosotros | CBIT">
  <Navbar />
  <main class="sn-main">

    <!-- ══════════════════════════════════
         HERO
    ══════════════════════════════════ -->
    <section class="sn-hero" id="sn-hero">
      <div class="sn-hero-mesh" aria-hidden="true"></div>
      <div class="sn-orb sn-orb-1" aria-hidden="true"></div>
      <div class="sn-orb sn-orb-2" aria-hidden="true"></div>
      <div class="sn-orb sn-orb-3" aria-hidden="true"></div>

      <div class="sn-container sn-hero-inner">
        <div class="sn-reveal">
          <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 border-b border-white/10 pb-12 mb-0">

            <h1 class="sn-hero-title font-display">
              SOBRE<br/>
              <span style="color:#f2c82f">NOSOTROS</span>
            </h1>

            <div class="sn-hero-side sn-reveal sn-d1">
              <p class="sn-hero-sub">
                Somos una Institución Boliviana, Dedicada a la Formación Integral, el Adiestramiento y la Capacitación Especializada, Promoviendo el Aprendizaje, la Disciplina, la Inclusión y el Desarrollo Humano, a Través de Programas y Proyectos en el Ámbito de la Salud, la Educación y el Deporte.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         HISTORIA
    ══════════════════════════════════ -->
    <section class="sn-section" id="historia">
      <div class="sn-container">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow">Reseña Histórica</span>
          <h2 class="sn-section-title font-display">El Inicio de la <span class="sn-gold">Excelencia</span></h2>
          <div class="sn-bar" data-bar></div>
        </div>

        <div class="sn-historia-grid">
          <div class="sn-float-card sn-reveal sn-img-card">
            <div class="sn-img-overflow" data-parallax>
              <img src="/images/mila.webp" alt="Historia CBIT" class="sn-img" />
            </div>
            <div class="sn-img-pill">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
              Corporación Boliviana de Talento y Formacion Integral
            </div>
          </div>

          <div class="sn-reveal sn-d1 sn-historia-txt">
            <p class="sn-body">
            Desde Nuestra Corporación, nos Propusimos Demostrar que el Desarrollo Intelectual y el Rendimiento Físico se Complementan para Formar Personas Íntegras, Capaces de Liderar con Valores y Visión.
          </p>
          <p class="sn-body">
            La Historia de la Organización se Inicia a Principios del 2025, con la Visión de Crear un Espacio Dedicado a la Formación Educativa, Técnica y Deportiva. Desde Entonces, su Labor se Enfoca en Desarrollar Talentos, Fortalecer Habilidades y Promover Valores Humanos, Contribuyendo al Crecimiento Personal y al Progreso del País.
          </p>
          <p class="sn-body">
            A lo Largo de los Años, se han Consolidado Alianzas Estratégicas con Diversas Instituciones Educativas, Centros de Capacitación y Organizaciones Sociales, Evaluando Constantemente Nuevas Oportunidades Académicas tanto a Nivel Nacional como Internacional, por medio de:
          </p>
            <div class="sn-checks">
              <div class="sn-check"><span class="sn-dot"></span>Alianzas Educativas Nacionales e Internacionales de Alto Nivel</div>
              <div class="sn-check"><span class="sn-dot"></span>Programas Integrados de Formación Académica y Deportiva</div>
              <div class="sn-check"><span class="sn-dot"></span>Reconocimiento Institucional a Nivel Nacional</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         MISIÓN & VISIÓN
    ══════════════════════════════════ -->
    <section class="sn-section sn-blue-bg" id="mision">
      <div class="sn-orb sn-orb-mv1" aria-hidden="true"></div>
      <div class="sn-orb sn-orb-mv2" aria-hidden="true"></div>
      <div class="sn-container" style="position:relative;z-index:2">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow sn-eyebrow-gold">Nuestra Esencia</span>
          <h2 class="sn-section-title sn-white font-display">MISIÓN <span class="sn-gold">&amp;</span> VISIÓN</h2>
          <div class="sn-bar sn-bar-gold" data-bar></div>
        </div>
        <div class="sn-mv-grid">
          <div class="sn-mv-card sn-reveal">
            <span class="sn-mv-label">MISIÓN</span>
            <p class="sn-mv-text">Promover el Desarrollo Integral de las Personas en Diferentes Etapas de su Vida mediante Actividades de Formación con Enfoque Deportivo y Programas Educativos Complementarios Innovadores, Impulsando el Aprendizaje, la Salud Física, el Bienestar Emocional, la Construcción de Valores y la Inclusión Social.</p>
          </div>
          <div class="sn-mv-card sn-reveal sn-d1">
            <span class="sn-mv-label">VISIÓN</span>
            <p class="sn-mv-text">Ser una Institución de Referencia Nacional Reconocida por su Excelencia para promover un Ecosistema de Formación Integral de Talento Deportivo de Alto Rendimiento, Logrando el Bienestar y Salud en la Comunidad, haciendo que el Deporte sea un Pilar Fundamental para una Vida Plena y un Motor de Desarrollo Social.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         VALORES
    ══════════════════════════════════ -->
    <section class="sn-section sn-soft-bg" id="valores">
      <div class="sn-container">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow">Nuestros Principios</span>
          <h2 class="sn-section-title font-display">VALORES <span class="sn-gold">CORPORATIVOS</span></h2>
          <div class="sn-bar" data-bar></div>
        </div>
        <div class="sn-valores-grid">
          {valores.map((val, i) => (
            <div class={`sn-float-card sn-valor-card sn-reveal sn-s${i % 3}`}>
              <div class="sn-val-img-wrap">
                <img src={val.image} alt={val.title} class="sn-img sn-zoom-target" />
              </div>
              <div class="sn-val-body">
                <div class="sn-val-accent" style={`background:${val.color}`}></div>
                <h3 class="sn-val-title font-display" style={`color:${val.color}`}>{val.title}</h3>
                <p class="sn-val-desc">{val.desc}</p>
                <p class="sn-val-detail">{val.details}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         AUTORIDADES
    ══════════════════════════════════ -->
    <section class="sn-section sn-blue-bg" id="autoridades">
      <div class="sn-orb sn-orb-aut" aria-hidden="true"></div>
      <div class="sn-container" style="position:relative;z-index:2">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow sn-eyebrow-gold">Liderazgo Activo</span>
          <h2 class="sn-section-title sn-white font-display">NUESTRAS <span class="sn-gold">AUTORIDADES</span></h2>
          <div class="sn-bar sn-bar-gold" data-bar></div>
        </div>
        <div class="sn-reveal">
          <AutoridadesCarousel />
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         PERSONAL
    ══════════════════════════════════ -->
    <section class="sn-section" id="personal">
      <div class="sn-container">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow">Equipo de Excelencia</span>
          <h2 class="sn-section-title font-display">NUESTRO <span class="sn-gold">PERSONAL</span></h2>
          <div class="sn-bar" data-bar></div>
        </div>
        <div class="sn-personal-grid">
          {personal.map((staff, i) => (
            <div class={`sn-float-card sn-staff-card sn-reveal sn-s${i % 4}`}>
              <div class="sn-staff-avatar-wrap">
                <div class={`sn-staff-avatar${staff.anon ? ' sn-staff-avatar-anon' : ''}`}>
                  <img
                    src={staff.image}
                    alt={staff.name}
                    class="sn-staff-photo"
                    loading="lazy"
                    onerror="this.onerror=null; this.src='/images/personal/default-avatar.svg'; this.parentElement.classList.add('sn-staff-avatar-anon');"
                  />
                </div>
              </div>
              <div class="sn-staff-body">
                <span class="sn-badge-gold">{staff.badge}</span>
                <h3 class={`sn-staff-name${staff.anon ? ' sn-staff-name-anon' : ''}`}>{staff.name}</h3>
                <hr class="sn-staff-hr" />
                <p class="sn-staff-role">{staff.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         CERTIFICACIONES · SELLO OFICIAL
    ══════════════════════════════════ -->
    <section class="sn-section sn-soft-bg" id="certificacion">
      <div class="sn-container">
        <div class="sn-section-head sn-reveal">
          <span class="sn-eyebrow">Documentación Oficial</span>
          <h2 class="sn-section-title font-display">VALIDEZ Y <span class="sn-gold">CERTIFICACIÓN</span></h2>
          <div class="sn-bar" data-bar></div>
          <p class="sn-cert-lead">Cada institución que Forma parte de CBIT cuenta con Respaldo Legal Vigente, avalado por Resoluciones Ministeriales y Administrativas del Estado Plurinacional de Bolivia.</p>
        </div>

        <div class="sn-cert-grid">
          {sellos.map((cert, i) => (
            <div class={`sn-cert-card sn-reveal sn-s${i % 3}`}>
              <div class="sn-cert-fold" aria-hidden="true"></div>
              <span class="sn-cert-stamp">Vigente</span>

              <div class="sn-cert-medal" style={`--shine-delay:${i * 0.7}s`}>
                <div class="sn-cert-rosette" aria-hidden="true"></div>
                <div class="sn-cert-medal-core">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l7.5 3v6c0 5-3.2 8.7-7.5 11-4.3-2.3-7.5-6-7.5-11V5L12 2z"/>
                    <path d="M9 12l2 2 4-4"/>
                  </svg>
                  <span class="sn-cert-year">{cert.year}</span>
                </div>
                <span class="sn-cert-ribbon-tail sn-cert-tail-l" aria-hidden="true"></span>
                <span class="sn-cert-ribbon-tail sn-cert-tail-r" aria-hidden="true"></span>
              </div>

              <div class="sn-cert-divider" aria-hidden="true"></div>

              <div class="sn-cert-body">
                <span class="sn-cert-type">{cert.type}</span>
                <h3 class="sn-cert-title font-display">{cert.title}</h3>
                <span class="sn-cert-code">{cert.code}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>




<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('sn-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.sn-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. GOLD BAR DRAW ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('sn-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX IMAGEN HISTORIA ── */
      const pImg = document.querySelector<HTMLElement>('[data-parallax] .sn-img');
      if (pImg) {
        gsap.fromTo(pImg,
          { yPercent: -6 },
          {
            yPercent: 6,
            ease: 'none',
            scrollTrigger: {
              trigger: '#historia',
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.4,
            }
          }
        );
      }

      /* ── 4. PARALLAX HERO TITLE ── */
      const heroTitle = document.querySelector<HTMLElement>('.sn-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.sn-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.8,
          }
        });
      }

      /* ── 5. PARALLAX ORBS HERO ── */
      document.querySelectorAll<HTMLElement>('.sn-orb-1, .sn-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -25 : 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '.sn-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 2,
          }
        });
      });

      /* ── 6. STAGGER GRID ENTRANCE ── */
      ['#valores .sn-valores-grid', '#personal .sn-personal-grid', '#certificacion .sn-cert-grid'].forEach(sel => {
        const grid = document.querySelector(sel);
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll<HTMLElement>('.sn-reveal'));
        ScrollTrigger.create({
          trigger: grid,
          start: 'top 86%',
          once: true,
          onEnter: () => {
            cards.forEach((card, i) => {
              gsap.to(card, {
                opacity: 1, y: 0,
                duration: 0.72,
                delay: i * 0.1,
                ease: 'power3.out',
                overwrite: true,
              });
            });
          }
        });
      });

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>