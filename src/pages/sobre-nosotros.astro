---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AutoridadesCarousel from '../components/AutoridadesCarousel.astro';

// Datos de los Valores Corporativos (Imágenes tipo Álbum)
const valores = [
  {
    id: "integridad",
    title: "INTEGRIDAD",
    color: "#f59e0b", // Dorado / Ámbar
    glow: "rgba(245,158,11,0.25)",
