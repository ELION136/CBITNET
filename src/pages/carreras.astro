---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const services = [
  {
    title: "DEPORTES",
    tag: "Alto Rendimiento",
    number: "01",
    color: "#C9993A",
    img: "/images/gol.jpg",
    link: "/deportes",
    desc: "Formación de alto rendimiento deportivo con metodologías de clase mundial. Nuestro programa integra dirección técnica especializada, preparación física avanzada y psicología del deporte para desarrollar atletas completos.",
    bullets: [
      "Dirección técnica con entrenadores certificados",
      "Preparación física avanzada y biomecánica",
      "Psicología del deporte y liderazgo mental",
      "Evaluación continua de rendimiento"
    ]
  },
  {
    title: "RAMAS TÉCNICAS",
    tag: "Formación Digital",
    number: "02",
    color: "#1A4B8C",
    img: "/images/mira.jpg",
    link: "/ramas-tecnicas",
    desc: "Carreras técnicas y digitales diseñadas para el mercado laboral actual. Integramos habilidades prácticas con fundamentos sólidos para formar profesionales altamente competitivos a nivel nacional e internacional.",
    bullets: [
      "Diseño gráfico y comunicación visual",
      "Desarrollo full-stack y tecnologías web",
      "Administración de proyectos (PMP / SCRUM)",
      "Sistemas de gestión de calidad ISO"
    ]
  },
  {
    title: "CURSOS Y CONFERENCIAS",
    tag: "Actualización Continua",
    number: "03",
    color: "#2D7DD2",
    img: "/images/huju.webp",
    link: "/cursos-conferencias",
    desc: "Programas de actualización continua que conectan el conocimiento académico con las tendencias globales. Nuestros seminarios y masterclasses son diseñados por expertos con trayectoria internacional.",
    bullets: [
      "Masterclasses con ponentes internacionales",
      "Talleres prácticos de oratoria y liderazgo",
      "Seminarios de emprendimiento e innovación",
      "Certificaciones y credenciales reconocidas"
    ]
  }
];
---

<Layout title="Carreras y Servicios | CBIT">
  <Navbar />

  <main class="cs-main">

    <!-- ══════════════════════════════════
         HERO
    ══════════════════════════════════ -->
    <section class="cs-hero" id="cs-hero">
      <div class="cs-hero-mesh"  aria-hidden="true"></div>
      <div class="cs-orb cs-orb-1" aria-hidden="true"></div>
      <div class="cs-orb cs-orb-2" aria-hidden="true"></div>
      <div class="cs-orb cs-orb-3" aria-hidden="true"></div>

      <div class="cs-container cs-hero-inner">
        <div class="cs-reveal">
          <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6
                      border-b pb-12"
               style="border-color:rgba(255,255,255,0.10);">
            <div>
              <div class="cs-hero-eyebrow cs-reveal cs-d0">
                <span class="cs-hero-line"></span>
                <span>Desarrollo Profesional</span>
              </div>
              <h1 class="cs-hero-title font-display">
                PROGRAMAS<br/>
                <span style="color:#f2c82f">ACADEMICOS</span>
              </h1>
            </div>
            <div class="cs-hero-side cs-reveal cs-d1">
              <p class="cs-hero-sub">
                Nuestra infraestructura académica y de entrenamiento te proporciona las herramientas, el análisis y el soporte integral necesario para llevar tu talento al siguiente nivel.
              </p>
            </div>
          </div>
        </div>

        <!-- STATS STRIP -->
        <div class="cs-stats-strip cs-reveal cs-d2">
          <div class="cs-stat">
            <span class="cs-stat-value font-display">{services.length}</span>
            <span class="cs-stat-label">Áreas de formación</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">100%</span>
            <span class="cs-stat-label">Docentes certificados</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">+500</span>
            <span class="cs-stat-label">Egresados activos</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">24/7</span>
            <span class="cs-stat-label">Soporte académico</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         FILAS DE SERVICIOS
    ══════════════════════════════════ -->
    <section class="cs-section cs-soft-bg" id="servicios">
      <div class="cs-container">

        <div class="cs-section-head cs-reveal">
          <span class="cs-eyebrow">Nuestras Especialidades</span>
          <h2 class="cs-section-title font-display">PROGRAMAS <span class="cs-gold">CBIT</span></h2>
          <div class="cs-bar" data-bar></div>
        </div>

        <div class="cs-services-list">
          {services.map((s, i) => (
            <div class="cs-service-row cs-reveal" data-index={i}>
              <div class={`cs-row-grid ${i % 2 === 1 ? 'cs-row-reverse' : ''}`}>

                <!-- ── IMAGEN ── -->
                <div class="cs-img-col">
                  <!-- número decorativo -->
                  <div class="cs-num-deco font-display" style={`color:${s.color}`}>
                    {s.number}
                  </div>

                  <!-- tarjeta imagen -->
                  <div class="cs-float-card cs-img-card" data-img-card>
                    <div class="cs-img-overflow">
                      <img
                        src={s.img}
                        alt={s.title}
                        width="900" height="600"
                        loading="lazy" decoding="async"
                        class="cs-img cs-zoom-target"
                        data-img
                      />
                      <!-- overlay degradado inferior -->
                      <div class="cs-img-overlay" aria-hidden="true"></div>
                    </div>

                    <!-- pill tag -->
                    <div class="cs-img-pill" style={`border-left-color:${s.color}`}>
                      <div class="cs-pill-dot" style={`background:${s.color}`}></div>
                      <span class="cs-pill-tag" style={`color:${s.color}`}>{s.tag}</span>
                      <span class="cs-pill-title">{s.title}</span>
                    </div>

                    <!-- número en tarjeta -->
                    <div class="cs-img-num font-display" style={`color:${s.color}`}>
                      {s.number}
                    </div>
                  </div>
                </div>

                <!-- ── TEXTO ── -->
                <div class="cs-text-col">

                  <!-- header fila -->
                  <div class="cs-row-eyebrow">
                    <span class="cs-row-num font-display" style={`color:${s.color}`}>{s.number}</span>
                    <div class="cs-row-eyebrow-line" style={`background:${s.color}`}></div>
                    <span class="cs-row-tag" style={`color:${s.color};border-color:${s.color}55`}>{s.tag}</span>
                  </div>

                  <!-- título -->
                  <div class="cs-title-overflow">
                    <h2 class="cs-service-title font-display" style={`color:${s.color}`}>
                      {s.title}
                    </h2>
                  </div>

                  <!-- barra color -->
                  <div class="cs-title-bar" data-bar-row style={`background:${s.color}`}></div>

                  <!-- descripción -->
                  <p class="cs-service-desc">{s.desc}</p>

                  <!-- bullets -->
                  <ul class="cs-bullets">
                    {s.bullets.map(b => (
                      <li class="cs-bullet">
                        <span class="cs-bullet-dot" style={`background:${s.color}`}></span>
                        <span class="cs-bullet-text">{b}</span>
                      </li>
                    ))}
                  </ul>

                  <!-- CTA -->
                  <a href={s.link} class="cs-cta-btn" style={`--btn-color:${s.color}`}>
                    <span>CONOCER MÁS</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                    <div class="cs-cta-fill"></div>
                  </a>

                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

  </main>
</Layout>

<style>
/* ══════════════════════════════════
   TOKENS — sistema CBIT
══════════════════════════════════ */
:root {
  --blue:      #1A4B8C;
  --blue-mid:  #2D7DD2;
  --blue-lt:   #EBF3FB;
  --cyan:      #f5c21a;
  --gold:      #C9993A;
  --gold-lt:   #F5E8CC;
  --white:     #ffffff;
  --soft:      #F0F4FA;
  --text:      #1e293b;
  --muted:     #64748B;
  --faint:     #94A3B8;

  --sh2:     0 4px 12px rgba(0,0,0,0.10), 0 8px 24px rgba(26,75,140,0.10);
  --sh3:     0 8px 28px rgba(0,0,0,0.12), 0 18px 48px rgba(26,75,140,0.16);
  --sh-hover:0 14px 40px rgba(0,0,0,0.14), 0 28px 60px rgba(26,75,140,0.22);
  --r-xl:    36px;
}

/* ══════════════════════════════════
   BASE
══════════════════════════════════ */
.cs-main      { background: var(--white); overflow-x: hidden; }
.cs-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
.cs-gold      { color: var(--gold); }
.cs-soft-bg   { background: var(--soft); }

/* ══════════════════════════════════
   HERO — igual que SobreNosotros
══════════════════════════════════ */
.cs-hero {
  background: var(--blue);
  padding: 10rem 0 5rem;
  position: relative;
  overflow: hidden;
}
.cs-hero-mesh {
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}
.cs-orb {
  position: absolute; border-radius: 50%;
  pointer-events: none; filter: blur(80px);
}
.cs-orb-1 { width:520px;height:520px; top:-150px;right:-130px; background:radial-gradient(circle,rgba(14,165,233,0.18),transparent 70%); }
.cs-orb-2 { width:360px;height:360px; bottom:-80px;left:-80px;  background:radial-gradient(circle,rgba(201,153,58,0.16),transparent 70%); }
.cs-orb-3 { width:260px;height:260px; top:40%;left:38%;          background:radial-gradient(circle,rgba(45,125,210,0.12),transparent 70%); }

.cs-hero-inner { display: flex; flex-direction: column; gap: 0; }

.cs-hero-eyebrow {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 1rem;
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--gold);
}
.cs-hero-line { display: block; width: 24px; height: 1.5px; background: var(--gold); flex-shrink: 0; }

.cs-hero-title {
  font-size: clamp(3.8rem, 10vw, 8rem);
  color: #fff;
  line-height: 1.02;
  margin: 0;
}
.cs-hero-side { max-width: 42%; }
.cs-hero-sub {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.6);
  border-left: 2px solid var(--cyan);
  padding-left: 1.4rem;
  line-height: 1.85;
}

/* STATS STRIP */
.cs-stats-strip {
  display: flex; gap: 0;
  border-top: 1px solid rgba(255,255,255,0.09);
  margin-top: 3rem;
  padding-top: 2rem;
}
.cs-stat {
  flex: 1;
  padding: 0 1.5rem 0 0;
  border-right: 1px solid rgba(255,255,255,0.09);
  display: flex; flex-direction: column; gap: 0.3rem;
}
.cs-stat:last-child { border-right: none; padding-right: 0; padding-left: 1.5rem; }
.cs-stat:first-child { padding-left: 0; }
.cs-stat-value {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--gold);
  line-height: 1;
}
.cs-stat-label {
  font-size: 0.68rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(255,255,255,0.45);
}

/* ══════════════════════════════════
   SECCIÓN
══════════════════════════════════ */
.cs-section { padding: 6rem 0; }

.cs-section-head { text-align: center; margin-bottom: 4.5rem; }
.cs-eyebrow {
  display: inline-block; font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--blue-mid); margin-bottom: 0.6rem;
}
.cs-section-title {
  font-size: clamp(2.2rem, 4.5vw, 3.2rem);
  color: var(--blue); line-height: 1.12; margin: 0 0 1.2rem;
}
.cs-bar {
  display: block; height: 3px; width: 0;
  background: var(--blue-mid); border-radius: 2px;
  margin: 0 auto;
  transition: width 0.9s cubic-bezier(0.22,1,0.36,1) 0.3s;
}
.cs-bar.cs-bar-on { width: 56px; }

/* ══════════════════════════════════
   FLOAT CARD
══════════════════════════════════ */
.cs-float-card {
  background: var(--white);
  border-radius: var(--r-xl);
  box-shadow: var(--sh2);
  border: 1px solid rgba(26,75,140,0.06);
  transition: transform 0.42s cubic-bezier(0.22,1,0.36,1), box-shadow 0.42s;
  overflow: hidden;
}
.cs-float-card:hover {
  transform: translateY(-10px) scale(1.012);
  box-shadow: var(--sh-hover);
}
.cs-float-card:hover .cs-zoom-target { transform: scale(1.05); }

/* ══════════════════════════════════
   FILAS DE SERVICIOS
══════════════════════════════════ */
.cs-services-list { display: flex; flex-direction: column; gap: 5rem; }

.cs-service-row {
  /* separador superior suave */
}

.cs-row-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.cs-row-reverse { direction: rtl; }
.cs-row-reverse > * { direction: ltr; }

/* ── COLUMNA IMAGEN ── */
.cs-img-col { position: relative; }

.cs-num-deco {
  position: absolute;
  font-size: 12rem; line-height: 1;
  opacity: 0.04;
  top: -1rem; right: -1.5rem;
  pointer-events: none; select-none: true;
  z-index: 0;
}
.cs-row-reverse .cs-num-deco { right: auto; left: -1.5rem; }

.cs-img-card {
  position: relative; z-index: 1;
}
.cs-img-overflow {
  height: 460px;
  overflow: hidden;
  position: relative;
}
.cs-img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.65s cubic-bezier(0.22,1,0.36,1);
}
.cs-img-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(26,75,140,0.18) 0%, transparent 55%);
  pointer-events: none;
}

/* pill inferior */
.cs-img-pill {
  position: absolute; bottom: 1.25rem; left: 1.25rem;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10px);
  border-left: 3px solid;
  border-radius: 12px;
  padding: 0.65rem 1.1rem;
  display: flex; align-items: center; gap: 0.6rem;
  box-shadow: 0 4px 16px rgba(0,0,0,0.10);
}
.cs-pill-dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  animation: cs-pulse 2.2s infinite;
}
@keyframes cs-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(201,153,58,0.5); }
  50%      { box-shadow: 0 0 0 5px rgba(201,153,58,0); }
}
.cs-pill-tag {
  font-size: 0.6rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
}
.cs-pill-title {
  font-size: 0.78rem; font-weight: 800;
  color: var(--blue); letter-spacing: 0.04em;
}

/* número en la tarjeta imagen esquina superior derecha */
.cs-img-num {
  position: absolute; top: 1rem; right: 1.25rem;
  font-size: 2.5rem; line-height: 1;
  opacity: 0.18;
  pointer-events: none;
}

/* ── COLUMNA TEXTO ── */
.cs-text-col {
  display: flex; flex-direction: column; gap: 1.2rem;
}

.cs-row-eyebrow {
  display: flex; align-items: center; gap: 0.85rem;
}
.cs-row-num {
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.35em;
}
.cs-row-eyebrow-line {
  flex: 1; height: 1.5px; opacity: 0.35;
  max-width: 3rem;
}
.cs-row-tag {
  font-size: 0.6rem; font-weight: 700;
  letter-spacing: 0.2em; text-transform: uppercase;
  border: 1px solid;
  padding: 0.25rem 0.75rem; border-radius: 50px;
}

.cs-title-overflow { overflow: hidden; }
.cs-service-title {
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.08;
  margin: 0;
  letter-spacing: 0.02em;
}

.cs-title-bar {
  height: 3px; width: 0; border-radius: 2px;
  transition: width 0.7s cubic-bezier(0.22,1,0.36,1) 0.2s;
}
.cs-title-bar.cs-bar-row-on { width: 48px; }

.cs-service-desc {
  font-size: 1.02rem; line-height: 1.88;
  color: var(--muted); margin: 0;
  max-width: 48ch;
}

/* bullets */
.cs-bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
.cs-bullet  { display: flex; align-items: flex-start; gap: 0.85rem; }
.cs-bullet-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  margin-top: 0.5rem;
  transition: transform 0.3s;
}
.cs-bullet:hover .cs-bullet-dot { transform: scale(1.5); }
.cs-bullet-text { font-size: 0.96rem; line-height: 1.7; color: var(--muted); }

/* CTA */
.cs-cta-btn {
  display: inline-flex; align-items: center; gap: 0.75rem;
  padding: 0.85rem 1.75rem;
  background: var(--white);
  color: var(--btn-color, var(--blue));
  border: 1.5px solid var(--btn-color, var(--blue));
  border-radius: 50px;
  font-size: 0.68rem; font-weight: 800;
  letter-spacing: 0.2em; text-transform: uppercase;
  text-decoration: none;
  position: relative; overflow: hidden;
  transition: color 0.3s, transform 0.35s cubic-bezier(0.22,1,0.36,1), box-shadow 0.35s;
  align-self: flex-start;
}
.cs-cta-fill {
  position: absolute; inset: 0;
  background: var(--btn-color, var(--blue));
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  z-index: 0;
}
.cs-cta-btn span,
.cs-cta-btn svg { position: relative; z-index: 1; }
.cs-cta-btn:hover .cs-cta-fill { transform: scaleX(1); }
.cs-cta-btn:hover {
  color: var(--white);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(26,75,140,0.20);
}
.cs-cta-btn:hover svg { transform: translateX(4px); }
.cs-cta-btn svg { transition: transform 0.3s ease; }

/* ══════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════ */
.cs-reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.75s cubic-bezier(0.22,1,0.36,1), transform 0.75s cubic-bezier(0.22,1,0.36,1);
}
.cs-reveal.cs-on { opacity: 1; transform: translateY(0); }
.cs-d0 { transition-delay: 0s; }
.cs-d1 { transition-delay: .13s; }
.cs-d2 { transition-delay: .26s; }

/* ══════════════════════════════════
   RESPONSIVE
══════════════════════════════════ */
@media(max-width:1024px){
  .cs-row-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .cs-row-reverse { direction: ltr; }
  .cs-hero-side { max-width: 100%; }
  .cs-num-deco  { display: none; }
}
@media(max-width:768px){
  .cs-stats-strip { flex-wrap: wrap; }
  .cs-stat { flex: 1 1 45%; border-right: none; padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.09); }
  .cs-stat:last-child { border-bottom: none; }
  .cs-img-overflow { height: 300px; }
}
@media(max-width:640px){
  .cs-hero    { padding: 9rem 0 4rem; }
  .cs-section { padding: 4rem 0; }
  .cs-container { padding: 0 1.25rem; }
  .cs-services-list { gap: 3.5rem; }
}
@media(prefers-reduced-motion:reduce){
  .cs-reveal { opacity: 1; transform: none; transition: none; }
  .cs-bar    { width: 56px; transition: none; }
  .cs-title-bar { width: 48px; transition: none; }
  .cs-pill-dot  { animation: none; }
}
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL global ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cs-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.cs-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. BAR DRAW (sección header) ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cs-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO ── */
      const heroTitle = document.querySelector<HTMLElement>('.cs-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20, ease: 'none',
          scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom top', scrub: 1.8 }
        });
      }
      document.querySelectorAll<HTMLElement>('.cs-orb-1, .cs-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -22 : 18, ease: 'none',
          scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom top', scrub: 2 }
        });
      });

      /* ── 4. ANIMACIÓN POR FILA ── */
      document.querySelectorAll<HTMLElement>('.cs-service-row').forEach((row) => {
        const imgCard   = row.querySelector<HTMLElement>('[data-img-card]');
        const img       = row.querySelector<HTMLElement>('[data-img]');
        const title     = row.querySelector<HTMLElement>('.cs-service-title');
        const titleBar  = row.querySelector<HTMLElement>('.cs-title-bar');
        const desc      = row.querySelector<HTMLElement>('.cs-service-desc');
        const bullets   = row.querySelectorAll<HTMLElement>('.cs-bullet');
        const cta       = row.querySelector<HTMLElement>('.cs-cta-btn');
        const eyebrow   = row.querySelector<HTMLElement>('.cs-row-eyebrow');

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: row,
            start: 'top 78%',
            once: true,
          }
        });

        if (imgCard) tl.fromTo(imgCard,
          { opacity: 0, y: 50, scale: 0.96 },
          { opacity: 1, y: 0,  scale: 1,   duration: 1.1, ease: 'power3.out' },
          0
        );
        if (img) tl.fromTo(img,
          { scale: 1.08 },
          { scale: 1, duration: 1.4, ease: 'power2.out' },
          0
        );
        if (eyebrow) tl.from(eyebrow,
          { opacity: 0, x: -20, duration: 0.6, ease: 'power2.out' },
          0.3
        );
        if (title) tl.fromTo(title,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0,  duration: 0.8, ease: 'power3.out' },
          0.45
        );
        if (titleBar) tl.add(() => titleBar.classList.add('cs-bar-row-on'), 0.7);
        if (desc) tl.fromTo(desc,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0,  duration: 0.75, ease: 'power2.out' },
          0.75
        );
        if (bullets.length) tl.fromTo(bullets,
          { opacity: 0, x: 18 },
          { opacity: 1, x: 0,  duration: 0.55, stagger: 0.09, ease: 'power2.out' },
          0.9
        );
        if (cta) tl.fromTo(cta,
          { opacity: 0, y: 14 },
          { opacity: 1, y: 0,  duration: 0.6, ease: 'back.out(1.5)' },
          1.25
        );
      });

      /* ── 5. HOVER IMAGEN ── */
      document.querySelectorAll<HTMLElement>('.cs-img-card').forEach(card => {
        const img = card.querySelector<HTMLElement>('[data-img]');
        if (!img) return;
        card.addEventListener('mouseenter', () =>
          gsap.to(img, { scale: 1.06, duration: 0.7, ease: 'power2.out' })
        );
        card.addEventListener('mouseleave', () =>
          gsap.to(img, { scale: 1,    duration: 0.7, ease: 'power2.out' })
        );
      });

      /* ── 6. STAT COUNTERS ── */
      document.querySelectorAll<HTMLElement>('.cs-stat-value').forEach(el => {
        const raw = el.textContent?.trim() ?? '';
        if (!/^\d+$/.test(raw)) return;
        const end = parseInt(raw, 10);
        el.textContent = '0';
        ScrollTrigger.create({
          trigger: el, start: 'top 90%', once: true,
          onEnter: () => {
            gsap.to({ val: 0 }, {
              val: end, duration: 1.4, ease: 'power2.out',
              onUpdate: function() {
                el.textContent = Math.round(this.targets()[0].val).toString();
              }
            });
          }
        });
      });

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>