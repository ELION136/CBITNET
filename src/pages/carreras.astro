---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/carreras.css';

const services = [
  {
    title: "DEPORTES",
    tag: "Alto Rendimiento",
    number: "01",
    color: "#C9993A",
    img: "/images/gol.jpg",
    link: "/deportes",
    desc: "Formación de Alto Rendimiento Deportivo con Metodologías de Clase Mundial. Nuestros Programas Integran Dirección Técnica Especializada, Preparación Física Avanzada y Psicología del Deporte para Desarrollar Atletas Completos. Nos Especializamos en:",
    bullets: [
      "Dirección Técnica con Entrenadores Certificados",
      "Preparación Física Avanzada y Biomecánica",
      "Psicología del Deporte y Liderazgo Mental",
      "Evaluación Continua de Alto Rendimiento"
    ]
  },
  {
    title: "RAMAS TÉCNICAS",
    tag: "Formación Digital",
    number: "02",
    color: "#1A4B8C",
    img: "/images/mira.jpg",
    link: "/ramas-tecnicas",
    desc: "Carreras Técnicas y Digitales Diseñadas para el Mercado Laboral Actual. Integramos Habilidades Prácticas con Fundamentos Sólidos para Formar Profesionales Altamente Competitivos a Nivel Nacional e Internacional. Nos Especializamos en:",
    bullets: [
      "Diseño Gráfico y Comunicación Visual",
      "Desarrollo en Informática Industrial",
      "Gerencia de Proyectos",
      "Sistemas de Gestión de Calidad ISO"
    ]
  },
  {
    title: "CURSOS Y CONFERENCIAS",
    tag: "Actualización Continua",
    number: "03",
    color: "#2D7DD2",
    img: "/images/huju.webp",
    link: "/cursos-conferencias",
    desc: "Programas de Actualización Continua que Conectan el Conocimiento Académico con las Tendencias Globales. Nuestros Seminarios y Masterclasses son diseñados por Expertos con trayectoria Nacional e Internacional. Nos Especializamos en:",
    bullets: [
      "Masterclasses con Ponentes Internacionales",
      "Talleres Prácticos de Oratoria y Liderazgo",
      "Seminarios de Emprendimiento, Innovación y Negocios",
      "Aplicamos Herramientas Digitales e Inteligencia Artificial "
    ]
  }
];
---

<Layout title="Carreras y Servicios | CBIT">
  <Navbar />

  <main class="cs-main">

    <!-- ══════════════════════════════════
         HERO
    ══════════════════════════════════ -->
    <section class="cs-hero" id="cs-hero">
      <div class="cs-hero-mesh"  aria-hidden="true"></div>
      <div class="cs-orb cs-orb-1" aria-hidden="true"></div>
      <div class="cs-orb cs-orb-2" aria-hidden="true"></div>
      <div class="cs-orb cs-orb-3" aria-hidden="true"></div>

      <div class="cs-container cs-hero-inner">
        <div class="cs-reveal">
          <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6
                      border-b pb-12"
               style="border-color:rgba(255,255,255,0.10);">
            <div>
              <h1 class="cs-hero-title font-display">
                PROGRAMAS<br/>
                <span style="color:#f2c82f">ACADEMICOS</span>
              </h1>
            </div>
            <div class="cs-hero-side cs-reveal cs-d1">
              <p class="cs-hero-sub">
                Nuestra infraestructura académica y de entrenamiento te proporciona las herramientas, el análisis y el soporte integral necesario para llevar tu talento al siguiente nivel.
              </p>
            </div>
          </div>
        </div>

        <!-- STATS STRIP -->
        <div class="cs-stats-strip cs-reveal cs-d2">
          <div class="cs-stat">
            <span class="cs-stat-value font-display">{services.length}</span>
            <span class="cs-stat-label">Áreas de formación</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">100%</span>
            <span class="cs-stat-label">Docentes certificados</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">+500</span>
            <span class="cs-stat-label">Egresados activos</span>
          </div>
          <div class="cs-stat">
            <span class="cs-stat-value font-display">24/7</span>
            <span class="cs-stat-label">Soporte académico</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════
         FILAS DE SERVICIOS
    ══════════════════════════════════ -->
    <section class="cs-section cs-soft-bg" id="servicios">
      <div class="cs-container">

        <div class="cs-section-head cs-reveal">
          <span class="cs-eyebrow">Nuestras Especialidades</span>
          <h2 class="cs-section-title font-display">PROGRAMAS <span class="cs-gold">CBIT</span></h2>
          <div class="cs-bar" data-bar></div>
        </div>

        <div class="cs-services-list">
          {services.map((s, i) => (
            <div class="cs-service-row cs-reveal" data-index={i}>
              <div class={`cs-row-grid ${i % 2 === 1 ? 'cs-row-reverse' : ''}`}>

                <!-- ── IMAGEN ── -->
                <div class="cs-img-col">
                  <!-- número decorativo -->
                  <div class="cs-num-deco font-display" style={`color:${s.color}`}>
                    {s.number}
                  </div>

                  <!-- tarjeta imagen -->
                  <div class="cs-float-card cs-img-card" data-img-card>
                    <div class="cs-img-overflow">
                      <img
                        src={s.img}
                        alt={s.title}
                        width="900" height="600"
                        loading="lazy" decoding="async"
                        class="cs-img cs-zoom-target"
                        data-img
                      />
                      <!-- overlay degradado inferior -->
                      <div class="cs-img-overlay" aria-hidden="true"></div>
                    </div>

                    <!-- pill tag -->
                    <div class="cs-img-pill" style={`border-left-color:${s.color}`}>
                      <div class="cs-pill-dot" style={`background:${s.color}`}></div>
                      <span class="cs-pill-tag" style={`color:${s.color}`}>{s.tag}</span>
                      <span class="cs-pill-title">{s.title}</span>
                    </div>

                    <!-- número en tarjeta -->
                    <div class="cs-img-num font-display" style={`color:${s.color}`}>
                      {s.number}
                    </div>
                  </div>
                </div>

                <!-- ── TEXTO ── -->
                <div class="cs-text-col">

                  <!-- header fila -->
                  <div class="cs-row-eyebrow">
                    <span class="cs-row-num font-display" style={`color:${s.color}`}>{s.number}</span>
                    <div class="cs-row-eyebrow-line" style={`background:${s.color}`}></div>
                    <span class="cs-row-tag" style={`color:${s.color};border-color:${s.color}55`}>{s.tag}</span>
                  </div>

                  <!-- título -->
                  <div class="cs-title-overflow">
                    <h2 class="cs-service-title font-display" style={`color:${s.color}`}>
                      {s.title}
                    </h2>
                  </div>

                  <!-- barra color -->
                  <div class="cs-title-bar" data-bar-row style={`background:${s.color}`}></div>

                  <!-- descripción -->
                  <p class="cs-service-desc">{s.desc}</p>

                  <!-- bullets -->
                  <ul class="cs-bullets">
                    {s.bullets.map(b => (
                      <li class="cs-bullet">
                        <span class="cs-bullet-dot" style={`background:${s.color}`}></span>
                        <span class="cs-bullet-text">{b}</span>
                      </li>
                    ))}
                  </ul>

                  <!-- CTA -->
                  <a href={s.link} class="cs-cta-btn" style={`--btn-color:${s.color}`}>
                    <span>CONOCER MÁS</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                      <polyline points="12 5 19 12 12 19"/>
                    </svg>
                    <div class="cs-cta-fill"></div>
                  </a>

                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>



<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  let ctx: gsap.Context | null = null;

  function initPage() {
    if (ctx) { ctx.revert(); ctx = null; }
    gsap.registerPlugin(ScrollTrigger);

    ctx = gsap.context(() => {

      /* ── 1. SCROLL REVEAL global ── */
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cs-on');
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -48px 0px' });

      document.querySelectorAll('.cs-reveal').forEach(el => revealIO.observe(el));

      /* ── 2. BAR DRAW (sección header) ── */
      const barIO = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('cs-bar-on');
            barIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('[data-bar]').forEach(el => barIO.observe(el));

      /* ── 3. PARALLAX HERO ── */
      const heroTitle = document.querySelector<HTMLElement>('.cs-hero-title');
      if (heroTitle) {
        gsap.to(heroTitle, {
          yPercent: 20, ease: 'none',
          scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom top', scrub: 1.8 }
        });
      }
      document.querySelectorAll<HTMLElement>('.cs-orb-1, .cs-orb-2').forEach((orb, i) => {
        gsap.to(orb, {
          yPercent: i % 2 === 0 ? -22 : 18, ease: 'none',
          scrollTrigger: { trigger: '.cs-hero', start: 'top top', end: 'bottom top', scrub: 2 }
        });
      });

      /* ── 4. ANIMACIÓN POR FILA ── */
      document.querySelectorAll<HTMLElement>('.cs-service-row').forEach((row) => {
        const imgCard   = row.querySelector<HTMLElement>('[data-img-card]');
        const img       = row.querySelector<HTMLElement>('[data-img]');
        const title     = row.querySelector<HTMLElement>('.cs-service-title');
        const titleBar  = row.querySelector<HTMLElement>('.cs-title-bar');
        const desc      = row.querySelector<HTMLElement>('.cs-service-desc');
        const bullets   = row.querySelectorAll<HTMLElement>('.cs-bullet');
        const cta       = row.querySelector<HTMLElement>('.cs-cta-btn');
        const eyebrow   = row.querySelector<HTMLElement>('.cs-row-eyebrow');

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: row,
            start: 'top 78%',
            once: true,
          }
        });

        if (imgCard) tl.fromTo(imgCard,
          { opacity: 0, y: 50, scale: 0.96 },
          { opacity: 1, y: 0,  scale: 1,   duration: 1.1, ease: 'power3.out' },
          0
        );
        if (img) tl.fromTo(img,
          { scale: 1.08 },
          { scale: 1, duration: 1.4, ease: 'power2.out' },
          0
        );
        if (eyebrow) tl.from(eyebrow,
          { opacity: 0, x: -20, duration: 0.6, ease: 'power2.out' },
          0.3
        );
        if (title) tl.fromTo(title,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0,  duration: 0.8, ease: 'power3.out' },
          0.45
        );
        if (titleBar) tl.add(() => titleBar.classList.add('cs-bar-row-on'), 0.7);
        if (desc) tl.fromTo(desc,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0,  duration: 0.75, ease: 'power2.out' },
          0.75
        );
        if (bullets.length) tl.fromTo(bullets,
          { opacity: 0, x: 18 },
          { opacity: 1, x: 0,  duration: 0.55, stagger: 0.09, ease: 'power2.out' },
          0.9
        );
        if (cta) tl.fromTo(cta,
          { opacity: 0, y: 14 },
          { opacity: 1, y: 0,  duration: 0.6, ease: 'back.out(1.5)' },
          1.25
        );
      });

      /* ── 5. HOVER IMAGEN ── */
      document.querySelectorAll<HTMLElement>('.cs-img-card').forEach(card => {
        const img = card.querySelector<HTMLElement>('[data-img]');
        if (!img) return;
        card.addEventListener('mouseenter', () =>
          gsap.to(img, { scale: 1.06, duration: 0.7, ease: 'power2.out' })
        );
        card.addEventListener('mouseleave', () =>
          gsap.to(img, { scale: 1,    duration: 0.7, ease: 'power2.out' })
        );
      });

      /* ── 6. STAT COUNTERS ── */
      document.querySelectorAll<HTMLElement>('.cs-stat-value').forEach(el => {
        const raw = el.textContent?.trim() ?? '';
        if (!/^\d+$/.test(raw)) return;
        const end = parseInt(raw, 10);
        el.textContent = '0';
        ScrollTrigger.create({
          trigger: el, start: 'top 90%', once: true,
          onEnter: () => {
            gsap.to({ val: 0 }, {
              val: end, duration: 1.4, ease: 'power2.out',
              onUpdate: function() {
                el.textContent = Math.round(this.targets()[0].val).toString();
              }
            });
          }
        });
      });

    });
  }

  function cleanup() {
    if (ctx) { ctx.revert(); ctx = null; }
    ScrollTrigger.getAll().forEach(t => t.kill());
  }

  initPage();
  document.addEventListener('astro:page-load', () => { cleanup(); initPage(); });
  document.addEventListener('astro:before-swap', cleanup);
</script>