---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CoverflowHero from '../components/CoverflowHero.astro';
import HeroSection from '../components/HeroSection.astro';
import Loader from '../components/Loader.astro';
---

<Layout title="Comparación Boliviana de Talento y Formacion Integral">
  <Navbar />
  <main style="padding-top: var(--nav-h-desk);">
    <CoverflowHero />
  </main>
</Layout>

<style>
  /* En móvil usa la altura móvil del navbar */
  @media (max-width: 820px) {
    main {
      padding-top: var(--nav-h-mob) !important;
    }
  }
</style>