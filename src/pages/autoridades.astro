---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AutoridadesCarousel from '../components/AutoridadesCarousel.astro';
---

<Layout title="Autoridades | Sports & Academic Hub">
	<Navbar />
	<main class="bg-[#030303] min-h-screen overflow-hidden pt-24 pb-20">
        <div class="container mx-auto px-6 relative z-10 text-center mb-10">
            <h1 class="text-4xl md:text-6xl font-display font-bold text-white tracking-widest uppercase mb-4">
                NUESTRAS <span class="text-yellow-500">AUTORIDADES</span>
            </h1>
            <p class="text-gray-400 max-w-2xl mx-auto text-lg">
                Conoce a los líderes que guían nuestra institución hacia la excelencia académica y deportiva.
            </p>
        </div>
		<AutoridadesCarousel />
	</main>
</Layout>
