---
import Layout from '../layouts/Layout.astro';

const principles = [
  {
    num: "01",
    title: "We Serve",
    titleEs: "Servimos",
    desc: "Más de 1.4 millones de socios en 200+ países. La organización de servicio voluntario más grande del mundo, activa en cada comunidad que lo necesita.",
  },
  {
    num: "02",
    title: "We Care",
    titleEs: "Nos Importa",
    desc: "Erradicamos la ceguera, atendemos a los jóvenes, ofrecemos auxilio en desastres y abordamos necesidades humanitarias urgentes.",
  },
  {
    num: "03",
    title: "We Lead",
    titleEs: "Lideramos",
    desc: "Formamos líderes comunitarios íntegros que inspiran a sus entornos, con civismo activo y valores de servicio sostenido.",
  },
  {
    num: "04",
    title: "We Unite",
    titleEs: "Unimos",
    desc: "Conectamos familias, comunidades y naciones bajo un mismo propósito: hacer del mundo un lugar mejor para todos.",
  },
];

const activities = [
  { title: "Torneos Comunitarios", desc: "Ligas deportivas juveniles reuniendo a más de 500 atletas en disciplinas múltiples.", imagen: "/images/miu1.jpeg" },
  { title: "Brigadas de Salud", desc: "Campañas médicas gratuitas y soporte nutricional para familias de escasos recursos.", imagen: "/images/miu2.jpeg" },
  { title: "Equipamiento Deportivo", desc: "Renovación de complejos deportivos barriales y dotación de material técnico de calidad.", imagen: "/images/miu3.jpeg" },
  { title: "Becas y Formacion", desc: "Clínicas de liderazgo cívico para guiar el carácter ético de los futuros campeones.", imagen: "/images/miu4.jpeg" },
  { title: "Ceremonia de Afiliacion", desc: "Acto formal de bienvenida a nuevos miembros del Club de Leones Sacaba.", imagen: "/images/miro1.JPG" },
  { title: "Accion Comunitaria", desc: "Voluntariado activo transformando el entorno social de nuestra región.", imagen: "/images/miu5.jpeg" },
];

const stats = [
  { num: "1.4M+", label: "Socios en el Mundo" },
  { num: "45K+", label: "Clubes Activos" },
  { num: "200+", label: "Países Presentes" },
  { num: "100+", label: "Años de Servicio" },
];
---

<Layout title="Club de Leones Sacaba | Lions Clubs International" showBackgroundFX={false}>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue:        #1a3a8f;
    --blue-dark:   #0f2460;
    --blue-mid:    #2650b8;
    --blue-light:  #3b6fd4;
    --blue-pale:   #dde8ff;
    --gold:        #f5c518;
    --gold-dark:   #c9a010;
    --gold-light:  #fad84a;
    --gold-pale:   #fff8dc;
    --ink:         #0d1a3a;
    --white:       #ffffff;
    --off-white:   #f7f9ff;
    --gray:        #8395b8;
    --gray-light:  #e8edf8;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Source Sans 3', sans-serif;
    background: var(--off-white);
    color: var(--ink);
    overflow-x: hidden;
  }

  /* ── NAVBAR ── */
  #navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 76px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(20px);
    border-bottom: 3px solid var(--gold);
    box-shadow: 0 2px 24px rgba(26,58,143,0.08);
    transition: all 0.4s;
  }
  .nav-left {
    display: flex; align-items: center; gap: 14px;
    text-decoration: none;
  }
  .nav-logo-img { height: 52px; width: auto; }
  .nav-wordmark { display: flex; flex-direction: column; line-height: 1.1; }
  .nav-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem; font-weight: 700;
    color: var(--blue-dark);
    letter-spacing: 0.03em;
  }
  .nav-name em { color: var(--gold-dark); font-style: normal; }
  .nav-sub {
    font-size: 0.62rem; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gray); margin-top: 2px;
  }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-link {
    font-size: 0.82rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--blue);
    text-decoration: none;
    position: relative;
    transition: color 0.25s;
  }
  .nav-link::after {
    content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
    height: 2px; background: var(--gold);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .nav-link:hover { color: var(--blue-dark); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 26px;
    background: var(--blue);
    color: var(--gold);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    border: 2px solid var(--blue);
    transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(26,58,143,0.25);
  }
  .nav-cta:hover {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--blue-dark);
    box-shadow: 0 6px 24px rgba(245,197,24,0.4);
    transform: translateY(-2px);
  }

  /* ── HERO ── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: url('/images/miro1.JPG') center center / cover no-repeat;
    will-change: transform;
    filter: brightness(0.45) saturate(0.7);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, rgba(10,22,64,0.98) 0%, rgba(10,22,64,0.6) 50%, rgba(10,22,64,0.25) 100%),
      linear-gradient(to right, rgba(10,22,64,0.6) 0%, transparent 60%);
  }
  /* Diagonal gold stripe accent */
  .hero-stripe {
    position: absolute; bottom: 0; left: 0; right: 0; height: 5px; z-index: 3;
    background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
  }

  .hero-content {
    position: relative; z-index: 10;
    padding: 0 64px 100px;
    max-width: 1000px;
  }
  .hero-kicker {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 7px 16px 7px 12px;
    background: var(--gold);
    color: var(--blue-dark);
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    border-radius: 3px;
    margin-bottom: 32px;
    opacity: 0;
  }
  .hero-kicker-dot { width: 6px; height: 6px; background: var(--blue-dark); border-radius: 50%; }

  .hero-h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(4rem, 9vw, 8.5rem);
    line-height: 0.92; font-weight: 900;
    color: var(--white);
    margin-bottom: 8px;
  }
  .h1-line { display: block; overflow: hidden; }
  .h1-inner { display: block; }
  .h1-gold { color: var(--gold); }
  .h1-outline {
    -webkit-text-stroke: 2px rgba(255,255,255,0.22);
    color: transparent;
  }

  .hero-divider {
    width: 0; height: 3px;
    background: var(--gold);
    margin: 30px 0;
    border-radius: 2px;
  }
  .hero-tagline {
    font-size: 1.05rem; font-weight: 300;
    color: rgba(255,255,255,0.6);
    max-width: 460px; line-height: 1.85;
    margin-bottom: 40px; opacity: 0;
  }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; opacity: 0; }
  .btn-gold {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 15px 38px;
    background: var(--gold);
    color: var(--blue-dark);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.88rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; border-radius: 4px;
    transition: all 0.3s;
    box-shadow: 0 6px 28px rgba(245,197,24,0.4);
  }
  .btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(245,197,24,0.55);
  }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 30px;
    border: 2px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.75);
    font-size: 0.86rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    text-decoration: none; border-radius: 4px;
    transition: all 0.3s;
  }
  .btn-outline:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* Hero floating badge */
  .hero-badge {
    position: absolute; top: 130px; right: 64px; z-index: 10;
    padding: 24px 28px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
    border: 2px solid rgba(245,197,24,0.4);
    border-radius: 12px;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0; text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .hero-badge-logo {
    width: 56px; height: 56px;
    background: var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.6rem; font-weight: 900;
    color: var(--blue-dark);
    margin-bottom: 6px;
    box-shadow: 0 0 0 3px rgba(245,197,24,0.2);
  }
  .hero-badge-title {
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold);
  }
  .hero-badge-org {
    font-size: 0.7rem; font-weight: 400;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute; bottom: 36px; right: 64px; z-index: 10;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    opacity: 0;
  }
  .scroll-hint span {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.25); writing-mode: vertical-rl;
  }
  .scroll-line {
    width: 1.5px; height: 56px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scanDown 2.5s ease-in-out infinite;
  }
  @keyframes scanDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ── STATS STRIP ── */
  #stats-strip {
    background: var(--blue-dark);
    border-top: 4px solid var(--gold);
  }
  .stats-row {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr);
  }
  .stat-cell {
    padding: 48px 32px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.08);
    position: relative; overflow: hidden;
    transition: background 0.3s;
  }
  .stat-cell:last-child { border-right: none; }
  .stat-cell:hover { background: rgba(245,197,24,0.06); }
  .stat-cell::before {
    content: '';
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 0; height: 3px; background: var(--gold);
    transition: width 0.4s;
  }
  .stat-cell:hover::before { width: 60%; }
  .stat-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 3rem; font-weight: 900; line-height: 1;
    color: var(--gold);
    display: block;
  }
  .stat-label {
    font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-top: 10px; display: block;
  }

  /* ── SECTION BASE ── */
  .section-wrap { max-width: 1260px; margin: 0 auto; padding: 110px 52px; }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--blue-mid);
    margin-bottom: 16px;
  }
  .eyebrow::before {
    content: ''; width: 24px; height: 2px;
    background: var(--gold); display: block;
  }
  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    font-weight: 900; line-height: 0.95;
    color: var(--blue-dark);
  }
  .section-title .hl { color: var(--gold-dark); }
  .section-title .light { color: var(--blue-light); }

  /* ── QUIENES SOMOS ── */
  #quienes {
    background: var(--white);
    border-top: 1px solid var(--gray-light);
  }
  .quienes-layout {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }
  .quienes-body {
    font-size: 1rem; font-weight: 300;
    color: #4a5580; line-height: 1.9;
    margin: 28px 0 32px;
  }
  .quienes-quote {
    padding: 22px 26px;
    border-left: 4px solid var(--gold);
    background: var(--gold-pale);
    border-radius: 0 8px 8px 0;
    margin-bottom: 32px;
  }
  .quienes-quote p {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.15rem; font-weight: 700;
    color: var(--blue-dark); line-height: 1.5;
    font-style: italic;
  }
  .quienes-quote span {
    display: block; margin-top: 8px;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gray);
  }
  .quienes-link {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--blue); text-decoration: none;
    transition: gap 0.25s, color 0.25s;
  }
  .quienes-link:hover { gap: 16px; color: var(--blue-dark); }
  .quienes-img-wrap {
    position: relative; height: 580px;
    border-radius: 12px; overflow: hidden;
    box-shadow: 0 24px 64px rgba(26,58,143,0.18);
  }
  .quienes-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s ease;
  }
  .quienes-img-wrap:hover .quienes-img { transform: scale(1.04); }
  /* Corner decorations using brand blue */
  .quienes-img-wrap::before {
    content: '';
    position: absolute; top: 16px; left: 16px;
    width: 40px; height: 40px;
    border-top: 3px solid var(--gold);
    border-left: 3px solid var(--gold);
    z-index: 2; border-radius: 2px;
  }
  .quienes-img-wrap::after {
    content: '';
    position: absolute; bottom: 16px; right: 16px;
    width: 40px; height: 40px;
    border-bottom: 3px solid var(--gold);
    border-right: 3px solid var(--gold);
    z-index: 2; border-radius: 2px;
  }
  .quienes-float {
    position: absolute; bottom: 28px; left: -20px; z-index: 3;
    padding: 18px 24px;
    background: var(--blue-dark);
    border-left: 4px solid var(--gold);
    border-radius: 0 8px 8px 0;
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
  }
  .quienes-float-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.6rem; font-weight: 900; line-height: 1;
    color: var(--gold);
  }
  .quienes-float-label {
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.4); margin-top: 4px;
  }

  /* ── PRINCIPLES ── */
  #principles {
    background: var(--blue-dark);
  }
  .principles-header { margin-bottom: 56px; }
  .principles-header .section-title { color: var(--white); }
  .principles-header .section-title .hl { color: var(--gold); }
  .principles-header .eyebrow { color: var(--gold-light); }
  .principles-header .eyebrow::before { background: var(--gold); }

  .principles-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .principle-card {
    padding: 40px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    position: relative; overflow: hidden;
    transition: all 0.35s;
  }
  .principle-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s;
  }
  .principle-card:hover {
    background: rgba(245,197,24,0.05);
    border-color: rgba(245,197,24,0.2);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3);
  }
  .principle-card:hover::before { transform: scaleX(1); }
  .principle-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 5rem; font-weight: 900; line-height: 1;
    -webkit-text-stroke: 1px rgba(245,197,24,0.12);
    color: transparent;
    position: absolute; top: 16px; right: 24px;
    user-select: none; transition: -webkit-text-stroke 0.3s;
  }
  .principle-card:hover .principle-num { -webkit-text-stroke-color: rgba(245,197,24,0.25); }
  .principle-en {
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem; font-weight: 700;
    color: var(--gold); margin-bottom: 4px;
    display: block;
  }
  .principle-es {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem; font-weight: 400; font-style: italic;
    color: rgba(255,255,255,0.25);
    display: block; margin-bottom: 18px;
  }
  .principle-desc {
    font-size: 0.88rem; font-weight: 300;
    color: rgba(255,255,255,0.5); line-height: 1.8;
  }

  /* ── ACTIVIDADES ── */
  #actividades {
    background: var(--off-white);
    border-top: 1px solid var(--gray-light);
  }
  .act-header { margin-bottom: 56px; }
  .act-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .act-card {
    position: relative; overflow: hidden;
    height: 300px; border-radius: 10px;
    box-shadow: 0 4px 20px rgba(26,58,143,0.1);
    cursor: default;
  }
  .act-card:first-child, .act-card:nth-child(5) { grid-column: span 2; }
  .act-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
    filter: brightness(0.6) saturate(0.8);
    transition: transform 0.7s ease, filter 0.5s;
  }
  .act-card:hover .act-img { transform: scale(1.06); filter: brightness(0.7) saturate(1.1); }
  .act-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,22,64,0.95) 0%, rgba(10,22,64,0.35) 55%, transparent 100%);
    transition: background 0.4s;
  }
  .act-card:hover .act-overlay {
    background: linear-gradient(to top, rgba(10,22,64,0.98) 0%, rgba(10,22,64,0.5) 60%, rgba(26,58,143,0.1) 100%);
  }
  .act-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 24px 26px; z-index: 2;
  }
  .act-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 8px;
  }
  .act-tag::before { content: ''; width: 4px; height: 4px; background: var(--gold); border-radius: 50%; }
  .act-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem; font-weight: 700;
    color: var(--white); margin-bottom: 6px;
    transition: color 0.3s;
  }
  .act-card:hover .act-title { color: var(--gold-light); }
  .act-desc {
    font-size: 0.82rem; font-weight: 300;
    color: rgba(255,255,255,0.5); line-height: 1.6;
    max-height: 0; overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .act-card:hover .act-desc { max-height: 80px; }

  /* ── UNIRSE ── */
  #unirse {
    background: var(--white);
    border-top: 1px solid var(--gray-light);
  }
  .unirse-layout {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }
  .unirse-steps { display: flex; flex-direction: column; gap: 10px; }
  .step-item {
    display: flex; align-items: flex-start; gap: 20px;
    padding: 22px 24px;
    border: 1.5px solid var(--gray-light);
    border-radius: 10px;
    background: var(--off-white);
    transition: all 0.3s;
  }
  .step-item:hover {
    border-color: var(--gold);
    background: var(--gold-pale);
    transform: translateX(6px);
    box-shadow: 0 4px 20px rgba(245,197,24,0.15);
  }
  .step-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.2rem; font-weight: 900; line-height: 1;
    color: var(--blue-pale); flex-shrink: 0;
    transition: color 0.3s;
  }
  .step-item:hover .step-num { color: var(--gold-dark); }
  .step-title {
    font-size: 1rem; font-weight: 700;
    color: var(--blue-dark); margin-bottom: 5px;
    letter-spacing: 0.02em;
  }
  .step-desc {
